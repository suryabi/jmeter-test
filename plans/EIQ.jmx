                                          <hashTree/>
                                          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Document Type Extractor" enabled="true">
                                            <stringProp name="scriptLanguage">groovy</stringProp>
                                            <stringProp name="parameters"></stringProp>
                                            <stringProp name="filename"></stringProp>
                                            <stringProp name="cacheKey">true</stringProp>
                                            <stringProp name="script">import groovy.json.JsonSlurper

// Cache check: skip if document types already loaded
def cachedCount = vars.get(&quot;documentTypeCount&quot;)
if (cachedCount != null &amp;&amp; cachedCount.toInteger() &gt; 0) {
    return
}

try {
    def response = prev.getResponseDataAsString()
    def json = new JsonSlurper().parseText(response)
    
    def uploadTypes = json._embedded?.uploadTypeModels ?: []
    
//    // Filter: exclude Video and Digital Signage
//    def filteredTypes = uploadTypes.findAll { type -&gt;
//    		def typeName = (type.uploadTypeName ?: &quot;&quot;).toLowerCase()
//    		!typeName.contains(&quot;video&quot;) &amp;&amp; !typeName.contains(&quot;digital signage&quot;)
//	}
//    

    // Filter: include only &quot;Other Document&quot; and &quot;Executive Briefing Document&quot;
	def allowedTypes = [&quot;other document&quot;, &quot;executive briefing document&quot;]

    def filteredTypes = uploadTypes.findAll { type -&gt;
    		def typeName = (type.uploadTypeName ?: &quot;&quot;).toLowerCase()
    		allowedTypes.contains(typeName)
	}
    
    for (int i = 1; i &lt;= 20; i++) {
        vars.remove(&quot;docType_${i}_id&quot;)
        vars.remove(&quot;docType_${i}_name&quot;)
    }
    
    if (filteredTypes.size() &gt; 0) {
        vars.put(&quot;documentTypeCount&quot;, filteredTypes.size().toString())
        filteredTypes.eachWithIndex { type, idx -&gt;
            def typeNum = idx + 1
            vars.put(&quot;docType_${typeNum}_id&quot;, type.uniqueId ?: &quot;&quot;)
            vars.put(&quot;docType_${typeNum}_name&quot;, type.uploadTypeName ?: &quot;&quot;)
        }
    } else {
        vars.put(&quot;documentTypeCount&quot;, &quot;0&quot;)
        log.warn(&quot;No document types found&quot;)
    }
} catch (Exception e) {
    log.error(&quot;Document Type Extractor error: ${e.message}&quot;)
    vars.put(&quot;documentTypeCount&quot;, &quot;0&quot;)
}</stringProp>
