                <stringProp name="script">import groovy.json.JsonSlurper

// Parse the Get LoggedIn User API response
def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

// Extract role details 
vars.put(&quot;roleId&quot;, json.roleId ?: &quot;&quot;)
vars.put(&quot;roleName&quot;, json.roleName ?: &quot;&quot;)

// Extract actual logged-in user email from API response
def loggedInEmail = json.email ?: json.userName ?: json.userId ?: vars.get(&quot;currentUser&quot;) ?: &quot;&quot;

// Log extracted role details
log.info(&quot;LoggedIn User: ${loggedInEmail} | Role: ${json.roleName} (${json.roleId})&quot;)</stringProp>
