              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Module Access PostProcessor" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">// STEP 0: Clear previous module variables to prevent bleed-through between users
def previousCount = vars.get(&quot;navModules_count&quot;)?.toInteger() ?: 0
for (int i = 1; i &lt;= previousCount; i++) {
    vars.remove(&quot;moduleUniqueId_&quot; + i)
    vars.remove(&quot;moduleName_&quot; + i)
    vars.remove(&quot;moduleTypeId_&quot; + i)
    vars.remove(&quot;moduleTypeName_&quot; + i)
}
vars.remove(&quot;navModules_count&quot;)
vars.remove(&quot;currentModuleName&quot;)
vars.remove(&quot;currentModuleTypeId&quot;)
vars.remove(&quot;lastLoggedNavModule&quot;)

import groovy.json.JsonSlurper

// STEP 1: Parse the Get Role Module Access API response
def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

// STEP 2: Get Excluded Module IDs from UDV (optional - allows skipping specific modules)
def excludedModuleIdsRaw = vars.get(&quot;excludedModuleIds&quot;) ?: &quot;&quot;
def excludedModuleIds = excludedModuleIdsRaw ? excludedModuleIdsRaw.split(&apos;,&apos;).collect { it.trim().toUpperCase() } : []
if (excludedModuleIds) {
    log.info(&quot;Excluded Module IDs: &quot; + excludedModuleIds)
}

// STEP 3: Extract moduleAccess array from HAL response (_embedded format)
def moduleAccessList = json._embedded?.moduleAccess ?: []
if (moduleAccessList.isEmpty()) {
    log.warn(&quot;No moduleAccess entries found!&quot;)
    vars.put(&quot;navModules_count&quot;, &quot;0&quot;)
    return
}
log.info(&quot;Total moduleAccess entries: &quot; + moduleAccessList.size())

// STEP 4: Filter modules based on three conditions:
//   1. isNavigation = true (module is a navigation tab)
//   2. writeAccess = true (role has write permission - at moduleAccess level, not inside module)
//   3. Not in excluded module IDs list
// Note: Some moduleAccess entries may not have writeAccess field - treat missing as false
def navigationModules = moduleAccessList.findAll { access -&gt;
    def module = access.module
    def moduleId = module?.uniqueId?.toUpperCase() ?: &quot;&quot;
    def moduleName = module?.moduleName ?: &quot;Unknown&quot;

    // Check if module is a navigation module
    def isNav = module?.isNavigation == true

    // Check if role has write access (writeAccess is at access level, not module level)
    def hasWriteAccess = access.writeAccess == true

    // Check if module is in the exclusion list
    def isExcluded = excludedModuleIds.contains(moduleId)

    // Log skipped modules with reason for debugging
    if (isNav &amp;&amp; !hasWriteAccess) {
    }
    if (isExcluded) {
    }

    // Module must be navigable, writable, and not excluded
    isNav &amp;&amp; hasWriteAccess &amp;&amp; !isExcluded
}

// STEP 5: Extract unique modules - avoid duplicates when same module appears multiple times
// Uses moduleId as key to ensure each module is stored only once
def uniqueModulesMap = [:]
navigationModules.each { access -&gt;
    def module = access.module
    def moduleId = module.uniqueId

    // Only store first occurrence of each module (skip duplicates)
    if (!uniqueModulesMap.containsKey(moduleId)) {
        uniqueModulesMap[moduleId] = [
            moduleId      : module.uniqueId,
            moduleName    : module.moduleName,
            moduleTypeId  : module.moduleType?.uniqueId,
            moduleTypeName: module.moduleType?.moduleTypeName,
            sortOrder     : module.sortOrder ?: 0
        ]
    }
}

// STEP 6: Sort modules by sortOrder for consistent processing order
def uniqueModules = uniqueModulesMap.values().toList()
uniqueModules.sort { it.sortOrder }

// STEP 7: Store as indexed JMeter variables for ForEach controller consumption
// Format: moduleUniqueId_1, moduleName_1, moduleTypeId_1, moduleTypeName_1, etc.
vars.put(&quot;navModules_count&quot;, uniqueModules.size().toString())
uniqueModules.eachWithIndex { module, index -&gt;
    def idx = index + 1
    vars.put(&quot;moduleUniqueId_${idx}&quot;, module.moduleId ?: &quot;&quot;)
    vars.put(&quot;moduleName_${idx}&quot;, module.moduleName ?: &quot;&quot;)
    vars.put(&quot;moduleTypeId_${idx}&quot;, module.moduleTypeId ?: &quot;&quot;)
    vars.put(&quot;moduleTypeName_${idx}&quot;, module.moduleTypeName ?: &quot;&quot;)
}

// STEP 8: Log summary of stored modules
uniqueModules.eachWithIndex { module, index -&gt;
}
</stringProp>
