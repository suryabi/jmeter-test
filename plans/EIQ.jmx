                <hashTree/>
                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Module Config PostProcessor" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">import groovy.json.JsonSlurper

log.info(&quot;Module: &quot; + vars.get(&quot;currentModuleName&quot;))

// STEP 1: Parse API Response
def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

// STEP 2: Extract Configs Array - handle both /configs and /configs/details response formats
def configs = []
if (json._embedded?.configs) {
    configs = json._embedded.configs
} else if (json.journeys instanceof List) {
    json.journeys.each { journey -&gt;
        journey.pages?.each { page -&gt;
            page.forms?.each { form -&gt;
                configs &lt;&lt; [
                    module : [uniqueId: json.uniqueId],
                    journey: [uniqueId: journey.uniqueId, journeyName: journey.journeyName ?: &quot;&quot;],
                    page   : [uniqueId: page.uniqueId, pageName: page.pageName ?: &quot;&quot;],
                    form   : [uniqueId: form.uniqueId, formName: form.formName ?: &quot;&quot;, formIdentifier: form.formIdentifier ?: &quot;&quot;, handler: form.handler ?: &quot;&quot;],
                    isMultiEntry: form.isMultiEntry ?: false,
                    minEntries: form.minEntries,
                    maxEntries: form.maxEntries
                ]
            }
        }
    }
} else if (json instanceof List) {
    configs = json
} else if (json.configs instanceof List) {
    configs = json.configs
} else if (json.form || json.module || json.journey || json.page) {
    configs = [json]
} else {
    log.warn(&quot;Unknown config response structure. Keys: ${json instanceof Map ? json.keySet() : json.getClass().name}&quot;)
}
def totalConfigs = configs.size()

// STEP 3: Clear Previous Config Variables
def prevConfigCount = (vars.get(&quot;moduleConfigsCount&quot;) ?: &quot;0&quot;).toInteger()
for (int i = 1; i &lt;= prevConfigCount + 5; i++) {
    vars.remove(&quot;journeyId_&quot; + i)
    vars.remove(&quot;journeyName_&quot; + i)
    vars.remove(&quot;pageId_&quot; + i)
    vars.remove(&quot;pageName_&quot; + i)
    vars.remove(&quot;formId_&quot; + i)
    vars.remove(&quot;formName_&quot; + i)
    vars.remove(&quot;formIdentifier_&quot; + i)
    vars.remove(&quot;formHandler_&quot; + i)
    vars.remove(&quot;isMultiEntry_&quot; + i)
    vars.remove(&quot;minEntries_&quot; + i)
    vars.remove(&quot;maxEntries_&quot; + i)
}

// STEP 4: Store Count for ForEach Controller
vars.put(&quot;moduleConfigsCount&quot;, totalConfigs.toString())

// STEP 5: Handle Empty Config - Skip to Calendar Flow
if (totalConfigs == 0) {
    vars.put(&quot;configIndex&quot;, &quot;0&quot;)
    vars.put(&quot;moduleFormHandler&quot;, &quot;&quot;)
    return
}

// Reset skip flags when config exists

// STEP 6: Extract and Store Config Details
configs.eachWithIndex { config, idx -&gt;
    def i = idx + 1

    // Journey Details
    vars.put(&quot;journeyId_&quot; + i, config.journey?.uniqueId ?: &quot;&quot;)

    // Page Details
    vars.put(&quot;pageId_&quot; + i, config.page?.uniqueId ?: &quot;&quot;)

    // Module Details
    vars.put(&quot;moduleId_&quot; + i, config.module?.uniqueId ?: &quot;&quot;)

    // Form Details
    vars.put(&quot;formId_&quot; + i, config.form?.uniqueId ?: &quot;&quot;)
    vars.put(&quot;formName_&quot; + i, config.form?.formName ?: &quot;&quot;)
    vars.put(&quot;formHandler_&quot; + i, config.form?.handler ?: &quot;&quot;)

    // Entry Configuration (from config response minEntries/maxEntries)
    def isMultiEntry = config.isMultiEntry ?: false
    vars.put(&quot;isMultiEntry_&quot; + i, isMultiEntry.toString())

    if (isMultiEntry) {
        def configMin = config.minEntries
        def configMax = config.maxEntries

        if (configMin != null &amp;&amp; configMax != null) {
            vars.put(&quot;minEntries_&quot; + i, configMin.toString())
            vars.put(&quot;maxEntries_&quot; + i, configMax.toString())
        } else {
            // No minEntries/maxEntries in config response - default to 1
            vars.put(&quot;minEntries_&quot; + i, &quot;1&quot;)
            vars.put(&quot;maxEntries_&quot; + i, &quot;1&quot;)
            log.warn(&quot;Config ${i} is multiEntry but missing minEntries/maxEntries - defaulting to 1&quot;)
        }
    } else {
        vars.put(&quot;minEntries_&quot; + i, &quot;1&quot;)
        vars.put(&quot;maxEntries_&quot; + i, &quot;1&quot;)
    }
}

// STEP 7: Store Module-Level Form Handler (for If Condition check)
def moduleFormHandler = &quot;&quot;
if (configs.size() &gt; 0) {
    moduleFormHandler = configs[0].form?.handler ?: &quot;&quot;
}
vars.put(&quot;moduleFormHandler&quot;, moduleFormHandler)

// STEP 8: Reset Config Index for ForEach Iteration
vars.put(&quot;configIndex&quot;, &quot;0&quot;)

log.info(&quot;Module: ${vars.get(&apos;currentModuleName&apos;)} | Handler: ${moduleFormHandler} | Configs: ${totalConfigs}&quot;)</stringProp>
                </JSR223PostProcessor>
