                    <stringProp name="script">// Skip if test is already aborting
if (vars.get(&quot;_abortTest&quot;) == &quot;true&quot;) {
    prev.setSuccessful(false)
    prev.setResponseMessage(&quot;Skipped - test is aborting: &quot; + vars.get(&quot;_abortReason&quot;))
    return
}


def rand = java.util.concurrent.ThreadLocalRandom.current()
def catName = vars.get(&quot;categoryName&quot;) ?: &quot;Event&quot;
def currentYear = java.time.Year.now().toString()

// STEP 1: Collect existing event names from API response
def existingEventNames = [] as Set
def matchCount = vars.get(&quot;eventNames_matchNr&quot;)?.toInteger() ?: 0

if (matchCount &gt; 0) {
    for (int i = 1; i &lt;= matchCount; i++) {
        def name = vars.get(&quot;eventNames_&quot; + i) ?: &quot;&quot;
        if (name.trim()) existingEventNames.add(name.trim())
    }
}

// Also include names created in this test run (tracked via JMeter property)
def propKey = &quot;eventNames_&quot; + catName
def testRunNames = (props.get(propKey) ?: ([] as Set)) as Set
existingEventNames.addAll(testRunNames)

log.info(&quot;Category: ${catName}&quot;)
log.info(&quot;Existing event names (${existingEventNames.size()}): ${existingEventNames}&quot;)

// STEP 2: Load all timezones from stored variables
def tzCount = vars.get(&quot;tz_count&quot;)?.toInteger() ?: 0
def allTimezones = []
for (int i = 1; i &lt;= tzCount; i++) {
    def zoneName = vars.get(&quot;tz_zoneName_&quot; + i) ?: &quot;&quot;
    def key = vars.get(&quot;tz_key_&quot; + i) ?: &quot;&quot;
    if (zoneName) {
        def city = zoneName.contains(&quot;/&quot;) ? zoneName.split(&quot;/&quot;).last().replace(&quot;_&quot;, &quot; &quot;) : zoneName
        def country = vars.get(&quot;tz_country_&quot; + i) ?: city
        allTimezones.add([zoneName: zoneName, key: key, city: city, country: country])
    }
}


// STEP 3: Try pre-selected timezone first (from Timezone PostProcessor), then shuffle remaining
def preSelectedZone = vars.get(&quot;requestTimeZone&quot;) ?: &quot;&quot;
def selectedTz = null

// Try pre-selected timezone first (so Get Timezones label matches)
if (preSelectedZone) {
    def preTz = allTimezones.find { it.zoneName == preSelectedZone }
    if (preTz) {
        def candidateName = catName + &quot; - &quot; + preTz.country + &quot; - &quot; + currentYear
        if (!existingEventNames.contains(candidateName)) {
            selectedTz = preTz
        }
    }
}

// If pre-selected was duplicate, shuffle and find another unique city
if (!selectedTz) {
    Collections.shuffle(allTimezones, new Random())
    for (def tz : allTimezones) {
        def candidateName = catName + &quot; - &quot; + tz.country + &quot; - &quot; + currentYear
        if (!existingEventNames.contains(candidateName)) {
            selectedTz = tz
            break
        }
    }
}

// STEP 4: Build event name (fallback with number if all cities exhausted)
def eventName
if (selectedTz) {
    eventName = catName + &quot; - &quot; + selectedTz.country + &quot; - &quot; + currentYear
} else {
    log.warn(&quot;All timezone cities already used for &apos;${catName}&apos;, adding number suffix&quot;)
    selectedTz = allTimezones[rand.nextInt(allTimezones.size())]
    def n = 2
    eventName = catName + &quot; - &quot; + selectedTz.country + &quot; - &quot; + currentYear + &quot; - &quot; + n
    while (existingEventNames.contains(eventName)) {
        n++
        eventName = catName + &quot; - &quot; + selectedTz.country + &quot; - &quot; + currentYear + &quot; - &quot; + n
    }
}

// STEP 5: Track for subsequent requests in same test run
testRunNames.add(eventName)
props.put(propKey, testRunNames)

// STEP 6: Set all variables - override timezone selection to match event name
vars.put(&quot;eventName&quot;, eventName)
vars.put(&quot;requestTimeZone&quot;, selectedTz.zoneName)
vars.put(&quot;baseTimezone&quot;, selectedTz.zoneName)
vars.put(&quot;requestTimeZoneCity&quot;, selectedTz.city)
vars.put(&quot;requestTimeZoneCountry&quot;, selectedTz.country)
vars.put(&quot;skipEventCreation&quot;, &quot;false&quot;)

log.info(&quot;Event Name: &quot; + eventName)

// Update the Get All Events sampler label to show the final selected timezone
// This replaces the separate &quot;Final Timezone&quot; sampler — keeps the tree clean
prev.setSampleLabel(&quot;Get All Events - &quot; + vars.get(&quot;categoryName&quot;))

</stringProp>
                  </JSR223PostProcessor>
