                      <hashTree/>
                      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Activity Day Counter Extractor" enabled="true">
                        <stringProp name="scriptLanguage">groovy</stringProp>
                        <stringProp name="parameters"></stringProp>
                        <stringProp name="filename"></stringProp>
                        <stringProp name="cacheKey">true</stringProp>
                        <stringProp name="script">// ============================================================================
// ACTIVITY DAYS EXTRACTOR
// Extracts activity days from API response and stores for Day Loop iteration
// ============================================================================

def totalDays = vars.get(&quot;activityid_matchNr&quot;)?.toInteger() ?: 0

// ---------------------------------------------------------------------------
// Store Total Days for Day Loop
// ---------------------------------------------------------------------------
vars.put(&quot;TotalActivityDays&quot;, totalDays.toString())
vars.put(&quot;ActivityDayCount&quot;, &quot;1&quot;)

// ---------------------------------------------------------------------------
// Log Extracted Days Summary
// ---------------------------------------------------------------------------
if (totalDays == 0) {
    log.warn(&quot;[Activity Days Extractor] No activity days found&quot;)
} else {
    def daysSummary = []
    for (int i = 1; i &lt;= totalDays; i++) {
        def dayDate = vars.get(&quot;activityDate_&quot; + i) ?: &quot;N/A&quot;
        def dayStart = vars.get(&quot;activityStartTime_&quot; + i) ?: &quot;&quot;
        def dayEnd = vars.get(&quot;activityEndTime_&quot; + i) ?: &quot;&quot;

        def dateStr = dayDate?.take(10) ?: &quot;N/A&quot;
        def startStr = (dayStart?.length() &gt; 16) ? dayStart.substring(11, 16) : &quot;??&quot;
        def endStr = (dayEnd?.length() &gt; 16) ? dayEnd.substring(11, 16) : &quot;??&quot;

        daysSummary.add(&quot;Day${i}:${dateStr}(${startStr}-${endStr})&quot;)
    }
    }
</stringProp>
                      </JSR223PostProcessor>
                      <hashTree/>
                      <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                      <hashTree/>
                    </hashTree>
                    <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Reset Day Counter" enabled="true">
                      <stringProp name="scriptLanguage">groovy</stringProp>
                      <stringProp name="parameters"></stringProp>
                      <stringProp name="filename"></stringProp>
                      <stringProp name="cacheKey">true</stringProp>
                      <stringProp name="script">SampleResult.setIgnore()

// Initialize/Reset DAY LOOP
// Resets day loop counter before iterating through activity days

// Reset counter to 0 (will be incremented at start of each iteration)
vars.put(&quot;dayLoopCounter&quot;, &quot;0&quot;)

def totalDays = vars.get(&quot;TotalActivityDays&quot;)?.toInteger() ?: 0

</stringProp>
                    </JSR223Sampler>
                    <hashTree/>
                    <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ While (Activity Days)" enabled="true">
                      <stringProp name="WhileController.condition">${__groovy(vars.get(&quot;dayLoopCounter&quot;)?.toInteger() &lt; vars.get(&quot;TotalActivityDays&quot;)?.toInteger())}</stringProp>
                    </WhileController>
                    <hashTree>
                      <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="───── Activity Day (${dayLoopCounter}/${TotalActivityDays}) ─────" enabled="true">
                        <stringProp name="scriptLanguage">groovy</stringProp>
                        <stringProp name="parameters"></stringProp>
                        <stringProp name="filename"></stringProp>
                        <stringProp name="cacheKey">true</stringProp>
                        <stringProp name="script">// Activity Day marker - visible in View Results Tree (black)
def dayCount = vars.get(&quot;dayLoopCounter&quot;) ?: &quot;1&quot;
def totalDays = vars.get(&quot;TotalActivityDays&quot;) ?: &quot;1&quot;
SampleResult.setResponseData(&quot;Activity Day: ${dayCount}/${totalDays}&quot;, &quot;UTF-8&quot;)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)</stringProp>
                      </JSR223Sampler>
                      <hashTree>
                        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Day Counter Increment" enabled="true">
                          <stringProp name="scriptLanguage">groovy</stringProp>
                          <stringProp name="parameters"></stringProp>
                          <stringProp name="filename"></stringProp>
                          <stringProp name="cacheKey">true</stringProp>
                          <stringProp name="script">// Increment Day Counter (1-based)
def dayCounter = (vars.get(&quot;dayLoopCounter&quot;)?.toInteger() ?: 0) + 1
vars.put(&quot;dayLoopCounter&quot;, dayCounter.toString())
vars.put(&quot;ActivityDayCount&quot;, dayCounter.toString())
vars.put(&quot;currentDayIndex&quot;, dayCounter.toString())

// Set current day&apos;s activity date for existing activities check
def activityDateForDay = vars.get(&quot;activityDate_&quot; + dayCounter) ?: &quot;&quot;
// Extract just the date part (YYYY-MM-DD) and append T00:00:00
if (activityDateForDay.contains(&quot;T&quot;)) {
    activityDateForDay = activityDateForDay.substring(0, activityDateForDay.indexOf(&quot;T&quot;)) + &quot;T00:00:00&quot;
}

// Reset module logger so each module logs once per day
vars.put(&quot;lastLoggedActivityModule&quot;, &quot;&quot;)

// Reset blocked details shown flags for all rooms (so full details show once per day/room)
def selectedRoomCountReset = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
for (int r = 1; r &lt;= selectedRoomCountReset; r++) {
    vars.remove(&quot;blockedDetailsShown_Day&quot; + dayCounter + &quot;_Room&quot; + r)
}

// Enhanced Day Logging for v14 diagnostic
def activityDate = vars.get(&quot;activityDate_&quot; + dayCounter) ?: &quot;Unknown&quot;
def totalDays = vars.get(&quot;TotalActivityDays&quot;) ?: &quot;?&quot;
def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
for (int i = 1; i &lt;= selectedRoomCount; i++) {
    def roomId = vars.get(&quot;selectedRoomId_&quot; + i) ?: &quot;EMPTY&quot;
    def roomName = vars.get(&quot;selectedRoomName_&quot; + i) ?: &quot;Unknown&quot;
    }
</stringProp>
                        </JSR223PreProcessor>
                        <hashTree/>
                      </hashTree>
                      <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Reset Room Counter (Day Level)" enabled="true">
                        <stringProp name="scriptLanguage">groovy</stringProp>
                        <stringProp name="parameters"></stringProp>
                        <stringProp name="filename"></stringProp>
                        <stringProp name="cacheKey">true</stringProp>
                        <stringProp name="script">SampleResult.setIgnore()

// INITIALIZE ROOM LOOP (DAY LEVEL)
// Resets room loop counter before iterating through rooms
// Also loads the correct rooms for THIS DAY from Logistics

// Reset counter to 0 (will be incremented at start of each iteration)
vars.put(&quot;roomLoopCounter&quot;, &quot;0&quot;)
vars.put(&quot;skipDayActivities&quot;, &quot;false&quot;)
vars.put(&quot;existingActivityModuleIds&quot;, &quot;&quot;)

// Get current day
def dayIndex = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;

// CRITICAL: Clear ALL usedSlotRanges and persistedSlots for THIS day before processing
// Prevents stale data from previous days bleeding into the current day
def maxRooms = (vars.get(&quot;selectedRoomCount&quot;) ?: &quot;10&quot;).toInteger()
def clearedRoomIds = [] as Set
for (int r = 1; r &lt;= maxRooms; r++) {
    def slotKey = &quot;usedSlotRanges_Day&quot; + dayIndex + &quot;_Room&quot; + r
    def oldSlots = vars.get(slotKey) ?: &quot;&quot;
    if (oldSlots) {
    }
    vars.remove(slotKey)

    // Clear room-ID-keyed persisted slots - from both vars and system properties
    def roomId = vars.get(&quot;selectedRoomId_&quot; + r) ?: &quot;&quot;
    if (roomId) { clearedRoomIds.add(roomId) }
    def sysRoomId = System.getProperty(&quot;jmeter.room.Day${dayIndex}_${r}_id&quot;.toString()) ?: &quot;&quot;
    if (sysRoomId) { clearedRoomIds.add(sysRoomId) }
}
// Clear persistedSlots for all known room IDs on this day
clearedRoomIds.each { rid -&gt;
    vars.remove(&quot;persistedSlots_Day&quot; + dayIndex + &quot;_&quot; + rid)
}

// Load rooms for THIS DAY from Logistics - read from SYSTEM properties
String countPropName = &quot;jmeter.roomCount.Day${dayIndex}&quot;.toString()
String countFromSys = System.getProperty(countPropName)
String countFromVars = vars.get(&quot;createdRoomCount_Day${dayIndex}&quot;.toString())
def dayRoomCount = (countFromSys ?: countFromVars)?.toInteger() ?: 0


// Copy day-specific rooms to selectedRoom variables
def roomIds = []
for (int i = 1; i &lt;= dayRoomCount; i++) {
    String idPropName = &quot;jmeter.room.Day${dayIndex}_${i}_id&quot;.toString()
    String namePropName = &quot;jmeter.room.Day${dayIndex}_${i}_name&quot;.toString()
    // Read from SYSTEM properties with fallback to vars
    String idFromSys = System.getProperty(idPropName)
    String idFromVars = vars.get(&quot;createdRoom_Day${dayIndex}_${i}_id&quot;.toString())
    def resolvedId = idFromSys ?: idFromVars ?: &quot;&quot;
    def roomName = System.getProperty(namePropName) ?: vars.get(&quot;createdRoom_Day${dayIndex}_${i}_name&quot;.toString()) ?: &quot;Room &quot; + i
    
    
    vars.put(&quot;selectedRoomId_&quot; + i, resolvedId)
    vars.put(&quot;selectedRoomName_&quot; + i, roomName)
    
    if (resolvedId) {
        roomIds.add(resolvedId)
    } else {
        log.warn(&quot;  Day ${dayIndex} Room [${i}]: EMPTY ID - name=${roomName}&quot;)
    }
}

vars.put(&quot;selectedRoomCount&quot;, dayRoomCount.toString())

// Build JSON body for Add Rooms to Request (for this day)
def roomListJson = roomIds.collect { &quot;\&quot;${it}\&quot;&quot; }.join(&quot;,\n&quot;)


SampleResult.setResponseMessage(&quot;Day ${dayIndex}: ${dayRoomCount} rooms&quot;)
</stringProp>
                      </JSR223Sampler>
                      <hashTree/>
                      <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ Room Loop" enabled="true">
                        <stringProp name="WhileController.condition">${__groovy(vars.get(&quot;skipDayActivities&quot;) != &quot;true&quot; &amp;&amp; vars.get(&quot;roomLoopCounter&quot;)?.toInteger() &lt; vars.get(&quot;selectedRoomCount&quot;)?.toInteger())}</stringProp>
                      </WhileController>
                      <hashTree>
                        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Next Room" enabled="true">
                          <stringProp name="scriptLanguage">groovy</stringProp>
                          <stringProp name="parameters"></stringProp>
                          <stringProp name="filename"></stringProp>
                          <stringProp name="cacheKey">true</stringProp>
                          <stringProp name="script">// ROOM LOOP START (OUTER LEVEL)
// Increments room counter and sets current room details
// All activity types for this room will be processed before moving to next room

// Increment Room Counter (1-based)
def counter = (vars.get(&quot;roomLoopCounter&quot;)?.toInteger() ?: 0) + 1
vars.put(&quot;roomLoopCounter&quot;, counter.toString())
vars.put(&quot;currentRoomCounter&quot;, counter.toString())

// Get selected room count
def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0

// Check if counter exceeds selected rooms
if (counter &gt; selectedRoomCount) {
    log.error(&quot;[Room Loop OUTER] CRITICAL: Room counter (${counter}) exceeds selectedRoomCount (${selectedRoomCount})! Stopping.&quot;)
    vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)
    vars.put(&quot;currentRoomId&quot;, &quot;&quot;)
    vars.put(&quot;currentRoomName&quot;, &quot;INVALID&quot;)
    return
}

// Set Current Room Details
def currentRoomId = vars.get(&quot;selectedRoomId_&quot; + counter) ?: &quot;&quot;
def currentRoomName = vars.get(&quot;selectedRoomName_&quot; + counter) ?: &quot;Room ${counter}&quot;

// Validate room ID is not empty
if (!currentRoomId || currentRoomId.trim().isEmpty()) {
    log.error(&quot;[Room Loop OUTER] CRITICAL: selectedRoomId_${counter} is empty or null!&quot;)
    currentRoomId = &quot;&quot;
    currentRoomName = &quot;INVALID_ROOM&quot;
    vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)
}

vars.put(&quot;currentRoomId&quot;, currentRoomId)
vars.put(&quot;currentRoomName&quot;, currentRoomName)

// CROSS-ROOM DEBUG: Verify all selectedRoomName variables
for (int r = 1; r &lt;= selectedRoomCount; r++) {
    def storedName = vars.get(&quot;selectedRoomName_&quot; + r)
    def storedId = vars.get(&quot;selectedRoomId_&quot; + r)
    def isCurrent = (r == counter) ? &quot; CURRENT&quot; : &quot;&quot;
    }
// Reset flags for new room
vars.put(&quot;skipActivityModule&quot;, &quot;false&quot;)
vars.put(&quot;stopRoomActivityLoop&quot;, &quot;false&quot;)

// Clear &quot;roomProcessedForActivityType_X&quot; flags for ALL activity types
// This allows ForEach (ActivityType) to process all types for this room
def activityTypesAll = vars.get(&quot;activityType_ALL&quot;) ?: &quot;&quot;
if (activityTypesAll) {
    activityTypesAll.split(&quot;,&quot;).each { actType -&gt;
        vars.remove(&quot;roomProcessedForActivityType_&quot; + actType.trim())
    }
}


// Get Context Variables
def dayIndex = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def roomCount = vars.get(&quot;selectedRoomCount&quot;) ?: &quot;?&quot;
def activityDate = vars.get(&quot;activityDate_&quot; + dayIndex)?.take(10) ?: &quot;Unknown&quot;

// CRITICAL FIX: Clean stale per-room variables from previous user iterations
// These accumulate across iterations and cause blocked range violations / wrong slot tracking
def roomKey = &quot;Day&quot; + dayIndex + &quot;_Room&quot; + counter

// PERSIST current room&apos;s usedSlotRanges BEFORE clearing
// When User 2 runs, usedSlotRanges_Day1_Room1 still has User 1&apos;s Room 1 data
// Save it to a room-ID-keyed variable so we can reload it after clearing
def existingUsedSlots = vars.get(&quot;usedSlotRanges_&quot; + roomKey) ?: &quot;&quot;
if (existingUsedSlots &amp;&amp; currentRoomId) {
    vars.put(&quot;persistedSlots_Day&quot; + dayIndex + &quot;_&quot; + currentRoomId, existingUsedSlots)
}

vars.remove(&quot;reservedBlockedTimes_&quot; + roomKey)
vars.remove(&quot;blockedRangesGenerated_&quot; + roomKey)
vars.remove(&quot;usedSlotRanges_&quot; + roomKey)

// Pre-populate usedSlotRanges from PERSISTED data (previous user&apos;s room-specific slots)
// This is ROOM-SPECIFIC: only slots for THIS room, no cross-room contamination
if (currentRoomId) {
    def persistedSlots = vars.get(&quot;persistedSlots_Day&quot; + dayIndex + &quot;_&quot; + currentRoomId) ?: &quot;&quot;
    if (persistedSlots) {
        vars.put(&quot;usedSlotRanges_&quot; + roomKey, persistedSlots)
    } else {
    }
}

// Get activity types priority order (reuse activityTypesAll from above)
def typesList = activityTypesAll ? activityTypesAll.split(&quot;,&quot;).collect { it.trim() } : []

SampleResult.setSampleLabel(&quot;ROOM : &quot; + currentRoomName)
SampleResult.setResponseMessage(&quot;Room ${counter}/${roomCount}: ${currentRoomName}&quot;)
SampleResult.setSuccessful(false)
</stringProp>
                        </JSR223Sampler>
                        <hashTree/>
                        <ForeachController guiclass="ForeachControlPanel" testclass="ForeachController" testname="◉ ForEach (ActivityType by Priority)" enabled="true">
                          <stringProp name="ForeachController.inputVal">activityModuleId</stringProp>
                          <stringProp name="ForeachController.returnVal">currentActivityModuleId</stringProp>
                          <boolProp name="ForeachController.useSeparator">true</boolProp>
                          <stringProp name="ForeachController.startIndex">0</stringProp>
                        </ForeachController>
                        <hashTree>
                          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Set Activity Type PreProcessor" enabled="true">
                            <stringProp name="scriptLanguage">groovy</stringProp>
                            <stringProp name="parameters"></stringProp>
                            <stringProp name="filename"></stringProp>
                            <stringProp name="cacheKey">true</stringProp>
                            <stringProp name="script">// ACTIVITY MODULE PREPROCESSOR
  // Finds activity module name and type from current ForEach iteration ID
  // Sets variables for downstream processors and HTTP request names
  // v7: Added clearing of ResourceType/MasterType variables to prevent stale data

  // ═══════════════════════════════════════════════════════════════════════════
  // DO NOT reset counts or IDs here!
  // PreProcessors run before EVERY sampler in ForEach, which would reset values
  // set by PostProcessors (Config PostProcessor, Resource/Master PostProcessor)
  // Counts and IDs are properly managed by PostProcessors
  // ═══════════════════════════════════════════════════════════════════════════

  // Track ForEach Iteration
  def iterationKey = &quot;activityForEachIteration&quot;
  def currentIteration = (vars.get(iterationKey)?.toInteger() ?: 0) + 1
  vars.put(iterationKey, currentIteration.toString())

  def currentId = vars.get(&quot;currentActivityModuleId&quot;)
  def activityCount = vars.get(&quot;activityModules_count&quot;)?.toInteger() ?: 0

  def moduleName = &quot;Activity&quot;
  def activityType = &quot;&quot;
  boolean found = false

  // ---------------------------------------------------------------------------
  // Find Module Name and Type from Stored Variables (set by Feature Extractor)
  // ---------------------------------------------------------------------------
  int modulePosition = 0
  for (int i = 1; i &lt;= activityCount; i++) {
      if (vars.get(&quot;activityModuleId_&quot; + i) == currentId) {
          moduleName = vars.get(&quot;activityModuleName_&quot; + i) ?: &quot;Activity&quot;
          activityType = vars.get(&quot;activityType_&quot; + i) ?: &quot;&quot;
          modulePosition = i
          found = true
          break
      }
  }

  if (!found) {
      log.error(&quot;Module ID &apos;${currentId}&apos; not found in stored IDs&quot;)
  }

  // Fallback: Derive activityType from moduleName if empty
  if (!activityType?.trim()) {
      activityType = moduleName.toLowerCase()
  }

  // Store Variables for Downstream Use
  vars.put(&quot;currentActivityModuleName&quot;, moduleName)
  vars.put(&quot;activityType&quot;, activityType)
  // Also store in loopActivityType for consistency in room loops
  vars.put(&quot;loopActivityType&quot;, activityType)

  // VERIFY the variable was set correctly
  def verifyType = vars.get(&quot;activityType&quot;)
  if (verifyType != activityType) {
      log.error(&quot;activityType NOT SET! Expected: &quot; + activityType + &quot;, Got: &quot; + verifyType)
      // Force set again
      vars.put(&quot;activityType&quot;, activityType)
      vars.put(&quot;loopActivityType&quot;, activityType)
      log.error(&quot;Forced re-set activityType to: &quot; + vars.get(&quot;activityType&quot;))
  }

  def shouldSkip = false

  // Check if activities already exist for this moduleId (created by previous user)
  if (!shouldSkip) {
      def existingModuleIds = (vars.get(&quot;existingActivityModuleIds&quot;) ?: &quot;&quot;).split(&quot;,&quot;).collect { it.trim() }.findAll { it }
      if (existingModuleIds.contains(currentId)) {
          shouldSkip = true
          log.info(&quot;[Existing Check] Activities already exist for moduleId=${currentId} (${moduleName}/${activityType}) - SKIPPING&quot;)
      }
  }

  vars.put(&quot;skipActivityModule&quot;, shouldSkip ? &quot;true&quot; : &quot;false&quot;)

  

  
  def lastLoggedModule = vars.get(&quot;lastLoggedActivityModule&quot;) ?: &quot;&quot;
  if (lastLoggedModule != activityType) {
      
      if (modulePosition == 1) {
          def roomCounter = vars.get(&quot;roomLoopCounter&quot;)?.toInteger() ?: 1
          def roomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown&quot;
          def dayCount = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
          def totalDays = vars.get(&quot;duration&quot;) ?: &quot;1&quot;
      }
      def status = shouldSkip ? &quot;SKIP&quot; : &quot;OK&quot;
      vars.put(&quot;lastLoggedActivityModule&quot;, activityType)
  }</stringProp>
                          </JSR223PreProcessor>
                          <hashTree/>
