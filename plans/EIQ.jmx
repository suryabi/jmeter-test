;Lufthansa&quot;, &quot;Marriott International&quot;, &quot;Marshall&quot;, &quot;Marubeni Corporation&quot;, &quot;Maserati&quot;, &quot;Mastercard&quot;, &quot;Mazda&quot;, &quot;McDonald&apos;s&quot;, &quot;McKesson&quot;, &quot;MediaTek&quot;, &quot;Mercedes-Benz&quot;, &quot;Meta Platforms&quot;, &quot;MetLife&quot;, &quot;Microsoft&quot;, &quot;Mitsubishi Corporation&quot;, &quot;MongoDB&quot;, &quot;Montblanc&quot;, &quot;Morgan Stanley&quot;, &quot;Motorola&quot;, &quot;National Grid&quot;, &quot;Nestle&quot;, &quot;NetApp&quot;, &quot;NetSuite&quot;, &quot;Netflix&quot;, &quot;New Balance&quot;, &quot;Nike&quot;, &quot;Nikon&quot;, &quot;Nissan Motor&quot;, &quot;Novartis&quot;, &quot;NTPC Limited&quot;, &quot;Nutanix&quot;, &quot;NVIDIA&quot;, &quot;Oakley&quot;, &quot;Omega&quot;, &quot;OpenText&quot;, &quot;Oracle&quot;, &quot;PACCAR&quot;, &quot;Palo Alto Networks&quot;, &quot;Panasonic&quot;, &quot;PayPal&quot;, &quot;Paytm&quot;, &quot;PepsiCo&quot;, &quot;Persistent Systems&quot;, &quot;Pfizer&quot;, &quot;Philips&quot;, &quot;PhonePe&quot;, &quot;Pinterest&quot;, &quot;Pizza Hut&quot;, &quot;PNC Financial Services&quot;, &quot;Porsche&quot;, &quot;Prada&quot;, &quot;Procter &amp; Gamble&quot;, &quot;Puma&quot;, &quot;Qantas Airways&quot;, &quot;Qatar Airways&quot;, &quot;Qualcomm&quot;, &quot;Rackspace&quot;, &quot;Razorpay&quot;, &quot;Reebok&quot;, &quot;Reliance Industries&quot;, &quot;Renault&quot;, &quot;Rolex&quot;, &quot;Rolls-Royce&quot;, &quot;Royal Bank of Canada&quot;, &quot;Salesforce&quot;, &quot;Samsung&quot;, &quot;SAP&quot;, &quot;ServiceNow&quot;, &quot;Shell&quot;, &quot;Shopify&quot;, &quot;Siemens&quot;, &quot;Singapore Airlines&quot;, &quot;Slack&quot;, &quot;Snapchat&quot;, &quot;Snowflake&quot;, &quot;Sony&quot;, &quot;Southwest Airlines&quot;, &quot;Spotify&quot;, &quot;Standard Chartered&quot;, &quot;Starbucks&quot;, &quot;State Bank of India&quot;, &quot;State Farm&quot;, &quot;Stryker&quot;, &quot;Subaru Corporation&quot;, &quot;Subway&quot;, &quot;Sun Life Financial&quot;, &quot;Suzuki&quot;, &quot;Synopsys&quot;, &quot;T-Mobile US&quot;, &quot;Taco Bell&quot;, &quot;Takeda Pharmaceutical&quot;, &quot;Target&quot;, &quot;Tata Consultancy Services&quot;, &quot;Tata Motors&quot;, &quot;Tech Mahindra&quot;, &quot;Teradata&quot;, &quot;Tesla&quot;, &quot;TikTok&quot;, &quot;Toyota Motor&quot;, &quot;Turkish Airlines&quot;, &quot;Tyson Foods&quot;, &quot;Uber&quot;, &quot;Under Armour&quot;, &quot;Unilever&quot;, &quot;United Airlines&quot;, &quot;Vedanta Limited&quot;, &quot;Verizon&quot;, &quot;Virtusa&quot;, &quot;Visa&quot;, &quot;Vodafone&quot;, &quot;Volkswagen&quot;, &quot;Volvo&quot;, &quot;Walmart&quot;, &quot;Walt Disney&quot;, &quot;Wells Fargo&quot;, &quot;WhatsApp&quot;, &quot;Wipro&quot;, &quot;Workday&quot;, &quot;Xbox&quot;, &quot;YouTube&quot;, &quot;Zara&quot;, &quot;Zoho Corporation&quot;, &quot;Zoom&quot;
] as String[])


// ============ 11. Default Text Fields → use fn_defaultTextFields (defined above) ============

// ============ 12. Default TextArea Values ============
props.put(&quot;fn_defaultTextAreas&quot;, [
    &quot;Provide overview of enterprise solutions and demonstrate alignment with strategic goals. Cover key capabilities and expected business outcomes&quot;,
    &quot;Explore partnership opportunities and discuss how combined expertise can drive innovation. Topics include market trends and solution integration&quot;,
    &quot;Technical deep dive covering architecture design, security considerations, and integration patterns. Q&amp;A session included&quot;,
    &quot;Discussed infrastructure challenges and cloud migration strategy. Customer interested in pilot program and POC planning&quot;,
    &quot;Current processes are manual with optimization opportunity. Team is supportive. Executive sponsorship confirmed&quot;,
    &quot;Strong interest in automation and analytics. Key concerns: data migration and user adoption. Recommend phased approach&quot;,
    &quot;Showcase product roadmap, gather feedback on upcoming features, and ensure alignment with customer requirements&quot;,
    &quot;Hands-on workshop to explore platform capabilities including configuration, workflow automation, and reporting dashboards&quot;,
    &quot;Go-live checklist: Data migration validated, user training completed, support team briefed, rollback plan ready&quot;,
    &quot;Resource constraint on customer side. Only 1 dedicated resource for implementation. May impact timeline&quot;
] as String[])

// ============ 13. Email Domains Fallback ============
props.put(&quot;fn_emailDomains&quot;, [&quot;gmail.com&quot;, &quot;outlook.com&quot;, &quot;yahoo.com&quot;] as String[])

// ============ 14. Countries List ============
props.put(&quot;fn_countries&quot;, [
    &quot;United States&quot;, &quot;United Kingdom&quot;, &quot;Canada&quot;, &quot;Switzerland&quot;, &quot;India&quot;,
    &quot;Japan&quot;, &quot;Germany&quot;, &quot;Australia&quot;, &quot;South Africa&quot;, &quot;Italy&quot;, &quot;Ireland&quot;,
    &quot;France&quot;, &quot;Brazil&quot;, &quot;Singapore&quot;, &quot;Netherlands&quot;, &quot;South Korea&quot;,
    &quot;Sweden&quot;, &quot;Mexico&quot;, &quot;New Zealand&quot;, &quot;United Arab Emirates&quot;
] as String[])

// ============ 15. Parse Time To Minutes Helper ============
props.put(&quot;fn_parseTimeToMinutes&quot;, { String timeStr -&gt;
    if (!timeStr || !timeStr.contains(&quot;:&quot;)) return -1
    try {
        if (timeStr.contains(&quot;T&quot;) &amp;&amp; timeStr.length() &gt;= 16) {
            def timePart = timeStr.substring(11, 16)
            def parts = timePart.split(&quot;:&quot;)
            return parts[0].toInteger() * 60 + parts[1].toInteger()
        } else {
            def parts = timeStr.trim().split(&quot;:&quot;)
            return parts[0].toInteger() * 60 + parts[1].toInteger()
        }
    } catch (Exception e) {
        return -1
    }
})

// ============ 16. Pick Fresh User Helper (thread-safe, no repeats per event) ============
props.put(&quot;fn_pickFreshUser&quot;, { varsRef -&gt;
    def randomUserCount = (varsRef.get(&quot;randomUserCount&quot;) ?: &quot;0&quot;).toInteger()
    if (randomUserCount == 0) {
        return [firstName: varsRef.get(&quot;customerFirstName&quot;) ?: &quot;John&quot;, lastName: varsRef.get(&quot;customerLastName&quot;) ?: &quot;Doe&quot;]
    }
    def requestId = varsRef.get(&quot;requestId&quot;) ?: &quot;default&quot;
    def usedKey = &quot;usedUserIndices_&quot; + requestId + &quot;_&quot; + Thread.currentThread().getId()
    def usedIndices = props.get(usedKey) ?: ([] as Set)
    def available = (1..randomUserCount).findAll { !usedIndices.contains(it) }
    if (available.isEmpty()) {
        usedIndices.clear()
        available = (1..randomUserCount).toList()
    }
    def rand = java.util.concurrent.ThreadLocalRandom.current()
    def idx = available[rand.nextInt(available.size())]
    usedIndices.add(idx)
    props.put(usedKey, usedIndices)
    return [
        firstName: varsRef.get(&quot;randomUser_${idx}_firstName&quot;) ?: &quot;John&quot;,
        lastName : varsRef.get(&quot;randomUser_${idx}_lastName&quot;) ?: &quot;Doe&quot;
    ]
})

</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Load Users" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">SampleResult.setIgnore()

// User Iteration Setup Script
def users = vars.get(&quot;users&quot;)
def defaultUser = vars.get(&quot;defaultUser&quot;)


def userList = []

// Check if users variable is empty or null
if (users == null || users.trim().isEmpty()) {
    userList.add(defaultUser)
} else {
    users.split(&quot;,&quot;).each { user -&gt;
        def trimmedUser = user.trim()
        if (!trimmedUser.isEmpty()) {
            userList.add(trimmedUser)
        }
    }
}

// Store user list for ForEach controller
userList.eachWithIndex { user, index -&gt;
    vars.put(&quot;user_${index + 1}&quot;, user)
}

// Store total count
vars.put(&quot;userCount&quot;, userList.size().toString())

log.info(&quot;Total users to iterate: ${userList.size()}&quot;)</stringProp>
        </JSR223Sampler>
