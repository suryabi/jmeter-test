                <hashTree>
                  <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                    <collectionProp name="HeaderManager.headers">
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-customerid</stringProp>
                        <stringProp name="Header.value">${customerId}</stringProp>
                      </elementProp>
                    </collectionProp>
                  </HeaderManager>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Parent Category PostProcessor" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">import groovy.json.JsonSlurper

// Parse JSON response
def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

// Extract parent categories from response
def parentCategories = json._embedded?.categories ?: []

// Validate parent categories exist
if (parentCategories.isEmpty()) {
    log.error(&quot;No parent categories found!&quot;)
    prev.setSuccessful(false)
    prev.setResponseMessage(&quot;ABORTING: No parent categories found in API response&quot;)
    vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
    vars.put(&quot;_abortReason&quot;, &quot;No parent categories found in API response&quot;)
    ctx.getEngine().stopTest()
    return
}

// Get preferred parent category from User Defined Variables
def preferredParentCategory = vars.get(&quot;parentCategory&quot;)?.trim()
def selectedParentCategory = null

// Search for preferred parent category if specified
if (preferredParentCategory) {
    selectedParentCategory = parentCategories.find {
        it.uniqueId?.equalsIgnoreCase(preferredParentCategory)
    }

    if (selectedParentCategory) {
        log.info(&quot;Parent category: &quot; + preferredParentCategory)
    } else {
        def availableParents = parentCategories.collect { it.uniqueId + &quot; (&quot; + (it.categoryName ?: &quot;&quot;) + &quot;)&quot; }.join(&quot;, &quot;)
        log.error(&quot;========================================&quot;)
        log.error(&quot;parentCategory &apos;&quot; + preferredParentCategory + &quot;&apos; not found in API response&quot;)
        log.error(&quot;Available: &quot; + availableParents)
        log.error(&quot;========================================&quot;)
        prev.setSuccessful(false)
        prev.setResponseMessage(&quot;ABORTING: parentCategory &apos;&quot; + preferredParentCategory + &quot;&apos; not found. Available: &quot; + availableParents)
        vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
        vars.put(&quot;_abortReason&quot;, &quot;parentCategory &apos;&quot; + preferredParentCategory + &quot;&apos; not found in API response. Available: &quot; + availableParents)
        ctx.getEngine().stopTest()
        return
    }
}

// Extract baseTimezone from selectedParentCategory timezone or default to UTC
def baseTimezone = selectedParentCategory?.timezone ?: &quot;UTC&quot;

// Extract Location ResourceType
def locationResourceType = selectedParentCategory.resourceType
def locationResourceTypeId = locationResourceType?.uniqueId ?: &quot;&quot;
def locationResourceTypeName = locationResourceType?.name ?: &quot;&quot;

// Store selected parent category variables
vars.put(&quot;parentCategoryId&quot;, selectedParentCategory.uniqueId ?: &quot;&quot;)
vars.put(&quot;parentCategoryName&quot;, selectedParentCategory.categoryName ?: &quot;&quot;)
vars.put(&quot;baseTimezone&quot;, baseTimezone)

