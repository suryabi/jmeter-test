              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract All Location Resources" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">import groovy.json.JsonSlurper

def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)
def resources = json?._embedded?.resources ?: []

if (resources.isEmpty()) {
    log.warn(&quot;Get Location ResourceTypes: No locations found in response&quot;)
    vars.put(&quot;locationId_matchNr&quot;, &quot;0&quot;)
    vars.put(&quot;locationExists&quot;, &quot;false&quot;)
    return
}

// Store each locationId + locationName as indexed vars for ForEach controller
// ForEach expects: locationId_1, locationId_2 ... locationId_matchNr
resources.eachWithIndex { resource, idx -&gt;
    def name = resource.data?.locationName?.trim() ?: resource.metaData?.searchDisplayText?.trim() ?: resource.uniqueId
    vars.put(&quot;locationId_&quot;     + (idx + 1), resource.uniqueId)
    vars.put(&quot;locationName_&quot;   + (idx + 1), name)
}
vars.put(&quot;locationId_matchNr&quot;, resources.size().toString())
vars.put(&quot;locationExists&quot;, &quot;true&quot;)

log.info(&quot;Total locations found: ${resources.size()}&quot;)
</stringProp>
              </JSR223PostProcessor>
