                              <hashTree/>
                              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Config PostProcessor" enabled="true">
                                <stringProp name="scriptLanguage">groovy</stringProp>
                                <stringProp name="parameters"></stringProp>
                                <stringProp name="filename"></stringProp>
                                <stringProp name="cacheKey">true</stringProp>
                                <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput

// ACTIVITY TYPE CONFIG POST PROCESSOR
// Extracts form, journey, and page details from module configs API response
// Stores indexed variables for ForEach iteration (formId_1, formId_2, etc.)

def activityType = vars.get(&quot;activityType&quot;) ?: &quot;unknown&quot;

def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

// Extract Configs - handle both /configs and /configs/details response formats
def configs = []
if (json._embedded?.configs) {
    configs = json._embedded.configs
} else if (json.journeys instanceof List) {
    json.journeys.each { journey -&gt;
        journey.pages?.each { page -&gt;
            page.forms?.each { form -&gt;
                configs &lt;&lt; [
                    module : [uniqueId: json.uniqueId],
                    journey: [uniqueId: journey.uniqueId, journeyName: journey.journeyName ?: &quot;&quot;],
                    page   : [uniqueId: page.uniqueId, pageName: page.pageName ?: &quot;&quot;],
                    form   : [uniqueId: form.uniqueId, formName: form.formName ?: &quot;&quot;, formIdentifier: form.formIdentifier ?: &quot;&quot;, handler: form.handler ?: &quot;&quot;],
                    isMultiEntry: form.isMultiEntry ?: false,
                    minEntries: form.minEntries,
                    maxEntries: form.maxEntries
                ]
            }
        }
    }
} else if (json instanceof List) {
    configs = json
} else if (json.configs instanceof List) {
    configs = json.configs
} else if (json.form || json.module || json.journey || json.page) {
    configs = [json]
} else {
    log.warn(&quot;Unknown activity config response structure. Keys: ${json instanceof Map ? json.keySet() : json.getClass().name}&quot;)
}
def totalConfigs = configs.size()
log.info(&quot;Parsed ${totalConfigs} activity configs for: ${activityType}&quot;)

vars.put(&quot;moduleConfigsCount&quot;, totalConfigs.toString())

// Clear previous indexed variables
for (int i = 1; i &lt;= 20; i++) {
    vars.remove(&quot;formId_&quot; + i)
    vars.remove(&quot;formName_&quot; + i)
    vars.remove(&quot;formIdentifier_&quot; + i)
    vars.remove(&quot;formHandler_&quot; + i)
    vars.remove(&quot;journeyId_&quot; + i)
    vars.remove(&quot;journeyName_&quot; + i)
    vars.remove(&quot;pageId_&quot; + i)
    vars.remove(&quot;pageName_&quot; + i)
    vars.remove(&quot;moduleId_&quot; + i)
    vars.remove(&quot;isMultiEntry_&quot; + i)
    vars.remove(&quot;minEntries_&quot; + i)
    vars.remove(&quot;maxEntries_&quot; + i)
    vars.remove(&quot;activityResourceTypeId_&quot; + i)
    vars.remove(&quot;activityResourceTypeName_&quot; + i)
    vars.remove(&quot;activityMasterTypeId_&quot; + i)
    vars.remove(&quot;activityMasterTypeName_&quot; + i)
}

vars.put(&quot;activityDocumentFormId&quot;, &quot;&quot;)

if (totalConfigs == 0) {
    log.warn(&quot;No configs found for ${activityType}&quot;)
    vars.put(&quot;formId&quot;, &quot;&quot;)
    vars.put(&quot;currentFormName&quot;, &quot;&quot;)
    vars.put(&quot;activityJourneyId&quot;, &quot;&quot;)
    vars.put(&quot;activityPageId&quot;, &quot;&quot;)
    vars.put(&quot;configIndex&quot;, &quot;0&quot;)
    return
}

def primaryConfig = configs[0]
vars.put(&quot;activityJourneyId&quot;, primaryConfig.journey?.uniqueId ?: &quot;&quot;)
vars.put(&quot;activityPageId&quot;, primaryConfig.page?.uniqueId ?: &quot;&quot;)
vars.put(&quot;formId&quot;, primaryConfig.form?.uniqueId ?: &quot;&quot;)
vars.put(&quot;currentFormName&quot;, primaryConfig.form?.formName ?: &quot;&quot;)

def isMultiEntry = primaryConfig.isMultiEntry ?: false
def minEntries = isMultiEntry ? (primaryConfig.minEntries ?: 1) : 1
def maxEntries = isMultiEntry ? (primaryConfig.maxEntries ?: 1) : 1
def totalEntries = isMultiEntry ? (java.util.concurrent.ThreadLocalRandom.current().nextInt(maxEntries - minEntries + 1) + minEntries) : 1

def secondaryConfigCount = 0

configs.eachWithIndex { cfg, idx -&gt;
    def num = idx + 1
    def prefix = &quot;activityConfig_${idx}_&quot;

    vars.put(&quot;formId_&quot; + num, cfg.form?.uniqueId ?: &quot;&quot;)
    vars.put(&quot;formName_&quot; + num, cfg.form?.formName ?: &quot;&quot;)
    vars.put(&quot;formHandler_&quot; + num, cfg.form?.handler ?: &quot;&quot;)
    vars.put(&quot;journeyId_&quot; + num, cfg.journey?.uniqueId ?: &quot;&quot;)
    vars.put(&quot;pageId_&quot; + num, cfg.page?.uniqueId ?: &quot;&quot;)
    vars.put(&quot;moduleId_&quot; + num, cfg.module?.uniqueId ?: &quot;&quot;)

    def cfgIsMultiEntry = cfg.isMultiEntry ?: false
    vars.put(&quot;isMultiEntry_&quot; + num, cfgIsMultiEntry.toString())
    if (cfgIsMultiEntry) {
        vars.put(&quot;minEntries_&quot; + num, (cfg.minEntries ?: 1).toString())
        vars.put(&quot;maxEntries_&quot; + num, (cfg.maxEntries ?: 1).toString())
    } else {
        vars.put(&quot;minEntries_&quot; + num, &quot;1&quot;)
        vars.put(&quot;maxEntries_&quot; + num, &quot;1&quot;)
    }

    vars.put(prefix + &quot;formId&quot;, cfg.form?.uniqueId ?: &quot;&quot;)
    vars.put(prefix + &quot;formName&quot;, cfg.form?.formName ?: &quot;&quot;)
    vars.put(prefix + &quot;formIdentifier&quot;, cfg.form?.formIdentifier ?: &quot;&quot;)
    vars.put(prefix + &quot;handler&quot;, cfg.form?.handler ?: &quot;&quot;)
    vars.put(prefix + &quot;journeyId&quot;, cfg.journey?.uniqueId ?: &quot;&quot;)
    vars.put(prefix + &quot;pageId&quot;, cfg.page?.uniqueId ?: &quot;&quot;)
    vars.put(prefix + &quot;moduleId&quot;, cfg.module?.uniqueId ?: &quot;&quot;)
    vars.put(prefix + &quot;isMultiEntry&quot;, cfgIsMultiEntry.toString())

    def uiConfig = cfg.form?.formUIConfig
    if (uiConfig instanceof String) {
        vars.put(prefix + &quot;formUIConfig&quot;, uiConfig)
    } else {
        vars.put(prefix + &quot;formUIConfig&quot;, JsonOutput.toJson(uiConfig ?: [:]))
    }

    if (idx &gt; 0) {
        secondaryConfigCount++
        extractResourceTypeId(cfg.form?.formUIConfig, prefix, false)
        def extractedRtId = vars.get(prefix + &quot;resourceTypeId&quot;)
        if (extractedRtId) {
        }
    } else {
        extractResourceTypeId(cfg.form?.formUIConfig, prefix, true)
    }

    def cfgFormIdentifier = cfg.form?.formIdentifier ?: &quot;&quot;
    def cfgHandler = cfg.form?.handler ?: &quot;&quot;
    if (cfgFormIdentifier == &quot;DOCUMENT&quot; || cfgHandler == &quot;documentFormHandler&quot;) {
        vars.put(&quot;activityDocumentFormId&quot;, cfg.form?.uniqueId ?: &quot;&quot;)
        def docUIConfig = cfg.form?.formUIConfig
    }

}

vars.put(&quot;configIndex&quot;, &quot;0&quot;)


def extractResourceTypeId(formUIConfigRaw, prefix, isPrimaryForm = false) {
    try {
        def formUIConfig = []
        if (formUIConfigRaw instanceof String) {
            def parsed = new JsonSlurper().parseText(formUIConfigRaw)
            formUIConfig = parsed?.config ?: parsed ?: []
        } else if (formUIConfigRaw instanceof Map) {
            formUIConfig = formUIConfigRaw?.config ?: []
        } else if (formUIConfigRaw instanceof List) {
            formUIConfig = formUIConfigRaw
        }

        def allFields = []
        formUIConfig.each { item -&gt;
            if (item?.type == &quot;SECTION&quot;) {
                allFields.addAll(item.formFields ?: [])
            } else {
                allFields.add(item)
            }
        }

        allFields.each { field -&gt;
            def resourceTypeId = field?.resourceTypeId ?: field?.resourceType?.uniqueId
            if (field?.resourceType instanceof String) resourceTypeId = field.resourceType
            if (resourceTypeId) {
                vars.put(prefix + &quot;resourceTypeId&quot;, resourceTypeId)
                if (!isPrimaryForm) vars.put(&quot;presenterResourceTypeId&quot;, resourceTypeId)
            }

            def masterTypeId = field?.masterTypeId ?: field?.masterType?.uniqueId
            if (field?.masterType instanceof String) masterTypeId = field.masterType
            if (field?.formControlType == &quot;MASTER&quot; &amp;&amp; field?.masterType instanceof Map) {
                masterTypeId = masterTypeId ?: field.masterType.uniqueId
            }
            if (masterTypeId) {
                vars.put(prefix + &quot;masterTypeId&quot;, masterTypeId.toString())
            }
        }
    } catch (Exception e) {
        log.error(&quot;[extractResourceTypeId] Error: ${e.message}&quot;)
    }
}
</stringProp>
                              </JSR223PostProcessor>
                              <hashTree/>
                              <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                              <hashTree/>
                            </hashTree>
                            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Restore Primary Form" enabled="true">
                              <stringProp name="scriptLanguage">groovy</stringProp>
                              <stringProp name="parameters"></stringProp>
                              <stringProp name="filename"></stringProp>
                              <stringProp name="cacheKey">true</stringProp>
                              <stringProp name="script">SampleResult.setIgnore()
vars.put(&quot;formId&quot;, vars.get(&quot;formId_1&quot;) ?: &quot;&quot;)
vars.put(&quot;currentFormId&quot;, vars.get(&quot;formId_1&quot;) ?: &quot;&quot;)
vars.put(&quot;currentFormName&quot;, vars.get(&quot;formName_1&quot;) ?: &quot;&quot;)
vars.put(&quot;configIndex&quot;, &quot;0&quot;)
</stringProp>
                            </JSR223Sampler>
                            <hashTree/>
                            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Reset Activity (Per Room)" enabled="true">
                              <stringProp name="scriptLanguage">groovy</stringProp>
                              <stringProp name="parameters"></stringProp>
                              <stringProp name="filename"></stringProp>
                              <stringProp name="cacheKey">true</stringProp>
                              <stringProp name="script">SampleResult.setIgnore()

// RESET ACTIVITY FLAGS - once per activity type per room

// Reset activity loop flags for this activity type
vars.put(&quot;stopRoomActivityLoop&quot;, &quot;false&quot;)
vars.put(&quot;activityLoopCounter&quot;, &quot;0&quot;)
vars.put(&quot;activityAttemptCounter&quot;, &quot;0&quot;)

// Reset ResourceType/MasterType counts to prevent stale data from previous activity type

// Presenter count repopulated by Extract All Presenter Resources

// RT/MT cleanup removed (single activity type)

// Get current context
def roomCounter = vars.get(&quot;currentRoomCounter&quot;) ?: vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;
def roomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown&quot;
def activityType = vars.get(&quot;activityType&quot;) ?: &quot;unknown&quot;
def dayIndex = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;

// Get activity type priority index
def activityTypesAll = vars.get(&quot;activityType_ALL&quot;) ?: &quot;&quot;
def typesList = activityTypesAll.split(&quot;,&quot;).collect { it.trim() }
def priorityIndex = typesList.findIndexOf { it.equalsIgnoreCase(activityType) } + 1

SampleResult.setResponseMessage(&quot;${activityType} for ${roomName}&quot;)
</stringProp>
                            </JSR223Sampler>
                            <hashTree/>
                            <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ Process Current Room" enabled="true">
                              <stringProp name="WhileController.condition">${__groovy(vars.get(&quot;roomProcessedForActivityType_&quot; + vars.get(&quot;activityType&quot;)) != &quot;true&quot;)}</stringProp>
                            </WhileController>
                            <hashTree>
                              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Validate Room (Single Pass)" enabled="true">
                                <stringProp name="scriptLanguage">groovy</stringProp>
                                <stringProp name="parameters"></stringProp>
                                <stringProp name="filename"></stringProp>
                                <stringProp name="cacheKey">true</stringProp>
                                <stringProp name="script">SampleResult.setIgnore()

// VALIDATE ROOM FOR ACTIVITY TYPE (Single Pass)
// Room is already set by outer loop - this just validates and marks as processed
// Prevents this controller from running more than once per activity type

def activityType = vars.get(&quot;activityType&quot;) ?: &quot;unknown&quot;

// Mark this room as processed for this activity type (prevents re-entry)
vars.put(&quot;roomProcessedForActivityType_&quot; + activityType, &quot;true&quot;)

// CROSS-ROOM SLOT SUMMARY: Log slots for ALL rooms at this point
def dayIdx = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def totalRooms = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
def roomIdx = vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;
for (int r = 1; r &lt;= totalRooms; r++) {
    def rKey = &quot;usedSlotRanges_Day&quot; + dayIdx + &quot;_Room&quot; + r
    def rRanges = vars.get(rKey) ?: &quot;(empty)&quot;
    def rName = vars.get(&quot;selectedRoomName_&quot; + r) ?: &quot;Room ${r}&quot;
    def rId = vars.get(&quot;selectedRoomId_&quot; + r)?.take(12) ?: &quot;?&quot;
    def slotCount = rRanges == &quot;(empty)&quot; ? 0 : rRanges.split(&quot;;&quot;).size()
    def marker = (r.toString() == roomIdx) ? &quot; ◄◄ CURRENT&quot; : &quot;&quot;
        if (slotCount &gt; 0 &amp;&amp; slotCount &lt;= 5) {
            }
}
// Get room details (already set by outer loop)
def currentRoomId = vars.get(&quot;currentRoomId&quot;) ?: &quot;&quot;
def currentRoomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown&quot;
def counter = vars.get(&quot;currentRoomCounter&quot;) ?: vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;

// Validate room ID is not empty
if (!currentRoomId || currentRoomId.trim().isEmpty()) {
    log.error(&quot;[Validate Room] CRITICAL: currentRoomId is empty!&quot;)
    vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    return
}

// Reset activity-specific flags
vars.put(&quot;skipActivity&quot;, &quot;false&quot;)
vars.put(&quot;stopRoomActivityLoop&quot;, &quot;false&quot;)

def dayIndex = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def roomCount = vars.get(&quot;selectedRoomCount&quot;) ?: &quot;?&quot;
def activityDate = vars.get(&quot;activityDate_&quot; + dayIndex)?.take(10) ?: &quot;Unknown&quot;

SampleResult.setResponseMessage(&quot;${activityType} - ${currentRoomName}&quot;)</stringProp>
                              </JSR223Sampler>
                              <hashTree/>
                              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Calculate Activities Count" enabled="false">
                                <stringProp name="scriptLanguage">groovy</stringProp>
                                <stringProp name="parameters"></stringProp>
                                <stringProp name="filename"></stringProp>
                                <stringProp name="cacheKey">true</stringProp>
                                <stringProp name="script">SampleResult.setIgnore()

// SIMPLIFIED: Calculate visits per room based on customersPerRoom UDV
// No blocked slots concept - just fill percentage of available slots

def selectedDay = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def dayIndex = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def currentRoomCounter = vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;
def roomNameFromIndex = vars.get(&quot;selectedRoomName_&quot; + currentRoomCounter)
def currentRoomName = roomNameFromIndex ?: (vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown Room&quot;)

// Get activity type
def typeFromLoop = vars.get(&quot;loopActivityType&quot;)
def typeFromVar = vars.get(&quot;activityType&quot;)
def activityType = (typeFromLoop ?: typeFromVar ?: &quot;unknown&quot;).trim()

vars.put(&quot;loopActivityType&quot;, activityType)
vars.put(&quot;calcActivityType&quot;, activityType)

// Init loop counters
vars.put(&quot;activityLoopCounter&quot;, &quot;1&quot;)
vars.put(&quot;activityAttemptCounter&quot;, &quot;0&quot;)

// Get day time window
def dayStartTimeStr = vars.get(&quot;activityStartTime_&quot; + selectedDay) ?: &quot;&quot;
def dayEndTimeStr = vars.get(&quot;activityEndTime_&quot; + selectedDay) ?: &quot;&quot;

def parseTimeToMinutes = { timeStr -&gt;
    if (!timeStr) return -1
    try {
        def timePart = timeStr.contains(&quot;T&quot;) ? timeStr.substring(11, 16) : timeStr
        if (timePart.length() &gt;= 5) {
            def parts = timePart.split(&quot;:&quot;)
            return parts[0].toInteger() * 60 + parts[1].toInteger()
        }
    } catch (Exception e) { }
    return -1
}

int dayStartMins = parseTimeToMinutes(dayStartTimeStr)
int dayEndMins = parseTimeToMinutes(dayEndTimeStr)
int dayDurationMins = dayEndMins - dayStartMins

// Get vacant slot duration (for calculating max capacity)
def vacantSlotsDurationRaw = vars.get(&quot;vacantSlotDurations&quot;)?.trim()
int vacantSlotDuration = 60  // default 60 min per visit
try {
    if (vacantSlotsDurationRaw) {
        def options = vacantSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() }
        if (options) {
            // Use minimum duration for capacity calculation (gives max slots)
            vacantSlotDuration = options.min()
        }
    }
} catch (Exception e) {
    vacantSlotDuration = 60
}

// Store for Smart Slot Selector
def rand = java.util.concurrent.ThreadLocalRandom.current()
def allValidDurations = vacantSlotsDurationRaw ? vacantSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() } : [60]
if (allValidDurations.isEmpty()) allValidDurations = [60]
def parsedVacantSlotDuration = allValidDurations[rand.nextInt(allValidDurations.size())]
vars.put(&quot;parsedVacantSlotDuration&quot;, parsedVacantSlotDuration.toString())
vars.put(&quot;allValidDurations&quot;, allValidDurations.join(&quot;,&quot;))

// Calculate visits from customersPerRoom UDV
int loopCount = 0
String loopCountSource = &quot;&quot;

def customersPerRoomRaw = vars.get(&quot;customersPerRoom&quot;)?.trim() ?: &quot;&quot;

// Empty or 0 = skip customer/visit creation for this room
if (!customersPerRoomRaw || customersPerRoomRaw == &quot;0&quot; || customersPerRoomRaw == &quot;0%&quot;) {
    loopCount = 0
    loopCountSource = customersPerRoomRaw ? &quot;customersPerRoom=0 — skipping visit creation&quot; : &quot;customersPerRoom is empty — skipping visit creation&quot;
} else {
    // Extract percentage value — with or without % sign
    def pctValue = customersPerRoomRaw.replace(&quot;%&quot;, &quot;&quot;).trim()

    if (!pctValue.isInteger() || pctValue.toInteger() &lt; 0 || pctValue.toInteger() &gt; 100) {
        // Invalid value — abort
        log.error(&quot;========================================&quot;)
        log.error(&quot;customersPerRoom &apos;&quot; + customersPerRoomRaw + &quot;&apos; is invalid (expected: 0-100 with or without %, e.g. 80% or 80)&quot;)
        log.error(&quot;========================================&quot;)
        SampleResult.setSuccessful(false)
        SampleResult.setResponseCode(&quot;400&quot;)
        SampleResult.setResponseMessage(&quot;ABORTING: customersPerRoom &apos;&quot; + customersPerRoomRaw + &quot;&apos; is invalid. Expected: 0-100 with or without % (e.g. 80%, 80). 0 or empty = skip&quot;)
        vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
        vars.put(&quot;_abortReason&quot;, &quot;customersPerRoom &apos;&quot; + customersPerRoomRaw + &quot;&apos; is invalid&quot;)
        ctx.getEngine().stopTestNow()
        return
    }

    def pct = pctValue.toInteger()

    // Warn if % sign was missing
    if (!customersPerRoomRaw.contains(&quot;%&quot;)) {
        log.warn(&quot;⚠️ customersPerRoom=${customersPerRoomRaw} (no %). Treating as ${pct}%. Add &apos;%&apos; to suppress this warning&quot;)
    }

    def fillRate = pct / 100.0

    if (dayDurationMins &gt; 0 &amp;&amp; !allValidDurations.isEmpty()) {
        // Use MIN duration for accurate max capacity calculation
        def minDuration = allValidDurations.min()
        if (minDuration &lt;= 0) minDuration = 60
        int maxSlots = (int)(dayDurationMins / minDuration)
        loopCount = Math.max(1, (int)(maxSlots * fillRate))
        loopCountSource = &quot;customersPerRoom=${pct}% → ${dayDurationMins}min / ${minDuration}min(min of ${allValidDurations}) = ${maxSlots} max × ${pct}% = ${loopCount} visits&quot;
    } else {
        loopCount = 1
        loopCountSource = &quot;customersPerRoom=${pct}% (duration=0, default 1)&quot;
    }
}

// Cap at reasonable max
loopCount = Math.min(50, Math.max(0, loopCount))

vars.put(&quot;currentActivityLoopCount&quot;, loopCount.toString())

log.info(&quot;Room: ${currentRoomName} | Day: ${selectedDay}&quot;)
log.info(&quot;Time: ${dayStartTimeStr?.substring(11,16) ?: &apos;?&apos;} → ${dayEndTimeStr?.substring(11,16) ?: &apos;?&apos;} (${dayDurationMins} min)&quot;)
log.info(&quot;Slot Duration: ${vacantSlotDuration} min | ${loopCountSource}&quot;)
log.info(&quot;Visits to create: ${loopCount}&quot;)

SampleResult.setResponseData(&quot;Room: ${currentRoomName}\nVisits: ${loopCount}\n${loopCountSource}&quot;, &quot;UTF-8&quot;)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)
SampleResult.setResponseMessage(&quot;Day ${selectedDay}, Room ${currentRoomCounter}: ${loopCount} visit(s)&quot;)
</stringProp>
                              </JSR223Sampler>
                              <hashTree/>
                              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Calculate Activities Count" enabled="true">
                                <stringProp name="scriptLanguage">groovy</stringProp>
                                <stringProp name="parameters"></stringProp>
                                <stringProp name="filename"></stringProp>
                                <stringProp name="cacheKey">true</stringProp>
                                <stringProp name="script">SampleResult.setIgnore()

// SIMPLIFIED: Calculate visits per room based on customersPerRoom UDV
// No blocked slots concept - just fill percentage of available slots

def selectedDay = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def dayIndex = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def currentRoomCounter = vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;
def roomNameFromIndex = vars.get(&quot;selectedRoomName_&quot; + currentRoomCounter)
def currentRoomName = roomNameFromIndex ?: (vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown Room&quot;)

// Get activity type
def typeFromLoop = vars.get(&quot;loopActivityType&quot;)
def typeFromVar = vars.get(&quot;activityType&quot;)
def activityType = (typeFromLoop ?: typeFromVar ?: &quot;unknown&quot;).trim()

vars.put(&quot;loopActivityType&quot;, activityType)
vars.put(&quot;calcActivityType&quot;, activityType)

// Init loop counters
vars.put(&quot;activityLoopCounter&quot;, &quot;1&quot;)
vars.put(&quot;activityAttemptCounter&quot;, &quot;0&quot;)

// Get day time window
def dayStartTimeStr = vars.get(&quot;activityStartTime_&quot; + selectedDay) ?: &quot;&quot;
def dayEndTimeStr = vars.get(&quot;activityEndTime_&quot; + selectedDay) ?: &quot;&quot;

def parseTimeToMinutes = { timeStr -&gt;
    if (!timeStr) return -1
    try {
        def timePart = timeStr.contains(&quot;T&quot;) ? timeStr.substring(11, 16) : timeStr
        if (timePart.length() &gt;= 5) {
            def parts = timePart.split(&quot;:&quot;)
            return parts[0].toInteger() * 60 + parts[1].toInteger()
        }
    } catch (Exception e) { }
    return -1
}

int dayStartMins = parseTimeToMinutes(dayStartTimeStr)
int dayEndMins = parseTimeToMinutes(dayEndTimeStr)
int dayDurationMins = dayEndMins - dayStartMins

// Get vacant slot duration (for calculating max capacity)
def vacantSlotsDurationRaw = vars.get(&quot;vacantSlotDurations&quot;)?.trim()
int vacantSlotDuration = 60  // default 60 min per visit
try {
    if (vacantSlotsDurationRaw) {
        def options = vacantSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() }
        if (options) {
            // Use minimum duration for capacity calculation (gives max slots)
            vacantSlotDuration = options.min()
        }
    }
} catch (Exception e) {
    vacantSlotDuration = 60
}

// Store for Smart Slot Selector
def rand = java.util.concurrent.ThreadLocalRandom.current()
def allValidDurations = vacantSlotsDurationRaw ? vacantSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() } : [60]
if (allValidDurations.isEmpty()) allValidDurations = [60]
def parsedVacantSlotDuration = allValidDurations[rand.nextInt(allValidDurations.size())]
vars.put(&quot;parsedVacantSlotDuration&quot;, parsedVacantSlotDuration.toString())
vars.put(&quot;allValidDurations&quot;, allValidDurations.join(&quot;,&quot;))

// Calculate visits from customersPerRoom UDV
int loopCount = 0
String loopCountSource = &quot;&quot;

def customersPerRoomRaw = vars.get(&quot;customersPerRoom&quot;)?.trim() ?: &quot;&quot;

// Empty or 0 = skip customer/visit creation for this room
if (!customersPerRoomRaw || customersPerRoomRaw == &quot;0&quot; || customersPerRoomRaw == &quot;0%&quot;) {
    loopCount = 0
    loopCountSource = customersPerRoomRaw ? &quot;customersPerRoom=0 — skipping visit creation&quot; : &quot;customersPerRoom is empty — skipping visit creation&quot;
} else {
    def pct = 0

    if (customersPerRoomRaw.contains(&quot;-&quot;)) {
        // Range format: e.g. &quot;20%-50%&quot; or &quot;20-50&quot;
        def parts = customersPerRoomRaw.replace(&quot;%&quot;, &quot;&quot;).split(&quot;-&quot;)
        def min = parts[0].trim().toInteger()
        def max = parts[1].trim().toInteger()
        if (min &lt; 0 || max &gt; 100 || min &gt; max) {
            log.error(&quot;========================================&quot;)
            log.error(&quot;customersPerRoom &apos;${customersPerRoomRaw}&apos; is invalid range (expected: min-max between 0-100, e.g. 20%-50%)&quot;)
            log.error(&quot;========================================&quot;)
            SampleResult.setSuccessful(false)
            SampleResult.setResponseCode(&quot;400&quot;)
            SampleResult.setResponseMessage(&quot;ABORTING: customersPerRoom &apos;${customersPerRoomRaw}&apos; invalid range. Expected e.g. 20%-50%&quot;)
            vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
            vars.put(&quot;_abortReason&quot;, &quot;customersPerRoom &apos;${customersPerRoomRaw}&apos; is invalid range&quot;)
            ctx.getEngine().stopTestNow()
            return
        }
        pct = rand.nextInt(min, max + 1)
        log.info(&quot;customersPerRoom range ${min}%-${max}% → randomly picked ${pct}% for this room&quot;)
    } else {
        // Single value: e.g. &quot;20%&quot; or &quot;20&quot;
        def pctValue = customersPerRoomRaw.replace(&quot;%&quot;, &quot;&quot;).trim()
        if (!pctValue.isInteger() || pctValue.toInteger() &lt; 0 || pctValue.toInteger() &gt; 100) {
            log.error(&quot;========================================&quot;)
            log.error(&quot;customersPerRoom &apos;&quot; + customersPerRoomRaw + &quot;&apos; is invalid (expected: 0-100 with or without %, e.g. 80% or 80)&quot;)
            log.error(&quot;========================================&quot;)
            SampleResult.setSuccessful(false)
            SampleResult.setResponseCode(&quot;400&quot;)
            SampleResult.setResponseMessage(&quot;ABORTING: customersPerRoom &apos;&quot; + customersPerRoomRaw + &quot;&apos; is invalid. Expected: 0-100 with or without % (e.g. 80%, 80). 0 or empty = skip&quot;)
            vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
            vars.put(&quot;_abortReason&quot;, &quot;customersPerRoom &apos;&quot; + customersPerRoomRaw + &quot;&apos; is invalid&quot;)
            ctx.getEngine().stopTestNow()
            return
        }
        pct = pctValue.toInteger()
        if (!customersPerRoomRaw.contains(&quot;%&quot;)) {
            log.warn(&quot;⚠️ customersPerRoom=${customersPerRoomRaw} (no %). Treating as ${pct}%. Add &apos;%&apos; to suppress this warning&quot;)
        }
    }

    def fillRate = pct / 100.0

    if (dayDurationMins &gt; 0 &amp;&amp; !allValidDurations.isEmpty()) {
        // Use MIN duration for accurate max capacity calculation
        def minDuration = allValidDurations.min()
        if (minDuration &lt;= 0) minDuration = 60
        int maxSlots = (int)(dayDurationMins / minDuration)
        loopCount = Math.max(1, (int)(maxSlots * fillRate))
        loopCountSource = &quot;customersPerRoom=${pct}% → ${dayDurationMins}min / ${minDuration}min(min of ${allValidDurations}) = ${maxSlots} max × ${pct}% = ${loopCount} visits&quot;
    } else {
        loopCount = 1
        loopCountSource = &quot;customersPerRoom=${pct}% (duration=0, default 1)&quot;
    }
}

// Cap at reasonable max
loopCount = Math.min(50, Math.max(0, loopCount))

vars.put(&quot;currentActivityLoopCount&quot;, loopCount.toString())

log.info(&quot;Room: ${currentRoomName} | Day: ${selectedDay}&quot;)
log.info(&quot;Time: ${dayStartTimeStr?.substring(11,16) ?: &apos;?&apos;} → ${dayEndTimeStr?.substring(11,16) ?: &apos;?&apos;} (${dayDurationMins} min)&quot;)
log.info(&quot;Slot Duration: ${vacantSlotDuration} min | ${loopCountSource}&quot;)
log.info(&quot;Visits to create: ${loopCount}&quot;)

SampleResult.setResponseData(&quot;Room: ${currentRoomName}\nVisits: ${loopCount}\n${loopCountSource}&quot;, &quot;UTF-8&quot;)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)
SampleResult.setResponseMessage(&quot;Day ${selectedDay}, Room ${currentRoomCounter}: ${loopCount} visit(s)&quot;)</stringProp>
                              </JSR223Sampler>
                              <hashTree/>
                              <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ While (Create Activities)" enabled="true">
                                <stringProp name="WhileController.condition">${__groovy(vars.get(&quot;skipActivityModule&quot;) != &quot;true&quot; &amp;&amp; vars.get(&quot;stopRoomActivityLoop&quot;) != &quot;true&quot; &amp;&amp; vars.get(&quot;activityLoopCounter&quot;)?.toInteger() &lt;= vars.get(&quot;currentActivityLoopCount&quot;)?.toInteger())}</stringProp>
                              </WhileController>
                              <hashTree>
                                <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Next Activity" enabled="true">
                                  <stringProp name="scriptLanguage">groovy</stringProp>
                                  <stringProp name="parameters"></stringProp>
                                  <stringProp name="filename"></stringProp>
                                  <stringProp name="cacheKey">true</stringProp>
                                  <stringProp name="script">SampleResult.setIgnore()

// ACTIVITY LOOP START
// Increments attempt counter and validates room before creating activity

// Track ATTEMPTS (for safety to prevent infinite loop)
def attempts = (vars.get(&quot;activityAttemptCounter&quot;)?.toInteger() ?: 0) + 1
vars.put(&quot;activityAttemptCounter&quot;, attempts.toString())

// Safety limit
def maxAttempts = (vars.get(&quot;currentActivityLoopCount&quot;)?.toInteger() ?: 10) * 3
if (attempts &gt; maxAttempts) {
    log.warn(&quot;Max attempts reached (${attempts}/${maxAttempts}) - stopping loop&quot;)
    vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
}

// Reset skip flag for this iteration
vars.put(&quot;skipActivity&quot;, &quot;false&quot;)

// Clear previous iteration&apos;s data to prevent stale payload
vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
vars.put(&quot;currentVacantSlotEndTime&quot;, &quot;&quot;)
vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)

// Validate Current Room
def currentRoomId = vars.get(&quot;currentRoomId&quot;) ?: &quot;&quot;

if (!currentRoomId || currentRoomId.trim().isEmpty()) {
    log.error(&quot;[Activity Loop Start] CRITICAL: No valid room ID - skipping ALL remaining activities for this room&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)  // Stop the entire activity loop for this room
}

// Get Context Variables - use loopActivityType for correct activity type
def loopType = vars.get(&quot;loopActivityType&quot;)
def moduleType = vars.get(&quot;activityType&quot;)
def activityType = loopType ?: moduleType ?: &quot;unknown&quot;
def loopCount = vars.get(&quot;currentActivityLoopCount&quot;) ?: &quot;?&quot;
def currentRoomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown&quot;
def counter = vars.get(&quot;activityLoopCounter&quot;)?.toInteger() ?: 0

SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setResponseMessage(activityType + &quot; #&quot; + (counter + 1) + &quot;/&quot; + loopCount + &quot; (attempt &quot; + attempts + &quot;)&quot;)</stringProp>
                                </JSR223Sampler>
                                <hashTree/>
                                <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Get Vacant Slots" enabled="true">
                                  <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
                                    <collectionProp name="Arguments.arguments">
                                      <elementProp name="activityid" elementType="HTTPArgument">
                                        <boolProp name="HTTPArgument.always_encode">true</boolProp>
                                        <stringProp name="Argument.value">${__V(activityid_${ActivityDayCount})}</stringProp>
                                        <stringProp name="Argument.metadata">=</stringProp>
                                        <boolProp name="HTTPArgument.use_equals">true</boolProp>
                                        <stringProp name="Argument.name">activityid</stringProp>
                                      </elementProp>
                                      <elementProp name="eventDate" elementType="HTTPArgument">
                                        <boolProp name="HTTPArgument.always_encode">true</boolProp>
                                        <stringProp name="Argument.value">${__V(activityDate_${ActivityDayCount})}</stringProp>
                                        <stringProp name="Argument.metadata">=</stringProp>
                                        <boolProp name="HTTPArgument.use_equals">true</boolProp>
                                        <stringProp name="Argument.name">eventDate</stringProp>
                                      </elementProp>
                                      <elementProp name="startTime" elementType="HTTPArgument">
                                        <boolProp name="HTTPArgument.always_encode">true</boolProp>
                                        <stringProp name="Argument.value">${__V(activityStartTime_${ActivityDayCount})}</stringProp>
                                        <stringProp name="Argument.metadata">=</stringProp>
