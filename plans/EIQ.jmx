              <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ If (Logistics ModuleType Exists)" enabled="true">
                <stringProp name="IfController.condition">${__groovy(vars.get(&quot;currentModuleTypeId&quot;) == vars.get(&quot;logisticsModuleType&quot;))}</stringProp>
                <boolProp name="IfController.evaluateAll">false</boolProp>
                <boolProp name="IfController.useExpression">true</boolProp>
              </IfController>
