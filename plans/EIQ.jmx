                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">SampleResult.setSampleLabel(&quot;FORM : &quot; + vars.get(&quot;currentFormName&quot;))
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(false)</stringProp>
                  </JSR223Sampler>
                  <hashTree>
                    <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Set Current Form Variables" enabled="true">
                      <stringProp name="scriptLanguage">groovy</stringProp>
                      <stringProp name="parameters"></stringProp>
                      <stringProp name="filename"></stringProp>
                      <stringProp name="cacheKey">true</stringProp>
                      <stringProp name="script">// Increment Config Index
def prevIndex = vars.get(&quot;configIndex&quot;) ?: &quot;0&quot;
def configIndex = (prevIndex.toInteger() + 1).toString()
vars.put(&quot;configIndex&quot;, configIndex)

// Map Indexed Variables to Current Variables
vars.put(&quot;currentJourneyId&quot;, vars.get(&quot;journeyId_&quot; + configIndex) ?: &quot;&quot;)
vars.put(&quot;currentPageId&quot;, vars.get(&quot;pageId_&quot; + configIndex) ?: &quot;&quot;)
vars.put(&quot;currentModuleId&quot;, vars.get(&quot;moduleId_&quot; + configIndex) ?: &quot;&quot;)
vars.put(&quot;currentFormId&quot;, vars.get(&quot;formId_&quot; + configIndex) ?: &quot;&quot;)
vars.put(&quot;currentFormName&quot;, vars.get(&quot;formName_&quot; + configIndex) ?: &quot;&quot;)
vars.put(&quot;currentIsMultiEntry&quot;, vars.get(&quot;isMultiEntry_&quot; + configIndex) ?: &quot;false&quot;)

// Calculate Entry Count for Multi-Entry Forms
def isMultiEntry = vars.get(&quot;currentIsMultiEntry&quot;) == &quot;true&quot;
def entryCount = 1

if (isMultiEntry) {
    def minEntriesStr = vars.get(&quot;minEntries_&quot; + configIndex)
    def maxEntriesStr = vars.get(&quot;maxEntries_&quot; + configIndex)
    def minEntries = (minEntriesStr != null) ? minEntriesStr.toInteger() : 1
    def maxEntries = (maxEntriesStr != null) ? maxEntriesStr.toInteger() : 1
    entryCount = (minEntries == 0 &amp;&amp; maxEntries == 0) ? 0 : minEntries + new java.util.Random().nextInt((maxEntries - minEntries) + 1)
}


</stringProp>
                    </JSR223PreProcessor>
                    <hashTree/>
                  </hashTree>
                  <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Get Field Mappings" enabled="true">
                    <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
                      <collectionProp name="Arguments.arguments"/>
                    </elementProp>
                    <stringProp name="HTTPSampler.domain"></stringProp>
