                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">import groovy.json.JsonSlurper

// Get current form name for reference
def formName = vars.get(&quot;currentFormName&quot;)

// STEP 1: Get API Response
def response = prev.getResponseDataAsString()

// STEP 2: Store Complete Response (for Dynamic Payload Builder)
vars.put(&quot;currentFieldMappings&quot;, response)

// STEP 3: Parse JSON Response
def json = new JsonSlurper().parseText(response)

// STEP 4: Extract Field Mappings Array
// API returns: { &quot;_embedded&quot;: { &quot;fieldMappings&quot;: [...] } }
def fieldMappings = json._embedded?.fieldMappings ?: []

// STEP 5: Log Each Field Mapping (for debugging)
fieldMappings.each { mapping -&gt;
    def attrName = mapping.columnAttribute?.attributeName   // e.g., textField30
    def aliasName = mapping.aliasName                       // e.g., oppStatus
    def displayText = mapping.displayText                   // e.g., Status
    def dataType = mapping.columnAttribute?.dataType        // e.g., VARCHAR2(2000 BYTE)
}

</stringProp>
