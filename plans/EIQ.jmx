                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Config PostProcessor" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">import groovy.json.JsonSlurper


def response = prev.getResponseDataAsString()

if (response == null || !response.trim().startsWith(&quot;{&quot;)) {
    log.error(&quot;Config API returned NON-JSON response → skipping event creation&quot;)
    vars.put(&quot;skipEventCreation&quot;, &quot;true&quot;)
    return
}

def json = new JsonSlurper().parseText(response)

def configs = []

// ⭐ Case 1 — OLD HAL structure
if (json._embedded?.configs) {

    configs = json._embedded.configs

}

// ⭐ Case 2 — NEW Module → Journeys → Pages → Forms structure
else if (json.journeys instanceof List) {

    json.journeys.each { journey -&gt;

        journey.pages?.each { page -&gt;

            page.forms?.each { form -&gt;

                configs &lt;&lt; [
                        module : [uniqueId: json.uniqueId],
                        journey: [uniqueId: journey.uniqueId],
                        page   : [uniqueId: page.uniqueId],
                        form   : [
                                uniqueId: form.uniqueId,
                                formName: form.formName
                        ],
                        isMultiEntry : form.isMultiEntry
                ]

            }

        }

    }

}

// ⭐ Case 3 — Direct List response
else if (json instanceof List) {

    configs = json

}

// ⭐ Case 4 — Single Config Object
else if (json.form || json.module || json.page || json.journey) {

    configs = [json]

}

// ⭐ Unknown response
else {

    log.error(&quot;Unknown config response structure → ${json.keySet()}&quot;)
    vars.put(&quot;skipEventCreation&quot;, &quot;true&quot;)
    return
}


// ⭐ No configs found → STOP FLOW
if (configs.isEmpty()) {

    log.error(&quot;No configs found → Skipping event creation&quot;)
    vars.put(&quot;skipEventCreation&quot;, &quot;true&quot;)
    return
}


// ⭐ Select RANDOM config (Best for Load Testing)
def config = configs[new Random().nextInt(configs.size())]


// ⭐ Store Variables
vars.put(&quot;eventFormId&quot;, config.form?.uniqueId ?: &quot;&quot;)
vars.put(&quot;eventFormName&quot;, config.form?.formName ?: &quot;&quot;)

vars.put(&quot;currentJourneyId&quot;, config.journey?.uniqueId ?: &quot;&quot;)
vars.put(&quot;currentPageId&quot;, config.page?.uniqueId ?: &quot;&quot;)
vars.put(&quot;currentFormId&quot;, config.form?.uniqueId ?: &quot;&quot;)
vars.put(&quot;currentFormName&quot;, config.form?.formName ?: &quot;&quot;)
vars.put(&quot;currentIsMultiEntry&quot;, (config.isMultiEntry ?: false).toString())

vars.put(&quot;moduleId&quot;, config.module?.uniqueId ?: &quot;&quot;)
vars.put(&quot;formId&quot;, config.form?.uniqueId ?: &quot;&quot;)


// ⭐ Final Safety
if (!vars.get(&quot;formId&quot;)) {
    log.error(&quot;Form ID empty → Skip Event Creation&quot;)
    vars.put(&quot;skipEventCreation&quot;, &quot;true&quot;)
    return
}

log.info(&quot;Selected Config → Module=${vars.get(&quot;moduleId&quot;)} | Journey=${vars.get(&quot;currentJourneyId&quot;)} | Page=${vars.get(&quot;currentPageId&quot;)} | Form=${vars.get(&quot;formId&quot;)}&quot;)
</stringProp>
