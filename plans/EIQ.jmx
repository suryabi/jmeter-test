import groovy.json.JsonSlurper
import groovy.json.JsonOutput

def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)
def lookupValues = json._embedded?.lookupValues ?: []
def lookupMap = [:]
lookupValues.each { lookup -&gt;
    def code = lookup.lookupType?.code
    def value = lookup.value
    if (code &amp;&amp; value) {
        if (!lookupMap.containsKey(code)) lookupMap[code] = []
        lookupMap[code].add(value)
    }
}

// Store each lookup type as JMeter variables
lookupMap.each { code, values -&gt;
    def words = code.toLowerCase().split(&apos;_&apos;)
    def camelCaseName = words[0] + words.drop(1).collect { it.capitalize() }.join(&apos;&apos;)

    vars.put(camelCaseName + &quot;_all&quot;, values.join(&quot;,&quot;))
    vars.put(camelCaseName + &quot;_count&quot;, String.valueOf(values.size()))
    values.eachWithIndex { val, idx -&gt; vars.put(camelCaseName + &quot;_&quot; + (idx + 1), val) }
}


