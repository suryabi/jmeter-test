                <hashTree/>
                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Category Type PostProcessor" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">import groovy.json.JsonSlurper

// Parse JSON response
def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

// Extract category types from response
def categoryTypes = json._embedded?.categoryTypes ?: []

// Validate category types exist
if (categoryTypes.isEmpty()) {
    log.error(&quot;No category types found!&quot;)
    return
}

// Get preferred category type from User Defined Variables
def preferredCategoryType = vars.get(&quot;categoryType&quot;)?.trim()
def selectedCategoryType = null

// Search for preferred category type if specified
if (preferredCategoryType) {
    selectedCategoryType = categoryTypes.find {
        it.uniqueId?.equalsIgnoreCase(preferredCategoryType)
    }

    if (selectedCategoryType) {
        log.info(&quot;Category type: &quot; + preferredCategoryType)
    } else {
        def availableTypes = categoryTypes.collect { it.uniqueId + &quot; (&quot; + (it.categoryTypeName ?: &quot;&quot;) + &quot;)&quot; }.join(&quot;, &quot;)
        log.error(&quot;========================================&quot;)
        log.error(&quot;categoryType &apos;&quot; + preferredCategoryType + &quot;&apos; not found in API response&quot;)
        log.error(&quot;Available: &quot; + availableTypes)
        log.error(&quot;========================================&quot;)
        prev.setSuccessful(false)
        prev.setResponseMessage(&quot;ABORTING: categoryType &apos;&quot; + preferredCategoryType + &quot;&apos; not found. Available: &quot; + availableTypes)
        vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
        vars.put(&quot;_abortReason&quot;, &quot;categoryType &apos;&quot; + preferredCategoryType + &quot;&apos; not found in API response. Available: &quot; + availableTypes)
        ctx.getEngine().stopTest()
        return
    }
}

// Use selected category type (already validated)
// Store selected category type in JMeter variables
vars.put(&quot;categoryTypeId&quot;, selectedCategoryType.uniqueId ?: &quot;&quot;)
vars.put(&quot;categoryTypeName&quot;, selectedCategoryType.categoryTypeName ?: &quot;&quot;)

// Update sampler label with selected category type
def categoryTypeName = vars.get(&quot;categoryTypeName&quot;) ?: &quot;&quot;
if (categoryTypeName) {
    prev.setSampleLabel(prev.getSampleLabel() + &quot; - &quot; + categoryTypeName)
}

</stringProp>
                </JSR223PostProcessor>
