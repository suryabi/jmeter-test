                                      <hashTree>
                                        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                                          <collectionProp name="HeaderManager.headers">
                                            <elementProp name="" elementType="Header">
                                              <stringProp name="Header.name">x-cloud-customerid</stringProp>
                                              <stringProp name="Header.value">${customerId}</stringProp>
                                            </elementProp>
                                            <elementProp name="" elementType="Header">
                                              <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                                              <stringProp name="Header.value">${categoryTypeId}</stringProp>
                                            </elementProp>
                                            <elementProp name="" elementType="Header">
                                              <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                                              <stringProp name="Header.value">${categoryId}</stringProp>
                                            </elementProp>
                                            <elementProp name="" elementType="Header">
                                              <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
