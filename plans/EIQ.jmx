                          <stringProp name="Header.value">${currentUser}</stringProp>
                        </elementProp>
                      </collectionProp>
                    </HeaderManager>
                    <hashTree/>
                    <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Activity Id Extractor" enabled="true">
                      <stringProp name="JSONPostProcessor.referenceNames">activityid</stringProp>
                      <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.eventDates[*].eventDateId</stringProp>
                      <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                    </JSONPostProcessor>
                    <hashTree/>
                    <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Activity Day Extractor" enabled="true">
                      <stringProp name="JSONPostProcessor.referenceNames">activityDate</stringProp>
                      <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.eventDates[*].eventDate.context.contextZoneDate</stringProp>
                      <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                    </JSONPostProcessor>
                    <hashTree/>
                    <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Activity StartTime Extractor" enabled="true">
                      <stringProp name="JSONPostProcessor.referenceNames">activityStartTime</stringProp>
                      <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.eventDates[*].eventStartTime.context.contextZoneDate</stringProp>
                      <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                    </JSONPostProcessor>
                    <hashTree/>
                    <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Activity EndTime Extractor" enabled="true">
                      <stringProp name="JSONPostProcessor.referenceNames">activityEndTime</stringProp>
                      <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.eventDates[*].eventEndTime.context.contextZoneDate</stringProp>
                      <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                    </JSONPostProcessor>
                    <hashTree/>
                    <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Activity Day Counter Extractor" enabled="true">
                      <stringProp name="scriptLanguage">groovy</stringProp>
                      <stringProp name="parameters"></stringProp>
                      <stringProp name="filename"></stringProp>
                      <stringProp name="cacheKey">true</stringProp>
                      <stringProp name="script">// ============================================================================
// ACTIVITY DAYS EXTRACTOR
// Extracts activity days from API response and stores for Day Loop iteration
// ============================================================================

def totalDays = vars.get(&quot;activityid_matchNr&quot;)?.toInteger() ?: 0

// ---------------------------------------------------------------------------
// Store Total Days for Day Loop
// ---------------------------------------------------------------------------
vars.put(&quot;TotalActivityDays&quot;, totalDays.toString())
vars.put(&quot;ActivityDayCount&quot;, &quot;1&quot;)

// ---------------------------------------------------------------------------
// Log Extracted Days Summary
// ---------------------------------------------------------------------------
if (totalDays == 0) {
    log.warn(&quot;[Activity Days Extractor] No activity days found&quot;)
} else {
    def daysSummary = []
    for (int i = 1; i &lt;= totalDays; i++) {
        def dayDate = vars.get(&quot;activityDate_&quot; + i) ?: &quot;N/A&quot;
        def dayStart = vars.get(&quot;activityStartTime_&quot; + i) ?: &quot;&quot;
        def dayEnd = vars.get(&quot;activityEndTime_&quot; + i) ?: &quot;&quot;

        def dateStr = dayDate?.take(10) ?: &quot;N/A&quot;
        def startStr = (dayStart?.length() &gt; 16) ? dayStart.substring(11, 16) : &quot;??&quot;
        def endStr = (dayEnd?.length() &gt; 16) ? dayEnd.substring(11, 16) : &quot;??&quot;

        daysSummary.add(&quot;Day${i}:${dateStr}(${startStr}-${endStr})&quot;)
    }
    }
</stringProp>
                    </JSR223PostProcessor>
                    <hashTree/>
                    <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                    <hashTree/>
                  </hashTree>
                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Copy Location Data to Logistics" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">SampleResult.setIgnore()
// Copy locationId_N from earlier setup to logisticsLocId_N for Logistics ForEach
def matchNr = (vars.get(&quot;locationId_matchNr&quot;) ?: &quot;0&quot;).toInteger()
vars.put(&quot;logisticsLocId_matchNr&quot;, matchNr.toString())
for (int i = 1; i &lt;= matchNr; i++) {
    vars.put(&quot;logisticsLocId_&quot; + i, vars.get(&quot;locationId_&quot; + i) ?: &quot;&quot;)
    vars.put(&quot;logisticsLocName_&quot; + i, vars.get(&quot;locationName_&quot; + i) ?: &quot;&quot;)
}
</stringProp>
                  </JSR223Sampler>
                  <hashTree/>
                  <ForeachController guiclass="ForeachControlPanel" testclass="ForeachController" testname="◉ ForEach (Location - Logistics)" enabled="true">
                    <stringProp name="ForeachController.inputVal">logisticsLocId</stringProp>
                    <stringProp name="ForeachController.returnVal">logisticsCurrentLocId</stringProp>
                    <boolProp name="ForeachController.useSeparator">true</boolProp>
                    <stringProp name="ForeachController.startIndex">0</stringProp>
                    <stringProp name="ForeachController.endIndex">${logisticsLocId_matchNr}</stringProp>
                  </ForeachController>
                  <hashTree>
                    <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Resolve Logistics Location" enabled="true">
                      <stringProp name="scriptLanguage">groovy</stringProp>
                      <stringProp name="parameters"></stringProp>
                      <stringProp name="filename"></stringProp>
                      <stringProp name="cacheKey">true</stringProp>
                      <stringProp name="script">SampleResult.setIgnore()

// Resolve current location name for logging
def currentLocId = vars.get(&quot;logisticsCurrentLocId&quot;)
def matchNr = (vars.get(&quot;logisticsLocId_matchNr&quot;) ?: &quot;0&quot;).toInteger()

for (int i = 1; i &lt;= matchNr; i++) {
    if (vars.get(&quot;logisticsLocId_${i}&quot;) == currentLocId) {
        vars.put(&quot;logisticsCurrentLocName&quot;, vars.get(&quot;logisticsLocName_${i}&quot;) ?: currentLocId)
        break
    }
}

// Also set parentRoom for backward compat with Get Vacant Rooms
vars.put(&quot;parentRoom&quot;, currentLocId)

// Reset activity day counter for this location
vars.put(&quot;ActivityDayCount&quot;, &quot;1&quot;)

vars.put(&quot;existingEventResourceCount&quot;, &quot;0&quot;)

SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)</stringProp>
                    </JSR223Sampler>
                    <hashTree/>
                    <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ If (No Rooms Exist)" enabled="true">
                      <stringProp name="IfController.condition">${__groovy((vars.get(&quot;existingEventResourceCount&quot;) ?: &quot;0&quot;).toInteger() == 0)}</stringProp>
                      <boolProp name="IfController.evaluateAll">false</boolProp>
                      <boolProp name="IfController.useExpression">true</boolProp>
                    </IfController>
                    <hashTree>
                      <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ While (Create Rooms Per Activity Day)" enabled="true">
                        <stringProp name="WhileController.condition">${__groovy(vars.get(&quot;ActivityDayCount&quot;).toInteger() &lt;= vars.get(&quot;TotalActivityDays&quot;).toInteger())}</stringProp>
                      </WhileController>
                      <hashTree>
                        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="───── Location (${logisticsCurrentLocName}) Day(${ActivityDayCount}/${TotalActivityDays}) ─────" enabled="true">
                          <stringProp name="cacheKey">true</stringProp>
                          <stringProp name="filename"></stringProp>
                          <stringProp name="parameters"></stringProp>
                          <stringProp name="script">// Set current activity day variables from indexed variables
def dayIndex = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def totalDays = vars.get(&quot;TotalActivityDays&quot;) ?: &quot;1&quot;

vars.put(&quot;activityid&quot;, vars.get(&quot;activityid_&quot; + dayIndex) ?: &quot;&quot;)
vars.put(&quot;activityDate&quot;, vars.get(&quot;activityDate_&quot; + dayIndex) ?: &quot;&quot;)
vars.put(&quot;activityStartTime&quot;, vars.get(&quot;activityStartTime_&quot; + dayIndex) ?: &quot;&quot;)
vars.put(&quot;activityEndTime&quot;, vars.get(&quot;activityEndTime_&quot; + dayIndex) ?: &quot;&quot;)

// Parse rooms variable and pick random count
// Empty = create ALL available rooms (resolved later in Get Vacant Rooms PostProcessor)
// 0     = skip room creation entirely
def rand = new Random()
def roomsRaw = vars.get(&quot;rooms&quot;)?.trim() ?: &quot;&quot;
def roomCount = 0

if (!roomsRaw) {
    // Empty = use ALL available rooms; set sentinel -1, resolved after fetching vacant rooms
    roomCount = -1
} else if (roomsRaw == &quot;0&quot;) {
    // 0 = skip room creation
    roomCount = 0
} else {
    def roomOptions = roomsRaw.split(&quot;,&quot;)
        .collect { it.trim() }
        .findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }
        .collect { it.toInteger() }
    
    if (roomOptions.size() &gt; 0) {
        roomCount = roomOptions[rand.nextInt(roomOptions.size())]
    }
}

vars.put(&quot;TotalRoomsToCreate&quot;, roomCount.toString())
vars.put(&quot;RoomIndex&quot;, &quot;1&quot;)

def activityDate = vars.get(&quot;activityDate&quot;) ?: &quot;&quot;

// Make visible
SampleResult.setResponseData(&quot;Activity Day: ${dayIndex}/${totalDays}\nDate: ${activityDate}\nRooms: ${roomCount}&quot;, &quot;UTF-8&quot;)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)

</stringProp>
                          <stringProp name="scriptLanguage">groovy</stringProp>
                        </JSR223Sampler>
                        <hashTree/>
                        <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ If (Rooms Exist)" enabled="true">
                          <stringProp name="IfController.condition">${__groovy(vars.get(&quot;TotalRoomsToCreate&quot;).toInteger() &gt; 0 || vars.get(&quot;TotalRoomsToCreate&quot;).toInteger() == -1)}</stringProp>
                          <boolProp name="IfController.evaluateAll">false</boolProp>
                          <boolProp name="IfController.useExpression">true</boolProp>
                        </IfController>
                        <hashTree>
                          <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ While (Room Loop)" enabled="true">
                            <stringProp name="WhileController.condition">${__groovy(def total = vars.get(&quot;TotalRoomsToCreate&quot;).toInteger(); def idx = vars.get(&quot;RoomIndex&quot;).toInteger(); total == -1 ? true : idx &lt;= total)}</stringProp>
                          </WhileController>
                          <hashTree>
                            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Set Room Index (${RoomIndex}/${TotalRoomsToCreate})" enabled="true">
                              <stringProp name="cacheKey">true</stringProp>
                              <stringProp name="filename"></stringProp>
                              <stringProp name="parameters"></stringProp>
                              <stringProp name="script">SampleResult.setIgnore()

def roomIndex = vars.get(&quot;RoomIndex&quot;)?.toInteger() ?: 1
def totalRooms = vars.get(&quot;TotalRoomsToCreate&quot;)?.toInteger() ?: 1

vars.put(&quot;currentRoomIndex&quot;, roomIndex.toString())

</stringProp>
                              <stringProp name="scriptLanguage">groovy</stringProp>
                            </JSR223Sampler>
                            <hashTree/>
                            <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ If (First Room - Fetch Vacant Rooms)" enabled="true">
                              <stringProp name="IfController.condition">${__groovy(vars.get(&quot;RoomIndex&quot;).toInteger() == 1)}</stringProp>
                              <boolProp name="IfController.evaluateAll">false</boolProp>
                              <boolProp name="IfController.useExpression">true</boolProp>
                            </IfController>
                            <hashTree>
                              <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Get Vacant Rooms" enabled="true">
                                <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
                                  <collectionProp name="Arguments.arguments">
                                    <elementProp name="eventDate" elementType="HTTPArgument">
                                      <boolProp name="HTTPArgument.always_encode">true</boolProp>
                                      <stringProp name="Argument.value">${activityDate}</stringProp>
                                      <stringProp name="Argument.metadata">=</stringProp>
                                      <boolProp name="HTTPArgument.use_equals">true</boolProp>
                                      <stringProp name="Argument.name">eventDate</stringProp>
                                    </elementProp>
                                    <elementProp name="type" elementType="HTTPArgument">
                                      <boolProp name="HTTPArgument.always_encode">true</boolProp>
                                      <stringProp name="Argument.value">VACANT_RESOURCE</stringProp>
                                      <stringProp name="Argument.metadata">=</stringProp>
                                      <boolProp name="HTTPArgument.use_equals">true</boolProp>
                                      <stringProp name="Argument.name">type</stringProp>
                                    </elementProp>
                                    <elementProp name="resource" elementType="HTTPArgument">
                                      <boolProp name="HTTPArgument.always_encode">true</boolProp>
                                      <stringProp name="Argument.value">${parentRoom}</stringProp>
                                      <stringProp name="Argument.metadata">=</stringProp>
                                      <boolProp name="HTTPArgument.use_equals">true</boolProp>
                                      <stringProp name="Argument.name">resource</stringProp>
                                    </elementProp>
                                    <elementProp name="startTime" elementType="HTTPArgument">
                                      <boolProp name="HTTPArgument.always_encode">true</boolProp>
                                      <stringProp name="Argument.value">${activityStartTime}</stringProp>
                                      <stringProp name="Argument.metadata">=</stringProp>
                                      <boolProp name="HTTPArgument.use_equals">true</boolProp>
                                      <stringProp name="Argument.name">startTime</stringProp>
                                    </elementProp>
                                    <elementProp name="endTime" elementType="HTTPArgument">
                                      <boolProp name="HTTPArgument.always_encode">true</boolProp>
                                      <stringProp name="Argument.value">${activityEndTime}</stringProp>
                                      <stringProp name="Argument.metadata">=</stringProp>
                                      <boolProp name="HTTPArgument.use_equals">true</boolProp>
                                      <stringProp name="Argument.name">endTime</stringProp>
                                    </elementProp>
                                  </collectionProp>
                                </elementProp>
                                <stringProp name="HTTPSampler.domain"></stringProp>
                                <stringProp name="HTTPSampler.port"></stringProp>
                                <stringProp name="HTTPSampler.protocol"></stringProp>
                                <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                                <stringProp name="HTTPSampler.path">/${contextname}/api/resourcetypes/${roomResourceTypeId}/resources/calendar</stringProp>
                                <stringProp name="HTTPSampler.method">GET</stringProp>
                                <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
                                <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                                <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
                                <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                                <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                                <stringProp name="HTTPSampler.connect_timeout"></stringProp>
                                <stringProp name="HTTPSampler.response_timeout"></stringProp>
                              </HTTPSamplerProxy>
                              <hashTree>
                                <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                                  <collectionProp name="HeaderManager.headers">
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-customerid</stringProp>
                                      <stringProp name="Header.value">${customerId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                                      <stringProp name="Header.value">${categoryTypeId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                                      <stringProp name="Header.value">${categoryId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                                      <stringProp name="Header.value">${baseTimezone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                                      <stringProp name="Header.value">${clientTimeZone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Context-Timezone</stringProp>
                                      <stringProp name="Header.value">${baseTimezone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-eventid</stringProp>
                                      <stringProp name="Header.value">${requestId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-activityday-resource</stringProp>
                                      <stringProp name="Header.value">${activityDayResourceId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X_cloud_user</stringProp>
                                      <stringProp name="Header.value">${currentUser}</stringProp>
                                    </elementProp>
                                  </collectionProp>
                                </HeaderManager>
                                <hashTree/>
                                <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Room ID Extractor" enabled="true">
                                  <stringProp name="JSONPostProcessor.referenceNames">roomId</stringProp>
                                  <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.resourceTimeSlots[*].resources[*].uniqueId</stringProp>
                                  <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                                  <stringProp name="JSONPostProcessor.defaultValues">NOT_FOUND</stringProp>
                                </JSONPostProcessor>
                                <hashTree/>
                                <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Room Name Extractor" enabled="true">
                                  <stringProp name="JSONPostProcessor.referenceNames">roomName</stringProp>
                                  <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.resourceTimeSlots[*].resources[*].data.name</stringProp>
                                  <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                                  <stringProp name="JSONPostProcessor.defaultValues">NOT_FOUND</stringProp>
                                </JSONPostProcessor>
                                <hashTree/>
                                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Prepare Room Selection" enabled="true">
                                  <stringProp name="scriptLanguage">groovy</stringProp>
                                  <stringProp name="parameters"></stringProp>
                                  <stringProp name="filename"></stringProp>
                                  <stringProp name="cacheKey">true</stringProp>
                                  <stringProp name="script">// Prepare room selection - create shuffle and adjust room count
// This only runs ONCE per Activity Day (when RoomIndex == 1)

def dayIndex = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def requestedRooms = vars.get(&quot;TotalRoomsToCreate&quot;)?.toInteger() ?: 0
def extractedRoomCount = vars.get(&quot;roomId_matchNr&quot;)?.toInteger() ?: 0


// Adjust TotalRoomsToCreate if more rooms requested than available
if (extractedRoomCount == 0) {
    log.warn(&quot;Day ${dayIndex}: No vacant rooms available&quot;)
    vars.put(&quot;TotalRoomsToCreate&quot;, &quot;0&quot;)
} else if (requestedRooms == -1) {
    // Empty rooms UDV = create ALL available rooms
    vars.put(&quot;TotalRoomsToCreate&quot;, extractedRoomCount.toString())
} else if (requestedRooms &gt; extractedRoomCount) {
    vars.put(&quot;TotalRoomsToCreate&quot;, extractedRoomCount.toString())
}

// Create shuffled list of room indices for this Activity Day
if (extractedRoomCount &gt; 0) {
    def rand = new Random()
    def availableIndices = (1..extractedRoomCount).collect { it }
    Collections.shuffle(availableIndices, rand)
    
    vars.put(&quot;shuffledRoomIndices_Day${dayIndex}&quot;, availableIndices.join(&quot;,&quot;))
}</stringProp>
                                </JSR223PostProcessor>
                                <hashTree/>
                                <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                                <hashTree/>
                              </hashTree>
                            </hashTree>
                            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Select Current Room (${currentRoomIndex})" enabled="true">
                              <stringProp name="scriptLanguage">groovy</stringProp>
                              <stringProp name="parameters"></stringProp>
                              <stringProp name="filename"></stringProp>
                              <stringProp name="cacheKey">true</stringProp>
                              <stringProp name="script">SampleResult.setIgnore()

// Make visible for debugging
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)

import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

// Select room based on current room index
def roomIndex = vars.get(&quot;currentRoomIndex&quot;)?.toInteger() ?: 1
def totalRooms = vars.get(&quot;TotalRoomsToCreate&quot;)?.toInteger() ?: 1
def dayIndex = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;

// Get extracted room count (from Get Vacant Rooms - only called for first room)
def extractedRoomCount = vars.get(&quot;roomId_matchNr&quot;)?.toInteger() ?: 0

// Get room type from lookup values - NO hardcoded values
def rand = new Random()
def roomTypeCount = vars.get(&quot;roomType_count&quot;)?.toInteger() ?: 0
def roomType = &quot;&quot;

// Skip room creation if no ROOM_TYPE lookup values found
if (roomTypeCount == 0) {
    log.warn(&quot;Day ${dayIndex}: No ROOM_TYPE lookup values found - skipping room creation&quot;)
    vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
    return
}

if (roomTypeCount &gt; 0) {
    if (roomIndex == 1) {
        // First room: Must be Main Room (find from lookup)
        for (int i = 1; i &lt;= roomTypeCount; i++) {
            def lookupValue = vars.get(&quot;roomType_&quot; + i)
            if (lookupValue?.toLowerCase()?.contains(&quot;main&quot;)) {
                roomType = lookupValue
                break
            }
        }
        // If no Main Room found in lookup, use first available
        if (!roomType) {
            roomType = vars.get(&quot;roomType_1&quot;) ?: &quot;&quot;
        }
    } else {
        // Other rooms: Pick randomly from non-Main Room types
        def otherTypes = []
        for (int i = 1; i &lt;= roomTypeCount; i++) {
            def lookupValue = vars.get(&quot;roomType_&quot; + i)
            if (lookupValue &amp;&amp; !lookupValue.toLowerCase().contains(&quot;main&quot;)) {
                otherTypes.add(lookupValue)
            }
        }
        if (otherTypes.size() &gt; 0) {
            roomType = otherTypes[rand.nextInt(otherTypes.size())]
        } else {
            // If only Main Room exists in lookup, pick randomly from all
            def randomIdx = rand.nextInt(roomTypeCount) + 1
            roomType = vars.get(&quot;roomType_&quot; + randomIdx) ?: &quot;&quot;
        }
    }
}

// Skip if no vacant rooms found
if (extractedRoomCount == 0) {
    log.warn(&quot;Day ${dayIndex}: No vacant rooms found - skipping room creation&quot;)
    vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
    return
}

// ROOM SELECTION - use shuffled list created during first room iteration
def selectedRoomId = &quot;&quot;
def selectedRoomName = &quot;&quot;

// Get shuffled indices (created when RoomIndex == 1 in Get Vacant Rooms PostProcessor)
def shuffledIndicesStr = vars.get(&quot;shuffledRoomIndices_Day${dayIndex}&quot;)
if (shuffledIndicesStr) {
    def shuffledIndices = shuffledIndicesStr.split(&quot;,&quot;).collect { it.toInteger() }
    
    // Pick room based on roomIndex from shuffled list
    if (roomIndex &lt;= shuffledIndices.size()) {
        def selectedIndex = shuffledIndices[roomIndex - 1]
        selectedRoomId = vars.get(&quot;roomId_&quot; + selectedIndex)
        selectedRoomName = vars.get(&quot;roomName_&quot; + selectedIndex) ?: &quot;&quot;
    }
} else {
    // Fallback to sequential if shuffle failed
    def selectedIndex = ((roomIndex - 1) % extractedRoomCount) + 1
    selectedRoomId = vars.get(&quot;roomId_&quot; + selectedIndex)
    selectedRoomName = vars.get(&quot;roomName_&quot; + selectedIndex) ?: &quot;&quot;
}

// Skip if roomId is empty
if (!selectedRoomId || selectedRoomId == &quot;NOT_FOUND&quot;) {
    log.warn(&quot;Day ${dayIndex} Room ${roomIndex}: No valid roomId found - skipping&quot;)
    vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
    return
}

// DYNAMIC TIME OFFSET - random start/end times per room
def activityStart = vars.get(&quot;activityStartTime&quot;) ?: &quot;&quot;
def activityEnd = vars.get(&quot;activityEndTime&quot;) ?: &quot;&quot;

// Clean up original times - remove milliseconds and Z suffix
def cleanTime = { String timeStr -&gt;
    if (!timeStr) return timeStr
    return timeStr.replace(&quot;Z&quot;, &quot;&quot;).replaceAll(/\\.[0-9]+/, &quot;&quot;)
}

def roomStartTime = cleanTime(activityStart)
def roomEndTime = cleanTime(activityEnd)


// Set current room variables
vars.put(&quot;roomId&quot;, selectedRoomId)
vars.put(&quot;currentRoomName&quot;, selectedRoomName)
vars.put(&quot;roomType&quot;, roomType)
vars.put(&quot;roomStartTime&quot;, roomStartTime)
vars.put(&quot;roomEndTime&quot;, roomEndTime)
vars.put(&quot;skipRoomCreation&quot;, &quot;false&quot;)

// Logistics Room Notes - random note for each room
def logisticsRoomNotesOptions = [
    &quot;Ensure projector and screen are set up before the session&quot;,
    &quot;Extra power strips required for laptop charging&quot;,
    &quot;Blinds to be closed for projector visibility&quot;,
    &quot;Reserved seating for VIP guests at the front&quot;,
    &quot;Signage to be placed outside the room&quot;,
    &quot;Whiteboard markers and eraser needed&quot;,
    &quot;Print and place agenda copies at each seat&quot;,
    &quot;Wireless microphone and speaker system required&quot;,
    &quot;Place welcome kits at each seat&quot;,
    &quot;Room lighting to be adjusted for presentation mode&quot;,
    &quot;Do not disturb sign to be placed during the session&quot;
]
def noteIndex = (roomIndex - 1) % logisticsRoomNotesOptions.size()
vars.put(&quot;logisticsRoomNotes&quot;, logisticsRoomNotesOptions[noteIndex])

// Store created room for Agenda section - PER DAY to avoid overwrites
// Using SYSTEM PROPERTIES for guaranteed cross-module persistence
def roomIdx = vars.get(&quot;RoomIndex&quot;)?.toInteger() ?: 1
def dayIdx = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;

// Build property names with prefix to avoid conflicts
String propNameId = &quot;jmeter.room.Day${dayIdx}_${roomIdx}_id&quot;.toString()
String propNameName = &quot;jmeter.room.Day${dayIdx}_${roomIdx}_name&quot;.toString()
String propNameCount = &quot;jmeter.roomCount.Day${dayIdx}&quot;.toString()

// Store values using SYSTEM properties (Java-level global)
String roomIdValue = selectedRoomId ?: &quot;&quot;
String roomNameValue = selectedRoomName ?: &quot;&quot;
String roomCountValue = roomIdx.toString()

System.setProperty(propNameId, roomIdValue)
System.setProperty(propNameName, roomNameValue)
System.setProperty(propNameCount, roomCountValue)

// VERIFY immediately after storage
String verifyId = System.getProperty(propNameId)
String verifyCount = System.getProperty(propNameCount)

// Also store in vars for local access
vars.put(&quot;createdRoom_Day${dayIdx}_${roomIdx}_id&quot;.toString(), roomIdValue)
vars.put(&quot;createdRoom_Day${dayIdx}_${roomIdx}_name&quot;.toString(), roomNameValue)
vars.put(&quot;createdRoomCount_Day${dayIdx}&quot;.toString(), roomCountValue)

log.info(&quot;Stored for Agenda - Day ${dayIdx} Room [${roomIdx}]: ${selectedRoomName} (${selectedRoomId})&quot;)

// Debug output


</stringProp>
                            </JSR223Sampler>
