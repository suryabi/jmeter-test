            </IfController>
            <hashTree>
              <ForeachController guiclass="ForeachControlPanel" testclass="ForeachController" testname="◉ ForEach (Location)" enabled="true">
                <stringProp name="ForeachController.inputVal">locationId</stringProp>
                <stringProp name="ForeachController.returnVal">currentLocationId</stringProp>
                <boolProp name="ForeachController.useSeparator">true</boolProp>
                <stringProp name="ForeachController.startIndex">0</stringProp>
                <stringProp name="ForeachController.endIndex">${locationId_matchNr}</stringProp>
              </ForeachController>
              <hashTree>
                <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build Location Payload" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">import groovy.json.JsonOutput

// Get current location ID from ForEach iteration
def locId = vars.get(&quot;currentLocationId&quot;)

// Find the corresponding location name by searching through locationId_N variables
def locName = locId
def matchNr = (vars.get(&quot;locationId_matchNr&quot;) ?: &quot;0&quot;).toInteger()

for (int i = 1; i &lt;= matchNr; i++) {
    if (vars.get(&quot;locationId_${i}&quot;) == locId) {
        locName = vars.get(&quot;locationName_${i}&quot;) ?: locId
        vars.put(&quot;currentLocationName&quot;, locName)
        break
    }
}

// Build payload in format: {&quot;uniqueIds&quot;: [&quot;locationId&quot;]}
def payload = JsonOutput.toJson([uniqueIds: [locId]])
vars.put(&quot;locationPayload&quot;, payload)

</stringProp>
