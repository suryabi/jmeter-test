                                    <hashTree/>
                                    <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Final Safety Check " enabled="true">
                                      <stringProp name="scriptLanguage">groovy</stringProp>
                                      <stringProp name="parameters"></stringProp>
                                      <stringProp name="filename"></stringProp>
                                      <stringProp name="cacheKey">true</stringProp>
                                      <stringProp name="script">// FINAL SAFETY CHECK - v16 (FIXED)
// This PreProcessor runs immediately before the HTTP request
// If validation fails, it clears the payload which causes 400 error (better than no-room activity)

import groovy.json.JsonSlurper

// Force fresh variable read by accessing through ctx
def payload = ctx.getVariables().get(&quot;createActivityPayload&quot;) ?: &quot;&quot;
def currentDay = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;?&quot;
def loopCounter = vars.get(&quot;activityLoopCounter&quot;) ?: &quot;?&quot;

if (!payload?.trim()) {
    log.error(&quot;🛡️ ABORT: Payload is empty - this should NOT happen after If Controller&quot;)
    sampler.setProperty(&quot;HTTPSampler.postBodyRaw&quot;, false)
    return
}

try {
    def jsonSlurper = new JsonSlurper()
    def payloadObj = jsonSlurper.parseText(payload)
    def resourceId = payloadObj?.resourceId ?: &quot;&quot;
    def moduleId = payloadObj?.moduleId ?: &quot;&quot;
    def startTime = payloadObj?.startTime?.isoDate ?: &quot;&quot;
    def endTime = payloadObj?.endTime?.isoDate ?: &quot;&quot;
    // Read activity type from payload, not stale variable
    def activityType = payloadObj?.activityType ?: &quot;unknown&quot;

    // Get room name from selectedRoom variables using resourceId from payload
    def currentRoomName = &quot;Unknown&quot;
    def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
    def validRoom = false
    for (int i = 1; i &lt;= selectedRoomCount; i++) {
        def selectedRoomId = vars.get(&quot;selectedRoomId_&quot; + i) ?: &quot;&quot;
        if (selectedRoomId == resourceId) {
            currentRoomName = vars.get(&quot;selectedRoomName_&quot; + i) ?: &quot;Room ${i}&quot;
            validRoom = true
            break
        }
    }

    // Validate resourceId
    if (!resourceId || resourceId.trim().isEmpty()) {
        log.error(&quot;🛡️ BLOCKED: Empty resourceId - skipping activity&quot;)
        vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
        return
    }

    if (!validRoom) {
        log.error(&quot;🛡️ BLOCKED: Invalid room - skipping activity&quot;)
        vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
        return
    }

} catch (Exception e) {
    log.error(&quot;🛡️ ERROR: &quot; + e.message)
    vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
}</stringProp>
                                    </JSR223PreProcessor>
                                    <hashTree/>
                                    <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Activity Id Extractor" enabled="true">
                                      <stringProp name="JSONPostProcessor.referenceNames">activityId</stringProp>
                                      <stringProp name="JSONPostProcessor.jsonPathExprs">$.activityId</stringProp>
                                      <stringProp name="JSONPostProcessor.match_numbers"></stringProp>
                                    </JSONPostProcessor>
                                    <hashTree/>
                                    <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                                    <hashTree/>
                                    <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Activity Creation Response Handler" enabled="true">
                                      <stringProp name="scriptLanguage">groovy</stringProp>
                                      <stringProp name="parameters"></stringProp>
                                      <stringProp name="filename"></stringProp>
                                      <stringProp name="cacheKey">true</stringProp>
                                      <stringProp name="script">// Activity Creation Response Handler
// This runs AFTER the Create Activity HTTP request

import groovy.json.JsonSlurper

def responseCode = prev.getResponseCode()
def activityId = vars.get(&quot;activityId&quot;) ?: &quot;&quot;
def currentDay = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;?&quot;
def currentDate = vars.get(&quot;activityDate_&quot; + currentDay) ?: &quot;Unknown&quot;
def loopCounter = vars.get(&quot;activityLoopCounter&quot;) ?: &quot;?&quot;

// Read actual values from the payload that was sent
def payload = vars.get(&quot;createActivityPayload&quot;) ?: &quot;&quot;
def activityType = &quot;unknown&quot;
def currentRoomName = &quot;Unknown Room&quot;
def resourceId = &quot;&quot;

if (payload?.trim()) {
    try {
        def jsonSlurper = new JsonSlurper()
        def payloadObj = jsonSlurper.parseText(payload)
        activityType = payloadObj?.activityType ?: vars.get(&quot;loopActivityType&quot;) ?: &quot;unknown&quot;
        resourceId = payloadObj?.resourceId ?: &quot;&quot;

        // Get room name from selected rooms using resourceId
        def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
        for (int i = 1; i &lt;= selectedRoomCount; i++) {
            if (vars.get(&quot;selectedRoomId_&quot; + i) == resourceId) {
                currentRoomName = vars.get(&quot;selectedRoomName_&quot; + i) ?: &quot;Room ${i}&quot;
                break
            }
        }
    } catch (Exception e) {
        activityType = vars.get(&quot;loopActivityType&quot;) ?: &quot;unknown&quot;
        currentRoomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown Room&quot;
    }
}

if (responseCode == &quot;200&quot; &amp;&amp; activityId) {
        // Increment counter only on SUCCESS
    def currentCount = (vars.get(&quot;activityLoopCounter&quot;)?.toInteger() ?: 0) + 1
    vars.put(&quot;activityLoopCounter&quot;, currentCount.toString())
} else {
    log.error(&quot;❌ FAILED: &quot; + activityType + &quot; #&quot; + loopCounter + &quot; | Room: &quot; + currentRoomName)
    log.error(&quot;Response Code: &quot; + responseCode)
    if (!activityId) {
        log.error(&quot;No activityId returned in response&quot;)
    }
}</stringProp>
                                    </JSR223PostProcessor>
                                    <hashTree/>
                                  </hashTree>
                                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Reset Submit Index" enabled="true">
                                    <stringProp name="scriptLanguage">groovy</stringProp>
                                    <stringProp name="parameters"></stringProp>
                                    <stringProp name="filename"></stringProp>
                                    <stringProp name="cacheKey">true</stringProp>
                                    <stringProp name="script">SampleResult.setIgnore()
vars.put(&quot;submitFormIdx&quot;, &quot;0&quot;)
vars.put(&quot;submitFormCount&quot;, vars.get(&quot;moduleConfigsCount&quot;) ?: &quot;0&quot;)
</stringProp>
                                  </JSR223Sampler>
                                  <hashTree/>
                                  <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ While (Submit Forms)" enabled="true">
                                    <stringProp name="WhileController.condition">${__groovy(vars.get(&quot;submitFormIdx&quot;)?.toInteger() &lt; vars.get(&quot;submitFormCount&quot;)?.toInteger())}</stringProp>
                                  </WhileController>
                                  <hashTree>
                                    <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="FORM : ${submitFormName}" enabled="true">
                                      <stringProp name="scriptLanguage">groovy</stringProp>
                                      <stringProp name="parameters"></stringProp>
                                      <stringProp name="filename"></stringProp>
                                      <stringProp name="cacheKey">true</stringProp>
                                      <stringProp name="script">def idx = (vars.get(&quot;submitFormIdx&quot;)?.toInteger() ?: 0) + 1
def nextFormName = vars.get(&quot;formName_&quot; + idx) ?: &quot;unknown&quot;
SampleResult.setSampleLabel(&quot;FORM : &quot; + nextFormName)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setResponseMessage(nextFormName)
SampleResult.setSuccessful(false)
SampleResult.setResponseData(&quot;Form: &quot; + nextFormName, &quot;UTF-8&quot;)
vars.put(&quot;submitFormIdx&quot;, idx.toString())

def submitFormId = vars.get(&quot;formId_&quot; + idx) ?: &quot;&quot;
def submitFormName = vars.get(&quot;formName_&quot; + idx) ?: &quot;&quot;
def submitHandler = vars.get(&quot;formHandler_&quot; + idx) ?: &quot;defaultFormHandler&quot;
def submitJourneyId = vars.get(&quot;journeyId_&quot; + idx) ?: vars.get(&quot;activityJourneyId&quot;) ?: &quot;&quot;
def submitPageId = vars.get(&quot;pageId_&quot; + idx) ?: vars.get(&quot;activityPageId&quot;) ?: &quot;&quot;
def submitModuleId = vars.get(&quot;moduleId_&quot; + idx) ?: vars.get(&quot;currentActivityModuleId&quot;) ?: &quot;&quot;

vars.put(&quot;submitFormId&quot;, submitFormId)
vars.put(&quot;submitFormName&quot;, submitFormName)
vars.put(&quot;submitJourneyId&quot;, submitJourneyId)
vars.put(&quot;submitPageId&quot;, submitPageId)
vars.put(&quot;submitModuleId&quot;, submitModuleId)

// Set variables needed by Dynamic Payload Builder
vars.put(&quot;currentModuleId&quot;, submitModuleId)
vars.put(&quot;currentJourneyId&quot;, submitJourneyId)
vars.put(&quot;currentPageId&quot;, submitPageId)
vars.put(&quot;moduleId&quot;, submitModuleId)

// Restore per-form UIConfig and FieldMappings
def storedUI = vars.get(&quot;storedFormUIConfig_&quot; + idx)
def storedFM = vars.get(&quot;storedFieldMappings_&quot; + idx)
if (storedUI) vars.put(&quot;currentFormUIConfig&quot;, storedUI)
if (storedFM) vars.put(&quot;currentFieldMappings&quot;, storedFM)
vars.put(&quot;formId&quot;, submitFormId)
vars.put(&quot;currentFormId&quot;, submitFormId)
vars.put(&quot;currentFormName&quot;, submitFormName)

// Determine form type
def isNormal = submitHandler != &quot;documentFormHandler&quot; &amp;&amp; submitHandler != &quot;activityParticipantFormHandler&quot;
def isPresenter = submitHandler == &quot;activityParticipantFormHandler&quot;
def isDocument = submitHandler == &quot;documentFormHandler&quot;
vars.put(&quot;isNormalForm&quot;, isNormal.toString())
vars.put(&quot;isPresenterForm&quot;, isPresenter.toString())
vars.put(&quot;isDocumentForm&quot;, isDocument.toString())

def typeLabel = isNormal ? &quot;NORMAL&quot; : (isPresenter ? &quot;PRESENTER&quot; : &quot;DOCUMENT&quot;)
</stringProp>
                                    </JSR223Sampler>
