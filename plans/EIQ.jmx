        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Common Function" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">SampleResult.setIgnore()

import java.util.concurrent.ThreadLocalRandom

// ============ Shared Helper Functions ============

// Generate future date based on request startDate
props.put(&quot;fn_generateFutureDate&quot;, { varsRef -&gt;
    def rand = ThreadLocalRandom.current()
    def startDateStr = varsRef.get(&quot;startDate&quot;) ?: &quot;&quot;
    def baseDate
    if (startDateStr) {
        baseDate = Date.parse(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;, startDateStr)
    } else {
        baseDate = new Date()
    }
    def futureDate = baseDate.plus(rand.nextInt(30) + 1)
    return futureDate.format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;)
})

// Generate future time with hour offset (uses same random day within a form)
props.put(&quot;fn_generateFutureTime&quot;, { varsRef, int hoursOffset -&gt;
    def rand = ThreadLocalRandom.current()
    def calendar = Calendar.getInstance()
    // Reuse the same random day offset if already generated for this form
    def dayOffsetKey = &quot;_futureTimeDayOffset&quot;
    def existingOffset = varsRef.get(dayOffsetKey)
    int dayOffset
    if (existingOffset != null &amp;&amp; existingOffset.isInteger()) {
        dayOffset = existingOffset.toInteger()
    } else {
        dayOffset = rand.nextInt(30) + 1
        varsRef.put(dayOffsetKey, String.valueOf(dayOffset))
    }
    calendar.add(Calendar.DAY_OF_MONTH, dayOffset)
    calendar.set(Calendar.HOUR_OF_DAY, hoursOffset)
    calendar.set(Calendar.MINUTE, 0)
    calendar.set(Calendar.SECOND, 0)
    calendar.set(Calendar.MILLISECOND, 0)
    return calendar.getTime().format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;)
})

// Reset future time day offset (call before each new form to get a fresh random day)
props.put(&quot;fn_resetFutureTimeDayOffset&quot;, { varsRef -&gt;
    varsRef.remove(&quot;_futureTimeDayOffset&quot;)
})

// Generate random number in range
props.put(&quot;fn_generateRandomNumber&quot;, { int min, int max -&gt;
    def rand = ThreadLocalRandom.current()
    return rand.nextInt(max - min + 1) + min
})

// Default text values for auto-generation
props.put(&quot;fn_defaultTextFields&quot;, [
    &quot;Innovation Workshop&quot;,
    &quot;Executive Briefing&quot;,
    &quot;Product Roadmap Discussion&quot;,
    &quot;Solution Architecture Review&quot;,
    &quot;Strategic Planning Session&quot;,
    &quot;Requirements Gathering&quot;,
    &quot;Revenue Growth Strategy&quot;,
    &quot;Workforce Planning Session&quot;,
    &quot;Cloud Migration Strategy&quot;,
    &quot;API Integration Planning&quot;,
    &quot;Data Analytics Discussion&quot;,
    &quot;Platform Evaluation&quot;,
    &quot;Weekly Sync Meeting&quot;,
    &quot;Training Workshop&quot;,
    &quot;Knowledge Transfer Session&quot;
] as String[])

// ============ 4. Get Random Selection Count ============
props.put(&quot;fn_multiSelectCount&quot;, { int availableCount -&gt;
    def rand = ThreadLocalRandom.current()
    def multiSelectRangeRaw = (props.get(&quot;multiSelectRange&quot;) ?: vars?.get(&quot;multiSelectRange&quot;) ?: &quot;1,3&quot;).split(&quot;,&quot;)*.trim()
    def minSel = multiSelectRangeRaw[0].toInteger()
    def maxSel = multiSelectRangeRaw.size() &gt; 1 ? multiSelectRangeRaw[1].toInteger() : multiSelectRangeRaw[0].toInteger()
    def maxPossible = Math.min(availableCount, maxSel)
    def minPossible = Math.min(minSel, maxPossible)
    return minPossible + rand.nextInt((maxPossible - minPossible) + 1)
})

// ============ 5. Parse Field Mappings ============
props.put(&quot;fn_parseFieldMappings&quot;, { String fieldMappingsStr -&gt;
    def fmMap = [:]
    if (fieldMappingsStr) {
        try {
            def fmJson = new groovy.json.JsonSlurper().parseText(fieldMappingsStr)
            def mappings = fmJson._embedded?.fieldMappings ?: []
            mappings.each { mapping -&gt;
                def attrName = mapping.columnAttribute?.attributeName
                def aliasName = mapping.aliasName
                if (attrName &amp;&amp; aliasName) {
                    fmMap[attrName] = [
                        aliasName  : aliasName,
                        displayText: mapping.displayText,
                        dataType   : mapping.columnAttribute?.dataType
                    ]
                }
            }
        } catch (Exception e) {
            log.warn(&quot;fn_parseFieldMappings: Error parsing mapping entry — ${e.message}&quot;)
        }
    }
    return fmMap
})

// ============ 6. Extract All Fields from formUIConfig ============
props.put(&quot;fn_extractAllFields&quot;, { String fuiConfigStr -&gt;
    def fuiConfig = new groovy.json.JsonSlurper().parseText(fuiConfigStr)
    def fields = []
    def items = fuiConfig.config ?: []
    items.each { item -&gt;
        if (item.type == &quot;SECTION&quot;) {
            fields.addAll(item.formFields ?: [])
        } else if (item.type == &quot;FORMFIELD&quot;) {
            fields.add(item)
        }
    }
    return fields
})

// ============ 7. Build Dependent Controls Map ============
props.put(&quot;fn_buildDependentControlsMap&quot;, { allFieldsList -&gt;
    def dcMap = [:]
    def dcFieldSet = [] as Set
    allFieldsList.each { field -&gt;
        def parentFN = field.dataMapping ?: field.formControlName
        def depControls = field.dependentControls ?: []
        if (depControls) {
            def depList = []
            depControls.each { dep -&gt;
                def depFN = dep.dataMapping ?: dep.formControlName
                def hideR = dep.rules?.hide
                if (depFN &amp;&amp; hideR) {
                    depList.add([fieldName: depFN, evalCondition: hideR.evalCondition, evalValue: hideR.evalValue])
                    dcFieldSet.add(depFN)
                }
            }
            if (depList) { dcMap[parentFN] = depList }
        }
    }
    return [map: dcMap, fieldSet: dcFieldSet]
})

// ============ 8. Should Show Dependent Field ============
props.put(&quot;fn_shouldShowDependentField&quot;, { String depFN, Map formDataSoFar, Map dcMap -&gt;
    def result = true
    dcMap.each { parentField, dependents -&gt;
        dependents.each { dep -&gt;
            if (dep.fieldName == depFN) {
                def parentValue = formDataSoFar[parentField]
                def shouldHide = false
                if (parentValue != null) {
                    def pVal = parentValue
                    def eVal = dep.evalValue
                    if (pVal instanceof Boolean || eVal instanceof Boolean) {
                        pVal = pVal?.toString()?.toLowerCase() == &quot;true&quot;
                        eVal = eVal?.toString()?.toLowerCase() == &quot;true&quot;
                    }
                    if (pVal instanceof List) {
                        switch(dep.evalCondition) {
                            case &quot;==&quot;: shouldHide = !pVal.contains(eVal); break
                            case &quot;!=&quot;: shouldHide = !pVal.contains(eVal); break
                        }
                    } else {
                        switch(dep.evalCondition) {
                            case &quot;==&quot;: shouldHide = (pVal == eVal); break
                            case &quot;!=&quot;: shouldHide = (pVal != eVal); break
                        }
                    }
                }
                if (shouldHide) { result = false }
            }
        }
    }
    return result
})

// ============ 9. Get Indexed Value ============
props.put(&quot;fn_getIndexedValue&quot;, { String csv, int entryIdx -&gt;
    if (!csv) return null
    if (csv.contains(&quot;,&quot;)) {
        def vals = csv.split(&quot;,&quot;)
        def idx = entryIdx - 1
        return (idx &gt;= 0 &amp;&amp; idx &lt; vals.length) ? vals[idx].trim() : vals[0].trim()
    }
    return csv.trim()
})

// ============ 10. Additional Shared Data Arrays ============
props.put(&quot;fn_businessTitles&quot;, [
    &quot;Manager&quot;, &quot;Director&quot;, &quot;Vice President&quot;, &quot;Team Lead&quot;,
    &quot;Project Manager&quot;, &quot;Business Analyst&quot;, &quot;Product Manager&quot;,
    &quot;Operations Manager&quot;, &quot;Account Executive&quot;, &quot;Sales Representative&quot;,
    &quot;Marketing Manager&quot;, &quot;Financial Analyst&quot;
] as String[])

// Get a random business title from the shared list
props.put(&quot;fn_getRandomBusinessTitle&quot;, {
    def titles = props.get(&quot;fn_businessTitles&quot;)
    return titles[ThreadLocalRandom.current().nextInt(titles.length)]
})

// Random digit generators (returns fresh value on each call)
props.put(&quot;fn_random4&quot;, { ThreadLocalRandom.current().nextInt(1000, 10000) })       // 4 digits (1000-9999)
props.put(&quot;fn_random5&quot;, { ThreadLocalRandom.current().nextInt(10000, 100000) })     // 5 digits (10000-99999)
props.put(&quot;fn_random6&quot;, { ThreadLocalRandom.current().nextInt(100000, 1000000) })   // 6 digits (100000-999999)

// Generate random 10-digit mobile number starting with 7, 8, or 9
props.put(&quot;fn_generatePhone&quot;, {
    def rand = ThreadLocalRandom.current()
    def validStartDigits = [7, 8, 9]
    def digit = validStartDigits[rand.nextInt(validStartDigits.size())]
    def rest = rand.nextLong(100000000L, 1000000000L)
    return String.valueOf(digit) + String.valueOf(rest)
})

// Extract email domain from formUIConfig DOMAIN_EMAIL validator (defaults to gmail.com)
props.put(&quot;fn_extractEmailDomain&quot;, { varsRef -&gt;
    def emailDomain = &quot;gmail.com&quot;
    try {
        def formUIConfigStr = varsRef.get(&quot;currentFormUIConfig&quot;)
        if (formUIConfigStr) {
            def formUIConfig = new groovy.json.JsonSlurper().parseText(formUIConfigStr)
            def configItems = formUIConfig.config ?: []
            configItems.each { item -&gt;
                if (item.validators) {
                    item.validators.each { validator -&gt;
                        if (validator.toString().startsWith(&quot;DOMAIN_EMAIL:&quot;)) {
                            emailDomain = validator.toString().split(&quot;:&quot;)[1]
                        }
                    }
                }
            }
        }
    } catch (Exception e) {
        log.warn(&quot;Error parsing formUIConfig for email domain: &quot; + e.message)
    }
    return emailDomain
})

