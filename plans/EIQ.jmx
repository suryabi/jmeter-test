                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">import groovy.json.JsonSlurper

def tenant = new JsonSlurper().parseText(prev.getResponseDataAsString())._embedded?.tenants?.getAt(0)

vars.put(&quot;customerId&quot;, tenant?.uniqueId ?: &quot;&quot;)
vars.put(&quot;activeCustomer&quot;, tenant?.customerName ?: &quot;&quot;)

// Update sampler label with selected customer
def customerName = vars.get(&quot;activeCustomer&quot;) ?: &quot;&quot;
if (customerName) {
	prev.setSampleLabel(prev.getSampleLabel() + &quot; - &quot; + customerName)
}

log.info(&quot;Active Customer: ${customerName} | ID: ${vars.get(&apos;customerId&apos;)}&quot;)

</stringProp>
