                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Beautify Form Config PostProcessor" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput

// UI Config JSON Beautifier

try {
    def response = prev.getResponseDataAsString()
    def json = new JsonSlurper().parseText(response)

    // Parse the stringified formUIConfig into actual JSON
    if (json.formUIConfig) {
        if (json.formUIConfig instanceof String) {
            json.formUIConfig = new JsonSlurper().parseText(json.formUIConfig)
        }
        // Update currentFormUIConfig variable with parsed JSON
        vars.put(&quot;currentFormUIConfig&quot;, JsonOutput.toJson(json.formUIConfig))
            }

    // Beautify and store
    def beautified = JsonOutput.prettyPrint(JsonOutput.toJson(json))
    prev.setResponseData(beautified, &quot;UTF-8&quot;)

} catch (Exception e) {
    log.warn(&quot;Could not beautify JSON: &quot; + e.getMessage())
}</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                  <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                  <hashTree/>
                </hashTree>
                <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="⌛ Create Event - ${eventName}" enabled="true">
                  <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
                  <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                    <collectionProp name="Arguments.arguments">
                      <elementProp name="" elementType="HTTPArgument">
                        <boolProp name="HTTPArgument.always_encode">false</boolProp>
                        <stringProp name="Argument.value">${dynamicFormPayload}</stringProp>
                        <stringProp name="Argument.metadata">=</stringProp>
                      </elementProp>
                    </collectionProp>
                  </elementProp>
                  <stringProp name="HTTPSampler.domain"></stringProp>
                  <stringProp name="HTTPSampler.port"></stringProp>
                  <stringProp name="HTTPSampler.protocol"></stringProp>
                  <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                  <stringProp name="HTTPSampler.path">/${contextname}/api/forms/${eventFormId}/data</stringProp>
                  <stringProp name="HTTPSampler.method">POST</stringProp>
                  <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
                  <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                  <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
                  <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                  <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                  <stringProp name="HTTPSampler.connect_timeout"></stringProp>
                  <stringProp name="HTTPSampler.response_timeout"></stringProp>
                </HTTPSamplerProxy>
                <hashTree>
                  <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                    <collectionProp name="HeaderManager.headers">
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-customerid</stringProp>
                        <stringProp name="Header.value">${customerId}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                        <stringProp name="Header.value">${categoryTypeId}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                        <stringProp name="Header.value">${categoryId}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                        <stringProp name="Header.value">${baseTimezone}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                        <stringProp name="Header.value">${clientTimeZone}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">X-Cloud-Context-Timezone</stringProp>
                        <stringProp name="Header.value">${baseTimezone}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">X_cloud_user</stringProp>
                        <stringProp name="Header.value">${currentUser}</stringProp>
                      </elementProp>
                    </collectionProp>
                  </HeaderManager>
                  <hashTree/>
                  <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="New Event PreProcessor" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">import java.util.concurrent.ThreadLocalRandom
import java.util.Random

def rand = java.util.concurrent.ThreadLocalRandom.current()

// Helper Function: Generate 4-digit random number (1000-9999)
def random4 = { -&gt; ThreadLocalRandom.current().nextInt(1000, 10000) }

def getRandomSelectionCount = props.get(&quot;fn_multiSelectCount&quot;)
def _msRange = (vars.get(&quot;multiSelectRange&quot;) ?: &quot;1,3&quot;).split(&quot;,&quot;)*.trim()
def minSelection = _msRange[0].toInteger()
def maxSelection = _msRange.size() &gt; 1 ? _msRange[1].toInteger() : _msRange[0].toInteger()

def selectedCustomer = vars.get(&quot;eventName&quot;)
log.info(&quot;Using customer: ${selectedCustomer}&quot;)
log.info(&quot;Skip event creation flag: ${vars.get(&apos;skipEventCreation&apos;)}&quot;)


// Secondary Opportunity IDs (based on isMultiple flag)
boolean isMultiple = true

def opportunityIds = []

if (isMultiple) {
    int opportunityCount = getRandomSelectionCount(maxSelection)
    for (int i = 0; i &lt; opportunityCount; i++) {
        opportunityIds.add(String.valueOf(random4()))
    }
    log.info(&quot;Secondary Opportunity IDs (isMultiple=true, count=${opportunityCount}, min=${minSelection}, max=${maxSelection}): &quot; + opportunityIds.join(&quot;, &quot;))
} else {
    // Generate single ID
    opportunityIds.add(String.valueOf(random4()))
    log.info(&quot;Secondary Opportunity ID (isMultiple=false): &quot; + opportunityIds[0])
}

vars.put(&quot;secondaryOpportunity&quot;, opportunityIds.join(&quot;,&quot;))
vars.put(&quot;opportunity&quot;, opportunityIds.join(&quot;,&quot;))
// Log Generated Values
log.info(&quot;Event Name: &quot; + selectedCustomer)
log.info(&quot;Duration: &quot; + vars.get(&quot;duration&quot;))
log.info(&quot;Start Date: &quot; + vars.get(&quot;startDate&quot;))
log.info(&quot;Start Time: &quot; + vars.get(&quot;startTime&quot;))
log.info(&quot;End Time: &quot; + vars.get(&quot;endTime&quot;))

// Set eventPlannerEmail alias (defaultUser or first user)
def eventPlannerEmail = vars.get(&quot;defaultUser&quot;) ?: vars.get(&quot;user_1&quot;) ?: vars.get(&quot;currentUser&quot;) ?: &quot;&quot;
log.info(&quot;Event Planner Email: &quot; + eventPlannerEmail)

// Country
def tzCountry = vars.get(&quot;requestTimeZoneCountry&quot;) ?: vars.get(&quot;requestTimeZoneCity&quot;)
log.info(&quot;Country (from timezone): &quot; + tzCountry)

// City (from timezone e.g. Australia/Adelaide → Adelaide)
def tzCity = vars.get(&quot;requestTimeZoneCity&quot;) ?: &quot;&quot;
vars.put(&quot;city&quot;, tzCity)
log.info(&quot;City (from timezone): &quot; + tzCity)

</stringProp>
                  </JSR223PreProcessor>
                  <hashTree/>
                  <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Dynamic Payload Builder PreProcessor" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput
import java.util.Random

def formName = vars.get(&quot;currentFormName&quot;)

def rand = java.util.concurrent.ThreadLocalRandom.current()

def getRandomSelectionCount = props.get(&quot;fn_multiSelectCount&quot;)
def generateRandomNumber    = props.get(&quot;fn_generateRandomNumber&quot;)
def generateFutureDate      = props.get(&quot;fn_generateFutureDate&quot;)
def generateFutureTime      = props.get(&quot;fn_generateFutureTime&quot;)
// STEP 1: Get formUIConfig
def formUIConfigStr = vars.get(&quot;currentFormUIConfig&quot;)

if (!formUIConfigStr) {
    log.warn(&quot;formUIConfig not found - skipping&quot;)
    vars.put(&quot;dynamicFormPayload&quot;, &quot;{}&quot;)
    return
}
// STEP 2: Get and Parse fieldMappings
def fieldMappingsStr = vars.get(&quot;currentFieldMappings&quot;)
def fieldMappingsMap = [:]

if (fieldMappingsStr) {
    try {
        def fieldMappingsJson = new JsonSlurper().parseText(fieldMappingsStr)
        def mappings = fieldMappingsJson._embedded?.fieldMappings ?: []

        // Build mapping: attributeName  to  aliasName, displayText, dataType
        mappings.each { mapping -&gt;
            def attrName = mapping.columnAttribute?.attributeName
            def aliasName = mapping.aliasName
            if (attrName &amp;&amp; aliasName) {
                fieldMappingsMap[attrName] = [
                    aliasName  : aliasName,
                    displayText: mapping.displayText,
                    dataType   : mapping.columnAttribute?.dataType
                ]
            }
        }
    } catch (Exception e) {
        log.warn(&quot;Error parsing fieldMappings: &quot; + e.message)
    }
}
// STEP 3: Parse formUIConfig and Extract All Fields
def formUIConfig = new JsonSlurper().parseText(formUIConfigStr)
def allFields = []

def configItems = formUIConfig.config ?: []
configItems.each { item -&gt;
    if (item.type == &quot;SECTION&quot;) {
        def sectionFields = item.formFields ?: []
        allFields.addAll(sectionFields)
    } else if (item.type == &quot;FORMFIELD&quot;) {
        allFields.add(item)
    }
}

// STEP 4: Initialize Form Data and Default Values
def formData = [:]

def randomUserCountDPB1 = (vars.get(&quot;randomUserCount&quot;) ?: &quot;0&quot;).toInteger()
def usedDPB1Indices = [] as Set
def lastPickedUser = [firstName: null, lastName: null]
def pickFreshUser = {
    if (randomUserCountDPB1 == 0) {
        lastPickedUser = [firstName: vars.get(&quot;customerFirstName&quot;) ?: &quot;John&quot;, lastName: vars.get(&quot;customerLastName&quot;) ?: &quot;Doe&quot;]
        return lastPickedUser
    }
    def avail = (1..randomUserCountDPB1).findAll { !usedDPB1Indices.contains(it) }
    if (avail.isEmpty()) {
        usedDPB1Indices.clear()
        avail = (1..randomUserCountDPB1).toList()
    }
    def idx = avail[rand.nextInt(avail.size())]
    usedDPB1Indices.add(idx)
    lastPickedUser = [
        firstName: vars.get(&quot;randomUser_${idx}_firstName&quot;) ?: &quot;John&quot;,
        lastName : vars.get(&quot;randomUser_${idx}_lastName&quot;) ?: &quot;Doe&quot;
    ]
    return lastPickedUser
}

// Default text values for auto-generation
// Loaded from Common Function via props (single source of truth)
def defaultTexts = (props.get(&quot;fn_defaultTextFields&quot;) ?: [&quot;Executive Briefing&quot;, &quot;Innovation Workshop&quot;, &quot;Strategic Planning Session&quot;]) as String[]

// Default textarea values for auto-generation
// Loaded from Common Function via props (single source of truth)
def textareaValues = (props.get(&quot;fn_defaultTextAreas&quot;) ?: [&quot;Provide overview of enterprise solutions and demonstrate alignment with strategic goals&quot;]) as String[]
// STEP 4.5: Build Dependent Controls Map
def dependentControlsMap = [:]
def dependentFieldsSet = [] as Set

allFields.each { field -&gt;
    def parentFieldName = field.dataMapping ?: field.formControlName
    def dependentControls = field.dependentControls ?: []

    if (dependentControls) {
        def dependentsList = []

        dependentControls.each { dep -&gt;
            def depFieldName = dep.dataMapping ?: dep.formControlName
            def hideRules = dep.rules?.hide

            if (depFieldName &amp;&amp; hideRules) {
                dependentsList.add([
                    fieldName    : depFieldName,
                    evalCondition: hideRules.evalCondition,
                    evalValue    : hideRules.evalValue
                ])
                dependentFieldsSet.add(depFieldName)
            }
        }

        if (dependentsList) {
            dependentControlsMap[parentFieldName] = dependentsList
        }
    }
}

// Helper: Check if dependent field should be shown
def shouldShowDependentField = { String depFieldName, Map formDataSoFar -&gt;
    def result = true

    dependentControlsMap.each { parentField, dependents -&gt;
        dependents.each { dep -&gt;
            if (dep.fieldName == depFieldName) {
                def parentValue = formDataSoFar[parentField]
                def evalCondition = dep.evalCondition
                def evalValue = dep.evalValue

                def shouldHide = false

                if (parentValue != null) {
                    def pVal = parentValue
                    def eVal = evalValue

                    // Handle boolean comparison
                    if (pVal instanceof Boolean || eVal instanceof Boolean) {
                        pVal = pVal?.toString()?.toLowerCase() == &quot;true&quot;
                        eVal = eVal?.toString()?.toLowerCase() == &quot;true&quot;
                    }

                    // Handle List comparison (multi-select parent fields)
                    if (pVal instanceof List) {
                        switch(evalCondition) {
                            case &quot;==&quot;: shouldHide = !pVal.contains(eVal); break
                            case &quot;!=&quot;: shouldHide = !pVal.contains(eVal); break
                        }
                    } else {
                        // Evaluate condition
                        switch(evalCondition) {
                            case &quot;==&quot;:
                                shouldHide = (pVal == eVal)
                                break
                            case &quot;!=&quot;:
                                shouldHide = (pVal != eVal)
                                break
                        }
                    }
                }

                if (shouldHide) {
                    result = false
                }
            }
        }
    }
    return result
}

// Get existing form data (stored from Get Form API)
def existingFormDataStr = vars.get(&quot;existingFormData&quot;)
def existingFormData = existingFormDataStr ? new JsonSlurper().parseText(existingFormDataStr) : [:]

// STEP 5: Process Each Field
allFields.each { field -&gt;

    // Extract field properties
    def fieldName = field.dataMapping ?: field.formControlName
    def fieldType = field.formControlType
    def fieldLabel = field.fieldLabel ?: fieldName
    def isMultiple = field.isMultiple ?: false
    def lookupName = field.lookupName
    def isHidden = field.hide ?: false
    def isDisabled = field.disabled ?: false    

    // CHECK: Skip if field already has MEANINGFUL value in existing data
    def existingValue = existingFormData[fieldName]
    def isNumericField = fieldType in [&quot;NUMBER&quot;, &quot;CURRENCY&quot;, &quot;DECIMAL&quot;]
    def isBooleanField = fieldType == &quot;CHECKBOX&quot;
    def isEmptyNumeric = isNumericField &amp;&amp; (existingValue == 0 || existingValue == 0.0)
    def isEmptyBoolean = isBooleanField &amp;&amp; (existingValue == false || existingValue == &quot;false&quot;)

    if (existingValue != null &amp;&amp; existingValue.toString().trim() != &quot;&quot; &amp;&amp; !isEmptyNumeric &amp;&amp; !isEmptyBoolean) {
        formData[fieldName] = existingValue
        return
    }

    // Extract Resource/Master Type IDs
    def resourceTypeId = field.resourceTypeId ?: field.resourceType?.id ?:
                         field.resourceType?.uniqueId ?:
                         (field.resourceType instanceof String ? field.resourceType : null)
    def masterTypeId = field.masterTypeId ?: field.masterType?.id ?:
                       field.masterType?.uniqueId ?:
                       (field.masterType instanceof String ? field.masterType : null)

    // Get aliasName from fieldMappings
    def mappingInfo = fieldMappingsMap[fieldName]
    def aliasName = mappingInfo?.aliasName
    // Skip hidden fields unless dependent (parent may show them)
    if (isHidden &amp;&amp; !dependentFieldsSet.contains(fieldName)) {
        return
    }

    // Skip fields based on hiddenRoles (check against selected role only)
    def hiddenRoles = field.hiddenRoles ?: []
    if (hiddenRoles) {
        def userRole = vars.get(&quot;roleId&quot;) ?: &quot;&quot;
        
        if (hiddenRoles.contains(userRole)) {
            return
        }
    }

    // Skip fields based on readOnlyRoles (check against selected role only)
    def readOnlyRoles = field.readOnlyRoles ?: []
    if (readOnlyRoles) {
        def userRole = vars.get(&quot;roleId&quot;) ?: &quot;&quot;
        
        if (readOnlyRoles.contains(userRole)) {
            return
        }
    }
    
    if (isDisabled) {
        
        return
    }
    // Check Dependent Field Visibility
    if (dependentFieldsSet.contains(fieldName)) {
        if (!shouldShowDependentField(fieldName, formData)) {
            return
        }
    }

    def value = null
    def skipField = false
    // PRIORITY 1: Get Value from JMeter Variable (via alias)
    // For SELECT fields with isMultiple=true and lookupName, skip alias to use multi-select logic
    def skipAliasForMultiSelect = (fieldType == &quot;SELECT&quot; &amp;&amp; isMultiple &amp;&amp; lookupName)
    if (skipAliasForMultiSelect) {

    }

    if (aliasName &amp;&amp; !skipAliasForMultiSelect) {
        value = vars.get(aliasName)

        if (value != null &amp;&amp; value != &quot;&quot;) {
            if (isMultiple &amp;&amp; fieldType != &quot;TEXTAREA&quot; &amp;&amp; value instanceof String &amp;&amp; value.contains(&quot;,&quot;)) {
                value = value.split(&quot;,&quot;).collect { it.trim() }.toList()
            } else if (isMultiple) {
                value = [value]
            }
        }
    }
    // PRIORITY 2: Auto-generate if No Alias or No Value
    if (value == null || value == &quot;&quot;) {
        switch(fieldType) {

            // TEXT Field
            case &quot;TEXT&quot;:
                // Smart field detection — detect name/email/phone/company fields
                def labelLower = (fieldLabel ?: fieldName).toLowerCase()
                def aliasLower = (aliasName ?: &quot;&quot;).toLowerCase()
                def validators = field.validators ?: []
                def isEmailField = validators.any { it.toString().contains(&quot;EMAIL&quot;) }
                def hasDomainEmail = validators.find { it.toString().startsWith(&quot;DOMAIN_EMAIL:&quot;) }
                def isPhoneField = labelLower.contains(&quot;mobile&quot;) || labelLower.contains(&quot;phone&quot;) || aliasLower.contains(&quot;phone&quot;) || aliasLower.contains(&quot;mobile&quot;)
                def isCompanyField = labelLower.contains(&quot;company&quot;) || labelLower.contains(&quot;organi&quot;) || aliasLower.contains(&quot;company&quot;) || aliasLower.contains(&quot;organi&quot;)
                def isNameField = (labelLower.contains(&quot;name&quot;) || aliasLower.contains(&quot;name&quot;)) &amp;&amp; !isCompanyField
                def isOpportunityField = labelLower.contains(&quot;opportunity&quot;) || aliasLower.contains(&quot;opportunity&quot;)

                if (isOpportunityField) {
                    def oppIds = vars.get(&quot;opportunity&quot;) ?: vars.get(&quot;secondaryOpportunity&quot;) ?: &quot;&quot;
                    if (oppIds) {
                        def idList = oppIds.split(&quot;,&quot;).collect { it.trim() }.findAll { it }
                        value = isMultiple ? idList : idList[0]
                    } else {
                        value = String.valueOf(rand.nextInt(9000) + 1000)
                    }
                } else if (isPhoneField) {
                    def digit = [7, 8, 9][rand.nextInt(3)]
                    def rest = java.util.concurrent.ThreadLocalRandom.current().nextLong(100000000L, 1000000000L)
                    value = String.valueOf(digit) + String.valueOf(rest)
                } else if (isCompanyField) {
                    value = vars.get(&quot;customerName&quot;) ?: vars.get(&quot;eventName&quot;) ?: &quot;Acme Corp&quot;
                } else if (isEmailField) {
                    def hasDomainEmailVal = hasDomainEmail ? hasDomainEmail.toString().split(&quot;:&quot;)[1]?.trim() : null
                    def emailDomainsUdv = vars.get(&quot;emailDomains&quot;)?.trim()
                    def domainOptionsList = emailDomainsUdv ? emailDomainsUdv.split(&quot;,&quot;).collect { it.trim() }.findAll { it } : ((props.get(&quot;fn_emailDomains&quot;) ?: [&quot;gmail.com&quot;]) as List)
                    def pickDomain = {
                        if (hasDomainEmailVal) return hasDomainEmailVal
                        if (domainOptionsList.size() &gt; 0) return domainOptionsList[rand.nextInt(domainOptionsList.size())]
                        return &quot;gmail.com&quot;
                    }
                    if (isMultiple) {
                        def count = getRandomSelectionCount(3)
                        def emails = []
                        for (int j = 0; j &lt; count; j++) {
                            def u = pickFreshUser()
                            emails.add(&quot;${u.firstName.toLowerCase()}.${u.lastName.toLowerCase()}@${pickDomain()}&quot;)
                        }
                        value = emails
                    } else if (lastPickedUser.firstName) {
                        // Single email — match the last name field&apos;s person
                        value = &quot;${lastPickedUser.firstName.toLowerCase()}.${lastPickedUser.lastName.toLowerCase()}@${pickDomain()}&quot;
                    } else {
                        def u = pickFreshUser()
                        value = &quot;${u.firstName.toLowerCase()}.${u.lastName.toLowerCase()}@${pickDomain()}&quot;
                    }
                } else if (isNameField) {
                    if (isMultiple) {
                        def count = getRandomSelectionCount(3)
                        def names = []
                        for (int j = 0; j &lt; count; j++) {
                            def u = pickFreshUser()
                            names.add(&quot;${u.firstName} ${u.lastName}&quot;)
                        }
                        value = names
                    } else {
                        def u = pickFreshUser()
                        value = &quot;${u.firstName} ${u.lastName}&quot;
                    }
                } else if (isMultiple) {
                    def count = getRandomSelectionCount(defaultTexts.size())
                    def values = []
                    for (int j = 0; j &lt; count; j++) {
                        values.add(defaultTexts[rand.nextInt(defaultTexts.size())])
                    }
                    value = values
                } else {
                    // Detect comment/meeting/note/topic TEXT fields
                    // Detect &quot;Additional Details&quot; field — route to textareaValues for richer content
                    def isCommentField = labelLower.contains(&quot;comment&quot;) || aliasLower.contains(&quot;comment&quot;)
                    def isNoteField = labelLower.contains(&quot;note&quot;) || aliasLower.contains(&quot;note&quot;)
                    def isAdditionalDetailField = (labelLower.contains(&quot;additional&quot;) &amp;&amp; labelLower.contains(&quot;detail&quot;)) || (aliasLower.contains(&quot;additional&quot;) &amp;&amp; aliasLower.contains(&quot;detail&quot;))
                    def isMeetingField = labelLower.contains(&quot;meeting&quot;) || labelLower.contains(&quot;topic&quot;) || labelLower.contains(&quot;detail&quot;) || labelLower.contains(&quot;purpose&quot;) || labelLower.contains(&quot;objective&quot;) || labelLower.contains(&quot;agenda&quot;) || aliasLower.contains(&quot;meeting&quot;) || aliasLower.contains(&quot;topic&quot;) || aliasLower.contains(&quot;detail&quot;) || aliasLower.contains(&quot;purpose&quot;) || aliasLower.contains(&quot;objective&quot;) || aliasLower.contains(&quot;agenda&quot;)

                    if (isCommentField) {
                        value = vars.get(&quot;comments&quot;) ?: defaultTexts[rand.nextInt(defaultTexts.size())]
                    } else if (isNoteField) {
                        value = vars.get(&quot;notes&quot;) ?: vars.get(&quot;meetingDetails&quot;) ?: defaultTexts[rand.nextInt(defaultTexts.size())]
                    } else if (isAdditionalDetailField) {
                        // Additional Details gets longer descriptive text
                        value = textareaValues[rand.nextInt(textareaValues.size())]
                    } else if (isMeetingField) {
                        value = vars.get(&quot;meetingDetails&quot;) ?: defaultTexts[rand.nextInt(defaultTexts.size())]
                    } else {
                        value = defaultTexts[rand.nextInt(defaultTexts.size())]
                    }
                }
                break

            // TEXTAREA Field
            case &quot;TEXTAREA&quot;:
                value = textareaValues[rand.nextInt(textareaValues.size())]
                break

            // NUMBER Field
            case &quot;NUMBER&quot;:
                value = generateRandomNumber(1, 10)
                break

            // CURRENCY Field
            case &quot;CURRENCY&quot;:
                value = generateRandomNumber(1, 10)
                break

            // CLOUD_DATE Field
            case &quot;CLOUD_DATE&quot;:
                value = generateFutureDate()
                break

            // CLOUD_TIME Field
            case &quot;CLOUD_TIME&quot;:
                if (fieldName.toLowerCase().contains(&quot;start&quot;)) {
                    value = generateFutureTime(9)
                } else if (fieldName.toLowerCase().contains(&quot;end&quot;)) {
                    value = generateFutureTime(18)
                } else {
                    value = generateFutureTime(rand.nextInt(9) + 8)
                }
                break

            // SELECT Field
            case &quot;SELECT&quot;:
                // Check for TIMEZONE enumType
                if ((field.enumType ?: &quot;&quot;) == &quot;TIMEZONE&quot;) {
                    value = vars.get(&quot;requestTimeZone&quot;) ?: &quot;&quot;
                } else if (lookupName) {
                    // Convert SNAKE_CASE to camelCase
                    def words = lookupName.toLowerCase().split(&apos;_&apos;)
                    def camelCaseName = words[0] + words.drop(1).collect { it.capitalize() }.join(&apos;&apos;)

                    if (isMultiple) {
                        // Multi-select: pick random values based on minSelection/maxSelection
                        def countStr = vars.get(camelCaseName + &quot;_count&quot;)

                        if (countStr &amp;&amp; countStr.isInteger()) {
                            def count = countStr.toInteger()
                            def selectCount = getRandomSelectionCount(count)
                            def selectedValues = []
                            def indices = (1..count).toList()
                            Collections.shuffle(indices)
                            indices.take(selectCount).each { idx -&gt;
                                def val = vars.get(camelCaseName + &quot;_&quot; + idx)
                                if (val) selectedValues.add(val)
                            }
                            if (selectedValues) {
                                value = selectedValues

                            } else {
                                log.warn(&quot;No lookup values for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                                skipField = true
                            }
                        } else {
                            log.warn(&quot;No lookup count for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                            skipField = true
                        }
                    } else {
                        // Single select: pick one random value

                        def countStr = vars.get(camelCaseName + &quot;_count&quot;)
                        if (countStr &amp;&amp; countStr.isInteger()) {
                            def count = countStr.toInteger()
                            def randomIndex = rand.nextInt(count) + 1
                            value = vars.get(camelCaseName + &quot;_&quot; + randomIndex)

                        } else {
                            value = vars.get(camelCaseName)
                            if (value) {

                            } else {
                                log.warn(&quot;No lookup value for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                                skipField = true
                            }
                        }
                    }
                } else {
                    log.warn(&quot;No lookupName defined - SKIPPING field&quot;)
                    skipField = true
                }
                break

            // CHECKBOX Field
            case &quot;CHECKBOX&quot;:
                value = rand.nextBoolean()
                break

            // RESOURCE Field
            case &quot;RESOURCE&quot;:
                if (resourceTypeId) {

                    def rtCountStr = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_count&quot;)
                    if (rtCountStr &amp;&amp; rtCountStr.isInteger() &amp;&amp; rtCountStr.toInteger() &gt; 0) {
                        def rtCount = rtCountStr.toInteger()

                        if (isMultiple) {
                            // Multi-select resources
                            def selectCount = getRandomSelectionCount(rtCount)
                            def selectedValues = []
                            def indices = (1..rtCount).toList()
                            Collections.shuffle(indices)
                            indices.take(selectCount).each { idx -&gt;
                                def resourceId = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                if (resourceId) selectedValues.add(resourceId)
                            }
                            if (selectedValues) {
                                value = selectedValues

                            }
                        } else {
                            // Single select resource
                            def randomIndex = rand.nextInt(rtCount) + 1
                            value = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                        }
                    } else {
                        log.warn(&quot;No masters fetched for masterTypeId: ${masterTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                } else {
                    log.warn(&quot;MASTER field without masterTypeId - SKIPPING&quot;)
                    skipField = true
                }
                break

            // Unknown Field Type
            default:
                log.warn(&quot;Unknown field type &apos;${fieldType}&apos; - SKIPPING field&quot;)
                skipField = true
        }
    }
    // STEP 6: Add to formData with Proper Type Handling
    if (!skipField &amp;&amp; value != null &amp;&amp; value != &quot;&quot;) {
        if ((fieldType == &quot;CLOUD_DATE&quot; || fieldType == &quot;CLOUD_TIME&quot;) &amp;&amp; !(value instanceof Map)) {
            // Wrap date/time in isoDate format
            formData[fieldName] = [&quot;isoDate&quot;: value]
        } else if (fieldType == &quot;CHECKBOX&quot;) {
            // Ensure boolean type
            formData[fieldName] = (value instanceof String) ? value.toLowerCase() == &quot;true&quot; : value
        } else if (fieldType == &quot;NUMBER&quot;) {
            // Ensure integer type
            formData[fieldName] = (value instanceof String &amp;&amp; value.isInteger()) ? value.toInteger() : value
        } else if (isMultiple &amp;&amp; !(value instanceof List)) {
            // Wrap single value in array for multi-select fields
            formData[fieldName] = [value]
        } else {
            formData[fieldName] = value
        }
    }
}
// STEP 7: Build Complete Payload
def payload = [
    &quot;moduleId&quot; : vars.get(&quot;currentModuleId&quot;) ?: vars.get(&quot;moduleId&quot;),
    &quot;formId&quot;   : vars.get(&quot;currentFormId&quot;) ?: vars.get(&quot;formId&quot;),
    &quot;journeyId&quot;: vars.get(&quot;currentJourneyId&quot;),
    &quot;pageId&quot;   : vars.get(&quot;currentPageId&quot;),
    &quot;data&quot;     : formData
]

// Convert to JSON and store
def payloadJson = JsonOutput.prettyPrint(JsonOutput.toJson(payload))
vars.put(&quot;dynamicFormPayload&quot;, payloadJson)</stringProp>
