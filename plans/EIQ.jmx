              <hashTree>
                <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Generate Dates for an Event" enabled="true">
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="script">import java.time.*
import java.time.format.DateTimeFormatter
import java.util.concurrent.ThreadLocalRandom

def rand = ThreadLocalRandom.current()
DateTimeFormatter dateFormatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;)
DateTimeFormatter timeFormatter = DateTimeFormatter.ofPattern(&quot;HH:mm&quot;)

// ===================== READ VARIABLES =====================
boolean allowWeekends = vars.get(&quot;allowWeekends&quot;)?.equalsIgnoreCase(&quot;true&quot;) ?: false
int eventCount = (vars.get(&quot;EventCount&quot;) ?: &quot;1&quot;).toInteger()
int eventsPerDay = (vars.get(&quot;eventsPerDay&quot;) ?: &quot;1&quot;).toInteger()
int totalValidDays = (vars.get(&quot;totalValidDays&quot;) ?: &quot;1&quot;).toInteger()

// ===================== HELPER METHODS =====================
def parseIntList = { String raw, List&lt;Integer&gt; defaults -&gt;
    if (!raw) return defaults
    def parsed = raw.split(&quot;,&quot;)
        .findAll { it.trim().isInteger() &amp;&amp; it.trim().toInteger() &gt; 0 }
        .collect { it.trim().toInteger() }
    return parsed.isEmpty() ? defaults : parsed
}

def parseTimeList = { String raw, List&lt;LocalTime&gt; defaults -&gt;
    if (!raw) return defaults
    def parsed = raw.split(&quot;,&quot;)
        .collect { it.trim() }
        .findAll { it ==~ /\d{2}:\d{2}/ &amp;&amp; LocalTime.parse(it, timeFormatter) != LocalTime.MIDNIGHT }
        .collect { LocalTime.parse(it, timeFormatter) }
    return parsed.isEmpty() ? defaults : parsed
}

// ===================== SEQUENTIAL DATE ASSIGNMENT =====================
int dayIndex = ((eventCount - 1) / eventsPerDay).intValue() + 1
int eventInDay = ((eventCount - 1) % eventsPerDay) + 1

String dateStr = vars.get(&quot;validDate_&quot; + dayIndex)
if (!dateStr) {
    log.error(&quot;No validDate found for dayIndex ${dayIndex}! Falling back to validDate_1&quot;)
    dateStr = vars.get(&quot;validDate_1&quot;)
}

LocalDate selectedDate = LocalDate.parse(dateStr, dateFormatter)
boolean actualWeekend = selectedDate.dayOfWeek in [DayOfWeek.SATURDAY, DayOfWeek.SUNDAY]

// ===================== START TIME &amp; DURATION =====================
def possibleTimes = parseTimeList(vars.get(&quot;eventStartTimes&quot;)?.trim(), [LocalTime.of(8, 0), LocalTime.of(9, 0)])
LocalTime randomStartTime = possibleTimes[rand.nextInt(possibleTimes.size())]

def daysOptions = parseIntList(vars.get(&quot;eventDays&quot;)?.trim(), [1])
int randomDurationDays = daysOptions[rand.nextInt(daysOptions.size())]

def durations = parseIntList(vars.get(&quot;eventDurations&quot;)?.trim(), [480, 540, 600])
int durationMinutes = durations[rand.nextInt(durations.size())]

// ===================== CALCULATE DATES =====================
LocalDateTime startDateMidnight = selectedDate.atTime(0, 0)
LocalDateTime startDateWithRandomTime = LocalDateTime.of(selectedDate, randomStartTime)
LocalDateTime endDateTime = startDateWithRandomTime.plusMinutes(durationMinutes)
DateTimeFormatter isoFormatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)

// ===================== SAVE VARIABLES =====================
vars.put(&quot;startDate&quot;, startDateMidnight.format(isoFormatter))
vars.put(&quot;startTime&quot;, startDateWithRandomTime.format(isoFormatter))
vars.put(&quot;endTime&quot;, endDateTime.format(isoFormatter))
vars.put(&quot;duration&quot;, String.valueOf(randomDurationDays))

log.info(&quot;Event ${eventCount}: Day ${dayIndex}/${totalValidDays} (${selectedDate} - ${selectedDate.dayOfWeek}) | Event ${eventInDay}/${eventsPerDay} for this day | Time: ${randomStartTime} | Duration: ${durationMinutes}min&quot;)</stringProp>
                  <stringProp name="scriptLanguage">groovy</stringProp>
                </JSR223Sampler>
