import groovy.json.JsonSlurper

// Parse JSON response
def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

// Extract categories from response
def categories = json._embedded?.categories ?: []

// Validate categories exist
if (categories.isEmpty()) {
    log.error(&quot;No categories found!&quot;)
    prev.setSuccessful(false)
    prev.setResponseMessage(&quot;ABORTING: No categories found in API response&quot;)
    vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
    vars.put(&quot;_abortReason&quot;, &quot;No categories found in API response&quot;)
    ctx.getEngine().stopTest()
    return
}

// Get preferred category from User Defined Variables
def preferredCategory = vars.get(&quot;category&quot;)?.trim()
def selectedCategory = null

// Search for preferred category if specified
if (preferredCategory) {
    selectedCategory = categories.find {
        it.uniqueId?.equalsIgnoreCase(preferredCategory)
    }

    if (selectedCategory) {
        log.info(&quot;Category: &quot; + preferredCategory)
    } else {
        def availableCategories = categories.collect { it.uniqueId + &quot; (&quot; + (it.categoryName ?: &quot;&quot;) + &quot;)&quot; }.join(&quot;, &quot;)
        log.error(&quot;========================================&quot;)
        log.error(&quot;category &apos;&quot; + preferredCategory + &quot;&apos; not found in API response&quot;)
        log.error(&quot;Available: &quot; + availableCategories)
        log.error(&quot;========================================&quot;)
        prev.setSuccessful(false)
        prev.setResponseMessage(&quot;ABORTING: category &apos;&quot; + preferredCategory + &quot;&apos; not found. Available: &quot; + availableCategories)
        vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
        vars.put(&quot;_abortReason&quot;, &quot;category &apos;&quot; + preferredCategory + &quot;&apos; not found in API response. Available: &quot; + availableCategories)
        ctx.getEngine().stopTest()
        return
    }
}

// Store Category Variables
vars.put(&quot;categoryId&quot;, selectedCategory.uniqueId ?: &quot;&quot;)
vars.put(&quot;categoryName&quot;, selectedCategory.categoryName ?: &quot;&quot;)

// Store Module Variables (first module from selected category)
def module = selectedCategory.modules?.getAt(0)
vars.put(&quot;newEventModuleId&quot;, module?.uniqueId ?: &quot;&quot;)
vars.put(&quot;newEventModuleName&quot;, module?.moduleName ?: &quot;&quot;)

// Update sampler label with selected category
def catName = vars.get(&quot;categoryName&quot;) ?: &quot;&quot;
if (catName) {
    prev.setSampleLabel(prev.getSampleLabel() + &quot; - &quot; + catName)
}

// Log Selected Details

