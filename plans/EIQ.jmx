                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Event Count PostProcessor" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">// Always define isFirstUser here so room-reset block below always has access to it
def isFirstUser = vars.get(&quot;isFirstUser&quot;) ?: &quot;true&quot;

def existingId = vars.get(&quot;existingEventId&quot;)?.trim() ?: &quot;&quot;
if (existingId) {
    // Hide this sampler from View Results Tree — ⌛ Get Existing Event already shows the event name
    prev.setIgnore()
} else {

def eventCount = vars.get(&quot;EventCount&quot;)
def eventsPerDay = (vars.get(&quot;eventsPerDay&quot;) ?: &quot;1&quot;).toInteger()
def totalValidDays = (vars.get(&quot;totalValidDays&quot;) ?: &quot;1&quot;).toInteger()
def totalEventCount = vars.get(&quot;totalEventCount&quot;) ?: &quot;1&quot;
def rc = eventCount.toInteger()
// Calculate day index and event-in-day
int dayIndex = ((rc - 1) / eventsPerDay).intValue() + 1
int eventInDay = ((rc - 1) % eventsPerDay) + 1
def dateForDay = vars.get(&quot;validDate_&quot; + dayIndex) ?: &quot;unknown&quot;
// Get short day name (Mon, Tue, etc.)
def dayName = &quot;&quot;
try {
    def parsedDate = java.time.LocalDate.parse(dateForDay)
    dayName = parsedDate.dayOfWeek.toString().substring(0, 3).toLowerCase().capitalize()
} catch (Exception e) {
    dayName = &quot;&quot;
}
// Set readable sampler label for View Results Tree
prev.setSampleLabel(&quot;✦─── Event (&quot; + eventCount + &quot;/&quot; + totalEventCount + &quot;) | &quot; + dateForDay + &quot; (&quot; + dayName + &quot;) | Per Day (&quot; + eventInDay + &quot;/&quot; + eventsPerDay + &quot;) ───✦&quot;)

} // end: skip label when existingEventId is set

// Only reset room counts for the first user
if (isFirstUser == &quot;true&quot;) {
    def totalDaysToReset = (vars.get(&quot;TotalActivityDays&quot;) ?: vars.get(&quot;totalValidDays&quot;) ?: &quot;10&quot;).toInteger()
    def totalRoomsToReset = (vars.get(&quot;roomResourceCount&quot;) ?: vars.get(&quot;selectedRoomCount&quot;) ?: &quot;10&quot;).toInteger()
    for (int day = 1; day &lt;= totalDaysToReset; day++) {
        String countVarName = &quot;createdRoomCount_Day${day}&quot;.toString()
        String countSysProp = &quot;jmeter.roomCount.Day${day}&quot;.toString()
        vars.put(countVarName, &quot;0&quot;)
        System.clearProperty(countSysProp)
        for (int i = 1; i &lt;= totalRoomsToReset; i++) {
            String idVarName = &quot;createdRoom_Day${day}_${i}_id&quot;.toString()
            String nameVarName = &quot;createdRoom_Day${day}_${i}_name&quot;.toString()
            String idSysProp = &quot;jmeter.room.Day${day}_${i}_id&quot;.toString()
            String nameSysProp = &quot;jmeter.room.Day${day}_${i}_name&quot;.toString()
            vars.remove(idVarName)
            vars.remove(nameVarName)
            System.clearProperty(idSysProp)
            System.clearProperty(nameSysProp)
        }
    }
} else {
}</stringProp>
                </JSR223PostProcessor>
