                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Room PostProcessor" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput
import java.util.Collections

def locationId   = vars.get(&quot;currentLocationId&quot;)
def locationName = vars.get(&quot;currentLocationName&quot;) ?: locationId

def response  = prev.getResponseDataAsString() ?: &quot;{}&quot;
def json      = new JsonSlurper().parseText(response)
def resources = json?._embedded?.resources ?: []

if (resources.isEmpty()) {
    log.warn(&quot;Location [${locationName}] → No rooms found&quot;)
    vars.put(&quot;roomResourcesPayload&quot;, &quot;{}&quot;)
    vars.put(&quot;roomResourceCount&quot;, &quot;0&quot;)
    vars.put(&quot;selectedRoomNames&quot;, &quot;&quot;)
    vars.putObject(&quot;selectedRoomsList&quot;, [])
    return
}

// Rooms per location from UDV
// Empty = select ALL available rooms; 0 = skip room selection
def roomsRaw = vars.get(&quot;rooms&quot;)?.trim() ?: &quot;&quot;

// Available rooms
def available = resources.size()

def pickCount
if (!roomsRaw) {
    // Empty = select ALL available rooms
    pickCount = available
} else if (roomsRaw == &quot;0&quot;) {
    // 0 = skip room selection entirely
    pickCount = 0
} else if (roomsRaw.contains(&quot;,&quot;)) {
    def parts = roomsRaw.split(&quot;,&quot;)*.trim()*.toInteger()
    def roomsPerLocation = parts[new Random().nextInt(parts.size())]
    pickCount = Math.min(roomsPerLocation, available)
} else {
    def roomsPerLocation = roomsRaw.toInteger()
    pickCount = Math.min(roomsPerLocation, available)
}

// Limit by available rooms (safety cap)
pickCount = Math.min(pickCount, available)

// Shuffle rooms
def shuffledResources = new ArrayList(resources)
Collections.shuffle(shuffledResources)

// Select required rooms
def selectedResources = shuffledResources.take(pickCount)

// Store selected rooms for logistics loop
vars.putObject(&quot;selectedRoomsList&quot;, selectedResources)

def selectedIds = selectedResources.collect { it.uniqueId }

def selectedRoomNames = selectedResources.collect {
    it.data?.name?.trim() ?: it.metaData?.searchDisplayText?.trim() ?: it.uniqueId
}.join(&quot;, &quot;)

// Store variables
vars.put(&quot;roomResourcesPayload&quot;, JsonOutput.toJson([uniqueIds: selectedIds]))
vars.put(&quot;roomResourceCount&quot;, pickCount.toString())
vars.put(&quot;selectedRoomNames&quot;, selectedRoomNames)

// Clean log
</stringProp>
                  </JSR223PostProcessor>
