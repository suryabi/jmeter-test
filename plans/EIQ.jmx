                                                <stringProp name="Argument.metadata">=</stringProp>
                                              </elementProp>
                                            </collectionProp>
                                          </elementProp>
                                          <stringProp name="HTTPSampler.domain"></stringProp>
                                          <stringProp name="HTTPSampler.port"></stringProp>
                                          <stringProp name="HTTPSampler.protocol"></stringProp>
                                          <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                                          <stringProp name="HTTPSampler.path">/${contextname}/api/forms/${submitFormId}/data</stringProp>
                                          <stringProp name="HTTPSampler.method">POST</stringProp>
                                          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
                                          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                                          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
                                          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                                          <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                                          <stringProp name="HTTPSampler.connect_timeout"></stringProp>
                                          <stringProp name="HTTPSampler.response_timeout"></stringProp>
                                        </HTTPSamplerProxy>
                                        <hashTree>
                                          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                                            <collectionProp name="HeaderManager.headers">
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">x-cloud-customerid</stringProp>
                                                <stringProp name="Header.value">${customerId}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                                                <stringProp name="Header.value">${categoryTypeId}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                                                <stringProp name="Header.value">${categoryId}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                                                <stringProp name="Header.value">${baseTimezone}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                                                <stringProp name="Header.value">${clientTimeZone}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">X-Cloud-Context-Timezone</stringProp>
                                                <stringProp name="Header.value">${baseTimezone}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">x-cloud-eventid</stringProp>
                                                <stringProp name="Header.value">${requestId}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">x-cloud-activityid</stringProp>
                                                <stringProp name="Header.value">${activityId}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">X_cloud_user</stringProp>
                                                <stringProp name="Header.value">${currentUser}</stringProp>
                                              </elementProp>
                                            </collectionProp>
                                          </HeaderManager>
                                          <hashTree/>
                                          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Form PreProcessor" enabled="true">
                                            <stringProp name="scriptLanguage">groovy</stringProp>
                                            <stringProp name="parameters"></stringProp>
                                            <stringProp name="filename"></stringProp>
                                            <stringProp name="cacheKey">true</stringProp>
                                            <stringProp name="script">import java.util.concurrent.ThreadLocalRandom
import groovy.json.JsonOutput

def rand = java.util.concurrent.ThreadLocalRandom.current()

def totalUsers = (vars.get(&quot;randomUserCount&quot;) ?: &quot;50&quot;).toInteger()

// Helper Function: Generate 4-digit random number (1000-9999)
def random4 = { -&gt; ThreadLocalRandom.current().nextInt(1000, 10000) }


// Helper: Generate random 10-digit mobile number starting with 7, 8, or 9
def validStartDigits = [7, 8, 9]
def generatePhone = {
    def digit = validStartDigits[rand.nextInt(validStartDigits.size())]
    def rest = ThreadLocalRandom.current().nextLong(100000000L, 1000000000L)
    return String.valueOf(digit) + String.valueOf(rest)
}


// ============ Email Domain ============
// Priority: 1) DOMAIN_EMAIL from form template  2) emailDomains UDV (random per email)  3) gmail.com
def emailDomainFromTemplate = null

try {
    def formUIConfigStr = vars.get(&quot;currentFormUIConfig&quot;)
    if (formUIConfigStr) {
        def formUIConfig = new groovy.json.JsonSlurper().parseText(formUIConfigStr)
        def configItems = formUIConfig.config ?: []

        configItems.each { item -&gt;
            // Check top-level validators
            if (item.validators) {
                item.validators.each { validator -&gt;
                    if (validator.toString().startsWith(&quot;DOMAIN_EMAIL:&quot;)) {
                        emailDomainFromTemplate = validator.toString().split(&quot;:&quot;)[1]
                    }
                }
            }
            // Check nested formFields within sections
            def fields = item.formFields ?: []
            fields.each { field -&gt;
                if (field.validators) {
                    field.validators.each { validator -&gt;
                        if (validator.toString().startsWith(&quot;DOMAIN_EMAIL:&quot;)) {
                            emailDomainFromTemplate = validator.toString().split(&quot;:&quot;)[1]
                        }
                    }
                }
            }
        }
    }
} catch (Exception e) {
    log.warn(&quot;Error parsing formUIConfig for email domain: &quot; + e.message)
}

// Build domain options list from UDV for random-per-email picking
def emailDomainOptionsList = []
if (!emailDomainFromTemplate) {
    def emailDomainsUdv = vars.get(&quot;emailDomains&quot;)?.trim()
    if (emailDomainsUdv) {
        emailDomainOptionsList = emailDomainsUdv.split(&quot;,&quot;).collect { it.trim() }.findAll { it }
    }
    if (emailDomainOptionsList.isEmpty()) emailDomainOptionsList = [&quot;gmail.com&quot;]
}

// Closure: picks a random domain each call (template domain wins if set)
def pickEmailDomain = {
    if (emailDomainFromTemplate) return emailDomainFromTemplate
    return emailDomainOptionsList[rand.nextInt(emailDomainOptionsList.size())]
}

// For backward compat: emailDomain variable (single value for non-loop usages)
def emailDomain = pickEmailDomain()
log.info(&quot;Email Domain resolved: ${emailDomain} (template=${emailDomainFromTemplate ?: &apos;none&apos;}, options=${emailDomainOptionsList})&quot;)

// ============ Customer Names Array ============
def allVisitsRaw = props.get(&quot;fn_allCustomers&quot;)
String[] allVisits
if (allVisitsRaw &amp;&amp; allVisitsRaw.length &gt; 0) {
    allVisits = allVisitsRaw as String[]
    log.info(&quot;allVisits loaded from props (fn_allCustomers): ${allVisits.length} companies&quot;)
} else {
    log.warn(&quot;fn_allCustomers not found in props — Common Function may not have run. Using fallback list.&quot;)
    // Use the full list from Common Function as fallback — it should always be available
    allVisits = props.get(&quot;fn_allCustomers&quot;) as String[] ?: [&quot;Accenture&quot;, &quot;Microsoft&quot;, &quot;Google&quot;] as String[]
}

def getRandomSelectionCount = props.get(&quot;fn_multiSelectCount&quot;)
def _msRange = (vars.get(&quot;multiSelectRange&quot;) ?: &quot;1,3&quot;).split(&quot;,&quot;)*.trim()
def minSelection = _msRange[0].toInteger()
def maxSelection = _msRange.size() &gt; 1 ? _msRange[1].toInteger() : _msRange[0].toInteger()

// ============ Pick unique customer name ============
def requestId = vars.get(&quot;requestId&quot;) ?: &quot;default&quot;
def usedKey = &quot;usedCustomers_&quot; + requestId
def usedCustomers = props.get(usedKey) ?: ([] as Set)

def availableCustomers = allVisits.findAll { !usedCustomers.contains(it) }
if (availableCustomers.isEmpty()) {
    log.warn(&quot;All customers used for event ${requestId} - resetting&quot;)
    availableCustomers = allVisits.toList()
    usedCustomers.clear()
}

def firstVisitCustomer = vars.get(&quot;firstVisitCustomer&quot;)?.trim() ?: &quot;&quot;
def customerName

if (usedCustomers.isEmpty() &amp;&amp; firstVisitCustomer) {
    customerName = firstVisitCustomer
    log.info(&quot;First visit — forcing ${firstVisitCustomer} as customer&quot;)
} else {
    def pool = firstVisitCustomer ? availableCustomers.findAll { it != firstVisitCustomer } : availableCustomers
    if (pool.isEmpty()) pool = availableCustomers
    customerName = pool[rand.nextInt(pool.size())]
}
usedCustomers.add(customerName)
props.put(usedKey, usedCustomers)
vars.put(&quot;customerName&quot;, customerName)
log.info(&quot;Customer: ${customerName} (visit #${usedCustomers.size()})&quot;)

// ============ Random User Count from Fetch Random Data ============
def randomUserCount = (vars.get(&quot;randomUserCount&quot;) ?: &quot;0&quot;).toInteger()

// ============ Business Titles ============
// Business titles from Common Function (single source of truth)
def titles = (props.get(&quot;fn_businessTitles&quot;) ?: [&quot;Manager&quot;, &quot;Director&quot;, &quot;Vice President&quot;]) as String[]


// ============ Helper: pick a UNIQUE random user (no repeats across forms in same event) ============
def usedUserKey = &quot;usedUserIndices_&quot; + requestId + &quot;_&quot; + Thread.currentThread().getId()
def usedUserIndices = props.get(usedUserKey) ?: ([] as Set)

def pickRandomUser = {
    if (randomUserCount == 0) return [firstName: &quot;John&quot;, lastName: &quot;Doe&quot;, index: -1]

    // Build pool of available indices excluding already-used ones
    def available = (1..randomUserCount).findAll { !usedUserIndices.contains(it) }

    // If all users exhausted, reset (log warning)
    if (available.isEmpty()) {
        log.warn(&quot;All ${randomUserCount} random users exhausted for event ${requestId} — resetting pool&quot;)
        usedUserIndices.clear()
        available = (1..randomUserCount).toList()
    }

    def idx = available[rand.nextInt(available.size())]
    usedUserIndices.add(idx)
    props.put(usedUserKey, usedUserIndices)

    return [
        firstName : vars.get(&quot;randomUser_${idx}_firstName&quot;) ?: &quot;John&quot;,
        lastName  : vars.get(&quot;randomUser_${idx}_lastName&quot;)  ?: &quot;Doe&quot;,
        index     : idx
    ]
}

// ============ Sibos Customer Information ============
def sibosCustomer = pickRandomUser()
def sibosFirstName = sibosCustomer.firstName 
def sibosLastName  = sibosCustomer.lastName
def sibosTitle = titles[rand.nextInt(titles.length)]

vars.put(&quot;sibosCustomerName&quot;, sibosFirstName + &quot; &quot; + sibosLastName)
vars.put(&quot;customerTitle&quot;, sibosTitle)
vars.put(&quot;customerMobileNumber&quot;, generatePhone())
vars.put(&quot;customerCompany&quot;, customerName)

// Track all generated emails across sections to prevent cross-field duplicates
def allGeneratedEmails = [] as Set
def additionalCustomerEmailCount = getRandomSelectionCount(randomUserCount &gt; 0 ? randomUserCount : maxSelection)
def additionalCustomerEmailList = []
for (int i = 0; i &lt; additionalCustomerEmailCount; i++) {
    def u = pickRandomUser()
    def email = &quot;${u.firstName.toLowerCase()}.${u.lastName.toLowerCase()}@${pickEmailDomain()}&quot;
    additionalCustomerEmailList.add(email)
    allGeneratedEmails.add(email)
}
vars.put(&quot;additionalCustomerEmail&quot;, additionalCustomerEmailList.join(&quot;,&quot;))
log.info(&quot;Sibos Customer Name: ${sibosFirstName} ${sibosLastName} (idx: ${sibosCustomer.index})&quot;)
log.info(&quot;Additional Customer Emails (${additionalCustomerEmailCount}): ${additionalCustomerEmailList.join(&apos; | &apos;)}&quot;)

// ============ Sales Coverage Information ============
def salesCoverageCustomer = pickRandomUser()
def salesCoverageFirstName = salesCoverageCustomer.firstName 
def salesCoverageLastName  = salesCoverageCustomer.lastName
def salesCoverageTitle = titles[rand.nextInt(titles.length)]

vars.put(&quot;salesCoverageRepName&quot;, salesCoverageFirstName + &quot; &quot; + salesCoverageLastName)
vars.put(&quot;salesCoverageRepTitle&quot;, salesCoverageTitle)
vars.put(&quot;salesCoverageRepEmail&quot;, &quot;${salesCoverageFirstName.toLowerCase()}.${salesCoverageLastName.toLowerCase()}@${pickEmailDomain()}&quot;)
log.info(&quot;Sales Coverage: ${salesCoverageFirstName} ${salesCoverageLastName} (idx: ${salesCoverageCustomer.index})&quot;)  


// ============ Onsite Information ============
def onsiteCustomer = pickRandomUser()
def onsiteFirstName = onsiteCustomer.firstName   
def onsiteLastName  = onsiteCustomer.lastName
def onsiteTitle = titles[rand.nextInt(titles.length)]

vars.put(&quot;onsiteSalesLeadName&quot;, onsiteFirstName + &quot; &quot; + onsiteLastName)
vars.put(&quot;onsiteSalesLeadTitle&quot;, onsiteTitle)
vars.put(&quot;onsiteSalesLeadMobileNumber&quot;, generatePhone())   
vars.put(&quot;onsiteSalesLeadEmail&quot;, &quot;${onsiteFirstName.toLowerCase()}.${onsiteLastName.toLowerCase()}@${pickEmailDomain()}&quot;)

// Skip emails already generated in earlier sections (additionalCustomerEmail etc.)
def additionalOnsiteEmailCount = getRandomSelectionCount(randomUserCount &gt; 0 ? randomUserCount : maxSelection)
def additionalOnsiteEmailList = []
def onsiteEmailAttempts = 0
while (additionalOnsiteEmailList.size() &lt; additionalOnsiteEmailCount &amp;&amp; onsiteEmailAttempts &lt; 30) {
    onsiteEmailAttempts++
    def u = pickRandomUser()
    def email = &quot;${u.firstName.toLowerCase()}.${u.lastName.toLowerCase()}@${pickEmailDomain()}&quot;
    if (!allGeneratedEmails.contains(email)) {
        additionalOnsiteEmailList.add(email)
        allGeneratedEmails.add(email)
    }
}
vars.put(&quot;additionalOnsiteSalesLeadEmails&quot;, additionalOnsiteEmailList.join(&quot;,&quot;))
log.info(&quot;Onsite Lead Name: ${onsiteFirstName} ${onsiteLastName} (idx: ${onsiteCustomer.index})&quot;)
log.info(&quot;Additional Onsite Emails (${additionalOnsiteEmailCount}): ${additionalOnsiteEmailList.join(&apos; | &apos;)}&quot;)

// ============ Sales Rep Info (unique person per form) ============
def salesRepUser = pickRandomUser()
def salesRepFirstName = salesRepUser.firstName
def salesRepLastName  = salesRepUser.lastName

vars.put(&quot;salesRepFirstName&quot;, salesRepFirstName)
vars.put(&quot;salesRepLastName&quot;,  salesRepLastName)
vars.put(&quot;salesRepEmail&quot;,     &quot;${salesRepFirstName.toLowerCase()}.${salesRepLastName.toLowerCase()}@${pickEmailDomain()}&quot;)
log.info(&quot;Sales Rep: ${salesRepFirstName} ${salesRepLastName} (idx: ${salesRepUser.index})&quot;)

// ============ Customer Info (unique person, different from sales rep) ============
def customerUser = pickRandomUser()
def customerFirstName = customerUser.firstName
def customerLastName  = customerUser.lastName

vars.put(&quot;customerFirstName&quot;, customerFirstName)
vars.put(&quot;customerLastName&quot;,  customerLastName)
vars.put(&quot;customerEmail&quot;,     &quot;${customerFirstName.toLowerCase()}.${customerLastName.toLowerCase()}@${pickEmailDomain()}&quot;)  
log.info(&quot;Customer Contact: ${customerFirstName} ${customerLastName} (idx: ${customerUser.index})&quot;)

// ============ External Attendees (1-3 unique people with matching emails) ============
def attendeeCount = rand.nextInt(3) + 1  // 1 to 3 attendees
def attendeeNamesList = []
def attendeeEmailsList = []

for (int a = 0; a &lt; attendeeCount; a++) {
    def attUser = pickRandomUser()
    def attFirstName = attUser.firstName
    def attLastName  = attUser.lastName
    def attTitle = titles[rand.nextInt(titles.length)]
    def attEmail = &quot;${attFirstName.toLowerCase()}.${attLastName.toLowerCase()}@${pickEmailDomain()}&quot;

    attendeeNamesList.add(&quot;${attFirstName} ${attLastName} - ${attTitle}&quot;)
    attendeeEmailsList.add(attEmail)
    allGeneratedEmails.add(attEmail)

    // Store first attendee details for backward compatibility
    if (a == 0) {
        vars.put(&quot;externalAttendeeFirstName&quot;, attFirstName)
        vars.put(&quot;externalAttendeeLastName&quot;,  attLastName)
        vars.put(&quot;externalAttendeeTitle&quot;,     attTitle)
    }
}

vars.put(&quot;externalAttendeeNamesAndJobTitles&quot;, attendeeNamesList.join(&quot;, &quot;))
vars.put(&quot;externalAttendeeEmails&quot;,            attendeeEmailsList.join(&quot;, &quot;))
vars.put(&quot;attendeeCount&quot;,             attendeeCount.toString())
log.info(&quot;Attendees (${attendeeCount}): ${attendeeNamesList.join(&apos; | &apos;)}&quot;)
log.info(&quot;Attendee Emails: ${attendeeEmailsList.join(&apos; | &apos;)}&quot;)

// ============ Opportunity IDs ============
def opportunityIds = []
int opportunityCount = getRandomSelectionCount(maxSelection)
for (int i = 0; i &lt; opportunityCount; i++) {
    opportunityIds.add(String.valueOf(random4()))
}
vars.put(&quot;secondaryOpportunity&quot;, opportunityIds.join(&quot;,&quot;))
vars.put(&quot;opportunity&quot;,          opportunityIds.join(&quot;,&quot;))

// ============ Opp Pipeline Type ============
def oppPipeline = [&quot;New&quot;, &quot;Existing&quot;]
vars.put(&quot;opportunityType&quot;, oppPipeline[rand.nextInt(oppPipeline.size())])

// ============ Country ============
// Countries list from Common Function
def countries = (props.get(&quot;fn_countries&quot;) ?: [&quot;United States&quot;, &quot;United Kingdom&quot;, &quot;India&quot;]) as String[]
vars.put(&quot;country&quot;, countries[rand.nextInt(countries.size())])

// ============ Meeting Details ============
String[] meetingDetails = [
    &quot;Discuss strategic initiatives and business priorities&quot;,
    &quot;Review product capabilities and solution overview&quot;,
    &quot;Explore partnership opportunities and collaboration&quot;,
    &quot;Understand customer requirements and pain points&quot;,
    &quot;Present technical architecture and integration options&quot;,
    &quot;Align on project goals and success criteria&quot;,
    &quot;Evaluate platform features and functionality&quot;,
    &quot;Discuss implementation roadmap and timeline&quot;,
    &quot;Review business case and expected outcomes&quot;,
    &quot;Strengthen executive relationships and engagement&quot;,
    &quot;Address technical questions and concerns&quot;,
    &quot;Demonstrate solution value and ROI potential&quot;,
    &quot;Gather feedback on proposed approach&quot;,
    &quot;Discuss expansion and growth opportunities&quot;,
    &quot;Review industry trends and best practices&quot;,
    &quot;Assess current challenges and solutions&quot;,
    &quot;Plan next steps and action items&quot;,
    &quot;Explore digital transformation opportunities&quot;,
    &quot;Validate solution fit for business needs&quot;,
    &quot;Discuss security and compliance requirements&quot;,
    &quot;Review performance metrics and optimization&quot;,
    &quot;Align stakeholders on key objectives&quot;,
    &quot;Present innovation and future roadmap&quot;,
    &quot;Evaluate competitive landscape and positioning&quot;,
    &quot;Discuss resource planning and allocation&quot;,
    &quot;Review customer success and adoption strategies&quot;,
    &quot;Assess training and enablement needs&quot;,
    &quot;Explore automation and efficiency improvements&quot;,
    &quot;Discuss data strategy and analytics capabilities&quot;,
    &quot;Plan for scalability and future growth&quot;
]
vars.put(&quot;meetingDetails&quot;, meetingDetails[rand.nextInt(meetingDetails.length)])

// ============ Comments — purposeful briefing comments (FIX: replaced generic topic phrases) ============
String[] comments = [
    &quot;Looking forward to connecting and exploring how we can support your goals&quot;,
    &quot;Excited to share our latest capabilities and hear about your current priorities&quot;,
    &quot;Thank you for the opportunity to present our solutions and roadmap&quot;,
    &quot;Happy to walk through the platform and answer any questions you may have&quot;,
    &quot;This session will help us better understand your environment and challenges&quot;,
    &quot;Looking forward to a productive discussion on your digital transformation journey&quot;,
    &quot;Keen to share our latest innovations and gather your valuable feedback&quot;,
    &quot;This session will focus on aligning our solutions with your strategic priorities&quot;,
    &quot;Appreciate the time to connect and explore potential partnership opportunities&quot;,
    &quot;Looking forward to a collaborative discussion on optimizing your current environment&quot;
]
vars.put(&quot;comments&quot;, comments[rand.nextInt(comments.length)])

// ============ Notes — reuse same pool as meetingDetails (purposeful agenda-style notes) ============
vars.put(&quot;notes&quot;, meetingDetails[rand.nextInt(meetingDetails.length)])

// ============ Hold Reason Details ============
String[] holdReasonDetailValues = [
    &quot;Pending internal approval before confirming meeting schedule&quot;,
    &quot;Awaiting executive availability confirmation&quot;,
    &quot;Presenter availability being finalized for requested date&quot;,
    &quot;Customer requested reschedule - awaiting new preferred dates&quot;,
    &quot;Briefing document under review by stakeholders&quot;,
    &quot;Sales opportunity stage under review by account team&quot;,
    &quot;Travel logistics being coordinated for attendees&quot;,
    &quot;Calendar conflict resolution in progress&quot;,
    &quot;Waiting for budget and resource confirmation&quot;,
    &quot;NDA execution pending between both organizations&quot;,
    &quot;Demo environment setup and validation in progress&quot;,
    &quot;Agenda revisions requested before final confirmation&quot;,
    &quot;Cross-functional team alignment meeting scheduled&quot;,
    &quot;Security clearance verification in progress for attendees&quot;,
    &quot;Internal team realignment may affect meeting format&quot;
]
vars.put(&quot;holdAdditionalDetails&quot;, holdReasonDetailValues[rand.nextInt(holdReasonDetailValues.length)])

// ============ Final Log ============
log.info(&quot;[Form PreProcessor] Done — Customer: ${customerName} | SalesRep: ${salesRepFirstName} ${salesRepLastName} | Attendees (${attendeeCount}): ${attendeeNamesList.join(&apos; | &apos;)} | Emails: ${attendeeEmailsList.join(&apos; | &apos;)} | Opportunities: ${opportunityIds.join(&apos;, &apos;)}&quot;)</stringProp>
                                          </JSR223PreProcessor>
                                          <hashTree/>
                                          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Form Method Switcher" enabled="true">
                                            <stringProp name="scriptLanguage">groovy</stringProp>
                                            <stringProp name="parameters"></stringProp>
                                            <stringProp name="filename"></stringProp>
                                            <stringProp name="cacheKey">true</stringProp>
                                            <stringProp name="script">// Dynamically switch between POST (create) and PUT (update) based on form data check
def formDataExists = vars.get(&quot;formDataExists&quot;) == &quot;true&quot;
def existingId = vars.get(&quot;existingFormDataId&quot;) ?: &quot;&quot;
def formId = vars.get(&quot;submitFormId&quot;) ?: &quot;&quot;
def contextname = vars.get(&quot;contextname&quot;) ?: &quot;events&quot;
def formName = vars.get(&quot;submitFormName&quot;) ?: &quot;unknown&quot;

if (formDataExists &amp;&amp; existingId) {
    sampler.setMethod(&quot;PUT&quot;)
    sampler.setPath(&quot;/&quot; + contextname + &quot;/api/forms/&quot; + formId + &quot;/data/&quot; + existingId)
    vars.put(&quot;activityDataId&quot;, existingId)
} else {
    sampler.setMethod(&quot;POST&quot;)
    sampler.setPath(&quot;/&quot; + contextname + &quot;/api/forms/&quot; + formId + &quot;/data&quot;)
}
</stringProp>
                                          </JSR223PreProcessor>
                                          <hashTree/>
                                          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Dynamic Payload Builder PreProcessor" enabled="true">
                                            <stringProp name="scriptLanguage">groovy</stringProp>
                                            <stringProp name="parameters"></stringProp>
                                            <stringProp name="filename"></stringProp>
                                            <stringProp name="cacheKey">true</stringProp>
                                            <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput
import java.util.Random
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

def formName = vars.get(&quot;currentFormName&quot;)
def rand = java.util.concurrent.ThreadLocalRandom.current()

def getRandomSelectionCount = props.get(&quot;fn_multiSelectCount&quot;)
def generateRandomNumber    = props.get(&quot;fn_generateRandomNumber&quot;)

// Default text values from Common Function
def defaultTexts = (props.get(&quot;fn_defaultTextFields&quot;) ?: [&quot;Executive Briefing&quot;, &quot;Innovation Workshop&quot;]) as String[]

// Loaded from Common Function via props (single source of truth)
def textareaValues = (props.get(&quot;fn_defaultTextAreas&quot;) ?: [&quot;Provide overview of enterprise solutions and demonstrate alignment with strategic goals&quot;]) as String[]

// STEP 1: Get formUIConfig
def formUIConfigStr = vars.get(&quot;currentFormUIConfig&quot;)
if (!formUIConfigStr) {
    log.warn(&quot;formUIConfig not found - skipping&quot;)
    vars.put(&quot;dynamicFormPayload&quot;, &quot;{}&quot;)
    return
}

// STEP 2: Parse fieldMappings
def fieldMappingsStr = vars.get(&quot;currentFieldMappings&quot;)
def fieldMappingsMap = [:]

if (fieldMappingsStr) {
    try {
        def fieldMappingsJson = new JsonSlurper().parseText(fieldMappingsStr)
        def mappings = fieldMappingsJson._embedded?.fieldMappings ?: []
        mappings.each { mapping -&gt;
            def attrName = mapping.columnAttribute?.attributeName
            def aliasName = mapping.aliasName
            if (attrName &amp;&amp; aliasName) {
                fieldMappingsMap[attrName] = [
                    aliasName  : aliasName,
                    displayText: mapping.displayText,
                    dataType   : mapping.columnAttribute?.dataType
                ]
            }
        }
    } catch (Exception e) {
        log.warn(&quot;Error parsing fieldMappings: &quot; + e.message)
    }
}

// STEP 3: Parse formUIConfig and extract all fields
def formUIConfig = new JsonSlurper().parseText(formUIConfigStr)
def allFields = []
def configItems = formUIConfig.config ?: []
configItems.each { item -&gt;
    if (item.type == &quot;SECTION&quot;) {
        allFields.addAll(item.formFields ?: [])
    } else if (item.type == &quot;FORMFIELD&quot;) {
        allFields.add(item)
    }
}

// STEP 4: Initialize
def formData = [:]
vars.put(&quot;existingFormData&quot;, &quot;{}&quot;)

def randomUserCountDPB = (vars.get(&quot;randomUserCount&quot;) ?: &quot;0&quot;).toInteger()
def usedDPBIndices = [] as Set
def lastPickedUser = [firstName: null, lastName: null]
def lastGeneratedNameGroup = []
def pickFreshUser = {
    if (randomUserCountDPB == 0) {
        lastPickedUser = [firstName: vars.get(&quot;customerFirstName&quot;) ?: &quot;John&quot;, lastName: vars.get(&quot;customerLastName&quot;) ?: &quot;Doe&quot;]
        return lastPickedUser
    }
    def avail = (1..randomUserCountDPB).findAll { !usedDPBIndices.contains(it) }
    if (avail.isEmpty()) {
        usedDPBIndices.clear()
        avail = (1..randomUserCountDPB).toList()
    }
    def idx = avail[rand.nextInt(avail.size())]
    usedDPBIndices.add(idx)
    lastPickedUser = [
        firstName: vars.get(&quot;randomUser_${idx}_firstName&quot;) ?: &quot;John&quot;,
        lastName : vars.get(&quot;randomUser_${idx}_lastName&quot;) ?: &quot;Doe&quot;
    ]
    return lastPickedUser
}
// Fallback default for backward compat
def generatedFirstName = vars.get(&quot;customerFirstName&quot;) ?: &quot;John&quot;
def generatedLastName = vars.get(&quot;customerLastName&quot;) ?: &quot;Doe&quot;

// Build Dependent Controls Map
def dependentControlsMap = [:]
def dependentFieldsSet = [] as Set

allFields.each { field -&gt;
    def parentFieldName = field.dataMapping ?: field.formControlName
    def dependentControls = field.dependentControls ?: []
    if (dependentControls) {
        def dependentsList = []
        dependentControls.each { dep -&gt;
            def depFieldName = dep.dataMapping ?: dep.formControlName
            def hideRules = dep.rules?.hide
            if (depFieldName &amp;&amp; hideRules) {
                dependentsList.add([fieldName: depFieldName, evalCondition: hideRules.evalCondition, evalValue: hideRules.evalValue])
                dependentFieldsSet.add(depFieldName)
            }
        }
        if (dependentsList) dependentControlsMap[parentFieldName] = dependentsList
    }
}

def shouldShowDependentField = { String depFieldName, Map formDataSoFar -&gt;
    def result = true
    dependentControlsMap.each { parentField, dependents -&gt;
        dependents.each { dep -&gt;
            if (dep.fieldName == depFieldName) {
                def parentValue = formDataSoFar[parentField]
                if (parentValue != null) {
                    def pVal = parentValue
                    def eVal = dep.evalValue
                    if (pVal instanceof Boolean || eVal instanceof Boolean) {
                        pVal = pVal?.toString()?.toLowerCase() == &quot;true&quot;
                        eVal = eVal?.toString()?.toLowerCase() == &quot;true&quot;
                    }
                    def shouldHide
                    if (pVal instanceof List) {
                        shouldHide = !pVal.contains(eVal)
                    } else {
                        shouldHide = dep.evalCondition == &quot;==&quot; ? (pVal == eVal) : (pVal != eVal)
                    }
                    if (shouldHide) result = false
                }
            }
        }
    }
    return result
}

def existingFormDataStr = vars.get(&quot;existingFormData&quot;)
def existingFormData = existingFormDataStr ? new JsonSlurper().parseText(existingFormDataStr) : [:]

// STEP 5: Process each field
allFields.each { field -&gt;
    def fieldName = field.dataMapping ?: field.formControlName
    def fieldType = field.formControlType
    def fieldLabel = field.fieldLabel ?: fieldName
    def isMultiple = field.isMultiple ?: false
    def lookupName = field.lookupName
    def isHidden = field.hide ?: false
    def isDisabled = field.disabled ?: false

    // Skip existing data
    def existingValue = existingFormData[fieldName]
    def isNumericField = fieldType in [&quot;NUMBER&quot;, &quot;CURRENCY&quot;, &quot;DECIMAL&quot;]
    def isBooleanField = fieldType == &quot;CHECKBOX&quot;
    def isEmptyNumeric = isNumericField &amp;&amp; (existingValue == 0 || existingValue == 0.0)
    def isEmptyBoolean = isBooleanField &amp;&amp; (existingValue == false || existingValue == &quot;false&quot;)
    if (existingValue != null &amp;&amp; existingValue.toString().trim() != &quot;&quot; &amp;&amp; !isEmptyNumeric &amp;&amp; !isEmptyBoolean) {
        formData[fieldName] = existingValue
        return
    }

    def resourceTypeId = field.resourceTypeId ?: field.resourceType?.id ?: field.resourceType?.uniqueId ?: (field.resourceType instanceof String ? field.resourceType : null)
    def masterTypeId = field.masterTypeId ?: field.masterType?.id ?: field.masterType?.uniqueId ?: (field.masterType instanceof String ? field.masterType : null)
    def enumType = field.enumType ?: &quot;&quot;
    def mappingInfo = fieldMappingsMap[fieldName]
    def aliasName = mappingInfo?.aliasName

    // Debug log each field for troubleshooting alias resolution

    // Don&apos;t skip hidden fields if they are dependent (parent may show them)
    if (isHidden &amp;&amp; !dependentFieldsSet.contains(fieldName)) return
    if (isDisabled) return

    def hiddenRoles = field.hiddenRoles ?: []
    def readOnlyRoles = field.readOnlyRoles ?: []
    def userRole = vars.get(&quot;roleId&quot;) ?: &quot;&quot;
    if (hiddenRoles &amp;&amp; hiddenRoles.contains(userRole)) return
    if (readOnlyRoles &amp;&amp; readOnlyRoles.contains(userRole)) return

    if (dependentFieldsSet.contains(fieldName) &amp;&amp; !shouldShowDependentField(fieldName, formData)) return

    def value = null
    def skipField = false

    // PRIORITY 1: Get value from JMeter variable (via alias)
    def skipAliasForMultiSelect = (fieldType == &quot;SELECT&quot; &amp;&amp; isMultiple &amp;&amp; lookupName)
    if (aliasName &amp;&amp; !skipAliasForMultiSelect) {
        value = vars.get(aliasName)
        if (value != null &amp;&amp; value != &quot;&quot;) {
            if (isMultiple &amp;&amp; fieldType != &quot;TEXTAREA&quot; &amp;&amp; value instanceof String &amp;&amp; value.contains(&quot;,&quot;)) {
                value = value.split(&quot;,&quot;).collect { it.trim() }.toList()
            } else if (isMultiple) {
                value = [value]
            }
        }
    }

    // PRIORITY 2: Auto-generate
    if (value == null || value == &quot;&quot;) {
        // Get validators for smart field detection
        def validators = field.validators ?: []

        switch(fieldType) {
            case &quot;TEXT&quot;:
                def isEmailField = validators.any { it.toString().contains(&quot;EMAIL&quot;) }
                def hasDomainEmail = validators.find { it.toString().startsWith(&quot;DOMAIN_EMAIL:&quot;) }
                def labelLower = fieldLabel.toLowerCase()
                def aliasLower = (aliasName ?: &quot;&quot;).toLowerCase()
                def isFirstNameField = labelLower.contains(&quot;first name&quot;) || aliasLower.contains(&quot;firstname&quot;)
                def isLastNameField = labelLower.contains(&quot;last name&quot;) || aliasLower.contains(&quot;lastname&quot;)
                def isDesignationField = labelLower.contains(&quot;designation&quot;) || labelLower.contains(&quot;job title&quot;) || labelLower.contains(&quot;title&quot;) || aliasLower.contains(&quot;designation&quot;) || aliasLower.contains(&quot;jobtitle&quot;) || aliasLower.contains(&quot;businesstitle&quot;)
                def isNameAndTitleField = labelLower.contains(&quot;name&quot;) &amp;&amp; (labelLower.contains(&quot;title&quot;) || labelLower.contains(&quot;designation&quot;) || aliasLower.contains(&quot;namesandjob&quot;) || aliasLower.contains(&quot;nameandtitle&quot;) || aliasLower.contains(&quot;attendeenames&quot;))
                // Sales executive / sales rep full name (not first/last split) — must be before isNameField
                def isSalesExecutiveField = !isFirstNameField &amp;&amp; !isLastNameField &amp;&amp; (labelLower.contains(&quot;sales executive&quot;) || labelLower.contains(&quot;sales rep name&quot;) || aliasLower.contains(&quot;salesexecutive&quot;))
                def isNameField = (!isFirstNameField &amp;&amp; !isLastNameField &amp;&amp; !isNameAndTitleField &amp;&amp; !isDesignationField &amp;&amp; !isSalesExecutiveField) &amp;&amp; (labelLower.contains(&quot;name&quot;) || aliasLower.contains(&quot;name&quot;))
                def isAccountField = labelLower.contains(&quot;account&quot;) || aliasLower.contains(&quot;account&quot;)
                // isOpportunityField only for actual multi-select opp ID fields, NOT pipeline type
                def isPipelineField = labelLower.contains(&quot;pipeline&quot;) || labelLower.contains(&quot;new or existing&quot;) || aliasLower.contains(&quot;pipeline&quot;) || aliasLower.contains(&quot;opportunitytype&quot;)
                def isOpportunityField = !isPipelineField &amp;&amp; (labelLower.contains(&quot;opportunity&quot;) || aliasLower.contains(&quot;opportunity&quot;))
                // Country field detection
                def isCountryField = labelLower.equals(&quot;country&quot;) || aliasLower.equals(&quot;country&quot;) || aliasLower.contains(&quot;country&quot;)
                // Phone/mobile field detection
                def isPhoneField = labelLower.contains(&quot;mobile&quot;) || labelLower.contains(&quot;phone&quot;) ||
                                   labelLower.contains(&quot;contact number&quot;) || aliasLower.contains(&quot;mobile&quot;) ||
                                   aliasLower.contains(&quot;phone&quot;) || aliasLower.contains(&quot;mobilenumber&quot;)
                // Company field detection
                def isCompanyField = labelLower.contains(&quot;company&quot;) || labelLower.contains(&quot;organisation&quot;) ||
                                     labelLower.contains(&quot;organization&quot;) || aliasLower.contains(&quot;company&quot;) ||
                                     aliasLower.contains(&quot;organisation&quot;) || aliasLower.contains(&quot;organization&quot;)

                // multiWrap helper — for isMultiple TEXT fields generates 1–3 values
                // For EMAIL fields: generates unique email per slot using randomUser pool
                // For other fields: calls singleValueFn 1–3 times
                def randomUserCountTxt = (vars.get(&quot;randomUserCount&quot;) ?: &quot;0&quot;).toInteger()
                def multiWrap = { Closure singleValueFn -&gt;
                    if (isMultiple) {
                        def count = rand.nextInt(3) + 1
                        return (1..count).collect { singleValueFn() }
                    } else {
                        return singleValueFn()
                    }
                }
                // Email multiWrap — picks a different random user each call to avoid duplicates
                // Helper: resolve domain options for email generation (form template wins, then UDV, then gmail.com)
                def emailDomainsUdvDPB3 = vars.get(&quot;emailDomains&quot;)?.trim()
                def domainOptionsListDPB3 = emailDomainsUdvDPB3 ? emailDomainsUdvDPB3.split(&quot;,&quot;).collect { it.trim() }.findAll { it } : ((props.get(&quot;fn_emailDomains&quot;) ?: [&quot;gmail.com&quot;]) as List)

                def multiWrapEmail = { String fixedDomain -&gt;
                    // If fixedDomain is from DOMAIN_EMAIL template, use it for all; otherwise pick random per email
                    def useFixedDomain = (fixedDomain != null &amp;&amp; !fixedDomain.isEmpty())
                    def pickDomainMWE = { -&gt;
                        if (useFixedDomain) return fixedDomain
                        return domainOptionsListDPB3[rand.nextInt(domainOptionsListDPB3.size())]
                    }
                    if (isMultiple) {
                        def count = rand.nextInt(3) + 1
                        def used = [] as Set
                        def result = []
                        int attempts = 0
                        while (result.size() &lt; count &amp;&amp; attempts &lt; 20) {
                            attempts++
                            if (randomUserCountTxt &gt; 0) {
                                def idx = rand.nextInt(randomUserCountTxt) + 1
                                if (!used.contains(idx)) {
                                    used.add(idx)
                                    def fn = vars.get(&quot;randomUser_${idx}_firstName&quot;)?.toLowerCase() ?: &quot;user&quot;
                                    def ln = vars.get(&quot;randomUser_${idx}_lastName&quot;)?.toLowerCase() ?: &quot;${idx}&quot;
                                    result.add(&quot;${fn}.${ln}@${pickDomainMWE()}&quot;)
                                }
                            } else {
                                // Fallback — use pickFreshUser for unique email even without randomUser pool
                                def u = pickFreshUser()
                                result.add(&quot;${u.firstName.toLowerCase()}.${u.lastName.toLowerCase()}${result.size() &gt; 0 ? result.size() : &apos;&apos;}@${pickDomainMWE()}&quot;)
                                break
                            }
                        }
                        return result
                    } else {
                        // Single email in multiWrapEmail — use lastPickedUser if set (matching name)
                        if (lastPickedUser.firstName) {
                            return &quot;${lastPickedUser.firstName.toLowerCase()}.${lastPickedUser.lastName.toLowerCase()}@${pickDomainMWE()}&quot;
                        }
                        def u = pickFreshUser()
                        return &quot;${u.firstName.toLowerCase()}.${u.lastName.toLowerCase()}@${pickDomainMWE()}&quot;
                    }
                }

                if (isPipelineField) {
                    // Pipeline type
                    def oppPipeline = [&quot;New&quot;, &quot;Existing&quot;]
                    value = vars.get(&quot;opportunityType&quot;) ?: oppPipeline[rand.nextInt(oppPipeline.size())]
                } else if (isCountryField) {
                    // Country
                    def countries = (props.get(&quot;fn_countries&quot;) ?: [&quot;United States&quot;, &quot;United Kingdom&quot;, &quot;India&quot;]) as String[]
                    value = vars.get(&quot;country&quot;) ?: countries[rand.nextInt(countries.length)]
                } else if (isSalesExecutiveField) {
                    // Sales Executive Name — full name from Form PreProcessor
                    def fn = vars.get(&quot;salesRepFirstName&quot;) ?: pickFreshUser().firstName
                    def ln = vars.get(&quot;salesRepLastName&quot;) ?: lastPickedUser.lastName ?: &quot;Doe&quot;
                    value = &quot;${fn} ${ln}&quot;
                    lastPickedUser = [firstName: fn, lastName: ln]
                } else
                if (isOpportunityField) {
                    def oppIds = vars.get(&quot;opportunity&quot;) ?: vars.get(&quot;secondaryOpportunity&quot;) ?: &quot;&quot;
                    if (oppIds) {
                        def idList = oppIds.split(&quot;,&quot;).collect { it.trim() }.findAll { it }
                        value = isMultiple ? idList : idList[0]
                    } else {
                        value = multiWrap { String.valueOf(rand.nextInt(9000) + 1000) }
                    }
                } else if (isPhoneField) {
                    // Phone/mobile — always single value even if isMultiple (phones are not multi-tag)
                    def digit = [7, 8, 9][rand.nextInt(3)]
                    def rest = java.util.concurrent.ThreadLocalRandom.current().nextLong(100000000L, 1000000000L)
                    value = String.valueOf(digit) + String.valueOf(rest)
                } else if (isCompanyField) {
                    // Company — use customerName (the visiting company), not defaultTexts
                    value = vars.get(&quot;customerName&quot;) ?: &quot;Acme Corp&quot;
                } else if (isNameAndTitleField) {
                    def attendeeNamesStr = vars.get(&quot;externalAttendeeNamesAndJobTitles&quot;) ?: &quot;&quot;
                    if (attendeeNamesStr) {
                        def nameList = attendeeNamesStr.split(&quot;,&quot;).collect { it.trim() }.findAll { it }
                        value = isMultiple ? nameList : nameList[0]
                        // Parse names from &quot;FirstName LastName - Title&quot; format for email matching
                        lastGeneratedNameGroup = nameList.collect { entry -&gt;
                            def namePart = entry.contains(&quot; - &quot;) ? entry.split(&quot; - &quot;)[0].trim() : entry.trim()
                            def parts = namePart.split(&quot; &quot;, 2)
                            [firstName: parts[0], lastName: parts.length &gt; 1 ? parts[1] : &quot;Doe&quot;]
                        }
                    } else {
                        // Pick fresh user for each name+title entry
                        String[] titleOptions = [&quot;Manager&quot;, &quot;Director&quot;, &quot;Vice President&quot;, &quot;Team Lead&quot;,
                            &quot;Project Manager&quot;, &quot;Business Analyst&quot;, &quot;Product Manager&quot;,
                            &quot;Operations Manager&quot;, &quot;Account Executive&quot;, &quot;Sales Representative&quot;]
                        lastGeneratedNameGroup = []
                        def count = rand.nextInt(3) + 1
                        def names = []
                        for (int j = 0; j &lt; count; j++) {
                            def u = pickFreshUser()
                            names.add(&quot;${u.firstName} ${u.lastName} - ${titleOptions[rand.nextInt(titleOptions.length)]}&quot;)
                            lastGeneratedNameGroup.add([firstName: u.firstName, lastName: u.lastName])
                        }
                        value = isMultiple ? names : names[0]
                    }
                } else if (isEmailField &amp;&amp; (labelLower.contains(&quot;attendee&quot;) || labelLower.contains(&quot;external&quot;) || aliasLower.contains(&quot;attendee&quot;) || aliasLower.contains(&quot;external&quot;) || labelLower.contains(&quot;oracle&quot;) || aliasLower.contains(&quot;oracle&quot;))) {
                    // Derive emails from lastGeneratedNameGroup (set by preceding name field)
                    // This ensures Oracle Attendee Emails match Oracle Attendee Names,
                    // and External Attendee Emails match External Attendee Names
                    def templateDomain = hasDomainEmail ? hasDomainEmail.toString().split(&quot;:&quot;)[1]?.trim() : null
                    def pickDomainLocal = { -&gt;
                        if (templateDomain) return templateDomain
                        return domainOptionsListDPB3[rand.nextInt(domainOptionsListDPB3.size())]
                    }
                    if (lastGeneratedNameGroup &amp;&amp; lastGeneratedNameGroup.size() &gt; 0) {
                        def emails = lastGeneratedNameGroup.collect { p -&gt;
                            &quot;${p.firstName.toLowerCase()}.${p.lastName.toLowerCase()}@${pickDomainLocal()}&quot;
                        }
                        value = isMultiple ? emails : emails[0]
                        // Clear after use so the next email group doesn&apos;t reuse
                        lastGeneratedNameGroup = []
                    } else {
                        // Fallback: try attendeeEmails variable, then multiWrapEmail
                        def attendeeEmailsStr = vars.get(&quot;externalAttendeeEmails&quot;) ?: &quot;&quot;
                        if (attendeeEmailsStr) {
                            def emailList = attendeeEmailsStr.split(&quot;,&quot;).collect { it.trim() }.findAll { it }
                            value = isMultiple ? emailList : emailList[0]
                        } else {
                            value = multiWrapEmail(templateDomain)
                        }
                    }
                } else if (isEmailField &amp;&amp; hasDomainEmail &amp;&amp; (labelLower.contains(&quot;additional&quot;) || isMultiple)) {
                    // Additional/multi email — use multiWrapEmail for unique emails per slot
                    def templateDomainAdd = hasDomainEmail.toString().split(&quot;:&quot;)[1]?.trim() ?: null
                    value = multiWrapEmail(templateDomainAdd)
                } else if (isEmailField) {
                    def templateDomainGen = hasDomainEmail ? hasDomainEmail.toString().split(&quot;:&quot;)[1]?.trim() : null
                    def pickDomainGen = { -&gt;
                        if (templateDomainGen) return templateDomainGen
                        return domainOptionsListDPB3[rand.nextInt(domainOptionsListDPB3.size())]
                    }
                    // Single email — try pre-set variables first, then lastPickedUser, then pickFreshUser
                    if (isMultiple) {
                        value = multiWrapEmail(templateDomainGen)
                    } else {
                        // Try pre-set Form PreProcessor email by label
                        def presetEmail = null
                        if (labelLower.contains(&quot;sales rep&quot;) || labelLower.contains(&quot;salesrep&quot;)) {
                            presetEmail = vars.get(&quot;salesRepEmail&quot;)
                        } else if (labelLower.contains(&quot;sales coverage&quot;)) {
                            presetEmail = vars.get(&quot;salesCoverageRepEmail&quot;)
                        } else if (labelLower.contains(&quot;onsite&quot;)) {
                            presetEmail = vars.get(&quot;onsiteSalesLeadEmail&quot;)
                        } else if (labelLower.contains(&quot;customer&quot;) &amp;&amp; !labelLower.contains(&quot;additional&quot;)) {
                            presetEmail = vars.get(&quot;customerEmail&quot;)
                        }
                        if (presetEmail) {
                            value = presetEmail
                        } else if (lastPickedUser.firstName) {
                            value = &quot;${lastPickedUser.firstName.toLowerCase()}.${lastPickedUser.lastName.toLowerCase()}@${pickDomainGen()}&quot;
                        } else {
                            def u = pickFreshUser()
                            value = &quot;${u.firstName.toLowerCase()}.${u.lastName.toLowerCase()}@${pickDomainGen()}&quot;
                        }
                    }
                } else if (isFirstNameField) {
                    // Try pre-set Form PreProcessor variables first by detecting person-group from label
                    def presetFirstName = null
                    if (labelLower.contains(&quot;sales rep&quot;) || labelLower.contains(&quot;salesrep&quot;)) {
                        presetFirstName = vars.get(&quot;salesRepFirstName&quot;)
                    } else if (labelLower.contains(&quot;customer&quot;)) {
                        presetFirstName = vars.get(&quot;customerFirstName&quot;)
                    } else if (labelLower.contains(&quot;external&quot;) || labelLower.contains(&quot;attendee&quot;)) {
                        presetFirstName = vars.get(&quot;externalAttendeeFirstName&quot;)
                    }
                    if (presetFirstName) {
                        // Also set lastPickedUser so lastName+email can reuse
                        def presetLastName = null
                        if (labelLower.contains(&quot;sales rep&quot;) || labelLower.contains(&quot;salesrep&quot;)) {
                            presetLastName = vars.get(&quot;salesRepLastName&quot;)
                        } else if (labelLower.contains(&quot;customer&quot;)) {
                            presetLastName = vars.get(&quot;customerLastName&quot;)
                        } else if (labelLower.contains(&quot;external&quot;) || labelLower.contains(&quot;attendee&quot;)) {
                            presetLastName = vars.get(&quot;externalAttendeeLastName&quot;)
                        }
                        lastPickedUser = [firstName: presetFirstName, lastName: presetLastName ?: &quot;Doe&quot;]
                        value = presetFirstName
                    } else {
                        value = multiWrap { pickFreshUser().firstName }
                    }
                } else if (isLastNameField) {
                    // Reuse lastPickedUser (set by firstName or Form PreProcessor)
                    if (lastPickedUser.firstName) {
                        value = multiWrap { lastPickedUser.lastName }
                    } else {
                        // Try pre-set variables by label
                        def presetLastName = null
                        if (labelLower.contains(&quot;sales rep&quot;) || labelLower.contains(&quot;salesrep&quot;)) {
                            presetLastName = vars.get(&quot;salesRepLastName&quot;)
                        } else if (labelLower.contains(&quot;customer&quot;)) {
                            presetLastName = vars.get(&quot;customerLastName&quot;)
                        } else if (labelLower.contains(&quot;external&quot;) || labelLower.contains(&quot;attendee&quot;)) {
                            presetLastName = vars.get(&quot;externalAttendeeLastName&quot;)
                        }
                        if (presetLastName) {
                            value = presetLastName
                        } else {
                            value = multiWrap { pickFreshUser().lastName }
                        }
                    }
                } else if (isAccountField) {
                    value = multiWrap { vars.get(&quot;customerName&quot;) ?: &quot;Acme Corp&quot; }
                } else if (isDesignationField) {
                    String[] titleOptions = [&quot;Manager&quot;, &quot;Director&quot;, &quot;Vice President&quot;, &quot;Team Lead&quot;,
                        &quot;Project Manager&quot;, &quot;Business Analyst&quot;, &quot;Product Manager&quot;,
                        &quot;Operations Manager&quot;, &quot;Account Executive&quot;, &quot;Sales Representative&quot;,
                        &quot;Marketing Manager&quot;, &quot;Financial Analyst&quot;]
                    value = multiWrap { titleOptions[rand.nextInt(titleOptions.length)] }
                } else if (isNameField) {
                    // Try pre-set Form PreProcessor full-name variables by label
                    def presetName = null
                    if (labelLower.contains(&quot;sales coverage&quot;)) {
                        presetName = vars.get(&quot;salesCoverageRepName&quot;)
                    } else if (labelLower.contains(&quot;onsite&quot;) || labelLower.contains(&quot;on-site&quot;)) {
                        presetName = vars.get(&quot;onsiteSalesLeadName&quot;)
                    } else if (labelLower.contains(&quot;customer&quot;) &amp;&amp; labelLower.contains(&quot;name&quot;) &amp;&amp; !labelLower.contains(&quot;account&quot;)) {
                        presetName = vars.get(&quot;sibosCustomerName&quot;)
                    }
                    if (presetName) {
                        def parts = presetName.split(&quot; &quot;, 2)
                        lastPickedUser = [firstName: parts[0], lastName: parts.length &gt; 1 ? parts[1] : &quot;Doe&quot;]
                        value = presetName
                    } else if (isMultiple) {
                        // Generate multiple names AND store them for matching email field
                        lastGeneratedNameGroup = []
                        def count = rand.nextInt(3) + 1
                        def names = []
                        for (int j = 0; j &lt; count; j++) {
                            def u = pickFreshUser()
                            names.add(&quot;${u.firstName} ${u.lastName}&quot;)
                            lastGeneratedNameGroup.add([firstName: u.firstName, lastName: u.lastName])
                        }
                        value = names
                    } else {
                        def u = pickFreshUser()
                        value = &quot;${u.firstName} ${u.lastName}&quot;
                        lastGeneratedNameGroup = [[firstName: u.firstName, lastName: u.lastName]]
                    }
                } else {
                    // Detect comment/meeting/note/topic TEXT fields — use pre-set values instead of defaultTexts
                    // Detect &quot;Additional Details&quot; field — route to textareaValues for richer content
                    def isCommentField = labelLower.contains(&quot;comment&quot;) || aliasLower.contains(&quot;comment&quot;)
                    def isNoteField = labelLower.contains(&quot;note&quot;) || aliasLower.contains(&quot;note&quot;)
                    def isAdditionalDetailField = (labelLower.contains(&quot;additional&quot;) &amp;&amp; labelLower.contains(&quot;detail&quot;)) || (aliasLower.contains(&quot;additional&quot;) &amp;&amp; aliasLower.contains(&quot;detail&quot;))
                    def isMeetingField = labelLower.contains(&quot;meeting&quot;) || labelLower.contains(&quot;topic&quot;) || labelLower.contains(&quot;detail&quot;) || labelLower.contains(&quot;purpose&quot;) || labelLower.contains(&quot;objective&quot;) || labelLower.contains(&quot;agenda&quot;) || aliasLower.contains(&quot;meeting&quot;) || aliasLower.contains(&quot;topic&quot;) || aliasLower.contains(&quot;detail&quot;) || aliasLower.contains(&quot;purpose&quot;) || aliasLower.contains(&quot;objective&quot;) || aliasLower.contains(&quot;agenda&quot;)

                    if (isCommentField) {
                        value = vars.get(&quot;comments&quot;) ?: defaultTexts[rand.nextInt(defaultTexts.size())]
                    } else if (isNoteField) {
                        value = vars.get(&quot;notes&quot;) ?: vars.get(&quot;meetingDetails&quot;) ?: defaultTexts[rand.nextInt(defaultTexts.size())]
                    } else if (isAdditionalDetailField) {
                        // Additional Details gets longer descriptive text
                        value = textareaValues[rand.nextInt(textareaValues.size())]
                    } else if (isMeetingField) {
                        value = vars.get(&quot;meetingDetails&quot;) ?: defaultTexts[rand.nextInt(defaultTexts.size())]
                    } else {
                        value = multiWrap { defaultTexts[rand.nextInt(defaultTexts.size())] }
                    }
                }
                break
            case &quot;TEXTAREA&quot;:
                def labelLowerTA = fieldLabel.toLowerCase()
                def aliasLowerTA = (aliasName ?: &quot;&quot;).toLowerCase()

                // Additional Details field — use holdAdditionalDetails directly
                def isHoldDetailField = labelLowerTA.contains(&quot;additional&quot;) &amp;&amp; labelLowerTA.contains(&quot;detail&quot;)

                if (isHoldDetailField) {
                    value = vars.get(&quot;holdAdditionalDetails&quot;) ?: textareaValues[rand.nextInt(textareaValues.size())]
                } else if (aliasLowerTA.contains(&quot;comment&quot;)) {
                    value = vars.get(&quot;comments&quot;) ?: textareaValues[rand.nextInt(textareaValues.size())]
                } else if (aliasLowerTA.contains(&quot;note&quot;)) {
                    value = vars.get(&quot;notes&quot;) ?: vars.get(&quot;meetingDetails&quot;) ?: textareaValues[rand.nextInt(textareaValues.size())]
                } else {
                    value = vars.get(&quot;meetingDetails&quot;) ?: textareaValues[rand.nextInt(textareaValues.size())]
                }
                break
            case &quot;NUMBER&quot;:
            case &quot;CURRENCY&quot;:
                value = generateRandomNumber(1, 10)
                break
            case &quot;CLOUD_DATE&quot;:
                def futureDate = new Date().plus(rand.nextInt(30) + 1)
                value = futureDate.format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;)
                break
            case &quot;CLOUD_TIME&quot;:
                def slotStartTime = vars.get(&quot;currentVacantSlotStartTime&quot;) ?: &quot;&quot;
                def slotEndTime = vars.get(&quot;currentVacantSlotEndTime&quot;) ?: &quot;&quot;
                def durationStr = vars.get(&quot;currentActivityDuration&quot;) ?: &quot;30&quot;
                def durationMins = durationStr.isInteger() ? durationStr.toInteger() : 30

                def fieldLower = fieldName?.toLowerCase() ?: &quot;&quot;
                def aliasLower = aliasName?.toLowerCase() ?: &quot;&quot;
                if ((fieldLower.contains(&quot;start&quot;) || aliasLower.contains(&quot;start&quot;)) &amp;&amp; slotStartTime) {
                    value = slotStartTime
                } else if ((fieldLower.contains(&quot;end&quot;) || aliasLower.contains(&quot;end&quot;)) &amp;&amp; slotStartTime) {
                    try {
                        def startDT = LocalDateTime.parse(slotStartTime, DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;))
                        value = startDT.plusMinutes(durationMins).format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;))
                    } catch (Exception e) {
                        value = slotEndTime ?: slotStartTime
                    }
                } else {
                    value = slotStartTime ?: new Date().format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;)
                }
                break
            case &quot;SELECT&quot;:
                if (enumType == &quot;TIMEZONE&quot;) {
                    value = vars.get(&quot;requestTimeZone&quot;) ?: &quot;&quot;
                } else if (enumType == &quot;MASTER&quot; &amp;&amp; masterTypeId) {
                    def mtCount = vars.get(&quot;mastersFor_${masterTypeId}_count&quot;)?.toInteger() ?: 0
                    if (mtCount &gt; 0) {
                        if (isMultiple) {
                            def indices = (1..mtCount).toList(); Collections.shuffle(indices)
                            value = indices.take(getRandomSelectionCount(mtCount)).collect { vars.get(&quot;mastersFor_${masterTypeId}_${it}_id&quot;) }.findAll { it }
                        } else {
                            value = vars.get(&quot;mastersFor_${masterTypeId}_${rand.nextInt(mtCount)+1}_id&quot;)
                        }
                    } else { skipField = true }
                } else if (enumType == &quot;RESOURCE&quot; &amp;&amp; resourceTypeId) {
                    def rtCount = vars.get(&quot;resourcesFor_${resourceTypeId}_count&quot;)?.toInteger() ?: 0
                    if (rtCount &gt; 0) {
                        // oracleAttendeeNames and similar oracle/presenter attendee fields
                        // must pick between 1 and 3 when isMultiple, not unbounded
                        def aliasLowerSel = (aliasName ?: &quot;&quot;).toLowerCase()
                        def labelLowerSel = fieldLabel.toLowerCase()
                        def isOracleAttendeeField = (aliasLowerSel.contains(&quot;oracle&quot;) &amp;&amp; aliasLowerSel.contains(&quot;attend&quot;)) ||
                                                    (labelLowerSel.contains(&quot;oracle&quot;) &amp;&amp; labelLowerSel.contains(&quot;attend&quot;))
                        if (isMultiple &amp;&amp; isOracleAttendeeField) {
                            // Cap strictly at 1–3 (dropdown multi-select for oracle attendees)
                            def cap = rand.nextInt(3) + 1   // 1, 2, or 3
                            def maxPick = Math.min(cap, rtCount)
                            def indices = (1..rtCount).toList(); Collections.shuffle(indices)
                            value = indices.take(maxPick).collect { vars.get(&quot;resourcesFor_${resourceTypeId}_${it}_id&quot;) }.findAll { it }
                        } else {
                            value = [&quot;uniqueId&quot;: vars.get(&quot;resourcesFor_${resourceTypeId}_${rand.nextInt(rtCount)+1}_id&quot;)]
                        }
                    } else { skipField = true }
                } else if (lookupName) {
                    def words = lookupName.toLowerCase().split(&apos;_&apos;)
                    def camelCase = words[0] + words.drop(1).collect { it.capitalize() }.join(&apos;&apos;)
                    def count = vars.get(camelCase + &quot;_count&quot;)?.toInteger() ?: 0
                    if (count &gt; 0) {
                        if (isMultiple) {
                            def indices = (1..count).toList(); Collections.shuffle(indices)
                            value = indices.take(getRandomSelectionCount(count)).collect { vars.get(camelCase + &quot;_&quot; + it) }.findAll { it }
                        } else {
                            value = vars.get(camelCase + &quot;_&quot; + (rand.nextInt(count) + 1))
                        }
                    } else { skipField = true }
                } else { skipField = true }
                break
            case &quot;CHECKBOX&quot;:
                value = rand.nextBoolean()
                break
            case &quot;RESOURCE&quot;:
                if (resourceTypeId) {
                    def rtCount = vars.get(&quot;resourcesFor_${resourceTypeId}_count&quot;)?.toInteger() ?: 0
                    if (rtCount &gt; 0) {
                        // oracleAttendeeNames and similar oracle attendee fields cap at 1–3
                        def aliasLowerR = (aliasName ?: &quot;&quot;).toLowerCase()
                        def labelLowerR = fieldLabel.toLowerCase()
                        def isOracleAttendeeR = (aliasLowerR.contains(&quot;oracle&quot;) &amp;&amp; aliasLowerR.contains(&quot;attend&quot;)) ||
                                                (labelLowerR.contains(&quot;oracle&quot;) &amp;&amp; labelLowerR.contains(&quot;attend&quot;))
                        if (isMultiple) {
                            def indices = (1..rtCount).toList(); Collections.shuffle(indices)
                            if (isOracleAttendeeR) {
                                // Hard cap 1–3 for oracle attendee dropdown fields
                                def cap = rand.nextInt(3) + 1
                                def maxPick = Math.min(cap, rtCount)
                                value = indices.take(maxPick).collect { vars.get(&quot;resourcesFor_${resourceTypeId}_${it}_id&quot;) }.findAll { it }
                            } else {
                                value = indices.take(getRandomSelectionCount(rtCount)).collect { vars.get(&quot;resourcesFor_${resourceTypeId}_${it}_id&quot;) }.findAll { it }
                            }
                        } else {
                            value = vars.get(&quot;resourcesFor_${resourceTypeId}_${rand.nextInt(rtCount)+1}_id&quot;)
                        }
                    } else { skipField = true }
                } else { skipField = true }
                break
            case &quot;MASTER&quot;:
                if (masterTypeId) {
                    def mtCount = vars.get(&quot;mastersFor_${masterTypeId}_count&quot;)?.toInteger() ?: 0
                    if (mtCount &gt; 0) {
                        // oracleAttendeeNames cap at 1–3 if isMultiple
                        def aliasLowerM = (aliasName ?: &quot;&quot;).toLowerCase()
                        def labelLowerM = fieldLabel.toLowerCase()
                        def isOracleAttendeeM = (aliasLowerM.contains(&quot;oracle&quot;) &amp;&amp; aliasLowerM.contains(&quot;attend&quot;)) ||
                                                (labelLowerM.contains(&quot;oracle&quot;) &amp;&amp; labelLowerM.contains(&quot;attend&quot;))
                        if (isMultiple) {
                            def indices = (1..mtCount).toList(); Collections.shuffle(indices)
                            if (isOracleAttendeeM) {
                                def cap = rand.nextInt(3) + 1
                                def maxPick = Math.min(cap, mtCount)
                                value = indices.take(maxPick).collect { vars.get(&quot;mastersFor_${masterTypeId}_${it}_id&quot;) }.findAll { it }
                            } else {
                                value = indices.take(getRandomSelectionCount(mtCount)).collect { vars.get(&quot;mastersFor_${masterTypeId}_${it}_id&quot;) }.findAll { it }
                            }
                        } else {
                            value = vars.get(&quot;mastersFor_${masterTypeId}_${rand.nextInt(mtCount)+1}_id&quot;)
                        }
                    } else { skipField = true }
                } else { skipField = true }
                break
            default:
                skipField = true
        }
    }

    // STEP 6: Add to formData
    if (!skipField &amp;&amp; value != null &amp;&amp; value != &quot;&quot;) {
        if (fieldType in [&quot;CLOUD_DATE&quot;, &quot;CLOUD_TIME&quot;] &amp;&amp; !(value instanceof Map)) {
            formData[fieldName] = [&quot;isoDate&quot;: value]
        } else if (fieldType == &quot;CHECKBOX&quot;) {
            formData[fieldName] = (value instanceof String) ? value.toLowerCase() == &quot;true&quot; : value
        } else if (fieldType == &quot;NUMBER&quot;) {
            formData[fieldName] = (value instanceof String &amp;&amp; value.isInteger()) ? value.toInteger() : value
        } else if (isMultiple &amp;&amp; !(value instanceof List)) {
            formData[fieldName] = [value]
        } else {
            formData[fieldName] = value
        }
    }
}

// STEP 7: Build payload
def payload = [
    &quot;moduleId&quot; : vars.get(&quot;currentModuleId&quot;) ?: vars.get(&quot;currentActivityModuleId&quot;) ?: vars.get(&quot;moduleId&quot;),
    &quot;formId&quot;   : vars.get(&quot;currentFormId&quot;) ?: vars.get(&quot;formId&quot;),
    &quot;journeyId&quot;: vars.get(&quot;currentJourneyId&quot;) ?: vars.get(&quot;activityJourneyId&quot;),
    &quot;pageId&quot;   : vars.get(&quot;currentPageId&quot;) ?: vars.get(&quot;activityPageId&quot;),
    &quot;data&quot;     : formData
]

vars.put(&quot;dynamicFormPayload&quot;, JsonOutput.prettyPrint(JsonOutput.toJson(payload)))
log.info(&quot;Payload built: ${formData.size()} fields for &apos;${formName}&apos;&quot;)</stringProp>
                                          </JSR223PreProcessor>
                                          <hashTree/>
                                          <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Activity Data Id Extractor" enabled="true">
                                            <stringProp name="JSONPostProcessor.referenceNames">activityDataId</stringProp>
                                            <stringProp name="JSONPostProcessor.jsonPathExprs">$.id</stringProp>
                                            <stringProp name="JSONPostProcessor.match_numbers"></stringProp>
                                          </JSONPostProcessor>
                                          <hashTree/>
                                          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Store State Action IDs" enabled="true">
                                            <stringProp name="scriptLanguage">groovy</stringProp>
                                            <stringProp name="parameters"></stringProp>
                                            <stringProp name="filename"></stringProp>
                                            <stringProp name="cacheKey">true</stringProp>
                                            <stringProp name="script">// Store first form&apos;s IDs for state action URL building (only set once per activity)
def formId = vars.get(&quot;submitFormId&quot;) ?: &quot;&quot;
def dataId = vars.get(&quot;activityDataId&quot;) ?: &quot;&quot;

if (formId &amp;&amp; dataId) {
    vars.put(&quot;stateActionFormId&quot;, formId)
    vars.put(&quot;stateActionDataId&quot;, dataId)
    log.info(&quot;[State Action IDs] formId=${formId} | dataId=${dataId}&quot;)
} else {
    log.warn(&quot;[State Action IDs] Missing - formId=${formId} | dataId=${dataId}&quot;)
}</stringProp>
                                          </JSR223PostProcessor>
                                          <hashTree/>
                                          <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                                          <hashTree/>
                                        </hashTree>
                                      </hashTree>
                                      <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ If (Presenter Form)" enabled="true">
                                        <stringProp name="IfController.condition">${__groovy(vars.get(&quot;isPresenterForm&quot;) == &quot;true&quot;)}</stringProp>
                                        <boolProp name="IfController.evaluateAll">false</boolProp>
                                        <boolProp name="IfController.useExpression">true</boolProp>
                                      </IfController>
                                      <hashTree>
                                        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Create" enabled="true">
                                          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
                                          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                                            <collectionProp name="Arguments.arguments">
                                              <elementProp name="" elementType="HTTPArgument">
                                                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                                                <stringProp name="Argument.value">${presenterPayload}</stringProp>
                                                <stringProp name="Argument.metadata">=</stringProp>
                                              </elementProp>
                                            </collectionProp>
                                          </elementProp>
                                          <stringProp name="HTTPSampler.domain"></stringProp>
                                          <stringProp name="HTTPSampler.port"></stringProp>
                                          <stringProp name="HTTPSampler.protocol"></stringProp>
                                          <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                                          <stringProp name="HTTPSampler.path">/${contextname}/api/forms/${submitFormId}/data</stringProp>
                                          <stringProp name="HTTPSampler.method">POST</stringProp>
                                          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
                                          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                                          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
                                          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                                          <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                                          <stringProp name="HTTPSampler.connect_timeout"></stringProp>
                                          <stringProp name="HTTPSampler.response_timeout"></stringProp>
                                        </HTTPSamplerProxy>
                                        <hashTree>
                                          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                                            <collectionProp name="HeaderManager.headers">
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">x-cloud-customerid</stringProp>
                                                <stringProp name="Header.value">${customerId}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                                                <stringProp name="Header.value">${categoryTypeId}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                                                <stringProp name="Header.value">${categoryId}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">x-cloud-eventid</stringProp>
                                                <stringProp name="Header.value">${requestId}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">x-cloud-activityid</stringProp>
                                                <stringProp name="Header.value">${activityId}</stringProp>
                                              </elementProp>
                                              <elementProp name="" elementType="Header">
                                                <stringProp name="Header.name">X_cloud_user</stringProp>
                                                <stringProp name="Header.value">${currentUser}</stringProp>
                                              </elementProp>
                                            </collectionProp>
                                          </HeaderManager>
                                          <hashTree/>
                                          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Presenter Method Switcher" enabled="true">
                                            <stringProp name="scriptLanguage">groovy</stringProp>
                                            <stringProp name="parameters"></stringProp>
                                            <stringProp name="filename"></stringProp>
                                            <stringProp name="cacheKey">true</stringProp>
                                            <stringProp name="script">// Dynamically switch between POST (create) and PUT (update) for presenter form
def formDataExists = vars.get(&quot;formDataExists&quot;) == &quot;true&quot;
def existingId = vars.get(&quot;existingFormDataId&quot;) ?: &quot;&quot;
def formId = vars.get(&quot;submitFormId&quot;) ?: &quot;&quot;
def contextname = vars.get(&quot;contextname&quot;) ?: &quot;events&quot;

if (formDataExists &amp;&amp; existingId) {
    sampler.setMethod(&quot;PUT&quot;)
    sampler.setPath(&quot;/&quot; + contextname + &quot;/api/forms/&quot; + formId + &quot;/data/&quot; + existingId)
} else {
    sampler.setMethod(&quot;POST&quot;)
    sampler.setPath(&quot;/&quot; + contextname + &quot;/api/forms/&quot; + formId + &quot;/data&quot;)
}
</stringProp>
                                          </JSR223PreProcessor>
                                          <hashTree/>
                                          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build Presenter Payload" enabled="true">
                                            <stringProp name="scriptLanguage">groovy</stringProp>
                                            <stringProp name="parameters"></stringProp>
                                            <stringProp name="filename"></stringProp>
                                            <stringProp name="cacheKey">true</stringProp>
                                            <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput
import java.util.concurrent.ThreadLocalRandom

def rand = ThreadLocalRandom.current()

def presenterFormId = vars.get(&quot;submitFormId&quot;) ?: &quot;&quot;
def moduleId = vars.get(&quot;submitModuleId&quot;) ?: vars.get(&quot;currentActivityModuleId&quot;) ?: &quot;&quot;
def journeyId = vars.get(&quot;submitJourneyId&quot;) ?: vars.get(&quot;activityJourneyId&quot;) ?: &quot;&quot;
def pageId = vars.get(&quot;submitPageId&quot;) ?: vars.get(&quot;activityPageId&quot;) ?: &quot;&quot;

if (!presenterFormId) {
    log.warn(&quot;No presenter form - skipping&quot;)
    vars.put(&quot;presenterPayload&quot;, &quot;{}&quot;)
    return
}

def availableCount = (vars.get(&quot;selectedPresenterCount&quot;) ?: &quot;0&quot;).toInteger()
if (availableCount == 0) {
    log.warn(&quot;No presenters available - skipping&quot;)
    vars.put(&quot;presenterPayload&quot;, &quot;{}&quot;)
    return
}

def multiSelectRange = (vars.get(&quot;multiSelectRange&quot;) ?: &quot;1,3&quot;).split(&quot;,&quot;)*.trim()
def minSel = multiSelectRange[0].toInteger()
def maxSel = multiSelectRange.size() &gt; 1 ? multiSelectRange[1].toInteger() : minSel

// Check if participant field is isMultiple from formUIConfig
def participantIsMultiple = false
def formUICheckStr = vars.get(&quot;currentFormUIConfig&quot;)
if (formUICheckStr) {
    try {
        def uiCheck = new JsonSlurper().parseText(formUICheckStr)
        def allCheckFields = []
        (uiCheck.config ?: []).each { item -&gt;
            if (item.type == &quot;SECTION&quot;) { allCheckFields.addAll(item.formFields ?: []) }
            else if (item.type == &quot;FORMFIELD&quot;) { allCheckFields.add(item) }
        }
        def participantField = allCheckFields.find { 
            (it.dataMapping ?: it.formControlName) == &quot;participant&quot; || it.formControlType == &quot;RESOURCE&quot;
        }
        if (participantField) {
            participantIsMultiple = participantField.isMultiple ?: false
        }
    } catch (Exception e) { log.warn(&quot;Could not check participant isMultiple: &quot; + e.message) }
}

// Pick presenter(s) based on isMultiple
def selectedPresenters = []
def primaryPresenterIdx = 1

if (participantIsMultiple) {
    // Multiple presenters: pick random count within range
    def maxPick = Math.min(availableCount, maxSel)
    def minPick = Math.min(minSel, maxPick)
    def pickCount = minPick + rand.nextInt((maxPick - minPick) + 1)
    def indices = (1..availableCount).toList()
    Collections.shuffle(indices)
    indices.take(pickCount).each { idx -&gt;
        def pid = vars.get(&quot;selectedPresenterId_&quot; + idx) ?: &quot;&quot;
        if (pid) selectedPresenters.add(idx)
    }
    primaryPresenterIdx = selectedPresenters.isEmpty() ? 1 : selectedPresenters[0]
} else {
    // Single presenter
    primaryPresenterIdx = rand.nextInt(availableCount) + 1
    selectedPresenters.add(primaryPresenterIdx)
}

// Primary presenter details (used for TEXT fields like name, email, designation)
def presenterId = vars.get(&quot;selectedPresenterId_&quot; + primaryPresenterIdx) ?: &quot;&quot;
def presenterName = vars.get(&quot;selectedPresenterName_&quot; + primaryPresenterIdx) ?: &quot;&quot;
def presenterEmail = vars.get(&quot;selectedPresenterEmail_&quot; + primaryPresenterIdx) ?: &quot;&quot;
def presenterDesignation = vars.get(&quot;selectedPresenterDesignation_&quot; + primaryPresenterIdx) ?: &quot;&quot;
def presenterFirstName = presenterName.split(&quot; &quot;)[0]?.trim()?.toLowerCase() ?: &quot;presenter&quot;

def formData = [:]

// Set participant field based on isMultiple
if (participantIsMultiple) {
    // isMultiple=true: flat array of ID strings → [&quot;id1&quot;, &quot;id2&quot;, &quot;id3&quot;]
    formData.put(&quot;participant&quot;, selectedPresenters.collect { idx -&gt;
        vars.get(&quot;selectedPresenterId_&quot; + idx) ?: &quot;&quot;
    }.findAll { it })
} else {
    // isMultiple=false: single object → {&quot;uniqueId&quot;: &quot;id&quot;}
    formData.put(&quot;participant&quot;, [&quot;uniqueId&quot;: presenterId])
}

def formUIConfigStr = vars.get(&quot;currentFormUIConfig&quot;)
if (formUIConfigStr) {
    def formUIConfig = new JsonSlurper().parseText(formUIConfigStr)
    def allFields = []
    (formUIConfig.config ?: []).each { item -&gt;
        if (item.type == &quot;SECTION&quot;) { allFields.addAll(item.formFields ?: []) }
        else if (item.type == &quot;FORMFIELD&quot;) { allFields.add(item) }
    }

    def fieldMappingsStr = vars.get(&quot;currentFieldMappings&quot;)
    def fmMap = [:]
    if (fieldMappingsStr) {
        try {
            def fmJson = new JsonSlurper().parseText(fieldMappingsStr)
            (fmJson._embedded?.fieldMappings ?: []).each { m -&gt;
                def attr = m.columnAttribute?.attributeName
                def alias = m.aliasName
                if (attr &amp;&amp; alias) fmMap[attr] = alias
            }
        } catch (Exception e) { log.warn(&quot;FM parse error: &quot; + e.message) }
    }

    def dependentFieldsSet = [] as Set
    allFields.each { field -&gt;
        (field.dependentControls ?: []).each { dep -&gt;
            if (dep.formControlName) dependentFieldsSet.add(dep.formControlName)
        }
    }

    allFields.each { field -&gt;
        def fieldName = field.dataMapping ?: field.formControlName
        def fieldType = field.formControlType ?: &quot;&quot;
        def fieldLabel = (field.fieldLabel ?: fieldName).toLowerCase()
        def isHidden = field.hide ?: false
        def isDisabled = field.disabled ?: false
        def isMultiple = field.isMultiple ?: false
        def lookupName = field.lookupName
        def aliasName = fmMap[fieldName] ?: &quot;&quot;
        def aliasLower = aliasName.toLowerCase()
        def validators = field.validators ?: []

        if (isHidden &amp;&amp; !dependentFieldsSet.contains(fieldName)) return
        if (isDisabled) return
        if (fieldType == &quot;RESOURCE&quot; || fieldName == &quot;participant&quot;) return

        def value = null

        switch(fieldType) {
            case &quot;SELECT&quot;:
                if (lookupName) {
                    def words = lookupName.toLowerCase().split(&apos;_&apos;)
                    def camelCase = words[0] + words.drop(1).collect { it.capitalize() }.join(&apos;&apos;)
                    def count = vars.get(camelCase + &quot;_count&quot;)?.toInteger() ?: 0
                    if (count &gt; 0) {
                        if (isMultiple) {
                            def maxP = Math.min(count, maxSel)
                            def minP = Math.min(minSel, maxP)
                            def selCount = minP + rand.nextInt((maxP - minP) + 1)
                            def indices = (1..count).toList()
                            Collections.shuffle(indices)
                            value = indices.take(selCount).collect { vars.get(camelCase + &quot;_&quot; + it) }.findAll { it }
                        } else {
                            value = vars.get(camelCase + &quot;_&quot; + (rand.nextInt(count) + 1))
                        }
                    }
                }
                break

            case &quot;TEXT&quot;:
                def isEmailField = validators.any { it.toString().contains(&quot;EMAIL&quot;) }
                def hasDomainEmail = validators.find { it.toString().startsWith(&quot;DOMAIN_EMAIL:&quot;) }

                if (isEmailField &amp;&amp; hasDomainEmail &amp;&amp; (fieldLabel.contains(&quot;additional&quot;) || isMultiple)) {
                    def attendeeEmailsStr = vars.get(&quot;externalAttendeeEmails&quot;) ?: &quot;&quot;
                    if (attendeeEmailsStr) {
                        def emailList = attendeeEmailsStr.split(&quot;,&quot;).collect { it.trim() }.findAll { it }
                        value = isMultiple ? emailList : emailList[0]
                    } else {
                        def domain = hasDomainEmail.toString().split(&quot;:&quot;)[1]?.trim() ?: null
                        if (!domain) {
                            def emailDomainsUdv = vars.get(&quot;emailDomains&quot;)?.trim()
                            if (emailDomainsUdv) {
                                def domainOptions = emailDomainsUdv.split(&quot;,&quot;).collect { it.trim() }.findAll { it }
                                domain = domainOptions.size() &gt; 0 ? domainOptions[rand.nextInt(domainOptions.size())] : &quot;gmail.com&quot;
                            } else {
                                domain = &quot;gmail.com&quot;
                            }
                        }
                        value = &quot;${presenterFirstName}@${domain}&quot;
                        if (isMultiple) value = [value]
                    }
                } else if (isEmailField || fieldLabel.contains(&quot;email&quot;) || aliasLower.contains(&quot;email&quot;)) {
                    value = presenterEmail
                } else if (fieldLabel.contains(&quot;designation&quot;) || fieldLabel.contains(&quot;title&quot;) || aliasLower.contains(&quot;designation&quot;) || aliasLower.contains(&quot;title&quot;)) {
                    value = presenterDesignation
                } else if (fieldLabel.contains(&quot;first name&quot;) || aliasLower.contains(&quot;firstname&quot;)) {
                    value = presenterName.split(&quot; &quot;)[0]?.trim()
                } else if (fieldLabel.contains(&quot;last name&quot;) || aliasLower.contains(&quot;lastname&quot;)) {
                    def parts = presenterName.split(&quot; &quot;)
                    value = parts.size() &gt; 1 ? parts[-1]?.trim() : &quot;&quot;
                } else if (fieldLabel.contains(&quot;name&quot;) || aliasLower.contains(&quot;name&quot;)) {
                    value = presenterName
                }
                break
            case &quot;TEXTAREA&quot;:
                value = &quot;Presenter: ${presenterName}&quot;
                break
            case &quot;CHECKBOX&quot;:
                value = rand.nextBoolean()
                break
        }

        if (value != null &amp;&amp; value.toString().trim() != &quot;&quot;) {
            if (fieldType == &quot;CHECKBOX&quot;) {
                formData[fieldName] = (value instanceof String) ? value.toLowerCase() == &quot;true&quot; : value
            } else if (isMultiple &amp;&amp; !(value instanceof List)) {
                formData[fieldName] = [value]
            } else {
                formData[fieldName] = value
            }
        } else if (isMultiple) {
            formData[fieldName] = []
        }
    }
}

def payload = [
    moduleId : moduleId,
    formId   : presenterFormId,
    journeyId: journeyId,
    pageId   : pageId,
    data     : formData
]

vars.put(&quot;presenterPayload&quot;, JsonOutput.prettyPrint(JsonOutput.toJson(payload)))
log.info(&quot;Presenter: ${presenterName} (${presenterId}) | Fields: ${formData.keySet()}&quot;)</stringProp>
                                          </JSR223PreProcessor>
