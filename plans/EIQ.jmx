              <hashTree/>
              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract All Presenter Resources" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput

def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)
def resources = json?._embedded?.resources ?: []

if (resources.isEmpty()) {
    vars.put(&quot;presenterExists&quot;, &quot;false&quot;)
    return
}

def presentersList = []
resources.each { r -&gt;
    def email = r.data?.primaryEmail ?: r.data?.textField4 ?: &quot;&quot;
    
    // Only include allianceit.com emails
    if (!email.toLowerCase().endsWith(&quot;@allianceit.com&quot;)) {
        return  // skip this presenter
    }
    
    def id = r.uniqueId
    def name = r.metaData?.searchDisplayText ?:
               (r.data?.firstName + &quot; &quot; + r.data?.lastName)
    def designation = r.data?.designation ?: r.data?.textField5 ?: &quot;&quot;
    presentersList.add([id:id, name:name, email:email, designation:designation])
}

log.info(&quot;Filtered presenters (allianceit.com only): ${presentersList.size()} of ${resources.size()}&quot;)

// Handle case where no presenters match the filter
if (presentersList.isEmpty()) {
    log.warn(&quot;No presenters found with @allianceit.com email&quot;)
    vars.put(&quot;presenterExists&quot;, &quot;false&quot;)
    return
}

// read presenters variable from UDV
def presenterVar = vars.get(&quot;presenters&quot;) ?: &quot;&quot;
if (presenterVar.trim().isEmpty() || presenterVar == &quot;0&quot;) {
    vars.put(&quot;presenterExists&quot;, &quot;false&quot;)
    return
}

def presenterCount
if (presenterVar.contains(&quot;,&quot;)) {
    def parts = presenterVar.split(&quot;,&quot;)*.trim()*.toInteger()
    def min = parts[0]
    def max = parts[1]
    presenterCount = new Random().nextInt(max - min + 1) + min
} else {
    presenterCount = presenterVar.toInteger()
}

// shuffle presenters for randomness
Collections.shuffle(presentersList)
def selected = presentersList.take(Math.min(presenterCount, presentersList.size()))

// build payload
def payload = JsonOutput.toJson([
    uniqueIds: selected.collect { it.id }
])

vars.put(&quot;presenterPayload&quot;, payload)
vars.put(&quot;presenterExists&quot;, &quot;true&quot;)

if (!selected.isEmpty()) {
}

// clean log output
selected.eachWithIndex { p, i -&gt;
    def idx = i + 1
    vars.put(&quot;selectedPresenterId_&quot; + idx, p.id)
