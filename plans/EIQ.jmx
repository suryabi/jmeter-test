                            <stringProp name="script">// Dummy sampler to ensure ForEach iterates through all activity types
// Even when activity type is skipped, this sampler runs so ForEach continues
SampleResult.setIgnore()
def activityType = vars.get(&quot;activityType&quot;) ?: &quot;unknown&quot;
def skip = vars.get(&quot;skipActivityModule&quot;) == &quot;true&quot;
SampleResult.setResponseMessage(activityType + (skip ? &quot; [SKIP]&quot; : &quot;&quot;))
</stringProp>
