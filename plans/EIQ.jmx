        <hashTree/>
        <ForeachController guiclass="ForeachControlPanel" testclass="ForeachController" testname="ForEach (User)" enabled="true">
          <stringProp name="ForeachController.inputVal">user</stringProp>
          <stringProp name="ForeachController.returnVal">currentUser</stringProp>
          <boolProp name="ForeachController.useSeparator">true</boolProp>
        </ForeachController>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="👤 User - ${currentUser}" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Read current user - use vars.get directly to ensure fresh value from ForEach
def currentUser = vars.get(&quot;currentUser&quot;)
def firstUser = vars.get(&quot;user_1&quot;)
def userCount = vars.get(&quot;userCount&quot;) ?: &quot;1&quot;

// Find user index by matching against stored user_1, user_2, etc.
def userIndex = 0
for (int i = 1; i &lt;= userCount.toInteger(); i++) {
    def storedUser = vars.get(&quot;user_&quot; + i)
    if (storedUser == currentUser) {
        userIndex = i
        break
    }
}

// Safety fallback
if (userIndex == 0) {
    log.error(&quot;Current user &apos;&quot; + currentUser + &quot;&apos; not found in user list! Defaulting to index 1&quot;)
    userIndex = 1
}

// Determine if this is the first user by comparing identity
def isFirstUser = (currentUser == firstUser) ? &quot;true&quot; : &quot;false&quot;
vars.put(&quot;isFirstUser&quot;, isFirstUser)

log.info(&quot;User: &quot; + currentUser)

// For subsequent users - set flags to reuse existing request
if (isFirstUser != &quot;true&quot;) {
    def existingRequestId = vars.get(&quot;requestId&quot;)
    if (existingRequestId != null &amp;&amp; !existingRequestId.trim().isEmpty()) {
    } else {
        log.error(&quot;SUBSEQUENT USER but no requestId found from previous user!&quot;)
    }
}

def originalLabel = SampleResult.getSampleLabel()
SampleResult.setSampleLabel(&quot;───── &quot; + originalLabel + &quot; (&quot; + userIndex + &quot;/&quot; + userCount + &quot;) ─────&quot;)

SampleResult.setResponseData(&quot;User &quot; + userIndex + &quot;: &quot; + vars.get(&quot;currentUser&quot;) + &quot; | isFirstUser: &quot; + isFirstUser, &quot;UTF-8&quot;)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)
</stringProp>
          </JSR223Sampler>
          <hashTree/>
          <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ If (No Existing Event - Calculate Event)" enabled="true">
            <stringProp name="IfController.condition">${__groovy(vars.get(&quot;existingEventId&quot;) == null || vars.get(&quot;existingEventId&quot;).trim().isEmpty())}</stringProp>
            <boolProp name="IfController.evaluateAll">false</boolProp>
            <boolProp name="IfController.useExpression">true</boolProp>
          </IfController>
          <hashTree>
            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Calculate Event" enabled="false">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import java.time.*
import java.time.format.DateTimeFormatter

def dateFormatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;)

// ===== VALIDATION: Check required UDV variables =====
def errors = []
def eventStartDate = vars.get(&quot;eventStartDate&quot;)?.trim()
def eventEndDate   = vars.get(&quot;eventEndDate&quot;)?.trim()
def eventStartTimes = vars.get(&quot;eventStartTimes&quot;)?.trim()
def eventDurations  = vars.get(&quot;eventDurations&quot;)?.trim()

// Check empty/missing — required fields
if (!eventStartDate)  errors.add(&quot;eventStartDate is empty — set a value in UDV (format: yyyy-MM-dd, e.g. 2026-01-15)&quot;)
if (!eventEndDate)    errors.add(&quot;eventEndDate is empty — set a value in UDV (format: yyyy-MM-dd, e.g. 2026-01-20)&quot;)
if (!eventStartTimes) errors.add(&quot;eventStartTimes is empty — set a value in UDV (format: HH:mm comma-separated, e.g. 07:00,08:00,09:00)&quot;)
if (!eventDurations)  errors.add(&quot;eventDurations is empty — set a value in UDV (in minutes comma-separated, e.g. 420,480,540,600)&quot;)

// Check categoryType, parentCategory, category, defaultUser — required
def categoryType    = vars.get(&quot;categoryType&quot;)?.trim()
def parentCategory  = vars.get(&quot;parentCategory&quot;)?.trim()
def category        = vars.get(&quot;category&quot;)?.trim()
def defaultUser     = vars.get(&quot;defaultUser&quot;)?.trim()

if (!categoryType)   errors.add(&quot;categoryType is empty — set a value in UDV (e.g. CATEGORY_TYPE_EVENTS)&quot;)
if (!parentCategory) errors.add(&quot;parentCategory is empty — set a value in UDV (UUID, e.g. CATEGORY_EVENTS)&quot;)
if (!category)       errors.add(&quot;category is empty — set a value in UDV (UUID, e.g. 798B5757-WERD-42C9-A4BE-F92A9D0DD070)&quot;)
if (!defaultUser)    errors.add(&quot;defaultUser is empty — set a value in UDV (e.g. supportuser@allianceit.com)&quot;)

// Check date format (yyyy-MM-dd)
if (eventStartDate &amp;&amp; !(eventStartDate ==~ /^\d{4}-\d{2}-\d{2}$/)) {
    errors.add(&quot;eventStartDate has invalid format: &apos;${eventStartDate}&apos; (expected: yyyy-MM-dd, e.g. 2026-08-04)&quot;)
} else if (eventStartDate) {
    try { LocalDate.parse(eventStartDate, dateFormatter) } catch (Exception e) {
        errors.add(&quot;eventStartDate is not a valid date: &apos;${eventStartDate}&apos; (${e.message})&quot;)
    }
}

if (eventEndDate &amp;&amp; !(eventEndDate ==~ /^\d{4}-\d{2}-\d{2}$/)) {
    errors.add(&quot;eventEndDate has invalid format: &apos;${eventEndDate}&apos; (expected: yyyy-MM-dd, e.g. 2026-08-31)&quot;)
} else if (eventEndDate) {
    try { LocalDate.parse(eventEndDate, dateFormatter) } catch (Exception e) {
        errors.add(&quot;eventEndDate is not a valid date: &apos;${eventEndDate}&apos; (${e.message})&quot;)
    }
}

// Check eventStartTimes format (HH:mm, comma-separated)
if (eventStartTimes) {
    def timeFormatter = java.time.format.DateTimeFormatter.ofPattern(&quot;HH:mm&quot;)
    def rawTimes = eventStartTimes.split(&quot;,&quot;).collect { it.trim() }
    def invalidTimes = []
    def validTimes = []
    rawTimes.each { t -&gt;
        if (!(t ==~ /^\d{2}:\d{2}$/)) {
            invalidTimes.add(t)
        } else {
            try {
                java.time.LocalTime.parse(t, timeFormatter)
                validTimes.add(t)
            } catch (Exception e) {
                invalidTimes.add(t)
            }
        }
    }
    if (validTimes.isEmpty()) {
        errors.add(&quot;eventStartTimes has no valid times: &apos;${eventStartTimes}&apos; (expected: HH:mm, e.g. 07:00,08:00,09:00)&quot;)
    } else if (!invalidTimes.isEmpty()) {
        errors.add(&quot;eventStartTimes has invalid entries that will be skipped: ${invalidTimes} (expected: HH:mm, e.g. 07:00)&quot;)
    }
}

// Check eventDurations format (positive integers &gt;= 30 minutes, comma-separated)
if (eventDurations) {
    def rawDurations = eventDurations.split(&quot;,&quot;).collect { it.trim() }
    def invalidDurations = []
    def validDurations = []
    rawDurations.each { d -&gt;
        if (d.isInteger() &amp;&amp; d.toInteger() &gt;= 300) {
            validDurations.add(d)
        } else {
            invalidDurations.add(d)
        }
    }
    if (validDurations.isEmpty()) {
        errors.add(&quot;eventDurations has no valid values: &apos;${eventDurations}&apos; (expected: integers &gt;= 300 minutes, e.g. 420,480,540,600)&quot;)
    } else if (!invalidDurations.isEmpty()) {
        errors.add(&quot;eventDurations has invalid entries that will be skipped: ${invalidDurations} (must be &gt;= 30 minutes)&quot;)
    }
}

// Check eventDays format (positive integers, comma-separated) — if empty defaults to 1
def eventDaysStr = vars.get(&quot;eventDays&quot;)?.trim()
if (eventDaysStr) {
    def rawDays = eventDaysStr.split(&quot;,&quot;).collect { it.trim() }
    def invalidDays = rawDays.findAll { !it.isInteger() || it.toInteger() &lt;= 0 }
    if (!invalidDays.isEmpty()) {
        errors.add(&quot;eventDays has invalid entries: ${invalidDays} in &apos;${eventDaysStr}&apos; (expected: positive integers, e.g. 1,2,3)&quot;)
    }
}

// Check eventsPerDay format (positive integers, comma-separated) — if empty defaults to 1
def eventsPerDayRaw = vars.get(&quot;eventsPerDay&quot;)?.trim()
if (eventsPerDayRaw) {
    def rawEpd = eventsPerDayRaw.split(&quot;,&quot;).collect { it.trim() }
    def invalidEpd = rawEpd.findAll { !it.isInteger() || it.toInteger() &lt;= 0 }
    if (!invalidEpd.isEmpty()) {
        errors.add(&quot;eventsPerDay has invalid entries: ${invalidEpd} in &apos;${eventsPerDayRaw}&apos; (expected: positive integers, e.g. 1,2,3)&quot;)
    }
}

// ===== Validate optional numeric comma-separated UDVs =====
// empty = skip silently | solo 0 = skip silently | negative or 0 mixed in list = ABORT | non-integer = ABORT
def validateIntList = { String varName, String description -&gt;
    def raw = vars.get(varName)?.trim()
    if (!raw || raw == &quot;0&quot;) return  // empty or solo 0 = skip, no error
    def entries = raw.split(&quot;,&quot;).collect { it.trim() }
    def invalid = entries.findAll { !it.isInteger() || it.toInteger() &lt;= 0 }
    if (!invalid.isEmpty()) {
        errors.add(&quot;${varName} has invalid entries: ${invalid} in &apos;${raw}&apos; (expected: ${description}). Use empty or 0 to skip, or positive integers only e.g. 2,3&quot;)
    }
}

def validateTimeList = { String varName, String description -&gt;
    def raw = vars.get(varName)?.trim()
    if (raw) {
        def entries = raw.split(&quot;,&quot;).collect { it.trim() }
        def timeFormatter = java.time.format.DateTimeFormatter.ofPattern(&quot;HH:mm&quot;)
        def invalid = entries.findAll { t -&gt;
            if (!(t ==~ /^\d{2}:\d{2}$/)) return true
            try { java.time.LocalTime.parse(t, timeFormatter); return false } catch (Exception e) { return true }
        }
        if (!invalid.isEmpty()) {
            errors.add(&quot;${varName} has invalid entries: ${invalid} in &apos;${raw}&apos; (expected: ${description})&quot;)
        }
    }
}

def validatePercentage = { String varName -&gt;
    def raw = vars.get(varName)?.trim()
    if (raw) {
        def cleaned = raw.endsWith(&quot;%&quot;) ? raw[0..-2] : raw
        if (!cleaned.isInteger() || cleaned.toInteger() &lt; 0 || cleaned.toInteger() &gt; 100) {
            errors.add(&quot;${varName} has invalid value: &apos;${raw}&apos; (expected: percentage, e.g. 80%)&quot;)
        }
    }
}

validateIntList(&quot;rooms&quot;,               &quot;positive integers, e.g. 1,2,3&quot;)
validateIntList(&quot;presenters&quot;,          &quot;positive integers, e.g. 3,5&quot;)
validateIntList(&quot;vacantSlotDurations&quot;, &quot;positive integers in minutes, e.g. 30,60&quot;)
validateIntList(&quot;stateActionIterations&quot;,&quot;positive integers, e.g. 2,3&quot;)
validatePercentage(&quot;customersPerRoom&quot;)

if (errors.size() &gt; 0) {
    def errorMsg = &quot;ABORTING: UDV validation failed:\n&quot; + errors.collect { &quot;  ✗ ${it}&quot; }.join(&quot;\n&quot;)
    log.error(&quot;========================================&quot;)
    errors.each { log.error(&quot;✗ ${it}&quot;) }
    log.error(&quot;Please fix these variables in User Defined Variables before running the test.&quot;)
    log.error(&quot;========================================&quot;)
    vars.put(&quot;totalEventCount&quot;, &quot;0&quot;)
    vars.put(&quot;totalValidDays&quot;, &quot;0&quot;)
    vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
    vars.put(&quot;_abortReason&quot;, errorMsg)
    SampleResult.setResponseData(errorMsg, &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;400&quot;)
    SampleResult.setSuccessful(false)
    ctx.getEngine().stopTestNow()
    return
}

// ===== Validation passed =====
boolean allowWeekends = vars.get(&quot;allowWeekends&quot;)?.equalsIgnoreCase(&quot;true&quot;) ?: false

// ===== Read eventsPerDay (default: 1, supports comma-separated e.g. 1,2,3) =====
int eventsPerDay = 1
try {
    if (eventsPerDayRaw) {
        def options = eventsPerDayRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() }
        if (options.size() &gt; 0) {
            def rand = new Random()
            eventsPerDay = options[rand.nextInt(options.size())]
        }
    }
} catch (Exception e) {
    log.warn(&quot;Invalid eventsPerDay: ${eventsPerDayRaw}, using default 1&quot;)
}

// ===== Read date range (already validated above) =====
LocalDate startDate = LocalDate.parse(eventStartDate, dateFormatter)
LocalDate endDate   = LocalDate.parse(eventEndDate, dateFormatter)

if (endDate.isBefore(startDate)) {
    def errorMsg = &quot;ABORTING: UDV validation failed:\n  ✗ eventEndDate (${eventEndDate}) is before eventStartDate (${eventStartDate}) — end date must be same as or after start date&quot;
    log.error(&quot;========================================&quot;)
    log.error(&quot;✗ eventEndDate (${eventEndDate}) is before eventStartDate (${eventStartDate}) — end date must be same as or after start date&quot;)
    log.error(&quot;Please fix these variables in User Defined Variables before running the test.&quot;)
    log.error(&quot;========================================&quot;)
    vars.put(&quot;totalEventCount&quot;, &quot;0&quot;)
    vars.put(&quot;totalValidDays&quot;, &quot;0&quot;)
    vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
    vars.put(&quot;_abortReason&quot;, errorMsg)
    SampleResult.setResponseData(errorMsg, &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;400&quot;)
    SampleResult.setResponseMessage(&quot;End date is before start date&quot;)
    SampleResult.setSuccessful(false)
    ctx.getEngine().stopTestNow()
    return
}

// ===== Collect valid days (skip weekends if not allowed) =====
def validDates = []
def skippedWeekends = []
LocalDate current = startDate
while (!current.isAfter(endDate)) {
    if (allowWeekends || !(current.dayOfWeek in [DayOfWeek.SATURDAY, DayOfWeek.SUNDAY])) {
        validDates.add(current)
    } else {
        skippedWeekends.add(current)
    }
    current = current.plusDays(1)
}

// ===== Store valid dates for sequential access =====
int totalDays = validDates.size()
int totalEventCount = totalDays * eventsPerDay

validDates.eachWithIndex { date, idx -&gt;
    vars.put(&quot;validDate_&quot; + (idx + 1), date.format(dateFormatter))
}

vars.put(&quot;totalValidDays&quot;,  totalDays.toString())
vars.put(&quot;eventsPerDay&quot;,    eventsPerDay.toString())
vars.put(&quot;totalEventCount&quot;, totalEventCount.toString())

// ===== Build summary =====
def sb = new StringBuilder()
sb.append(&quot;========================================\n&quot;)
sb.append(&quot;EVENT CALCULATION SUMMARY\n&quot;)
sb.append(&quot;========================================\n&quot;)
sb.append(&quot;Date Range      : ${startDate} to ${endDate}\n&quot;)
sb.append(&quot;Allow Weekends  : ${allowWeekends}\n&quot;)
sb.append(&quot;Events/Day      : ${eventsPerDay}\n&quot;)
sb.append(&quot;========================================\n&quot;)

if (totalEventCount == 0) {
    sb.append(&quot;\n⚠️ WARNING: No valid dates found!\n&quot;)
    sb.append(&quot;All dates in the range fall on weekends and allowWeekends is set to false.\n&quot;)
    if (!skippedWeekends.isEmpty()) {
        sb.append(&quot;Skipped weekend dates:\n&quot;)
        skippedWeekends.each { sb.append(&quot;  ❌ ${it} (${it.dayOfWeek})\n&quot;) }
    }
    sb.append(&quot;\nPlease change the date range or set allowWeekends=true in UDV.\n&quot;)

    log.error(&quot;========================================&quot;)
    log.error(&quot;No valid dates found — all dates are weekends and allowWeekends=false&quot;)
    log.error(&quot;Date Range: ${startDate} to ${endDate}&quot;)
    skippedWeekends.each { log.error(&quot;  ❌ ${it} (${it.dayOfWeek}) - SKIPPED (weekend)&quot;) }
    log.error(&quot;========================================&quot;)

    SampleResult.setResponseData(sb.toString(), &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;400&quot;)
    SampleResult.setResponseMessage(&quot;No valid dates - all dates are weekends&quot;)
    SampleResult.setSuccessful(false)
    vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
    vars.put(&quot;_abortReason&quot;, &quot;No valid dates - all dates in range are weekends and allowWeekends=false&quot;)
    ctx.getEngine().stopTestNow()
} else {
    validDates.each { sb.append(&quot;  ✅ ${it} (${it.dayOfWeek})\n&quot;) }
    if (!skippedWeekends.isEmpty()) {
        sb.append(&quot;\nSkipped weekend dates:\n&quot;)
        skippedWeekends.each { sb.append(&quot;  ❌ ${it} (${it.dayOfWeek})\n&quot;) }
    }
    sb.append(&quot;\n✅ ${totalEventCount} event(s) will be created across ${totalDays} valid day(s).\n&quot;)


    SampleResult.setResponseData(sb.toString(), &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;200&quot;)
    SampleResult.setResponseMessage(&quot;${totalEventCount} events planned&quot;)
    SampleResult.setSuccessful(true)
}
</stringProp>
            </JSR223Sampler>
            <hashTree/>
            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Calculate Event" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import java.time.*
import java.time.format.DateTimeFormatter

def dateFormatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;)

// ===== VALIDATION: Check required UDV variables =====
def errors = []
def eventStartDate = vars.get(&quot;eventStartDate&quot;)?.trim()
def eventEndDate   = vars.get(&quot;eventEndDate&quot;)?.trim()
def eventStartTimes = vars.get(&quot;eventStartTimes&quot;)?.trim()
def eventDurations  = vars.get(&quot;eventDurations&quot;)?.trim()

// Check empty/missing — required fields
if (!eventStartDate)  errors.add(&quot;eventStartDate is empty — set a value in UDV (format: yyyy-MM-dd, e.g. 2026-01-15)&quot;)
if (!eventEndDate)    errors.add(&quot;eventEndDate is empty — set a value in UDV (format: yyyy-MM-dd, e.g. 2026-01-20)&quot;)
if (!eventStartTimes) errors.add(&quot;eventStartTimes is empty — set a value in UDV (format: HH:mm comma-separated, e.g. 07:00,08:00,09:00)&quot;)
if (!eventDurations)  errors.add(&quot;eventDurations is empty — set a value in UDV (in minutes comma-separated, e.g. 420,480,540,600)&quot;)

// Check categoryType, parentCategory, category, defaultUser — required
def categoryType    = vars.get(&quot;categoryType&quot;)?.trim()
def parentCategory  = vars.get(&quot;parentCategory&quot;)?.trim()
def category        = vars.get(&quot;category&quot;)?.trim()
def defaultUser     = vars.get(&quot;defaultUser&quot;)?.trim()

if (!categoryType)   errors.add(&quot;categoryType is empty — set a value in UDV (e.g. CATEGORY_TYPE_EVENTS)&quot;)
if (!parentCategory) errors.add(&quot;parentCategory is empty — set a value in UDV (UUID, e.g. CATEGORY_EVENTS)&quot;)
if (!category)       errors.add(&quot;category is empty — set a value in UDV (UUID, e.g. 798B5757-WERD-42C9-A4BE-F92A9D0DD070)&quot;)
if (!defaultUser)    errors.add(&quot;defaultUser is empty — set a value in UDV (e.g. supportuser@allianceit.com)&quot;)

// Check date format (yyyy-MM-dd)
if (eventStartDate &amp;&amp; !(eventStartDate ==~ /^\d{4}-\d{2}-\d{2}$/)) {
    errors.add(&quot;eventStartDate has invalid format: &apos;${eventStartDate}&apos; (expected: yyyy-MM-dd, e.g. 2026-08-04)&quot;)
} else if (eventStartDate) {
    try { LocalDate.parse(eventStartDate, dateFormatter) } catch (Exception e) {
        errors.add(&quot;eventStartDate is not a valid date: &apos;${eventStartDate}&apos; (${e.message})&quot;)
    }
}

if (eventEndDate &amp;&amp; !(eventEndDate ==~ /^\d{4}-\d{2}-\d{2}$/)) {
    errors.add(&quot;eventEndDate has invalid format: &apos;${eventEndDate}&apos; (expected: yyyy-MM-dd, e.g. 2026-08-31)&quot;)
} else if (eventEndDate) {
    try { LocalDate.parse(eventEndDate, dateFormatter) } catch (Exception e) {
        errors.add(&quot;eventEndDate is not a valid date: &apos;${eventEndDate}&apos; (${e.message})&quot;)
    }
}

// Check eventStartTimes format (HH:mm, comma-separated)
if (eventStartTimes) {
    def timeFormatter = java.time.format.DateTimeFormatter.ofPattern(&quot;HH:mm&quot;)
    def rawTimes = eventStartTimes.split(&quot;,&quot;).collect { it.trim() }
    def invalidTimes = []
    def validTimes = []
    rawTimes.each { t -&gt;
        if (!(t ==~ /^\d{2}:\d{2}$/)) {
            invalidTimes.add(t)
        } else {
            try {
                java.time.LocalTime.parse(t, timeFormatter)
                validTimes.add(t)
            } catch (Exception e) {
                invalidTimes.add(t)
            }
        }
    }
    if (validTimes.isEmpty()) {
        errors.add(&quot;eventStartTimes has no valid times: &apos;${eventStartTimes}&apos; (expected: HH:mm, e.g. 07:00,08:00,09:00)&quot;)
    } else if (!invalidTimes.isEmpty()) {
        errors.add(&quot;eventStartTimes has invalid entries that will be skipped: ${invalidTimes} (expected: HH:mm, e.g. 07:00)&quot;)
    }
}

// Check eventDurations format (positive integers &gt;= 30 minutes, comma-separated)
if (eventDurations) {
    def rawDurations = eventDurations.split(&quot;,&quot;).collect { it.trim() }
    def invalidDurations = []
    def validDurations = []
    rawDurations.each { d -&gt;
        if (d.isInteger() &amp;&amp; d.toInteger() &gt;= 300) {
            validDurations.add(d)
        } else {
            invalidDurations.add(d)
        }
    }
    if (validDurations.isEmpty()) {
        errors.add(&quot;eventDurations has no valid values: &apos;${eventDurations}&apos; (expected: integers &gt;= 300 minutes, e.g. 420,480,540,600)&quot;)
    } else if (!invalidDurations.isEmpty()) {
        errors.add(&quot;eventDurations has invalid entries that will be skipped: ${invalidDurations} (must be &gt;= 30 minutes)&quot;)
    }
}

// Check eventDays format (positive integers, comma-separated) — if empty defaults to 1
def eventDaysStr = vars.get(&quot;eventDays&quot;)?.trim()
if (eventDaysStr) {
    def rawDays = eventDaysStr.split(&quot;,&quot;).collect { it.trim() }
    def invalidDays = rawDays.findAll { !it.isInteger() || it.toInteger() &lt;= 0 }
    if (!invalidDays.isEmpty()) {
        errors.add(&quot;eventDays has invalid entries: ${invalidDays} in &apos;${eventDaysStr}&apos; (expected: positive integers, e.g. 1,2,3)&quot;)
    }
}

// Check eventsPerDay format (positive integers, comma-separated) — if empty defaults to 1
def eventsPerDayRaw = vars.get(&quot;eventsPerDay&quot;)?.trim()
if (eventsPerDayRaw) {
    def rawEpd = eventsPerDayRaw.split(&quot;,&quot;).collect { it.trim() }
    def invalidEpd = rawEpd.findAll { !it.isInteger() || it.toInteger() &lt;= 0 }
    if (!invalidEpd.isEmpty()) {
        errors.add(&quot;eventsPerDay has invalid entries: ${invalidEpd} in &apos;${eventsPerDayRaw}&apos; (expected: positive integers, e.g. 1,2,3)&quot;)
    }
}

// ===== Validate optional numeric comma-separated UDVs =====
// empty = skip silently | solo 0 = skip silently | negative or 0 mixed in list = ABORT | non-integer = ABORT
def validateIntList = { String varName, String description -&gt;
    def raw = vars.get(varName)?.trim()
    if (!raw || raw == &quot;0&quot;) return  // empty or solo 0 = skip, no error
    def entries = raw.split(&quot;,&quot;).collect { it.trim() }
    def invalid = entries.findAll { !it.isInteger() || it.toInteger() &lt;= 0 }
    if (!invalid.isEmpty()) {
        errors.add(&quot;${varName} has invalid entries: ${invalid} in &apos;${raw}&apos; (expected: ${description}). Use empty or 0 to skip, or positive integers only e.g. 2,3&quot;)
    }
}

def validateTimeList = { String varName, String description -&gt;
    def raw = vars.get(varName)?.trim()
    if (raw) {
        def entries = raw.split(&quot;,&quot;).collect { it.trim() }
        def timeFormatter = java.time.format.DateTimeFormatter.ofPattern(&quot;HH:mm&quot;)
        def invalid = entries.findAll { t -&gt;
            if (!(t ==~ /^\d{2}:\d{2}$/)) return true
            try { java.time.LocalTime.parse(t, timeFormatter); return false } catch (Exception e) { return true }
        }
        if (!invalid.isEmpty()) {
            errors.add(&quot;${varName} has invalid entries: ${invalid} in &apos;${raw}&apos; (expected: ${description})&quot;)
        }
    }
}

def validatePercentage = { String varName -&gt;
    def raw = vars.get(varName)?.trim()
    if (raw &amp;&amp; raw != &quot;0&quot; &amp;&amp; raw != &quot;0%&quot;) {
        def stripped = raw.replace(&quot;%&quot;, &quot;&quot;).trim()
        if (stripped.contains(&quot;-&quot;)) {
            // Range format: e.g. &quot;20-50&quot; or &quot;20%-50%&quot;
            def parts = stripped.split(&quot;-&quot;)
            if (parts.size() != 2 || !parts[0].trim() || !parts[1].trim()
                || !parts[0].trim().isInteger() || !parts[1].trim().isInteger()) {
                errors.add(&quot;${varName} has invalid range: &apos;${raw}&apos; (expected: e.g. 50%-70% or 50%)&quot;)
            } else {
                def min = parts[0].trim().toInteger()
                def max = parts[1].trim().toInteger()
                if (min &lt; 0 || max &gt; 100 || min &gt; max) {
                    errors.add(&quot;${varName} range &apos;${raw}&apos; is invalid (min must be &gt;= 0, max must be &lt;= 100, min must be &lt;= max)&quot;)
                }
            }
        } else {
            // Single value: e.g. &quot;80&quot; or &quot;80%&quot;
            if (!stripped.isInteger() || stripped.toInteger() &lt; 0 || stripped.toInteger() &gt; 100) {
                errors.add(&quot;${varName} has invalid value: &apos;${raw}&apos; (expected: percentage e.g. 80% or range e.g. 20%-50%)&quot;)
            }
        }
    }
}

validateIntList(&quot;rooms&quot;,               &quot;positive integers, e.g. 1,2,3&quot;)
validateIntList(&quot;presenters&quot;,          &quot;positive integers, e.g. 3,5&quot;)
validateIntList(&quot;vacantSlotDurations&quot;, &quot;positive integers in minutes, e.g. 30,60&quot;)
validateIntList(&quot;stateActionIterations&quot;,&quot;positive integers, e.g. 2,3&quot;)
validatePercentage(&quot;customersPerRoom&quot;)

if (errors.size() &gt; 0) {
    def errorMsg = &quot;ABORTING: UDV validation failed:\n&quot; + errors.collect { &quot;  ✗ ${it}&quot; }.join(&quot;\n&quot;)
    log.error(&quot;========================================&quot;)
    errors.each { log.error(&quot;✗ ${it}&quot;) }
    log.error(&quot;Please fix these variables in User Defined Variables before running the test.&quot;)
    log.error(&quot;========================================&quot;)
    vars.put(&quot;totalEventCount&quot;, &quot;0&quot;)
    vars.put(&quot;totalValidDays&quot;, &quot;0&quot;)
    vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
    vars.put(&quot;_abortReason&quot;, errorMsg)
    SampleResult.setResponseData(errorMsg, &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;400&quot;)
    SampleResult.setSuccessful(false)
    ctx.getEngine().stopTestNow()
    return
}

// ===== Validation passed =====
boolean allowWeekends = vars.get(&quot;allowWeekends&quot;)?.equalsIgnoreCase(&quot;true&quot;) ?: false

// ===== Read eventsPerDay (default: 1, supports comma-separated e.g. 1,2,3) =====
int eventsPerDay = 1
try {
    if (eventsPerDayRaw) {
        def options = eventsPerDayRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() }
        if (options.size() &gt; 0) {
            def rand = new Random()
            eventsPerDay = options[rand.nextInt(options.size())]
        }
    }
} catch (Exception e) {
    log.warn(&quot;Invalid eventsPerDay: ${eventsPerDayRaw}, using default 1&quot;)
}

// ===== Read date range (already validated above) =====
LocalDate startDate = LocalDate.parse(eventStartDate, dateFormatter)
LocalDate endDate   = LocalDate.parse(eventEndDate, dateFormatter)

if (endDate.isBefore(startDate)) {
    def errorMsg = &quot;ABORTING: UDV validation failed:\n  ✗ eventEndDate (${eventEndDate}) is before eventStartDate (${eventStartDate}) — end date must be same as or after start date&quot;
    log.error(&quot;========================================&quot;)
    log.error(&quot;✗ eventEndDate (${eventEndDate}) is before eventStartDate (${eventStartDate}) — end date must be same as or after start date&quot;)
    log.error(&quot;Please fix these variables in User Defined Variables before running the test.&quot;)
    log.error(&quot;========================================&quot;)
    vars.put(&quot;totalEventCount&quot;, &quot;0&quot;)
    vars.put(&quot;totalValidDays&quot;, &quot;0&quot;)
    vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
    vars.put(&quot;_abortReason&quot;, errorMsg)
    SampleResult.setResponseData(errorMsg, &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;400&quot;)
    SampleResult.setResponseMessage(&quot;End date is before start date&quot;)
    SampleResult.setSuccessful(false)
    ctx.getEngine().stopTestNow()
    return
}

// ===== Collect valid days (skip weekends if not allowed) =====
def validDates = []
def skippedWeekends = []
LocalDate current = startDate
while (!current.isAfter(endDate)) {
    if (allowWeekends || !(current.dayOfWeek in [DayOfWeek.SATURDAY, DayOfWeek.SUNDAY])) {
        validDates.add(current)
    } else {
        skippedWeekends.add(current)
    }
    current = current.plusDays(1)
}

// ===== Store valid dates for sequential access =====
int totalDays = validDates.size()
int totalEventCount = totalDays * eventsPerDay

validDates.eachWithIndex { date, idx -&gt;
    vars.put(&quot;validDate_&quot; + (idx + 1), date.format(dateFormatter))
}

vars.put(&quot;totalValidDays&quot;,  totalDays.toString())
vars.put(&quot;eventsPerDay&quot;,    eventsPerDay.toString())
vars.put(&quot;totalEventCount&quot;, totalEventCount.toString())

// ===== Build summary =====
def sb = new StringBuilder()
sb.append(&quot;========================================\n&quot;)
sb.append(&quot;EVENT CALCULATION SUMMARY\n&quot;)
sb.append(&quot;========================================\n&quot;)
sb.append(&quot;Date Range      : ${startDate} to ${endDate}\n&quot;)
sb.append(&quot;Allow Weekends  : ${allowWeekends}\n&quot;)
sb.append(&quot;Events/Day      : ${eventsPerDay}\n&quot;)
sb.append(&quot;========================================\n&quot;)

if (totalEventCount == 0) {
    sb.append(&quot;\n⚠️ WARNING: No valid dates found!\n&quot;)
    sb.append(&quot;All dates in the range fall on weekends and allowWeekends is set to false.\n&quot;)
    if (!skippedWeekends.isEmpty()) {
        sb.append(&quot;Skipped weekend dates:\n&quot;)
        skippedWeekends.each { sb.append(&quot;  ❌ ${it} (${it.dayOfWeek})\n&quot;) }
    }
    sb.append(&quot;\nPlease change the date range or set allowWeekends=true in UDV.\n&quot;)

    log.error(&quot;========================================&quot;)
    log.error(&quot;No valid dates found — all dates are weekends and allowWeekends=false&quot;)
    log.error(&quot;Date Range: ${startDate} to ${endDate}&quot;)
    skippedWeekends.each { log.error(&quot;  ❌ ${it} (${it.dayOfWeek}) - SKIPPED (weekend)&quot;) }
    log.error(&quot;========================================&quot;)

    SampleResult.setResponseData(sb.toString(), &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;400&quot;)
    SampleResult.setResponseMessage(&quot;No valid dates - all dates are weekends&quot;)
    SampleResult.setSuccessful(false)
    vars.put(&quot;_abortTest&quot;, &quot;true&quot;)
    vars.put(&quot;_abortReason&quot;, &quot;No valid dates - all dates in range are weekends and allowWeekends=false&quot;)
    ctx.getEngine().stopTestNow()
} else {
    validDates.each { sb.append(&quot;  ✅ ${it} (${it.dayOfWeek})\n&quot;) }
    if (!skippedWeekends.isEmpty()) {
        sb.append(&quot;\nSkipped weekend dates:\n&quot;)
        skippedWeekends.each { sb.append(&quot;  ❌ ${it} (${it.dayOfWeek})\n&quot;) }
    }
    sb.append(&quot;\n✅ ${totalEventCount} event(s) will be created across ${totalDays} valid day(s).\n&quot;)


    SampleResult.setResponseData(sb.toString(), &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;200&quot;)
    SampleResult.setResponseMessage(&quot;${totalEventCount} events planned&quot;)
    SampleResult.setSuccessful(true)
}
</stringProp>
            </JSR223Sampler>
            <hashTree/>
