                                  <hashTree/>
                                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Smart Slot Selector" enabled="true">
                                    <stringProp name="scriptLanguage">groovy</stringProp>
                                    <stringProp name="parameters"></stringProp>
                                    <stringProp name="filename"></stringProp>
                                    <stringProp name="cacheKey">true</stringProp>
                                    <stringProp name="script">import groovy.json.JsonSlurper
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.util.concurrent.ThreadLocalRandom

def rand = ThreadLocalRandom.current()

// ==================== CONTEXT VARIABLES ====================
def calcType = vars.get(&quot;calcActivityType&quot;)?.trim()
def loopType = vars.get(&quot;loopActivityType&quot;)?.trim()
def varType = vars.get(&quot;activityType&quot;)?.trim()

def currentActivityType = (calcType ?: loopType ?: varType ?: &quot;unknown&quot;)
def currentRoomId = vars.get(&quot;currentRoomId&quot;) ?: &quot;&quot;
def roomIndex = vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;
def dayIndex = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def loopCounter = vars.get(&quot;activityLoopCounter&quot;)?.toInteger() ?: 1

// ==================== CONFIGURATION FROM UDVs ====================

// vacantSlotDurations (for topics/meetings): Skip if empty, 0, or negative
// Use parsedVacantSlotDuration from Get Vacant Slots if available (ensures consistency)
def vacantSlotsDurationRaw = vars.get(&quot;vacantSlotDurations&quot;)?.trim()
def parsedDurationFromRequest = vars.get(&quot;parsedVacantSlotDuration&quot;)?.trim()
def defaultDuration = &quot;30&quot;
def skipOtherActivity = false

// First try to use the duration from Get Vacant Slots request (ensures consistency)
if (parsedDurationFromRequest &amp;&amp; parsedDurationFromRequest.isInteger() &amp;&amp; parsedDurationFromRequest.toInteger() &gt; 0) {
    defaultDuration = parsedDurationFromRequest
} else if (!vacantSlotsDurationRaw) {
    skipOtherActivity = true
    log.info(&quot;[Duration Check] vacantSlotDurations is empty - will skip activity&quot;)
} else {
    def validOptions = vacantSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }
    if (validOptions.isEmpty()) {
        skipOtherActivity = true
        log.info(&quot;[Duration Check] vacantSlotDurations has no valid values (must be &gt; 0) - will skip activity&quot;)
    } else {
        defaultDuration = validOptions[rand.nextInt(validOptions.size())]
    }
}

// ==================== BLOCKED RANGES ====================
def reservedBlockedTimesKey = &quot;reservedBlockedTimes_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
def reservedBlockedStr = vars.get(reservedBlockedTimesKey) ?: &quot;&quot;
def globalReservedBlockedRanges = []
if (reservedBlockedStr) {
    reservedBlockedStr.split(&quot;,&quot;).each { range -&gt;
        def parts = range.split(&quot;-&quot;)
        if (parts.size() == 2) {
            globalReservedBlockedRanges.add([parts[0].trim().toInteger(), parts[1].trim().toInteger()])
        }
    }
}

// Always check blocked ranges if they exist
def shouldApplyBlockedRanges = (globalReservedBlockedRanges.size() &gt; 0)

def isSlotInBlockedRange = { int slotStartMins, int slotDuration = 60 -&gt;
    if (!shouldApplyBlockedRanges) return false
    int slotEndMins = slotStartMins + slotDuration
    for (def range : globalReservedBlockedRanges) {
        if (slotStartMins &lt; range[1] &amp;&amp; slotEndMins &gt; range[0]) return true
    }
    return false
}

// ==================== HELPER FUNCTIONS ====================
def responseData = prev.getResponseDataAsString()
def jsonSlurper = new JsonSlurper()

// Parse time from ISO datetime (2026-12-04T09:30:00) to minutes since midnight
def getTimeMinutes = { timeStr -&gt;
    if (!timeStr || timeStr.length() &lt; 16) return -1
    try {
        def timePart = timeStr.substring(11, 16)
        def parts = timePart.split(&quot;:&quot;)
        return parts[0].toInteger() * 60 + parts[1].toInteger()
    } catch (Exception e) { return -1 }
}

// Parse time supporting BOTH &quot;HH:mm&quot; and &quot;yyyy-MM-ddTHH:mm:ss&quot; formats
def parseTimeToMinutes = { timeStr -&gt;
    if (!timeStr || !timeStr.contains(&quot;:&quot;)) return -1
    try {
        if (timeStr.contains(&quot;T&quot;) &amp;&amp; timeStr.length() &gt;= 16) {
            // ISO format: &quot;2026-12-04T09:30:00&quot;
            def timePart = timeStr.substring(11, 16)
            def parts = timePart.split(&quot;:&quot;)
            return parts[0].toInteger() * 60 + parts[1].toInteger()
        } else {
            // Simple HH:mm format
            def parts = timeStr.trim().split(&quot;:&quot;)
            return parts[0].toInteger() * 60 + parts[1].toInteger()
        }
    } catch (Exception e) { 
        log.warn(&quot;[parseTimeToMinutes] Failed to parse: ${timeStr}&quot;)
        return -1 
    }
}

def formatMinutesToTime = { int mins -&gt;
    def hours = (int)(mins / 60)
    def minutes = mins % 60
    return &quot;${hours}:${String.format(&apos;%02d&apos;, minutes)}&quot;
}

def formatMinutesToDateTime = { int mins, String dateStr -&gt;
    def hours = (int)(mins / 60)
    def minutes = mins % 60
    if (!dateStr || dateStr.trim().isEmpty()) {
        return &quot;1970-01-01T${String.format(&apos;%02d&apos;, hours)}:${String.format(&apos;%02d&apos;, minutes)}:00&quot;
    }
    def datePart = dateStr.take(10)
    return &quot;${datePart}T${String.format(&apos;%02d&apos;, hours)}:${String.format(&apos;%02d&apos;, minutes)}:00&quot;
}

try {
    def json = jsonSlurper.parseText(responseData)
    def timeSlots = json?._embedded?.resourceTimeSlots ?: []
    def validSlots = timeSlots.findAll { slot -&gt; (slot?.resources ?: []).size() &gt; 0 }

    // Validate room ID
    if (!currentRoomId || currentRoomId.trim().isEmpty()) {
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)
        vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)
        vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
        vars.put(&quot;currentVacantSlotEndTime&quot;, &quot;&quot;)
        return
    }

    // Get day window
    def windowDayNum = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
    def windowStartStr = vars.get(&quot;activityStartTime_&quot; + windowDayNum) ?: &quot;08:00&quot;
    def windowEndStr = vars.get(&quot;activityEndTime_&quot; + windowDayNum) ?: &quot;18:30&quot;

    int windowStartMins = parseTimeToMinutes(windowStartStr)
    int windowEndMins = parseTimeToMinutes(windowEndStr)
    if (windowStartMins &lt; 0) windowStartMins = 480
    if (windowEndMins &lt; 0) windowEndMins = 1110

    def targetDateStr = vars.get(&quot;activityDate_&quot; + windowDayNum) ?: &quot;&quot;
    def targetDate = targetDateStr.length() &gt;= 10 ? targetDateStr.substring(0, 10) : &quot;&quot;
    int actualDuration = defaultDuration.toString().toInteger()

    // Filter slots to day window
    def roomSlots = validSlots.findAll { slot -&gt;
        def slotTimeStr = slot?.startTime?.context?.contextZoneDate ?: &quot;&quot;
        if (!slotTimeStr) return false
        def slotDate = slotTimeStr.length() &gt;= 10 ? slotTimeStr.substring(0, 10) : &quot;&quot;
        if (targetDate &amp;&amp; slotDate &amp;&amp; slotDate != targetDate) return false
        int slotMins = getTimeMinutes(slotTimeStr)
        if (slotMins &lt; 0) return false
        return slotMins &gt;= windowStartMins &amp;&amp; (slotMins + actualDuration) &lt;= windowEndMins
    }

    def selectedSlot = null
    def selectedDuration = defaultDuration.toInteger()

    if (roomSlots.size() == 0) {
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
    }

    if (roomSlots.size() &gt; 0) {

        // Skip if vacantSlotDurations (activity duration) is empty or 0
        if (skipOtherActivity) {
            log.info(&quot;[${currentActivityType}] Skipping - vacantSlotDurations is empty or 0&quot;)
            vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
            vars.put(&quot;currentActivityDuration&quot;, &quot;0&quot;)
            return
        }
        
        def usedSlotRangesKey = &quot;usedSlotRanges_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
        def usedSlotRangesStr = vars.get(usedSlotRangesKey) ?: &quot;&quot;
        def usedSlotRanges = []
        if (usedSlotRangesStr) {
            usedSlotRanges = usedSlotRangesStr.split(&quot;;&quot;).collect { rangeStr -&gt;
                def parts = rangeStr.split(&quot;:&quot;)
                if (parts.size() == 2) return [start: parts[0].toInteger(), end: parts[1].toInteger()]
                return null
            }.findAll { it != null }
        }

        globalReservedBlockedRanges.each { range -&gt;
            def blockedRange = [start: range[0], end: range[1]]
            if (!usedSlotRanges.any { it.start == blockedRange.start &amp;&amp; it.end == blockedRange.end }) {
                usedSlotRanges.add(blockedRange)
            }
        }

        def overlapsWithUsed = { int slotStart, int slotDuration -&gt;
            int slotEnd = slotStart + slotDuration
            def freshRangesStr = vars.get(usedSlotRangesKey) ?: &quot;&quot;
            def freshRanges = []
            if (freshRangesStr) {
                freshRanges = freshRangesStr.split(&quot;;&quot;).collect { rangeStr -&gt;
                    def parts = rangeStr.split(&quot;:&quot;)
                    if (parts.size() == 2) return [start: parts[0].toInteger(), end: parts[1].toInteger()]
                    return null
                }.findAll { it != null }
            }
            globalReservedBlockedRanges.each { range -&gt; freshRanges.add([start: range[0], end: range[1]]) }
            for (def usedRange : freshRanges) {
                if (!(slotEnd &lt;= usedRange.start || slotStart &gt;= usedRange.end)) return true
            }
            return false
        }

        def durationOptions = vacantSlotsDurationRaw.contains(&quot;,&quot;) ?
            vacantSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim().toInteger() } : [vacantSlotsDurationRaw.toInteger()]
        
        // Use ALL valid durations from Get Vacant Slots PreProcessor (not just the min used for API call)
        def allValidDurationsStr = vars.get(&quot;allValidDurations&quot;)?.trim()
        if (allValidDurationsStr) {
            durationOptions = allValidDurationsStr.split(&quot;,&quot;).collect { it.trim().toInteger() }.findAll { it &gt; 0 }
        }
        
        def minDuration = durationOptions.min()
        def maxDuration = durationOptions.max()

        // Filter by minDuration so small gaps aren&apos;t excluded - actual duration picked later based on fit
        def availableSlots = roomSlots.findAll { slot -&gt;
            def slotStart = getTimeMinutes(slot?.startTime?.context?.contextZoneDate ?: &quot;&quot;)
            if (slotStart &lt; 0) return false
            if (slotStart + minDuration &gt; windowEndMins) return false
            return !isSlotInBlockedRange(slotStart, minDuration) &amp;&amp; !overlapsWithUsed(slotStart, minDuration)
        }

        if (availableSlots.size() &gt; 0) {
            // ═══ ALLIANCEIT FIX: First activity in first room always gets EARLIEST slot ═══
            def isFirstRoom = (vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;) == &quot;1&quot;
            def isFirstActivity = (vars.get(&quot;activityLoopCounter&quot;) ?: &quot;1&quot;) == &quot;1&quot;
            def forceEarliest = isFirstRoom &amp;&amp; isFirstActivity

            if (forceEarliest) {
                // Sort by start time ascending and pick the earliest slot
                availableSlots.sort { slot -&gt;
                    getTimeMinutes(slot?.startTime?.context?.contextZoneDate ?: &quot;&quot;)
                }
                selectedSlot = availableSlots[0]
            } else {
                selectedSlot = availableSlots[rand.nextInt(availableSlots.size())]
            }
            def selectedSlotTime = getTimeMinutes(selectedSlot?.startTime?.context?.contextZoneDate ?: &quot;&quot;)

            def maxRetries = availableSlots.size()
            def retryCount = 0
            def foundValidSlot = false
            def latestRanges = []

            while (!foundValidSlot &amp;&amp; retryCount &lt; maxRetries) {
                def latestRangesStr = vars.get(usedSlotRangesKey) ?: &quot;&quot;
                latestRanges = []
                if (latestRangesStr) {
                    latestRanges = latestRangesStr.split(&quot;;&quot;).collect { rangeStr -&gt;
                        def parts = rangeStr.split(&quot;:&quot;)
                        if (parts.size() == 2) return [start: parts[0].toInteger(), end: parts[1].toInteger()]
                        return null
                    }.findAll { it != null }
                }
                globalReservedBlockedRanges.each { range -&gt; latestRanges.add([start: range[0], end: range[1]]) }

                def slotEndCheck = selectedSlotTime + minDuration
                def alreadyUsed = latestRanges.any { range -&gt; !(slotEndCheck &lt;= range.start || selectedSlotTime &gt;= range.end) }

                if (alreadyUsed) {
                    availableSlots = availableSlots.findAll { slot -&gt;
                        getTimeMinutes(slot?.startTime?.context?.contextZoneDate ?: &quot;&quot;) != selectedSlotTime
                    }
                    if (availableSlots.size() &gt; 0) {
                        if (forceEarliest) {
                            availableSlots.sort { slot -&gt;
                                getTimeMinutes(slot?.startTime?.context?.contextZoneDate ?: &quot;&quot;)
                            }
                            selectedSlot = availableSlots[0]
                        } else {
                            selectedSlot = availableSlots[rand.nextInt(availableSlots.size())]
                        }
                        selectedSlotTime = getTimeMinutes(selectedSlot?.startTime?.context?.contextZoneDate ?: &quot;&quot;)
                        retryCount++
                    } else {
                        selectedSlot = null
                        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                        break
                    }
                } else {
                    foundValidSlot = true
                }
            }

            if (!foundValidSlot &amp;&amp; selectedSlot != null) {
                selectedSlot = null
                vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
            }

            if (selectedSlot) {
                def maxAvailableTime = windowEndMins - selectedSlotTime
                def nextBlockStart = windowEndMins
                latestRanges.each { range -&gt;
                    if (range.start &gt; selectedSlotTime &amp;&amp; range.start &lt; nextBlockStart) nextBlockStart = range.start
                }
                maxAvailableTime = Math.min(maxAvailableTime, nextBlockStart - selectedSlotTime)

                def fittingDurations = durationOptions.findAll { it &lt;= maxAvailableTime }

                if (fittingDurations.size() == 0) {
                    selectedSlot = null
                    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                    vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
                } else {
                    def topicDuration = fittingDurations[rand.nextInt(fittingDurations.size())]
                    selectedDuration = topicDuration
                    def slotEnd = selectedSlotTime + topicDuration

                    def hasOverlap = latestRanges.any { range -&gt; !(slotEnd &lt;= range.start || selectedSlotTime &gt;= range.end) }

                    if (hasOverlap) {
                        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                    } else {
                        def activityCountKey = currentActivityType + &quot;Count_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
                        def activityNum = (vars.get(activityCountKey)?.toInteger() ?: 0) + 1
                        vars.put(activityCountKey, activityNum.toString())


                        def currentRanges = vars.get(usedSlotRangesKey) ?: &quot;&quot;
                        vars.put(usedSlotRangesKey, currentRanges ? currentRanges + &quot;;&quot; + selectedSlotTime + &quot;:&quot; + slotEnd : selectedSlotTime + &quot;:&quot; + slotEnd)
                    }
                }
            }
        } else {
            // Gap fill logic
            def latestRangesForGapFill = []
            def latestRangesStrForGapFill = vars.get(usedSlotRangesKey) ?: &quot;&quot;
            if (latestRangesStrForGapFill) {
                latestRangesForGapFill = latestRangesStrForGapFill.split(&quot;;&quot;).collect { rangeStr -&gt;
                    def parts = rangeStr.split(&quot;:&quot;)
                    if (parts.size() == 2) return [start: parts[0].toInteger(), end: parts[1].toInteger()]
                    return null
                }.findAll { it != null }
            }

            def allOccupied = []
            latestRangesForGapFill.each { allOccupied.add([start: it.start, end: it.end]) }
            globalReservedBlockedRanges.each { allOccupied.add([start: it[0], end: it[1]]) }
            allOccupied.sort { it.start }

            def gaps = []
            def currentPos = windowStartMins
            allOccupied.each { occupied -&gt;
                if (occupied.start &gt; currentPos &amp;&amp; (occupied.start - currentPos) &gt;= minDuration) {
                    gaps.add([start: currentPos, end: occupied.start, size: occupied.start - currentPos])
                }
                currentPos = Math.max(currentPos, occupied.end)
            }
            if (currentPos &lt; windowEndMins &amp;&amp; (windowEndMins - currentPos) &gt;= minDuration) {
                gaps.add([start: currentPos, end: windowEndMins, size: windowEndMins - currentPos])
            }

            if (gaps.size() &gt; 0) {
                def sortedDurations = durationOptions.sort { -it }
                def selectedGap = null
                def topicDuration = minDuration

                for (def tryDuration : sortedDurations) {
                    def fittingGaps = gaps.findAll { it.size &gt;= tryDuration }
                    if (fittingGaps.size() &gt; 0) {
                        selectedGap = fittingGaps[rand.nextInt(fittingGaps.size())]
                        topicDuration = tryDuration
                        break
                    }
                }

                if (selectedGap) {
                    def selectedSlotTime = selectedGap.start
                    selectedDuration = topicDuration
                    def slotEnd = selectedSlotTime + topicDuration

                    def activityCountKey = currentActivityType + &quot;Count_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
                    def activityNum = (vars.get(activityCountKey)?.toInteger() ?: 0) + 1
                    vars.put(activityCountKey, activityNum.toString())


                    def currentRanges = vars.get(usedSlotRangesKey) ?: &quot;&quot;
                    vars.put(usedSlotRangesKey, currentRanges ? currentRanges + &quot;;&quot; + selectedSlotTime + &quot;:&quot; + slotEnd : selectedSlotTime + &quot;:&quot; + slotEnd)

                    def eventDateStr = vars.get(&quot;activityDate_&quot; + (vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;)) ?: &quot;&quot;
                    selectedSlot = [
                        startTime: [context: [contextZoneDate: formatMinutesToDateTime(selectedSlotTime, eventDateStr)]],
                        endTime: [context: [contextZoneDate: formatMinutesToDateTime(slotEnd, eventDateStr)]]
                    ]
                } else {
                    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                    vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
                }
            } else {
                vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
            }
        }
    }

    // ==================== SET OUTPUT VARIABLES ====================
    if (selectedSlot) {
        vars.put(&quot;skipActivity&quot;, &quot;false&quot;)
        def startTimeStr = selectedSlot?.startTime?.context?.contextZoneDate ?: &quot;&quot;

        def endTimeStr = &quot;&quot;
        if (startTimeStr) {
            try {
                def formatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)
                def startDT = LocalDateTime.parse(startTimeStr, formatter)
                def endDT = startDT.plusMinutes(selectedDuration)
                endTimeStr = endDT.format(formatter)
            } catch (Exception e) {
                endTimeStr = selectedSlot?.endTime?.context?.contextZoneDate ?: startTimeStr
            }
        }

        def resourceId = currentRoomId
        if (!currentRoomId || currentRoomId.trim().isEmpty()) {
            vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
            vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)
            vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
            vars.put(&quot;currentVacantSlotEndTime&quot;, &quot;&quot;)
            vars.put(&quot;currentActivityDuration&quot;, defaultDuration)
            return
        }

        def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
        def roomValidated = false
        def roomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;UNKNOWN&quot;

        for (int i = 1; i &lt;= selectedRoomCount; i++) {
            if (vars.get(&quot;selectedRoomId_&quot; + i) == currentRoomId) {
                roomValidated = true
                roomName = vars.get(&quot;selectedRoomName_&quot; + i) ?: roomName
                break
            }
        }

        if (!roomValidated) {
            vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
            vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)
            vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
            vars.put(&quot;currentVacantSlotEndTime&quot;, &quot;&quot;)
            vars.put(&quot;currentActivityDuration&quot;, defaultDuration)
            return
        }

        vars.put(&quot;selectedRoomName&quot;, roomName)
        vars.put(&quot;currentVacantSlotId&quot;, resourceId)
        vars.put(&quot;currentVacantSlotStartTime&quot;, startTimeStr)
        vars.put(&quot;currentVacantSlotEndTime&quot;, endTimeStr)
        vars.put(&quot;currentActivityDuration&quot;, selectedDuration.toString())
    } else {
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
    }

} catch (Exception e) {
    log.error(&quot;Exception in Smart Slot Selector: &quot; + e.message)
    e.printStackTrace()
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
}

// ==================== FINAL VALIDATION ====================
def finalResourceId = vars.get(&quot;currentVacantSlotId&quot;) ?: &quot;&quot;
def finalStartTime = vars.get(&quot;currentVacantSlotStartTime&quot;) ?: &quot;&quot;
def finalSkipActivity = vars.get(&quot;skipActivity&quot;)

if (finalSkipActivity != &quot;true&quot;) {
    if (!finalResourceId || finalResourceId.trim().isEmpty()) {
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)
    }
    if (!finalStartTime || finalStartTime.trim().isEmpty()) {
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
    }
}

// Update cumulative slot usage
if (vars.get(&quot;skipActivity&quot;) != &quot;true&quot;) {
    def slotKey = &quot;Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
    def currentTotal = vars.get(&quot;totalSlotsUsed_&quot; + slotKey)?.toInteger() ?: 0
    def activityDuration = vars.get(&quot;currentActivityDuration&quot;)?.toInteger() ?: 30
    def slotDuration = (defaultDuration ?: &quot;30&quot;).toInteger()
    int slotsUsed = slotDuration &gt; 0 ? (int) Math.ceil(activityDuration / slotDuration) : 1
    vars.put(&quot;totalSlotsUsed_&quot; + slotKey, (currentTotal + slotsUsed).toString())
}</stringProp>
                                  </JSR223PostProcessor>
                                  <hashTree/>
                                  <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                                  <hashTree/>
                                  <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Constant Timer" enabled="true">
                                    <stringProp name="ConstantTimer.delay">100</stringProp>
                                  </ConstantTimer>
                                  <hashTree/>
                                </hashTree>
                                <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Build Activity Payload" enabled="true">
                                  <stringProp name="scriptLanguage">groovy</stringProp>
                                  <stringProp name="parameters"></stringProp>
                                  <stringProp name="filename"></stringProp>
                                  <stringProp name="cacheKey">true</stringProp>
                                  <stringProp name="script">SampleResult.setIgnore()

import groovy.json.JsonOutput
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

// Build Activity Payload - runs BEFORE If Controller so validation can block activity creation

// Clear any stale payload from previous iteration FIRST
vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)

// Check if we should even try to build payload
if (vars.get(&quot;skipActivity&quot;) == &quot;true&quot;) {
        SampleResult.setResponseMessage(&quot;Skipped - no slot&quot;)
    return
}

// Get current day info for logging
def currentDay = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;?&quot;
def currentDate = vars.get(&quot;activityDate_&quot; + currentDay) ?: &quot;Unknown&quot;
def currentRoom = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown Room&quot;

// Use unique variable name to avoid shadowing JMeter variable &apos;activityType&apos;
def calcType = vars.get(&quot;calcActivityType&quot;)
def loopType = vars.get(&quot;loopActivityType&quot;)
def moduleType = vars.get(&quot;activityType&quot;)
def payloadActivityType = calcType ?: loopType ?: moduleType ?: &quot;unknown&quot;

def moduleId = vars.get(&quot;currentActivityModuleId&quot;) ?: &quot;&quot;

def resourceId = vars.get(&quot;currentRoomId&quot;) ?: &quot;&quot;
def startTimeStr = vars.get(&quot;currentVacantSlotStartTime&quot;) ?: &quot;&quot;

if (!startTimeStr || !resourceId || resourceId.trim().isEmpty()) {
    log.error(&quot;VALIDATION FAILED: Missing startTime or resourceId - BLOCKING activity creation&quot;)
    log.error(&quot;startTime: ${startTimeStr ?: &apos;EMPTY&apos;}, resourceId: ${resourceId ?: &apos;EMPTY&apos;}&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
    SampleResult.setResponseMessage(&quot;BLOCKED - missing required fields&quot;)
    return
}

// Overlap check removed - Smart Slot Selector already validates and tracks slots
// The previous check was detecting overlap with ITSELF (same slot just added by Smart Slot Selector)

// VALIDATION 2: resourceId must match one of the selected rooms
def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
def validRoom = false
def matchedRoomName = &quot;UNKNOWN&quot;

for (int i = 1; i &lt;= selectedRoomCount; i++) {
    def selectedRoomId = vars.get(&quot;selectedRoomId_&quot; + i) ?: &quot;&quot;
    def selectedRoomName = vars.get(&quot;selectedRoomName_&quot; + i) ?: &quot;Room ${i}&quot;
        if (selectedRoomId == resourceId) {
        validRoom = true
        matchedRoomName = selectedRoomName
                                if (selectedRoomName != vars.get(&quot;currentRoomName&quot;)) {
            log.warn(&quot;[Room Validation]   ⚠️ NAME MISMATCH! selectedRoomName_${i} (${selectedRoomName}) != currentRoomName (${vars.get(&apos;currentRoomName&apos;)})&quot;)
        }
        break
    }
}

if (!validRoom) {
    log.error(&quot;❌ VALIDATION FAILED: resourceId does not match any selected room!&quot;)
    log.error(&quot;resourceId: ${resourceId}&quot;)
    log.error(&quot;currentRoomId: ${vars.get(&apos;currentRoomId&apos;)}&quot;)
    log.error(&quot;currentRoomName: ${vars.get(&apos;currentRoomName&apos;)}&quot;)
    log.error(&quot;Selected rooms (${selectedRoomCount}):&quot;)
    for (int i = 1; i &lt;= selectedRoomCount; i++) {
        log.error(&quot;Room ${i}: ${vars.get(&apos;selectedRoomName_&apos; + i)} = ${vars.get(&apos;selectedRoomId_&apos; + i)}&quot;)
    }
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
    SampleResult.setResponseMessage(&quot;BLOCKED - invalid room&quot;)
    return
}

// VALIDATION 3: moduleId must not be empty
if (!moduleId || moduleId.trim().isEmpty()) {
    log.error(&quot;VALIDATION FAILED: Missing moduleId - BLOCKING activity creation&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
    SampleResult.setResponseMessage(&quot;BLOCKED - missing moduleId&quot;)
    return
}

// Get duration - filter negative values, skip if no valid duration (like breaks/catering)
def durationStr = vars.get(&quot;currentActivityDuration&quot;)
if (!durationStr || !durationStr.isInteger() || durationStr.toInteger() &lt;= 0) {
    def vacantSlotsDurationRaw = vars.get(&quot;vacantSlotDurations&quot;)?.trim()
    if (vacantSlotsDurationRaw) {
        def validDurations = vacantSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }
        durationStr = validDurations ? validDurations[0] : null
    } else {
        durationStr = null
    }
}
// Skip activity if no valid duration found
if (!durationStr || !durationStr.isInteger() || durationStr.toInteger() &lt;= 0) {
    log.info(&quot;[Activity Payload] Skipping - no valid duration found (vacantSlotDurations empty or all negative)&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
    SampleResult.setResponseMessage(&quot;SKIPPED - no valid duration&quot;)
    return
}
def activityDur = durationStr.toInteger()

// Get requestDate from selected day
def selectedDay = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def activityDate = vars.get(&quot;activityDate_&quot; + selectedDay) ?: &quot;&quot;
def requestDateValue = activityDate
if (activityDate &amp;&amp; !activityDate.contains(&quot;T&quot;)) {
    requestDateValue = activityDate + &quot;T00:00:00&quot;
}

// Calculate endTime from startTime + duration
def endTimeStr = vars.get(&quot;currentVacantSlotEndTime&quot;) ?: &quot;&quot;
if (!endTimeStr &amp;&amp; startTimeStr) {
    try {
        def formatter = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)
        def startDT = java.time.LocalDateTime.parse(startTimeStr, formatter)
        def endDT = startDT.plusMinutes(activityDur)
        endTimeStr = endDT.format(formatter)
    } catch (Exception e) {
        log.warn(&quot;Could not calculate endTime: ${e.message}&quot;)
        endTimeStr = startTimeStr
    }
}

// VALIDATION 4: Activity must fit within day&apos;s time window
def windowStartStr = vars.get(&quot;activityStartTime_&quot; + selectedDay) ?: &quot;07:00&quot;
def windowEndStr = vars.get(&quot;activityEndTime_&quot; + selectedDay) ?: &quot;17:00&quot;

// Parse window times to minutes
def parseTimeToMinutes = { String timeStr -&gt;
    if (!timeStr) return -1
    try {
        if (timeStr.contains(&quot;T&quot;)) {
            def timePart = timeStr.substring(11)
            def parts = timePart.split(&quot;:&quot;)
            return parts[0].toInteger() * 60 + parts[1].toInteger()
        } else {
            def parts = timeStr.split(&quot;:&quot;)
            return parts[0].toInteger() * 60 + parts[1].toInteger()
        }
    } catch (Exception e) { return -1 }
}

int windowStartMins = parseTimeToMinutes(windowStartStr)
int windowEndMins = parseTimeToMinutes(windowEndStr)
int activityStartMins = parseTimeToMinutes(startTimeStr)
int activityEndMins = activityStartMins + activityDur

if (windowStartMins &lt; 0) windowStartMins = 420  // 7:00 AM
if (windowEndMins &lt; 0) windowEndMins = 1020     // 5:00 PM

// Check if activity fits within window
if (activityStartMins &lt; windowStartMins || activityEndMins &gt; windowEndMins) {
    def formatMins = { int mins -&gt; &quot;${(int)(mins/60)}:${String.format(&apos;%02d&apos;, mins%60)}&quot; }
    log.error(&quot;⏰ TIME WINDOW VIOLATION: Activity ${formatMins(activityStartMins)}-${formatMins(activityEndMins)} outside window ${formatMins(windowStartMins)}-${formatMins(windowEndMins)}&quot;)
    log.error(&quot;Blocking activity creation for ${payloadActivityType}&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
    SampleResult.setResponseMessage(&quot;BLOCKED - outside time window&quot;)
    return
}

// VALIDATION 5: FINAL SAFETY OVERLAP CHECK
// This is the last line of defense - verify no overlap with OTHER activities
// (excludes the current slot which was just added by Smart Slot Selector)
def dayIdx = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def roomIdx = vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;
def finalUsedRangesKey = &quot;usedSlotRanges_Day&quot; + dayIdx + &quot;_Room&quot; + roomIdx
def finalUsedRangesStr = vars.get(finalUsedRangesKey) ?: &quot;&quot;

// ENHANCED ROOM TRACKING LOG
def formatMinsDisplay = { int mins -&gt; &quot;${(int)(mins/60)}:${String.format(&apos;%02d&apos;, mins%60)}&quot; }

def blockedRangesKey = &quot;reservedBlockedTimes_Day&quot; + dayIdx + &quot;_Room&quot; + roomIdx
def blockedRangesStr = vars.get(blockedRangesKey) ?: &quot;&quot;
def blockedViolation = false
if (blockedRangesStr) {
    blockedRangesStr.split(&quot;,&quot;).each { range -&gt;
        if (blockedViolation) return
        def parts = range.split(&quot;-&quot;)
        if (parts.size() == 2) {
            def blockStart = parts[0].trim().toInteger()
            def blockEnd = parts[1].trim().toInteger()
            // Check overlap with blocked range
            if (!(activityEndMins &lt;= blockStart || activityStartMins &gt;= blockEnd)) {
                log.error(&quot;🚨 BLOCKED RANGE VIOLATION: Activity ${formatMinsDisplay(activityStartMins)}-${formatMinsDisplay(activityEndMins)} overlaps blocked ${formatMinsDisplay(blockStart)}-${formatMinsDisplay(blockEnd)}&quot;)
                blockedViolation = true
            }
        }
    }
}
if (blockedViolation) {
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
    SampleResult.setResponseMessage(&quot;BLOCKED - overlaps reserved time&quot;)
    return
}

if (finalUsedRangesStr) {
    def finalUsedRanges = finalUsedRangesStr.split(&quot;;&quot;).collect { rangeStr -&gt;
        def parts = rangeStr.split(&quot;:&quot;)
        if (parts.size() == 2) {
            return [start: parts[0].toInteger(), end: parts[1].toInteger()]
        }
        return null
    }.findAll { it != null }

    // Current activity range: [activityStartMins, activityEndMins]
    // Check overlap with each tracked range, EXCEPT if it&apos;s the exact same range (self)
    def overlappingRanges = finalUsedRanges.findAll { range -&gt;
        // Skip exact self-match (same start AND same end)
        if (range.start == activityStartMins &amp;&amp; range.end == activityEndMins) {
            return false
        }
        // Check overlap: NOT (activityEnd &lt;= rangeStart OR activityStart &gt;= rangeEnd)
        !(activityEndMins &lt;= range.start || activityStartMins &gt;= range.end)
    }

    if (overlappingRanges.size() &gt; 0) {
        log.error(&quot;🚨 FINAL SAFETY CHECK FAILED: Activity ${formatMinsDisplay(activityStartMins)}-${formatMinsDisplay(activityEndMins)} overlaps with existing!&quot;)
        overlappingRanges.each { range -&gt;
            log.error(&quot;   Overlaps with: ${formatMinsDisplay(range.start)}-${formatMinsDisplay(range.end)}&quot;)
        }
        log.error(&quot;All tracked ranges: ${finalUsedRanges.collect { formatMinsDisplay(it.start) + &apos;-&apos; + formatMinsDisplay(it.end) }}&quot;)
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
        SampleResult.setResponseMessage(&quot;BLOCKED - overlap detected in final check&quot;)
        return
    }
}

// Extract just time portion for cleaner display
def startTimeDisplay = startTimeStr?.contains(&quot;T&quot;) ? startTimeStr.substring(11, 16) : startTimeStr
def endTimeDisplay = endTimeStr?.contains(&quot;T&quot;) ? endTimeStr.substring(11, 16) : endTimeStr

// Get activity count for numbering (already incremented by Smart Slot Selector)
def slotKey = &quot;Day&quot; + selectedDay + &quot;_Room&quot; + (vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;)
def activityCountKey = payloadActivityType + &quot;Count_&quot; + slotKey
def activityNum = vars.get(activityCountKey)?.toInteger() ?: 1

// Use the validated room name from VALIDATION 2
// Build payload with endTime
def payload = [
    &quot;startTime&quot;   : [&quot;isoDate&quot;: startTimeStr],
    &quot;endTime&quot;     : [&quot;isoDate&quot;: endTimeStr],
    &quot;activityDate&quot; : [&quot;isoDate&quot;: requestDateValue],
    &quot;duration&quot;    : activityDur,
    &quot;resourceId&quot;  : resourceId,
    &quot;activityType&quot;: payloadActivityType,
    &quot;moduleId&quot;    : moduleId
]

// ABSOLUTE FINAL CHECK: Never allow empty resourceId in payload
if (!resourceId || resourceId.trim().isEmpty()) {
    log.error(&quot;CRITICAL: Attempted to build payload with EMPTY resourceId - BLOCKING&quot;)
    vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    SampleResult.setResponseMessage(&quot;BLOCKED - no resourceId&quot;)
    return
}

def payloadJson = JsonOutput.prettyPrint(JsonOutput.toJson(payload))
vars.put(&quot;createActivityPayload&quot;, payloadJson)

// Log CREATE payload - full JSON like ADD/UPDATE
SampleResult.setResponseMessage(&quot;Payload built for &quot; + payloadActivityType)</stringProp>
                                </JSR223Sampler>
                                <hashTree/>
                                <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ If (Slot Available AND Payload Valid AND Room Valid)" enabled="true">
                                  <stringProp name="IfController.condition">${__groovy(
// COMPREHENSIVE VALIDATION - v15
// This is the FINAL GATE before activity creation
try {
    // Check 1: skipActivity flag
    if (vars.get(&quot;skipActivity&quot;) == &quot;true&quot;) {
        return false
    }

    // Check 2: Payload exists and not empty
    def payload = vars.get(&quot;createActivityPayload&quot;) ?: &quot;&quot;
    if (!payload?.trim()) {
        return false
    }

    // Check 3: Parse JSON and extract resourceId
    def jsonSlurper = new groovy.json.JsonSlurper()
    def payloadObj = jsonSlurper.parseText(payload)
    def resourceId = payloadObj?.resourceId ?: &quot;&quot;

    if (!resourceId || resourceId.trim().isEmpty()) {
        log.error(&quot;IF CONTROLLER BLOCKED: resourceId is empty in payload&quot;)
        return false
    }

    // Check 4: Validate resourceId matches one of our selected rooms
    def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
    def validRoom = false
    for (int i = 1; i &lt;= selectedRoomCount; i++) {
        def selectedRoomId = vars.get(&quot;selectedRoomId_&quot; + i) ?: &quot;&quot;
        if (selectedRoomId == resourceId) {
            validRoom = true
            break
        }
    }

    if (!validRoom) {
        log.error(&quot;IF CONTROLLER BLOCKED: resourceId &quot; + resourceId + &quot; not in selected rooms!&quot;)
        log.error(&quot;Selected rooms (&quot; + selectedRoomCount + &quot;):&quot;)
        for (int i = 1; i &lt;= selectedRoomCount; i++) {
            log.error(&quot;  Room &quot; + i + &quot;: &quot; + vars.get(&quot;selectedRoomId_&quot; + i))
        }
        return false
    }

    // Check 5: Validate moduleId exists
    def moduleId = payloadObj?.moduleId ?: &quot;&quot;
    if (!moduleId || moduleId.trim().isEmpty()) {
        log.error(&quot;IF CONTROLLER BLOCKED: moduleId is empty in payload&quot;)
        return false
    }

    // All checks passed
    return true
} catch (Exception e) {
    log.error(&quot;IF CONTROLLER BLOCKED: Exception parsing payload - &quot; + e.message)
    return false
}
)}</stringProp>
                                  <boolProp name="IfController.evaluateAll">false</boolProp>
                                  <boolProp name="IfController.useExpression">true</boolProp>
                                </IfController>
                                <hashTree>
                                  <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Create - ${activityType} #${activityLoopCounter}" enabled="true">
                                    <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
                                    <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                                      <collectionProp name="Arguments.arguments">
                                        <elementProp name="" elementType="HTTPArgument">
                                          <boolProp name="HTTPArgument.always_encode">false</boolProp>
                                          <stringProp name="Argument.value">${createActivityPayload}</stringProp>
                                          <stringProp name="Argument.metadata">=</stringProp>
                                        </elementProp>
                                      </collectionProp>
                                    </elementProp>
                                    <stringProp name="HTTPSampler.domain"></stringProp>
                                    <stringProp name="HTTPSampler.port"></stringProp>
                                    <stringProp name="HTTPSampler.protocol"></stringProp>
                                    <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                                    <stringProp name="HTTPSampler.path">/${contextname}/api/activities</stringProp>
                                    <stringProp name="HTTPSampler.method">POST</stringProp>
                                    <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
                                    <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                                    <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
                                    <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                                    <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                                    <stringProp name="HTTPSampler.connect_timeout"></stringProp>
                                    <stringProp name="HTTPSampler.response_timeout"></stringProp>
                                  </HTTPSamplerProxy>
                                  <hashTree>
                                    <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Final Room Validation" enabled="true">
                                      <stringProp name="scriptLanguage">groovy</stringProp>
                                      <stringProp name="parameters"></stringProp>
                                      <stringProp name="filename"></stringProp>
                                      <stringProp name="cacheKey">true</stringProp>
                                      <stringProp name="script">// FINAL VALIDATION - Last check before CREATE request
// This PreProcessor runs immediately before the HTTP POST
// If validation fails, it disables the sampler to prevent the request

def payload = vars.get(&quot;createActivityPayload&quot;) ?: &quot;&quot;
def currentRoomId = vars.get(&quot;currentRoomId&quot;) ?: &quot;&quot;

// Check 1: Payload must exist
if (!payload?.trim()) {
    log.error(&quot;🔒 FINAL BLOCK: Empty payload - disabling request&quot;)
    sampler.setEnabled(false)
    return
}

// Check 2: Parse and validate resourceId
try {
    def jsonSlurper = new groovy.json.JsonSlurper()
    def payloadObj = jsonSlurper.parseText(payload)
    def resourceId = payloadObj?.resourceId ?: &quot;&quot;

    // Log all sources
    def payloadType = payloadObj?.activityType
    def calcType = vars.get(&quot;calcActivityType&quot;)
    def loopType = vars.get(&quot;loopActivityType&quot;)
    // Use unique variable name to avoid shadowing JMeter variable &apos;activityType&apos;
    def validatedActivityType = payloadType ?: calcType ?: loopType ?: &quot;unknown&quot;
        if (!resourceId || resourceId.trim().isEmpty()) {
        log.error(&quot;🔒 FINAL BLOCK: resourceId is EMPTY in payload - disabling request&quot;)
        log.error(&quot;   Activity type: ${validatedActivityType}&quot;)
        sampler.setEnabled(false)
        return
    }

    // Check 3: resourceId must match currentRoomId
    if (resourceId != currentRoomId) {
        log.error(&quot;🔒 FINAL BLOCK: resourceId mismatch!&quot;)
        log.error(&quot;Activity type: ${validatedActivityType}&quot;)
        log.error(&quot;Payload resourceId: ${resourceId}&quot;)
        log.error(&quot;currentRoomId: ${currentRoomId}&quot;)
        sampler.setEnabled(false)
        return
    }

    // Check 4: Validate against selected rooms and get actual room name
    def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
    def validRoom = false
    def actualRoomName = &quot;UNKNOWN&quot;

    for (int i = 1; i &lt;= selectedRoomCount; i++) {
        def selectedRoomId = vars.get(&quot;selectedRoomId_&quot; + i) ?: &quot;&quot;
        if (selectedRoomId == resourceId) {
            validRoom = true
            actualRoomName = vars.get(&quot;selectedRoomName_&quot; + i) ?: &quot;Room ${i}&quot;
            break
        }
    }

    if (!validRoom) {
        log.error(&quot;🔒 FINAL BLOCK: resourceId not in selected rooms!&quot;)
        log.error(&quot;Activity type: ${validatedActivityType}&quot;)
        log.error(&quot;resourceId: ${resourceId}&quot;)
        log.error(&quot;Selected rooms (${selectedRoomCount}):&quot;)
        for (int i = 1; i &lt;= selectedRoomCount; i++) {
            log.error(&quot;Room ${i}: ${vars.get(&apos;selectedRoomName_&apos; + i)} = ${vars.get(&apos;selectedRoomId_&apos; + i)}&quot;)
        }
        sampler.setEnabled(false)
        return
    }

    // All checks passed - log with CORRECT values from payload and lookup
    } catch (Exception e) {
    log.error(&quot;🔒 FINAL BLOCK: Exception parsing payload - ${e.message}&quot;)
    sampler.setEnabled(false)
}</stringProp>
                                    </JSR223PreProcessor>
                                    <hashTree/>
                                    <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                                      <collectionProp name="HeaderManager.headers">
                                        <elementProp name="" elementType="Header">
                                          <stringProp name="Header.name">x-cloud-customerid</stringProp>
                                          <stringProp name="Header.value">${customerId}</stringProp>
                                        </elementProp>
                                        <elementProp name="" elementType="Header">
                                          <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                                          <stringProp name="Header.value">${categoryTypeId}</stringProp>
                                        </elementProp>
                                        <elementProp name="" elementType="Header">
                                          <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                                          <stringProp name="Header.value">${categoryId}</stringProp>
                                        </elementProp>
                                        <elementProp name="" elementType="Header">
                                          <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                                          <stringProp name="Header.value">${baseTimezone}</stringProp>
                                        </elementProp>
                                        <elementProp name="" elementType="Header">
                                          <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                                          <stringProp name="Header.value">${clientTimeZone}</stringProp>
                                        </elementProp>
                                        <elementProp name="" elementType="Header">
                                          <stringProp name="Header.name">X-Cloud-Context-Timezone</stringProp>
                                          <stringProp name="Header.value">${baseTimezone}</stringProp>
                                        </elementProp>
                                        <elementProp name="" elementType="Header">
                                          <stringProp name="Header.name">x-cloud-eventid</stringProp>
                                          <stringProp name="Header.value">${requestId}</stringProp>
                                        </elementProp>
                                        <elementProp name="" elementType="Header">
                                          <stringProp name="Header.name">X_cloud_user</stringProp>
                                          <stringProp name="Header.value">${currentUser}</stringProp>
