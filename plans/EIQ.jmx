                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Module Feature Access Extractor" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">import groovy.json.JsonSlurper

// Parse API Response
String responseData = prev.getResponseDataAsString()
def parsedResponse = null

try {
    parsedResponse = new JsonSlurper().parseText(responseData)
} catch (Exception e) {
    log.error(&quot;Failed to parse response: ${e.message}&quot;)
    vars.put(&quot;activityModules_count&quot;, &quot;0&quot;)
    vars.put(&quot;roleModuleAccess_count&quot;, &quot;0&quot;)
    log.info(&quot;Terminated: Feature Access Extractor&quot;)
    return
}

// Convert to List (handle both Array and Map responses)
def roleModuleAccess = []

if (parsedResponse instanceof List) {
    roleModuleAccess = parsedResponse
} else if (parsedResponse instanceof Map) {
    if (parsedResponse._embedded) {
        roleModuleAccess = parsedResponse._embedded?.values()?.flatten() ?: []
    } else {
        roleModuleAccess = parsedResponse.values().toList()
    }
} else {
    log.error(&quot;Unexpected response type: ${parsedResponse?.getClass()?.getName()}&quot;)
    vars.put(&quot;activityModules_count&quot;, &quot;0&quot;)
    vars.put(&quot;roleModuleAccess_count&quot;, &quot;0&quot;)
    log.info(&quot;Terminated: Feature Access Extractor&quot;)
    return
}

vars.put(&quot;roleModuleAccess_count&quot;, roleModuleAccess.size().toString())

if (roleModuleAccess.isEmpty()) {
    log.warn(&quot;No role module access entries - Activities will NOT be created!&quot;)
    vars.put(&quot;activityModules_count&quot;, &quot;0&quot;)
    log.info(&quot;Terminated: Feature Access Extractor&quot;)
    return
}


// Get User Features for permission check (optional)
String userFeaturesRaw = vars.get(&quot;userFeatures_ALL&quot;) ?: &quot;&quot;
def userFeatures = userFeaturesRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it }

// Filter Activity Modules
// Criteria: User has feature permission (or all if userFeatures empty)
//           AND module has activityType in moduleUIConfig
// ---------------------------------------------------------------------------
def activityModules = roleModuleAccess.findAll { access -&gt;
    def feature = access?.feature
    def module = access?.module

    String featureCode = feature?.featureCode ?: feature?.code ?: &quot;&quot;

    // Skip feature check if userFeatures not defined
    boolean hasFeature = userFeatures.isEmpty() || userFeatures.contains(featureCode)

    // Check if module has activityType (is an activity module)
    def moduleUIConfig = module?.moduleUIConfig
    boolean hasActivityType = false

    if (moduleUIConfig instanceof Map) {
        String actType = moduleUIConfig?.activityType ?: &quot;&quot;
        hasActivityType = !actType.isEmpty()
    } else if (moduleUIConfig instanceof String &amp;&amp; moduleUIConfig.contains(&quot;activityType&quot;)) {
        try {
            def parsed = new JsonSlurper().parseText(moduleUIConfig)
            String actType = parsed?.activityType ?: &quot;&quot;
            hasActivityType = !actType.isEmpty()
        } catch (Exception e) {
            // Not valid JSON, skip
        }
    }

    hasFeature &amp;&amp; hasActivityType
}


// Using API order for activity modules

// Store Activity Module Variables for ForEach Controller
int count = activityModules.size()
vars.put(&quot;activityModules_count&quot;, count.toString())

def moduleIds = []
def moduleNames = []
def activityTypes = []
def featureCodes = []

activityModules.eachWithIndex { access, idx -&gt;
    int num = idx + 1

    def module = access?.module
    def feature = access?.feature

    String moduleId = module?.uniqueId ?: module?.id ?: &quot;&quot;
    String moduleName = module?.moduleName ?: module?.name ?: &quot;&quot;

    // Extract activityType from moduleUIConfig
    def moduleUIConfig = module?.moduleUIConfig
    String activityType = &quot;&quot;

    if (moduleUIConfig instanceof Map) {
        activityType = moduleUIConfig?.activityType ?: &quot;&quot;
    } else if (moduleUIConfig instanceof String &amp;&amp; moduleUIConfig.contains(&quot;activityType&quot;)) {
        try {
            def parsed = new JsonSlurper().parseText(moduleUIConfig)
            activityType = parsed?.activityType ?: &quot;&quot;
        } catch (Exception e) {
            log.warn(&quot;Could not parse moduleUIConfig: ${moduleUIConfig}&quot;)
        }
    }

    String featureCode = feature?.featureCode ?: feature?.code ?: &quot;&quot;

    // Store indexed variables
    vars.put(&quot;activityModuleId_&quot; + num, moduleId)
    vars.put(&quot;activityModuleName_&quot; + num, moduleName)
    vars.put(&quot;activityType_&quot; + num, activityType)

    moduleIds.add(moduleId)
    moduleNames.add(moduleName)
    activityTypes.add(activityType)
    featureCodes.add(featureCode)

}

// Store comma-separated lists
vars.put(&quot;activityType_ALL&quot;, activityTypes.join(&quot;,&quot;))

// Log final order
</stringProp>
                  </JSR223PostProcessor>
