                                        <stringProp name="Argument.name">resource</stringProp>
                                      </elementProp>
                                      <elementProp name="duration" elementType="HTTPArgument">
                                        <boolProp name="HTTPArgument.always_encode">true</boolProp>
                                        <stringProp name="Argument.value">${parsedVacantSlotDuration}</stringProp>
                                        <stringProp name="Argument.metadata">=</stringProp>
                                        <boolProp name="HTTPArgument.use_equals">true</boolProp>
                                        <stringProp name="Argument.name">duration</stringProp>
                                      </elementProp>
                                      <elementProp name="resourceIds" elementType="HTTPArgument">
                                        <boolProp name="HTTPArgument.always_encode">true</boolProp>
                                        <stringProp name="Argument.value">${currentRoomId}</stringProp>
                                        <stringProp name="Argument.metadata">=</stringProp>
                                        <boolProp name="HTTPArgument.use_equals">true</boolProp>
                                        <stringProp name="Argument.name">resourceIds</stringProp>
                                      </elementProp>
                                    </collectionProp>
                                  </elementProp>
                                  <stringProp name="HTTPSampler.domain"></stringProp>
                                  <stringProp name="HTTPSampler.port"></stringProp>
                                  <stringProp name="HTTPSampler.protocol"></stringProp>
                                  <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                                  <stringProp name="HTTPSampler.path">/${contextname}/api/resourcetypes/${roomResourceTypeId}/resources/calendar</stringProp>
                                  <stringProp name="HTTPSampler.method">GET</stringProp>
                                  <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
                                  <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                                  <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
                                  <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                                  <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                                  <stringProp name="HTTPSampler.connect_timeout"></stringProp>
                                  <stringProp name="HTTPSampler.response_timeout"></stringProp>
                                </HTTPSamplerProxy>
                                <hashTree>
                                  <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Validate Slot" enabled="true">
                                    <stringProp name="scriptLanguage">groovy</stringProp>
                                    <stringProp name="parameters"></stringProp>
                                    <stringProp name="filename"></stringProp>
                                    <stringProp name="cacheKey">true</stringProp>
                                    <stringProp name="script">// Validate slot entry - check duration UDV

def activityType = vars.get(&quot;activityType&quot;)?.toLowerCase() ?: &quot;activity&quot;
def rand = java.util.concurrent.ThreadLocalRandom.current()

// Get duration from vacantSlotDurations UDV
def durationRaw = vars.get(&quot;vacantSlotDurations&quot;)?.trim()
def durationUdvName = &quot;vacantSlotDurations&quot;

// Filter valid durations (positive integers only)
def validDurations = durationRaw ? durationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 } : []

// Skip if no valid durations
if (validDurations.isEmpty()) {
    log.info(&quot;[${activityType}] Skipping Get Vacant Slots - ${durationUdvName} is empty or has no valid values (must be &gt; 0)&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
    sampler.setEnabled(false)
    return
}

// ALWAYS use MINIMUM duration for API call to get ALL available slots
// Smart Slot Selector will randomly pick from full durationOptions later
def parsedDuration = validDurations.collect { it.toInteger() }.min().toString()
vars.put(&quot;parsedVacantSlotDuration&quot;, parsedDuration)
// Store ALL valid durations for Smart Slot Selector to pick from
vars.put(&quot;allValidDurations&quot;, validDurations.join(&quot;,&quot;))

if (vars.get(&quot;skipActivity&quot;) == &quot;true&quot;) {
    log.warn(&quot;Skipping Get Vacant Slots - skipActivity is true&quot;)
    sampler.setEnabled(false)
}

// Validate slot exit</stringProp>
                                  </JSR223PreProcessor>
