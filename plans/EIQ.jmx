                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">import groovy.json.JsonSlurper

def response = prev.getResponseDataAsString()
if (!response || response.trim().isEmpty()) {
    log.error(&quot;Existing Event API returned empty response for ID: ${vars.get(&apos;existingEventId&apos;)}&quot;)
    vars.put(&quot;eventCreated&quot;, &quot;false&quot;)
    return
}

def json = new JsonSlurper().parseText(response)

// Extract eventId
def eventId = json.eventId ?: &quot;&quot;
vars.put(&quot;requestId&quot;, eventId)

// Extract Visit Name
def visitName = json.eventName ?: json?.data?.eventName ?: &quot;&quot;

// Extract timezone
def timezone = json.timezone ?: &quot;UTC&quot;
vars.put(&quot;baseTimezone&quot;, timezone)

// Take existing HTTP sampler name
def baseLabel = prev.getSampleLabel()

// Append event info
prev.setSampleLabel(baseLabel + &quot; - &quot; + visitName)

// flags
vars.put(&quot;eventCreated&quot;, &quot;true&quot;)

</stringProp>
