          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Set Loop Count (Existing Event Mode)" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">SampleResult.setIgnore()
// When existingEventId is set, totalEventCount is not calculated by Calculate Events.
// Force it to 1 so the Event Creation Loop runs exactly once —
// enough to call Get Active Customer, Get Existing Event, and populate modules.
def existingId = vars.get(&quot;existingEventId&quot;)?.trim() ?: &quot;&quot;
if (existingId) {
    vars.put(&quot;totalEventCount&quot;, &quot;1&quot;)
}</stringProp>
