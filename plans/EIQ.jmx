                                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Pick Event State Action Iterations" enabled="true">
                                    <stringProp name="scriptLanguage">groovy</stringProp>
                                    <stringProp name="parameters"></stringProp>
                                    <stringProp name="filename"></stringProp>
                                    <stringProp name="cacheKey">true</stringProp>
                                    <stringProp name="script">SampleResult.setIgnore()
// Pick random iteration count from stateActionIterations (e.g. &quot;2,3&quot;)
// empty or &quot;0&quot; = skip state actions entirely
def iterationsConfig = vars.get(&quot;stateActionIterations&quot;)?.trim() ?: &quot;&quot;
if (!iterationsConfig || iterationsConfig == &quot;0&quot;) {
    log.info(&quot;stateActionIterations is empty or 0 — skipping state actions&quot;)
    vars.put(&quot;saLoopCurrent&quot;, &quot;9999&quot;)
    vars.put(&quot;eventStateActionLoopCount&quot;, &quot;0&quot;)
    return
}
def options = iterationsConfig.split(&quot;,&quot;)*.trim().findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() }
def randomIterations = options[new Random().nextInt(options.size())]
vars.put(&quot;eventStateActionLoopCount&quot;, randomIterations.toString())
// CRITICAL FIX: Reset WhileController counter fresh for every activity.
// LoopController caches the loop count on first read, so if it was set to 0
// for early-exit on a previous activity, subsequent activities get 0 loops.
// WhileController re-evaluates the condition each iteration using saLoopCurrent.
vars.put(&quot;saLoopCurrent&quot;, &quot;0&quot;)
// Reset the section marker counter so the red header shows once per event
vars.put(&quot;eventStateActionIterNum&quot;, &quot;0&quot;)
log.info(&quot;Event State Action Iterations: ${randomIterations} (saLoopCurrent reset to 0)&quot;)</stringProp>
                                  </JSR223Sampler>
                                  <hashTree/>
                                  <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ Event State Action" enabled="true">
                                    <stringProp name="WhileController.condition">${__groovy(vars.get(&quot;saLoopCurrent&quot;)?.toInteger() &lt; vars.get(&quot;eventStateActionLoopCount&quot;)?.toInteger())}</stringProp>
                                  </WhileController>
                                  <hashTree>
                                    <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="EVENT STATE ACTIONS" enabled="true">
                                      <stringProp name="scriptLanguage">groovy</stringProp>
                                      <stringProp name="parameters"></stringProp>
                                      <stringProp name="filename"></stringProp>
                                      <stringProp name="cacheKey">true</stringProp>
                                      <stringProp name="script">// Event State Actions section marker — shown in RED in View Results Tree
// Runs only once at the start of the first iteration; skipped on subsequent iterations
def iterationNum = vars.get(&quot;eventStateActionIterNum&quot;)?.toInteger() ?: 0
iterationNum++
vars.put(&quot;eventStateActionIterNum&quot;, iterationNum.toString())

if (iterationNum == 1) {
    // Only show the red marker on the very first iteration
    def loopCount = vars.get(&quot;eventStateActionLoopCount&quot;) ?: &quot;?&quot;
    SampleResult.setResponseData(&quot;Event State Actions section — ${loopCount} iteration(s) planned&quot;, &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;RED&quot;)
    SampleResult.setSuccessful(false)
} else {
    SampleResult.setIgnore()
}</stringProp>
                                    </JSR223Sampler>
                                    <hashTree/>
                                    <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Null Guard — activityId" enabled="true">
                                      <stringProp name="scriptLanguage">groovy</stringProp>
                                      <stringProp name="parameters"></stringProp>
                                      <stringProp name="filename"></stringProp>
                                      <stringProp name="cacheKey">true</stringProp>
                                      <stringProp name="script">def activityId = vars.get(&quot;activityId&quot;)?.trim()
if (!activityId || activityId == &quot;null&quot;) {
    log.warn(&quot;Null Guard: activityId is null or empty — skipping state action loop&quot;)
    vars.put(&quot;saLoopCurrent&quot;, &quot;9999&quot;)
    SampleResult.setIgnore()
} else {
    SampleResult.setIgnore()
}</stringProp>
                                    </JSR223Sampler>
