                                      <hashTree/>
                                      <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                                      <hashTree/>
                                      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="State Action PostProcessor" enabled="true">
                                        <stringProp name="scriptLanguage">groovy</stringProp>
                                        <stringProp name="parameters"></stringProp>
                                        <stringProp name="filename"></stringProp>
                                        <stringProp name="cacheKey">true</stringProp>
                                        <stringProp name="script">import groovy.json.JsonSlurper
import java.util.Random

def json = new JsonSlurper().parseText(prev.getResponseDataAsString())

// ⭐⭐⭐ Extract required values
def formId = json?.formData?.formId
def activityId = json?.activityId

if (formId) {
    vars.put(&quot;stateActionFormId&quot;, formId)
    log.info(&quot;Extracted formId = &quot; + formId)
}

if (activityId) {
    vars.put(&quot;stateActionDataId&quot;, activityId)
    log.info(&quot;Extracted activityId = &quot; + activityId)
}

def links = json._links

if (links == null || links.isEmpty()) {
    log.warn(&quot;No _links found in JSON response!&quot;)
    vars.put(&quot;skipEventStateAction&quot;, &quot;true&quot;)
    return
}

// Read included actions allowlist
def includedRaw = vars.get(&quot;includedStateActions&quot;)?.trim() ?: &quot;&quot;
def includedStateActions = includedRaw ? includedRaw.toUpperCase().split(&quot;,&quot;).collect { it.trim() }.findAll { it } : []

// Filter ONLY STATE_ACTION links
def stateActions = links.findAll { key, value -&gt;
    value?.type == &quot;STATE_ACTION&quot;
}

log.info(&quot;STATE_ACTIONS Available: &quot; + stateActions.keySet())

// If includedStateActions is set, allow only those; otherwise allow all
def allowedActions
if (includedStateActions) {
    log.info(&quot;Using INCLUDE list: &quot; + includedStateActions)
    allowedActions = stateActions.findAll { key, value -&gt;
        includedStateActions.contains(key.toUpperCase())
    }
} else {
    log.info(&quot;No INCLUDE list set — all available state actions allowed&quot;)
    allowedActions = stateActions
}

if (!allowedActions.isEmpty()) {

    def actionKeys = allowedActions.keySet().toList()
    Collections.sort(actionKeys)

    // Fully random selection each iteration
    int nextIndex = new Random().nextInt(actionKeys.size())

    def selectedAction = actionKeys[nextIndex]

    def selectedHref = allowedActions[selectedAction]?.href

    if (selectedHref) {
        vars.put(&quot;selectedAction&quot;, selectedAction)
        vars.put(&quot;skipEventStateAction&quot;, &quot;false&quot;)
        // saLoopCurrent is incremented AFTER action executes (in the action&apos;s PostProcessor)
        log.info(&quot;Selected Action: &quot; + selectedAction)
        log.info(&quot;Selected Href: &quot; + selectedHref)
    } else {
        log.warn(&quot;Selected action has no href!&quot;)
        vars.put(&quot;skipEventStateAction&quot;, &quot;true&quot;)
        // No valid href — exit WhileController by setting counter beyond max
        vars.put(&quot;saLoopCurrent&quot;, &quot;9999&quot;)
        log.info(&quot;No href available — terminating remaining state action iterations early&quot;)
    }

} else {
    // None of the includedStateActions are present in current _links.
    // Expected: e.g. event in INITIALIZED (CONFIRM/HOLD not yet available),
    // or event moved to HOLD and CONFIRM no longer available.
    // Simply stop iterating and leave the event in its current status.
    def currentStatus = json?.status ?: &quot;unknown&quot;
    log.info(&quot;None of the included actions [&quot; + includedStateActions + &quot;] found in _links (current status: &quot; + currentStatus + &quot;) — leaving event as-is and stopping iterations&quot;)
    vars.put(&quot;skipEventStateAction&quot;, &quot;true&quot;)
    vars.put(&quot;selectedAction&quot;, &quot;&quot;)
    vars.put(&quot;saLoopCurrent&quot;, &quot;9999&quot;)
}

</stringProp>
                                      </JSR223PostProcessor>
