              </HTTPSamplerProxy>
              <hashTree>
                <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                  <collectionProp name="HeaderManager.headers">
                    <elementProp name="" elementType="Header">
                      <stringProp name="Header.name">x-cloud-customerid</stringProp>
                      <stringProp name="Header.value">${customerId}</stringProp>
                    </elementProp>
                    <elementProp name="" elementType="Header">
                      <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                      <stringProp name="Header.value">${categoryTypeId}</stringProp>
                    </elementProp>
                    <elementProp name="" elementType="Header">
                      <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                      <stringProp name="Header.value">${parentCategoryId}</stringProp>
                    </elementProp>
                    <elementProp name="" elementType="Header">
                      <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                      <stringProp name="Header.value">${baseTimezone}</stringProp>
                    </elementProp>
                    <elementProp name="" elementType="Header">
                      <stringProp name="Header.name">X-Cloud-Context-Timezone</stringProp>
                      <stringProp name="Header.value">${baseTimezone}</stringProp>
                    </elementProp>
                    <elementProp name="" elementType="Header">
                      <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                      <stringProp name="Header.value">${clientTimeZone}</stringProp>
                    </elementProp>
                  </collectionProp>
                </HeaderManager>
                <hashTree/>
                <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Customer Name Extractor" enabled="true">
                  <stringProp name="JSONPostProcessor.referenceNames">customerNames</stringProp>
                  <stringProp name="JSONPostProcessor.jsonPathExprs"> $._embedded.eventGroups[*].events[*].eventName</stringProp>
                  <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                  <stringProp name="JSONPostProcessor.defaultValues">NOT_FOUND</stringProp>
                </JSONPostProcessor>
                <hashTree/>
                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Customer Name PostProcessor" enabled="true">
                  <stringProp name="script">

def rand = java.util.concurrent.ThreadLocalRandom.current()

def markCreationSkipped = {
    vars.put(&quot;skipEventCreation&quot;, &quot;true&quot;)
    vars.put(&quot;requestCreated&quot;, &quot;false&quot;)
    vars.remove(&quot;requestId&quot;)
}

// ===== CUSTOMER SELECTION =====
// userDefinedCustomerName = value from UDV/-J only (never the auto-picked runtime customerName).
// If set by the user, check duplicate against API. If empty, pick a unique random customer per iteration.

def userCustomer = vars.get(&quot;userDefinedCustomerName&quot;)?.trim()

// STEP 1: Always extract existing customers from API response
def existingCustomers = []
def matchCount = vars.get(&quot;customerNames_matchNr&quot;)?.toInteger() ?: 0

log.info(&quot;Extracted customer names count from API: ${matchCount}&quot;)

if (matchCount &gt; 0) {
    for (int i = 1; i &lt;= matchCount; i++) {
        def cName = vars.get(&quot;customerNames_${i}&quot;)
        if (cName &amp;&amp; cName.trim() != &quot;&quot; &amp;&amp; cName != &quot;NOT_FOUND&quot;) {
            existingCustomers.add(cName.trim())
        }
    }
    existingCustomers = existingCustomers.unique()
    log.info(&quot;Existing customers: ${existingCustomers.size()}&quot;)
    log.info(&quot;Existing customer list: ${existingCustomers}&quot;)
} else {
    log.info(&quot;No existing customers found&quot;)
}

vars.put(&quot;existingCustomerList&quot;, existingCustomers.join(&quot;,&quot;))

// STEP 2: If user has set customerName, apply duplicate check
if (userCustomer) {

    // Duplicate check against existing customers in API response
    def checkDup = vars.get(&quot;checkDuplicateCustomer&quot;) ?: &quot;true&quot;
    if (checkDup == &quot;true&quot; &amp;&amp; existingCustomers.contains(userCustomer)) {
        markCreationSkipped()
        vars.put(&quot;availableCustomerCount&quot;, &quot;0&quot;)
        log.warn(&quot;Customer &apos;${userCustomer}&apos; already exists - Request creation SKIPPED&quot;)
    } else {
        vars.put(&quot;customerName&quot;, userCustomer)
        vars.put(&quot;skipEventCreation&quot;, &quot;false&quot;)
        vars.put(&quot;availableCustomerCount&quot;, &quot;1&quot;)
        log.info(&quot;Customer &apos;${userCustomer}&apos; not found in existing list - proceeding with creation&quot;)
    }
    log.info(&quot;----- Terminated: Customer Name PostProcessor (user-defined customerName) -----&quot;)
    return
}

// STEP 3: customerName is empty - pick a unique random customer from full list
String[] allCustomers = props.get(&quot;fn_getCustomers&quot;)(vars)
log.info(&quot;customerName not set - using full customer list (${allCustomers.length} companies)&quot;)

def checkDuplicate = vars.get(&quot;checkDuplicateCustomer&quot;) ?: &quot;true&quot;
def duplicateFromDate = vars.get(&quot;duplicateCustomerFromDate&quot;) ?: &quot;&quot;
def duplicateToDate = vars.get(&quot;duplicateCustomerToDate&quot;) ?: &quot;&quot;

log.info(&quot;Check Duplicate Customer: ${checkDuplicate}&quot;)
log.info(&quot;Duplicate Check From Date: ${duplicateFromDate}&quot;)
log.info(&quot;Duplicate Check To Date: ${duplicateToDate}&quot;)

if (checkDuplicate.equalsIgnoreCase(&quot;false&quot;)) {
    // Duplicates allowed - pick any random customer
    String selectedCustomer = allCustomers[rand.nextInt(allCustomers.length)]
    vars.put(&quot;customerName&quot;, selectedCustomer)
    vars.put(&quot;skipEventCreation&quot;, &quot;false&quot;)
    vars.put(&quot;availableCustomerCount&quot;, allCustomers.length.toString())
    log.info(&quot;DUPLICATE CHECK DISABLED - Selected random customer: ${selectedCustomer}&quot;)
    return
}

// STEP 4: Filter out existing customers and pick a unique one
def availableCustomers = allCustomers.findAll { !existingCustomers.contains(it) }

log.info(&quot;Total customers in list: ${allCustomers.length}&quot;)
log.info(&quot;Existing customers (to exclude): ${existingCustomers.size()}&quot;)
log.info(&quot;Available customers (unique): ${availableCustomers.size()}&quot;)

vars.put(&quot;availableCustomerCount&quot;, availableCustomers.size().toString())

if (availableCustomers.size() &gt; 0) {
    String selectedCustomer = availableCustomers[rand.nextInt(availableCustomers.size())]
    vars.put(&quot;customerName&quot;, selectedCustomer)
    vars.put(&quot;skipEventCreation&quot;, &quot;false&quot;)
    log.info(&quot;SUCCESS - Selected unique customer: ${selectedCustomer}&quot;)
    log.info(&quot;Remaining available customers: ${availableCustomers.size() - 1}&quot;)
} else {
    vars.put(&quot;customerName&quot;, &quot;&quot;)
    markCreationSkipped()
    log.warn(&quot;NO AVAILABLE CUSTOMERS - All ${allCustomers.length} customers already exist!&quot;)
    log.warn(&quot;Date range checked: ${duplicateFromDate} to ${duplicateToDate}&quot;)
    log.warn(&quot;Action: Request creation SKIPPED&quot;)
}

log.info(&quot;Skip Event Creation: ${vars.get(&apos;skipEventCreation&apos;)}&quot;)
