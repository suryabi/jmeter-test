                <hashTree>
                  <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                    <collectionProp name="HeaderManager.headers">
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-customerid</stringProp>
                        <stringProp name="Header.value">${customerId}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                        <stringProp name="Header.value">${categoryTypeId}</stringProp>
                      </elementProp>
                      <elementProp name="X-Cloud-Client-Timezone" elementType="Header">
                        <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                        <stringProp name="Header.value">${clientTimeZone}</stringProp>
                      </elementProp>
                    </collectionProp>
                  </HeaderManager>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Category PostProcessor" enabled="true">
                    <stringProp name="script">

// Check if test is aborting due to previous validation failure
if (props.get(&quot;fn_checkAbort&quot;)(vars, prev)) return

// Parse JSON response
def response = prev.getResponseDataAsString()
def json = new groovy.json.JsonSlurper().parseText(response)

// Extract categories from response
def categories = json._embedded?.categories ?: []

// Validate categories exist
if (categories.isEmpty()) {
    log.error(&quot;No categories found!&quot;)
    return
}

// Get preferred category from User Defined Variables
def preferredCategory = vars.get(&quot;category&quot;)?.trim()
def selectedCategory = null

// Search for preferred category if specified
if (preferredCategory) {
    selectedCategory = categories.find {
        it.uniqueId?.equalsIgnoreCase(preferredCategory)
    }

    if (selectedCategory) {
        log.info(&quot;Category: &quot; + preferredCategory)
    } else {
        def availableCategories = categories.collect { it.uniqueId + &quot; (&quot; + (it.categoryName ?: &quot;&quot;) + &quot;)&quot; }.join(&quot;, &quot;)
        props.get(&quot;fn_abortNotFound&quot;)(vars, prev, &quot;category&quot;, preferredCategory, availableCategories, ctx)
        return
    }
}

// Use selected category (already validated)
// Store Category Variables
vars.put(&quot;categoryId&quot;, selectedCategory.uniqueId ?: &quot;&quot;)
vars.put(&quot;categoryName&quot;, selectedCategory.categoryName ?: &quot;&quot;)

// Store Module Variables (first module from selected category)
def module = selectedCategory.modules?.getAt(0)
vars.put(&quot;newRequestModuleId&quot;, module?.uniqueId ?: &quot;&quot;)
vars.put(&quot;newRequestModuleName&quot;, module?.moduleName ?: &quot;&quot;)

// Update sampler label with selected category
props.get(&quot;fn_appendSamplerLabel&quot;)(prev, vars.get(&quot;categoryName&quot;))

// Log Selected Details
log.info(&quot;Category: &quot; + vars.get(&quot;categoryName&quot;) + &quot; | ID: &quot; + vars.get(&quot;categoryId&quot;))

log.info(&quot;----- Terminated: Category Selection PostProcessor -----&quot;)</stringProp>
