                                    <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Activity Type Masters Extractor" enabled="true">
                                      <stringProp name="script">

def currentMasterTypeId = vars.get(&quot;currentActivityMasterTypeId&quot;)
def masterTypeName = vars.get(&quot;currentActivityMasterTypeName&quot;) ?: &quot;Master&quot;

def response = prev.getResponseDataAsString()

if (!response || response.trim().isEmpty()) {
    log.warn(&quot;Empty response - no masters found&quot;)
    vars.put(&quot;mastersFor_&quot; + currentMasterTypeId + &quot;_count&quot;, &quot;0&quot;)
        return
}

try {
    def json = new groovy.json.JsonSlurper().parseText(response)

    def masters = json._embedded?.masters ?: json.masters ?: (json instanceof List ? json : [])

    def count = 0
    masters.each { master -&gt;
        count++

        def data = master.data ?: master

        // FIX: BriefingIQ always places uniqueId at the TOP-LEVEL master object, never inside data.
        // Extracting from data first caused wrong/null IDs, breaking parent-child linking entirely.
        def uniqueId = (master.uniqueId ?: master.id ?: data.uniqueId ?: data.id ?: &quot;&quot;)?.toString()?.trim()

        def displayName = (master.metaData?.searchDisplayText ?:
                          data.topicName ?: data.textField1 ?:
                          data.searchDisplayText ?: data.displayName ?:
                          data.masterName ?: data.name ?:
                          master.displayName ?: master.name ?:
                          uniqueId)?.toString()?.trim()  // Fallback to ID if no name found

        if (!uniqueId) {
            log.warn(&quot;   [${count}] Skipping master with no uniqueId: ${master}&quot;)
            count--
            return
        }

        def varPrefix = &quot;mastersFor_&quot; + currentMasterTypeId + &quot;_&quot; + count
        vars.put(varPrefix + &quot;_id&quot;, uniqueId)
        vars.put(varPrefix + &quot;_name&quot;, displayName)
        // FIX: parentId comes from master.parent.uniqueId (top-level), same as main MasterType PostProcessor
        def parentId = (master?.parent?.uniqueId ?: master?.parent?.id)?.toString()?.trim() ?: &quot;&quot;
        vars.put(varPrefix + &quot;_parentId&quot;, parentId)
        // Store parent.isActive so root-level filter can exclude inactive-parent duplicates
        def parentIsActive = master?.parent?.isActive
        vars.put(varPrefix + &quot;_parentIsActive&quot;, parentIsActive == null ? &quot;true&quot; : parentIsActive.toString())

        if (count &lt;= 5) {
                    }
    }

    if (count &gt; 5) {
            }

    vars.put(&quot;mastersFor_&quot; + currentMasterTypeId + &quot;_count&quot;, count.toString())
    } catch (Exception e) {
    log.error(&quot;Error parsing masters: ${e.message}&quot;)
    vars.put(&quot;mastersFor_&quot; + currentMasterTypeId + &quot;_count&quot;, &quot;0&quot;)
}
</stringProp>
