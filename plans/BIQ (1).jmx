                                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Check Existing Presenters PostProcessor" enabled="true">
                                    <stringProp name="script">// Check if presenters already exist on the request via API
// If presenters found:
//   - Set presentersAddedToRequest=true  → skips the request-level POST
//   - Populate selectedPresenterId_N / selectedPresenterCount from GET response
//     so topic-level Prepare Participant Payloads still has presenters to assign
def alreadyHasPresenters = false
try {
    def response = prev.getResponseDataAsString()
    if (response &amp;&amp; response.trim().startsWith(&quot;{&quot;)) {
        def json = new groovy.json.JsonSlurper().parseText(response)
        def resources = json._embedded?.resources ?: []
        if (resources.size() &gt; 0) {
            alreadyHasPresenters = true
            log.info(&quot;GET Existing Presenters: ${resources.size()} presenter(s) already on request — skipping POST, loading for topic assignment&quot;)

            // Populate selectedPresenterId_N variables so Prepare Participant Payloads works
            int count = 0
            resources.each { res -&gt;
                def uid = res.uniqueId ?: res.id ?: &quot;&quot;
                def name = res.metaData?.searchDisplayText ?: res.name ?: &quot;Presenter&quot;
                def dataMap = res.data ?: [:]
                def email = dataMap.primaryEmail ?: dataMap.textField4 ?: &quot;&quot;

                if (uid &amp;&amp; email.toLowerCase().contains(&quot;allianceit.com&quot;)) {
                    count++
                    vars.put(&quot;selectedPresenterId_&quot; + count, uid)
                    vars.put(&quot;selectedPresenterName_&quot; + count, name)
                    vars.put(&quot;selectedPresenterData_&quot; + count, groovy.json.JsonOutput.toJson(dataMap))
                    log.info(&quot;Loaded existing presenter ${count}: ${uid} (${name})&quot;)
                } else if (uid) {
                    log.info(&quot;SKIPPED existing presenter: ${name} (email: ${email}) — not allianceit.com&quot;)
                }
            }
            vars.put(&quot;selectedPresenterCount&quot;, count.toString())
            log.info(&quot;GET Existing Presenters: ${count} presenter(s) loaded into selectedPresenterId variables for topic assignment&quot;)
        } else {
            log.info(&quot;GET Existing Presenters: no presenters on request — will add from JMeter&quot;)
        }
    } else {
        log.warn(&quot;GET Existing Presenters: unexpected response format — will attempt POST&quot;)
    }
} catch (Exception e) {
    log.warn(&quot;GET Existing Presenters: could not parse response (${e.message}) — will attempt POST&quot;)
}
vars.put(&quot;presentersAddedToRequest&quot;, alreadyHasPresenters ? &quot;true&quot; : &quot;false&quot;)
</stringProp>
