                                      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Pick Activity State Action Iterations" enabled="true">
                                        <stringProp name="script">if (vars.get(&quot;skipActivityStateAction&quot;) == &quot;true&quot;) {
    vars.put(&quot;activityStateActionLoopCount&quot;, &quot;0&quot;)
    log.info(&quot;Activity State Action Iterations: 0 (no valid actions)&quot;)
    return
}

def iterationsConfig = vars.get(&quot;maxIterationCount&quot;)?.trim() ?: &quot;2&quot;
def options = iterationsConfig.split(&quot;,&quot;)*.trim().findAll { it.isInteger() &amp;&amp; it.toInteger() &gt;= 0 }.collect { it.toInteger() }
if (options.isEmpty()) {
    log.info(&quot;maxIterationCount has no valid values (must be &gt;= 0) - defaulting to 2&quot;)
    options = [2]
}
def randomIterations = options[java.util.concurrent.ThreadLocalRandom.current().nextInt(options.size())]

def remainingIterations = Math.max(0, randomIterations - 1)
vars.put(&quot;activityStateActionLoopCount&quot;, remainingIterations.toString())
log.info(&quot;Activity State Action Iterations: ${randomIterations} total, ${remainingIterations} remaining for loop (picked from [${iterationsConfig}])&quot;)</stringProp>
