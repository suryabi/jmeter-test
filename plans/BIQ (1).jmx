                          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract Existing Activity ModuleIds" enabled="true">
                            <stringProp name="script">

try {
    def response = prev.getResponseDataAsString()
    def dayIdx = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;

    def existingModuleIds = [] as Set

    if (response &amp;&amp; response.trim()) {
        def json = new groovy.json.JsonSlurper().parseText(response)

        def activities = []
        if (json instanceof List) {
            activities = json
        } else if (json instanceof Map) {
            activities = json._embedded?.resourceTimeSlots ?: json._embedded?.activities ?: 
                         json._embedded?.activityModels ?: json.content ?: []
        }

        activities.each { activity -&gt;
            def moduleId = activity.moduleId ?: activity.module?.uniqueId ?: &quot;&quot;
            if (moduleId) {
                existingModuleIds.add(moduleId)
            }
        }

        log.info(&quot;Day ${dayIdx}: Found ${activities.size()} existing activities&quot;)
    }

    def moduleIdStr = existingModuleIds.join(&quot;,&quot;)
    vars.put(&quot;existingActivityModuleIds&quot;, moduleIdStr)

    log.info(&quot;Day ${dayIdx}: ${existingModuleIds.size()} existing activity moduleIds: ${moduleIdStr}&quot;)

    // NOTE: skipDayActivities is intentionally never set to &quot;true&quot; here anymore.
    // This endpoint returns whatever already occupies the room/date (e.g. leftover
    // data from a previous run), with no field tying a slot back to THIS request -
    // so &quot;an activity with a matching moduleId exists somewhere in this room/date&quot;
    // is not proof that THIS request already has its Day N activities. Using it to
    // kill the entire room loop caused real days to be silently skipped. We keep the
    // comparison purely for visibility/logging; it no longer gates the room loop.
    vars.put(&quot;skipDayActivities&quot;, &quot;false&quot;)

    if (existingModuleIds.size() &gt; 0) {
        def userModuleIdsStr = vars.get(&quot;activityModuleId_ALL&quot;) ?: &quot;&quot;
        def userModuleIds = userModuleIdsStr.split(&quot;,&quot;).collect { it.trim() }.findAll { it } as Set

        if (userModuleIds.isEmpty()) {
            log.info(&quot;Activities exist in this room/date but no user activity modules configured - proceeding anyway (skip disabled)&quot;)
        } else {
            def missingModules = userModuleIds.findAll { !existingModuleIds.contains(it) }

            if (missingModules.isEmpty()) {
                log.info(&quot;All ${userModuleIds.size()} user activity modules already present elsewhere for Day ${dayIdx} - proceeding anyway (skip disabled, ownership unverifiable)&quot;)
            } else {
                log.info(&quot;${missingModules.size()} of ${userModuleIds.size()} user activity modules not found for Day ${dayIdx} - proceeding to create&quot;)
                log.info(&quot;  Existing: ${existingModuleIds}&quot;)
                log.info(&quot;  Missing:  ${missingModules}&quot;)
            }
        }
    } else {
        vars.put(&quot;skipDayActivities&quot;, &quot;false&quot;)
    }
} catch (Exception e) {
    log.warn(&quot;Error checking existing activities: ${e.message}&quot;)
    vars.put(&quot;existingActivityModuleIds&quot;, &quot;&quot;)
    vars.put(&quot;skipDayActivities&quot;, &quot;false&quot;)
}</stringProp>
                            <stringProp name="scriptLanguage">groovy</stringProp>
                            <stringProp name="parameters"></stringProp>
                            <stringProp name="filename"></stringProp>
                            <stringProp name="cacheKey">true</stringProp>
                          </JSR223PostProcessor>
                          <hashTree/>
                          <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                          <hashTree/>
                        </hashTree>
                        <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ Room Loop" enabled="true">
                          <stringProp name="WhileController.condition">${__groovy(
// When rooms exist: loop once per room (counter &lt; roomCount).
// When no rooms (agenda-only): loop exactly once (counter &lt; 1) so activities are created with resourceId=null.
def skipDay = vars.get(&quot;skipDayActivities&quot;) == &quot;true&quot;
def counter = vars.get(&quot;roomLoopCounter&quot;)?.toInteger() ?: 0
def roomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
def effectiveMax = (roomCount &gt; 0) ? roomCount : 1
(!skipDay &amp;&amp; counter &lt; effectiveMax)
)}</stringProp>
                        </WhileController>
                        <hashTree>
                          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Next Room" enabled="true">
                            <stringProp name="script">SampleResult.setIgnore()

def counter = (vars.get(&quot;roomLoopCounter&quot;)?.toInteger() ?: 0) + 1
vars.put(&quot;roomLoopCounter&quot;, counter.toString())
vars.put(&quot;currentRoomCounter&quot;, counter.toString())

def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0

if (selectedRoomCount == 0) {
    // Agenda-only mode: no rooms for this day - run once with empty roomId
    if (counter &gt; 1) {
        log.info(&quot;[Room Loop OUTER] Agenda-only mode - already ran once, stopping&quot;)
        vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)
        vars.put(&quot;currentRoomId&quot;, &quot;&quot;)
        vars.put(&quot;currentRoomName&quot;, &quot;&quot;)
        return
    }
    log.info(&quot;[Room Loop OUTER] Agenda-only mode - no rooms for this day, running once with null resourceId&quot;)
    vars.put(&quot;currentRoomId&quot;, &quot;&quot;)
    vars.put(&quot;currentRoomName&quot;, &quot;&quot;)
    vars.put(&quot;skipActivityModule&quot;, &quot;false&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;false&quot;)
} else if (counter &gt; selectedRoomCount) {
    log.error(&quot;[Room Loop OUTER] CRITICAL: Room counter (${counter}) exceeds selectedRoomCount (${selectedRoomCount})! Stopping.&quot;)
    vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)
    vars.put(&quot;currentRoomId&quot;, &quot;&quot;)
    vars.put(&quot;currentRoomName&quot;, &quot;INVALID&quot;)
    return
}

def currentRoomId   = (selectedRoomCount &gt; 0) ? (vars.get(&quot;selectedRoomId_&quot; + counter) ?: &quot;&quot;) : &quot;&quot;
def currentRoomName = (selectedRoomCount &gt; 0) ? (vars.get(&quot;selectedRoomName_&quot; + counter) ?: &quot;Room ${counter}&quot;) : &quot;&quot;

if (selectedRoomCount &gt; 0 &amp;&amp; (!currentRoomId || currentRoomId.trim().isEmpty())) {
    log.error(&quot;[Room Loop OUTER] CRITICAL: selectedRoomId_${counter} is empty or null!&quot;)
    currentRoomId   = &quot;&quot;
    currentRoomName = &quot;INVALID_ROOM&quot;
    vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)
}

vars.put(&quot;currentRoomId&quot;,   currentRoomId)
vars.put(&quot;currentRoomName&quot;, currentRoomName)

vars.put(&quot;skipActivityModule&quot;,    &quot;false&quot;)
vars.put(&quot;stopRoomActivityLoop&quot;,  &quot;false&quot;)
vars.put(&quot;gapFillActive&quot;,         &quot;false&quot;)
vars.put(&quot;ZoomCount&quot;,             &quot;0&quot;)

def activityTypesAll = vars.get(&quot;activityType_ALL&quot;) ?: &quot;&quot;
if (activityTypesAll) {
    activityTypesAll.split(&quot;,&quot;).each { actType -&gt;
        vars.remove(&quot;roomProcessedForActivityType_&quot; + actType.trim())
    }
}

def topicType   = vars.get(&quot;topicTypeName&quot;)
def blockedType = vars.get(&quot;blockedTypeName&quot;)
[topicType, blockedType].each { actType -&gt;
    vars.remove(&quot;roomProcessedForActivityType_&quot; + actType)
}

// ✅ FIX: Use ActivityDayCount as fallback for currentDayIndex so the prop key
// matches what Select Current Room stored during Logistics (which uses ActivityDayCount).
// When currentDayIndex is null/missing in early Agenda context, without the fallback
// the lookup returns null and roomStartTime/roomEndTime remain at whatever the last
// Logistics day wrote globally — causing all rooms to show the wrong (last) day&apos;s date.
def dayIndex     = vars.get(&quot;currentDayIndex&quot;) ?: vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def roomCount    = vars.get(&quot;selectedRoomCount&quot;) ?: &quot;?&quot;
def activityDate = vars.get(&quot;activityDate_&quot; + dayIndex)?.take(10) ?: &quot;Unknown&quot;
def roomKey      = &quot;Day&quot; + dayIndex + &quot;_Room&quot; + counter

// ✅ FIX: Restore THIS room&apos;s own buffer-adjusted start/end time (persisted in
// Select Current Room) instead of leaving roomStartTime/roomEndTime at whatever
// value was last set by room creation. Without this, every room except the very
// last one ever created shares one wrong window for slot selection/gap-fill.
//
// ✅ FIX 2 (SmartSlot wrong date): Restore TIME-ONLY values (HH:mm:ss, no date prefix)
// so the SmartSlot window is date-neutral. Full ISO datetimes stored from the Logistics
// phase carry the Logistics day&apos;s date. When restored verbatim into roomStartTime/End,
// the SmartSlot log shows e.g. 2026-07-03T07:30:00 for Day-1 rooms because Day-3 was
// the last Logistics day processed. Time-only strings (07:30:00) let SmartSlot apply
// the correct activityDate_ date for each Agenda day independently.
if (currentRoomId) {
    // Prefer time-only variant; fall back to full ISO if time-only prop not yet written
    def restoredStart = System.getProperty(&quot;jmeter.roomTimeOnly.Day&quot; + dayIndex + &quot;_&quot; + currentRoomId + &quot;_start&quot;)
                     ?: System.getProperty(&quot;jmeter.roomTime.Day&quot;     + dayIndex + &quot;_&quot; + currentRoomId + &quot;_start&quot;)
    def restoredEnd   = System.getProperty(&quot;jmeter.roomTimeOnly.Day&quot; + dayIndex + &quot;_&quot; + currentRoomId + &quot;_end&quot;)
                     ?: System.getProperty(&quot;jmeter.roomTime.Day&quot;     + dayIndex + &quot;_&quot; + currentRoomId + &quot;_end&quot;)
    if (restoredStart) vars.put(&quot;roomStartTime&quot;, restoredStart)
    if (restoredEnd)   vars.put(&quot;roomEndTime&quot;, restoredEnd)
    log.info(&quot;[RoomBuffer] Restored window for ${roomKey} (roomId=${currentRoomId}, dayIndex=${dayIndex}): ${restoredStart}-${restoredEnd}&quot;)
}

def existingUsedSlots = vars.get(&quot;usedSlotRanges_&quot; + roomKey) ?: &quot;&quot;
if (existingUsedSlots &amp;&amp; currentRoomId) {
    vars.put(&quot;persistedSlots_Day&quot; + dayIndex + &quot;_&quot; + currentRoomId, existingUsedSlots)
    log.info(&quot;Persisted usedSlotRanges for ${roomKey} (roomId=${currentRoomId}): ${existingUsedSlots}&quot;)
}

// Persist this room&apos;s own per-activity-type occupancy too (mirrors the shared
// usedSlotRanges persistence above), so re-visiting the same physical room later
// in this thread still respects same-type exclusivity without resurrecting
// cross-type blocking.
if (currentRoomId) {
    activityTypesAll.split(&quot;,&quot;).collect { it.trim() }.findAll { it }.each { actType -&gt;
        def existingTypeRanges = vars.get(&quot;usedActivityRanges_${actType}_&quot; + roomKey) ?: &quot;&quot;
        if (existingTypeRanges) {
            vars.put(&quot;persistedActivityRanges_${actType}_Day&quot; + dayIndex + &quot;_&quot; + currentRoomId, existingTypeRanges)
        }
    }
}

vars.remove(&quot;reservedBlockedTimes_&quot;   + roomKey)
vars.remove(&quot;blockedRangesGenerated_&quot; + roomKey)
vars.remove(&quot;usedSlotRanges_&quot;         + roomKey)

activityTypesAll.split(&quot;,&quot;).collect { it.trim() }.findAll { it }.each { actType -&gt;
    vars.remove(&quot;usedTimings_${actType}_&quot; + roomKey)
    vars.remove(&quot;usedActivityRanges_${actType}_&quot; + roomKey)
}

vars.remove(&quot;usedCateringTimes_&quot;     + roomKey)
vars.remove(&quot;usedCateringDurations_&quot; + roomKey)

if (currentRoomId) {
    def persistedSlots = vars.get(&quot;persistedSlots_Day&quot; + dayIndex + &quot;_&quot; + currentRoomId) ?: &quot;&quot;
    if (persistedSlots) {
        vars.put(&quot;usedSlotRanges_&quot; + roomKey, persistedSlots)
        log.info(&quot;Pre-populated usedSlotRanges for ${roomKey} from PERSISTED room-specific slots (roomId=${currentRoomId}): ${persistedSlots}&quot;)
    } else {
        log.info(&quot;No persisted slots found for ${roomKey} (roomId=${currentRoomId}) - usedSlotRanges starts empty (first user)&quot;)
    }

    activityTypesAll.split(&quot;,&quot;).collect { it.trim() }.findAll { it }.each { actType -&gt;
        def persistedTypeRanges = vars.get(&quot;persistedActivityRanges_${actType}_Day&quot; + dayIndex + &quot;_&quot; + currentRoomId) ?: &quot;&quot;
        if (persistedTypeRanges) {
            vars.put(&quot;usedActivityRanges_${actType}_&quot; + roomKey, persistedTypeRanges)
            log.info(&quot;Pre-populated usedActivityRanges for ${actType}/${roomKey} from PERSISTED room-specific ranges (roomId=${currentRoomId}): ${persistedTypeRanges}&quot;)
        }
    }

    // ✅ FIX: Re-inject roomBufferMinutes zones from props after clearing usedSlotRanges.
    // Buffer zones are stored in System props (not vars) in Register Room Buffer Zones
    // so they survive across samplers for the full test duration.
    def bufferPropKey = &quot;jmeter.roomBuffer.Day&quot; + dayIndex + &quot;_&quot; + currentRoomId
    def bufferZones = System.getProperty(bufferPropKey) ?: &quot;&quot;
    if (bufferZones) {
        def currentUsed = vars.get(&quot;usedSlotRanges_&quot; + roomKey) ?: &quot;&quot;
        def existingList = currentUsed ? currentUsed.split(&quot;;&quot;).toList() : []
        bufferZones.split(&quot;;&quot;).each { bz -&gt;
            if (bz &amp;&amp; !existingList.contains(bz)) {
                existingList.add(bz)
            }
        }
        vars.put(&quot;usedSlotRanges_&quot; + roomKey, existingList.join(&quot;;&quot;))
        log.info(&quot;[RoomBuffer] Re-injected buffer zones for ${roomKey} (roomId=${currentRoomId}): ${bufferZones}&quot;)
    } else {
        log.info(&quot;[RoomBuffer] No buffer zones found in props for roomId=${currentRoomId} (Day${dayIndex}) - skipping re-inject&quot;)
    }
}

SampleResult.setResponseMessage(&quot;Room ${counter}/${roomCount}: ${currentRoomName}&quot;)</stringProp>
                            <stringProp name="scriptLanguage">groovy</stringProp>
