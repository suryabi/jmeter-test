// Populates Opportunity form fields.
def _fn_opportunityPreProcessor = { varsRef, logRef -&gt;
    // For multi-entry CREATE forms, always use fresh data from PreProcessors
    def isCreatePath = (varsRef.get(&quot;currentFormDataId&quot;) == null || varsRef.get(&quot;currentFormDataId&quot;) == &quot;&quot;)
    if (isCreatePath) {
        varsRef.put(&quot;existingFormData&quot;, &quot;{}&quot;)
    }

    def rand = java.util.concurrent.ThreadLocalRandom.current()
    def currentEntryIndex = (varsRef.get(&quot;currentEntryIndex&quot;) ?: &quot;1&quot;).toInteger()

    // ============ Random Number Generators (FRESH per entry) - using shared functions ============
    def random4 = props.get(&quot;fn_random4&quot;)()
    def random5 = props.get(&quot;fn_random5&quot;)()
    def random6 = props.get(&quot;fn_random6&quot;)()

    // ============ Revenue Fields (unique per entry) ============
    varsRef.put(&quot;opportunityId&quot;, String.valueOf(random4))
    varsRef.put(&quot;initialOpportunityRevenue&quot;, String.valueOf(props.get(&quot;fn_random4&quot;)()))
    varsRef.put(&quot;opportunityRevenue&quot;, String.valueOf(props.get(&quot;fn_random5&quot;)()))
    varsRef.put(&quot;closedOpportunityRevenue&quot;, String.valueOf(props.get(&quot;fn_random6&quot;)()))

    // ============ Date Fields ============
    def startDateStr = varsRef.get(&quot;startDate&quot;) ?: &quot;&quot;
    varsRef.put(&quot;openedDate&quot;, startDateStr)

    // Random closed date (1-30 days after open date)
    try {
        def sdf = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd&quot;)
        if (startDateStr) {
            def openDate = sdf.parse(startDateStr)
            def daysToAdd = rand.nextInt(1, 31)
            def calendar = Calendar.getInstance()
            calendar.setTime(openDate)
            calendar.add(Calendar.DAY_OF_MONTH, daysToAdd)
            varsRef.put(&quot;closedDate&quot;, sdf.format(calendar.getTime()))
        }
    } catch (Exception e) {
        varsRef.put(&quot;closedDate&quot;, varsRef.get(&quot;closedDate&quot;) ?: &quot;&quot;)
    }

    // Quarter of Close
    String[] quarters = [&quot;Q1&quot;, &quot;Q2&quot;, &quot;Q3&quot;, &quot;Q4&quot;]
    varsRef.put(&quot;quarterOfClose&quot;, quarters[rand.nextInt(quarters.length)])

    // ============ Status &amp; Probability ============
    def statusProbabilityMap = [
        &quot;Open&quot;        : [&quot;10&quot;, &quot;20&quot;, &quot;25&quot;],
        &quot;In Progress&quot; : [&quot;30&quot;, &quot;40&quot;, &quot;50&quot;],
        &quot;Pending&quot;     : [&quot;50&quot;, &quot;60&quot;, &quot;65&quot;],
        &quot;On Hold&quot;     : [&quot;20&quot;, &quot;30&quot;, &quot;40&quot;],
        &quot;Closed Won&quot;  : [&quot;100&quot;],
        &quot;Closed Lost&quot; : [&quot;0&quot;]
    ]

    String[] statuses = statusProbabilityMap.keySet() as String[]
    String randomStatus = statuses[rand.nextInt(statuses.length)]
    varsRef.put(&quot;oppStatus&quot;, randomStatus)

    String[] matchingProbabilities = statusProbabilityMap[randomStatus]
    String randomProbability = matchingProbabilities[rand.nextInt(matchingProbabilities.length)]
    varsRef.put(&quot;probabilityOfClose&quot;, randomProbability)

    // ============ isPrimary Logic ============
    boolean isPrimaryFlag = (currentEntryIndex == 1)
    varsRef.put(&quot;isPrimary&quot;, String.valueOf(isPrimaryFlag))

    logRef.info(&quot;----- Terminated: Opportunity Form PostProcessor -----&quot;)
}
props.put(&quot;fn_opportunityPreProcessor&quot;, _fn_opportunityPreProcessor)


