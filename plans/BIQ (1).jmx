                  <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
                    <collectionProp name="Arguments.arguments"/>
                  </elementProp>
                  <stringProp name="HTTPSampler.domain"></stringProp>
                  <stringProp name="HTTPSampler.port"></stringProp>
                  <stringProp name="HTTPSampler.protocol"></stringProp>
                  <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                  <stringProp name="HTTPSampler.path">/${contextname}/api/timezones</stringProp>
                  <stringProp name="HTTPSampler.method">GET</stringProp>
                  <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
                  <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                  <boolProp name="HTTPSampler.use_keepalive">false</boolProp>
                  <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                  <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                  <stringProp name="HTTPSampler.connect_timeout">30000</stringProp>
                  <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
                </HTTPSamplerProxy>
                <hashTree>
                  <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                    <collectionProp name="HeaderManager.headers">
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-customerid</stringProp>
                        <stringProp name="Header.value">${customerId}</stringProp>
                      </elementProp>
                      <elementProp name="X-Cloud-Client-Timezone" elementType="Header">
                        <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                        <stringProp name="Header.value">${clientTimeZone}</stringProp>
                      </elementProp>
                    </collectionProp>
                  </HeaderManager>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Timezone PostProcessor" enabled="true">
                    <stringProp name="script">

log.info(&quot;----- Started: Timezone PostProcessor -----&quot;)

// Parse JSON response
def response = prev.getResponseDataAsString()
def json = new groovy.json.JsonSlurper().parseText(response)

// Extract timezone models from response
def timezones = json._embedded?.timeZoneCodeModels ?: []

if (timezones.isEmpty()) {
    log.error(&quot;No timezones found in response!&quot;)
    return
}

log.info(&quot;Total timezones found: &quot; + timezones.size())

// Store timezone count
vars.put(&quot;tz_count&quot;, timezones.size().toString())

// Store each timezone&apos;s key, value, and zoneName as indexed variables
// Also build a lookup map by zoneName for quick access
def tzMap = [:]  // zoneName -&gt; [key, value]

timezones.eachWithIndex { tz, idx -&gt;
    def tzKey = tz.key ?: &quot;&quot;
    def tzValue = tz.value ?: &quot;&quot;
    def tzZoneName = tz.zoneName ?: &quot;&quot;

    // Store as indexed variables (1-based): tz_key_1, tz_value_1, tz_zoneName_1, etc.
    def index = (idx + 1).toString()
    vars.put(&quot;tz_key_&quot; + index, tzKey)
    vars.put(&quot;tz_value_&quot; + index, tzValue)
    vars.put(&quot;tz_zoneName_&quot; + index, tzZoneName)

    // Build lookup map by zoneName
    if (tzZoneName) {
        tzMap[tzZoneName] = [key: tzKey, value: tzValue]
    }
}

// Store the timezone map as a JMeter property for cross-thread access
props.put(&quot;timezoneMap&quot;, tzMap)

// Randomly select a timezone for this request
def rand = java.util.concurrent.ThreadLocalRandom.current()
def randomIndex = rand.nextInt(timezones.size())
def selectedTz = timezones[randomIndex]

def requestTimeZone = selectedTz.zoneName ?: &quot;&quot;
def requestTimeZoneKey = selectedTz.key ?: &quot;&quot;

vars.put(&quot;requestTimeZone&quot;, requestTimeZone)
vars.put(&quot;requestTimeZoneKey&quot;, requestTimeZoneKey)

def requestTimeZoneCountry = selectedTz.country ?: &quot;&quot;
log.info(&quot;Selected requestTimeZone: &quot; + requestTimeZoneCountry + &quot; (&quot; + requestTimeZone + &quot;) | key=&quot; + requestTimeZoneKey)

// Update sampler label with selected timezone - Country (ZoneName)
prev.setSampleLabel(prev.getSampleLabel() + &quot; - &quot; + requestTimeZoneCountry + &quot; (&quot; + requestTimeZone + &quot;)&quot;)

log.info(&quot;Timezone PostProcessor: Stored &quot; + timezones.size() + &quot; timezones (tz_key_N, tz_value_N, tz_zoneName_N)&quot;)
log.info(&quot;----- Terminated: Timezone PostProcessor -----&quot;)</stringProp>
