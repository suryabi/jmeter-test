                                      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Dynamic Payload Builder PreProcessor" enabled="true">
                                        <stringProp name="script">
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

def formName = vars.get(&quot;currentFormName&quot;)

def rand = java.util.concurrent.ThreadLocalRandom.current()

def minSelection = props.get(&quot;fn_parseMultiDropDownRange&quot;)(vars, null).min
def maxSelection = props.get(&quot;fn_parseMultiDropDownRange&quot;)(vars, null).max

def getRandomSelectionCount = { int availableCount -&gt;
    def maxPossible = Math.min(availableCount, maxSelection)
    def minPossible = Math.min(minSelection, maxPossible)
    return minPossible + rand.nextInt((maxPossible - minPossible) + 1)
}

def generateRandomNumber(int min, int max) { return props.get(&quot;fn_generateRandomNumber&quot;)(min, max) }

def generateFutureDate = { props.get(&quot;fn_generateFutureDate&quot;)(vars) }

def generateFutureTime(int hoursOffset) { return props.get(&quot;fn_generateFutureTime&quot;)(vars, hoursOffset) }
props.get(&quot;fn_resetFutureTimeDayOffset&quot;)(vars)

def formUIConfigStr = vars.get(&quot;currentFormUIConfig&quot;)

if (!formUIConfigStr) {
    log.warn(&quot;formUIConfig not found - skipping&quot;)
    vars.put(&quot;dynamicFormPayload&quot;, &quot;{}&quot;)
    log.info(&quot;Terminated: Dynamic Payload Builder&quot;)
    return
}

def fieldMappingsStr = vars.get(&quot;currentFieldMappings&quot;)
def fieldMappingsMap = props.get(&quot;fn_parseFieldMappings&quot;)(fieldMappingsStr)

def allFields = props.get(&quot;fn_extractAllFields&quot;)(formUIConfigStr)
vars.put(&quot;existingFormData&quot;, &quot;{}&quot;)

def currentActivityType = (vars.get(&quot;calcActivityType&quot;) ?: vars.get(&quot;loopActivityType&quot;) ?: vars.get(&quot;activityType&quot;) ?: &quot;unknown&quot;).toLowerCase()
def cateringTypeName = (vars.get(&quot;cateringTypeName&quot;) ?: &quot;catering&quot;).toLowerCase()

vars.remove(&quot;meetingName&quot;)
vars.remove(&quot;meetingDescription&quot;)
vars.remove(&quot;meetingAgenda&quot;)

if (currentActivityType == cateringTypeName) {
    def activityModuleName = vars.get(&quot;currentActivityModuleName&quot;) ?: vars.get(&quot;currentModuleName&quot;) ?: &quot;Catering&quot;
    vars.put(&quot;meetingName&quot;, activityModuleName)

    def cateringNotes = [
        &quot;Include extra napkins and utensils&quot;,
        &quot;Ensure hot items are kept warm until serving&quot;,
        &quot;Water and refreshments should be available throughout&quot;,
        &quot;Serve coffee and tea after the main course&quot;,
        &quot;Keep dietary restriction labels visible&quot;,
        &quot;Ensure gluten-free options are available&quot;,
        &quot;Set up a separate station for beverages&quot;,
        &quot;Include fresh fruit as a healthy option&quot;,
        &quot;Provide to-go containers for leftovers&quot;,
        &quot;Please bring serving spoons and tongs&quot;,
        &quot;Keep cold items refrigerated until serving&quot;,
        &quot;Setup should be complete before guests arrive&quot;,
        &quot;Ensure portion sizes are adequate for all guests&quot;,
        &quot;Desserts should be individually portioned&quot;,
        &quot;Avoid strongly scented foods for this meeting&quot;,
        &quot;Vegetarian options should be clearly marked&quot;,
        &quot;Use eco-friendly cutlery if possible&quot;,
        &quot;No peanuts or tree nuts in any dishes&quot;
    ]
    def note = cateringNotes[rand.nextInt(cateringNotes.size())]
    vars.put(&quot;notes&quot;, note)
    vars.put(&quot;meetingDescription&quot;, note)
    vars.put(&quot;meetingAgenda&quot;, &quot;&quot;)

    String[] caterers = [
        &quot;Sodexo Catering Services&quot;,
        &quot;Aramark Corporate Dining&quot;,
        &quot;Compass Group Catering&quot;,
        &quot;Wolfgang Puck Catering&quot;,
        &quot;Delaware North Catering&quot;,
        &quot;Fresh Ideas Food Service&quot;,
        &quot;Canteen Vending Services&quot;,
        &quot;Eurest Dining Services&quot;
    ]
    vars.put(&quot;catererOrderedFrom&quot;, caterers[rand.nextInt(caterers.length)])

    def contactIndex = rand.nextInt(1, (vars.get(&quot;randomUserCount&quot;) ?: &quot;50&quot;).toInteger() + 1)
    def contactFirst = vars.get(&quot;randomUser${contactIndex}firstName&quot;) ?: &quot;John&quot;
    def contactLast = vars.get(&quot;randomUser${contactIndex}lastName&quot;) ?: &quot;Doe&quot;
    def contactStartDigit = [7, 8, 9][rand.nextInt(3)]
    def contactPhone = String.valueOf(contactStartDigit) +
        String.valueOf(java.util.concurrent.ThreadLocalRandom.current().nextLong(100000000L, 1000000000L))
    vars.put(&quot;onsiteDeliveryContact&quot;, contactFirst + &quot; &quot; + contactLast + &quot; - &quot; + contactPhone)

    String[] setupLocations = [
        &quot;Main Cafeteria&quot;, &quot;Executive Dining Hall&quot;,
        &quot;Food Court&quot;, &quot;Bistro Corner&quot;,
        &quot;Coffee Bar&quot;, &quot;Snack Bar&quot;, &quot;Juice Bar&quot;, &quot;Pantry - Floor 1&quot;, &quot;Pantry - Floor 2&quot;,
        &quot;Pantry - Floor 3&quot;,
        &quot;Kitchen Area&quot;, &quot;Dining Area - East&quot;, &quot;Dining Area - West&quot;,
        &quot;Dining Area - North&quot;, &quot;Catering Station A&quot;, &quot;Catering Station B&quot;,
        &quot;Catering Station C&quot;, &quot;Buffet Area&quot;,
        &quot;Outdoor Dining Area&quot;, &quot;Patio Dining&quot;, &quot;Terrace Cafe&quot;,
        &quot;Vending Area&quot;, &quot;Refreshment Station&quot;, &quot;Beverage Station&quot;,
        &quot;Banquet Hall&quot;, &quot;Private Dining Room&quot;, &quot;Guest Dining Area&quot;,
        &quot;Staff Kitchen&quot;, &quot;Shared Kitchen&quot;, &quot;Satellite Kitchen&quot;,
        &quot;Tea Station&quot;, &quot;Coffee Lounge&quot;, &quot;Espresso Bar&quot;,
        &quot;Salad Bar Area&quot;, &quot;Hot Food Counter&quot;, &quot;Grab and Go Station&quot;,
        &quot;Food Service Area&quot;, &quot;Dining Lounge&quot;,
        &quot;Rooftop Cafe&quot;, &quot;Basement Cafeteria&quot;, &quot;Lobby Cafe&quot;
    ]
    vars.put(&quot;setupLocation&quot;, setupLocations[rand.nextInt(setupLocations.length)])

    log.info(&quot;[Activity DPB] CATERING: notes=&quot; + note)
    log.info(&quot;[Activity DPB] CATERING: catererOrderedFrom=&quot; + vars.get(&quot;catererOrderedFrom&quot;))
    log.info(&quot;[Activity DPB] CATERING: onsiteDeliveryContact=&quot; + vars.get(&quot;onsiteDeliveryContact&quot;))
    log.info(&quot;[Activity DPB] CATERING: setupLocation=&quot; + vars.get(&quot;setupLocation&quot;))
}

// FIX: Activity forms use the shared payload builder so nested MASTER/SELECT hierarchy
// (e.g. 6-level Topic chain, same-label parent/child rows) is picked correctly instead
// of random flat-list selection.
props.get(&quot;fn_dynamicPayloadBuilder&quot;)(vars, log)
log.info(&quot;[Activity DPB] completed via fn_dynamicPayloadBuilder&quot;)</stringProp>
