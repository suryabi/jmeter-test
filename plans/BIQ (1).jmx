def roomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
def hasRooms = (roomCount &gt; 0)
def hasActivityModules = (vars.get(&quot;activityModules_count&quot;)?.toInteger() ?: 0) &gt; 0
(hasRooms || hasActivityModules)
)}</stringProp>
