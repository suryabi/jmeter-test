                                      <stringProp name="JSONPostProcessor.referenceNames">availableSlots</stringProp>
                                      <stringProp name="JSONPostProcessor.jsonPathExprs">$.page.totalElements</stringProp>
                                      <stringProp name="JSONPostProcessor.match_numbers"></stringProp>
                                    </JSONPostProcessor>
                                    <hashTree/>
                                    <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Vacant Slot StartTime " enabled="true">
                                      <stringProp name="JSONPostProcessor.referenceNames">vacantSlotStartTime</stringProp>
                                      <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.resourceTimeSlots[*].startTime.context.contextZoneDate</stringProp>
                                      <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                                      <boolProp name="JSONPostProcessor.compute_concat">true</boolProp>
                                    </JSONPostProcessor>
                                    <hashTree/>
                                    <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Vacant Slot End Time " enabled="true">
                                      <stringProp name="JSONPostProcessor.referenceNames">vacantSlotEndTime</stringProp>
                                      <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.resourceTimeSlots[*].endTime.context.contextZoneDate</stringProp>
                                      <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                                      <boolProp name="JSONPostProcessor.compute_concat">true</boolProp>
                                    </JSONPostProcessor>
                                    <hashTree/>
                                    <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Smart Slot Selector" enabled="true">
                                      <stringProp name="script">import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

def rand = java.util.concurrent.ThreadLocalRandom.current()

def calcType = vars.get(&quot;calcActivityType&quot;)?.trim()
def loopType = vars.get(&quot;loopActivityType&quot;)?.trim()
def varType = vars.get(&quot;activityType&quot;)?.trim()

def currentActivityType = (calcType ?: loopType ?: varType ?: &quot;unknown&quot;)
def currentRoomId = vars.get(&quot;currentRoomId&quot;) ?: &quot;&quot;
def roomIndex = vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;
def dayIndex = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def loopCounter = vars.get(&quot;activityLoopCounter&quot;)?.toInteger() ?: 1

// Per-activity-type occupancy key. Holds ONLY this activity type&apos;s own booked
// ranges in this room, so a Topic can&apos;t double-book a Topic slot and a Catering
// can&apos;t double-book a Catering slot — but Topic and Catering CAN share the same
// time range (the API now supports multiple activity types per slot). Hard
// blocks that must apply to every type regardless (room buffer zones, API
// BLOCKED slots, and the priority-based &quot;Blocked&quot; activity reservation) stay
// on the existing shared usedSlotRanges key, untouched.
def usedActivityRangesKey = &quot;usedActivityRanges_${currentActivityType}_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex

def blockedTypeName = vars.get(&quot;blockedTypeName&quot;)

// ✅ FIX: Always re-inject room buffer zones from props into usedSlotRanges at the
// start of every Smart Slot Selector call. This is the safety net that ensures buffer
// zones are present regardless of whether Next Room already restored them. Runs once
// per activity attempt so no slot is ever picked inside a buffer window.
if (currentRoomId) {
    def _bufferPropKey = &quot;jmeter.roomBuffer.Day&quot; + dayIndex + &quot;_&quot; + currentRoomId
    def _bufferZones   = System.getProperty(_bufferPropKey) ?: &quot;&quot;
    if (_bufferZones) {
        def _usedKey  = &quot;usedSlotRanges_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
        def _existing = vars.get(_usedKey) ?: &quot;&quot;
        def _list     = _existing ? _existing.split(&quot;;&quot;).toList() : []
        _bufferZones.split(&quot;;&quot;).each { bz -&gt;
            if (bz &amp;&amp; !_list.contains(bz)) {
                _list.add(bz)
                log.info(&quot;[RoomBuffer][SSS] Injected buffer zone ${bz} into ${_usedKey}&quot;)
            }
        }
        vars.put(_usedKey, _list.join(&quot;;&quot;))
    }

    // ✅ FIX: Safety net for the window boundary itself, mirroring the buffer-zone
    // re-injection above. Ensures roomStartTime/roomEndTime reflect THIS room even
    // if Next Room did not run or restore them for some reason.
    def _rStart = System.getProperty(&quot;jmeter.roomTime.Day&quot; + dayIndex + &quot;_&quot; + currentRoomId + &quot;_start&quot;)
    def _rEnd   = System.getProperty(&quot;jmeter.roomTime.Day&quot; + dayIndex + &quot;_&quot; + currentRoomId + &quot;_end&quot;)
    if (_rStart) vars.put(&quot;roomStartTime&quot;, _rStart)
    if (_rEnd)   vars.put(&quot;roomEndTime&quot;, _rEnd)
}

def vacantSlotsDurationRaw = vars.get(&quot;vacantSlotDurations&quot;)?.trim()
def parsedDurationFromRequest = vars.get(&quot;parsedVacantSlotDuration&quot;)?.trim()
def defaultDuration = &quot;30&quot;
def skipOtherActivity = false

if (parsedDurationFromRequest &amp;&amp; parsedDurationFromRequest.isInteger() &amp;&amp; parsedDurationFromRequest.toInteger() &gt; 0) {
    defaultDuration = parsedDurationFromRequest
} else if (!vacantSlotsDurationRaw) {
    skipOtherActivity = true
    log.info(&quot;[Duration Check] vacantSlotDurations is empty - will skip activity&quot;)
} else {
    def validOptions = vacantSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }
    if (validOptions.isEmpty()) {
        skipOtherActivity = true
        log.info(&quot;[Duration Check] vacantSlotDurations has no valid values (must be &gt; 0) - will skip activity&quot;)
    } else {
        defaultDuration = validOptions[rand.nextInt(validOptions.size())]
    }
}

def reservedBlockedTimesKey = &quot;reservedBlockedTimes_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
def reservedBlockedStr = vars.get(reservedBlockedTimesKey) ?: &quot;&quot;
def globalReservedBlockedRanges = []
if (reservedBlockedStr) {
    reservedBlockedStr.split(&quot;,&quot;).each { range -&gt;
        def parts = range.split(&quot;-&quot;)
        if (parts.size() == 2) {
            globalReservedBlockedRanges.add([parts[0].trim().toInteger(), parts[1].trim().toInteger()])
        }
    }
}

def priorityStr = vars.get(&quot;activityTypesPriority&quot;) ?: &quot;&quot;
def priorityList = priorityStr.split(&quot;,&quot;).collect { it.trim().toLowerCase() }
def blockedPosition = priorityList.indexOf(blockedTypeName)
def currentTypePosition = priorityList.indexOf(currentActivityType?.trim()?.toLowerCase())

def isAfterBlockedInPriority = (blockedPosition &gt;= 0) &amp;&amp; (currentTypePosition &lt; 0 || currentTypePosition &gt; blockedPosition)
def shouldApplyBlockedRanges = (globalReservedBlockedRanges.size() &gt; 0)

def isSlotInBlockedRange = { int slotStartMins, int slotDuration = 60 -&gt;
    if (!shouldApplyBlockedRanges) return false
    int slotEndMins = slotStartMins + slotDuration
    for (def range : globalReservedBlockedRanges) {
        if (slotStartMins &lt; range[1] &amp;&amp; slotEndMins &gt; range[0]) return true
    }
    return false
}

def responseData = prev.getResponseDataAsString()
def jsonSlurper = new groovy.json.JsonSlurper()

def getTimeMinutes = { timeStr -&gt;
    if (!timeStr || timeStr.length() &lt; 16) return -1
    try {
        def timePart = timeStr.substring(11, 16)
        def parts = timePart.split(&quot;:&quot;)
        return parts[0].toInteger() * 60 + parts[1].toInteger()
    } catch (Exception e) { return -1 }
}

def parseTimeToMinutes = { timeStr -&gt;
    if (!timeStr || !timeStr.contains(&quot;:&quot;)) return -1
    try {
        if (timeStr.contains(&quot;T&quot;) &amp;&amp; timeStr.length() &gt;= 16) {
            def timePart = timeStr.substring(11, 16)
            def parts = timePart.split(&quot;:&quot;)
            return parts[0].toInteger() * 60 + parts[1].toInteger()
        } else {
            def parts = timeStr.trim().split(&quot;:&quot;)
            return parts[0].toInteger() * 60 + parts[1].toInteger()
        }
    } catch (Exception e) {
        log.warn(&quot;[parseTimeToMinutes] Failed to parse: ${timeStr}&quot;)
        return -1
    }
}

def formatMinutesToTime = { int mins -&gt;
    def hours = (int)(mins / 60)
    def minutes = mins % 60
    return &quot;${hours}:${String.format(&apos;%02d&apos;, minutes)}&quot;
}

def formatMinutesToDateTime = { int mins, String dateStr -&gt;
    def hours = (int)(mins / 60)
    def minutes = mins % 60
    if (!dateStr || dateStr.trim().isEmpty()) {
        return &quot;1970-01-01T${String.format(&apos;%02d&apos;, hours)}:${String.format(&apos;%02d&apos;, minutes)}:00&quot;
    }
    def datePart = dateStr.take(10)
    return &quot;${datePart}T${String.format(&apos;%02d&apos;, hours)}:${String.format(&apos;%02d&apos;, minutes)}:00&quot;
}

try {
    def json = jsonSlurper.parseText(responseData)
    def timeSlots = json?._embedded?.resourceTimeSlots ?: []
    // Exclude BLOCKED slots regardless of whether resources[] is populated.
    // Logistics-created blocks have resources populated, so a resources-only
    // check is not sufficient — slotType must be checked explicitly.
    // In no-rooms mode (selectedRoomCount == 0), resources[] will always be empty —
    // so we skip the resources check and only filter on slotType.
    def _smartSlotRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
    def _smartSlotNoRoomsMode = (_smartSlotRoomCount == 0)
    def validSlots = timeSlots.findAll { slot -&gt;
        (_smartSlotNoRoomsMode || (slot?.resources ?: []).size() &gt; 0) &amp;&amp; slot?.slotType != &quot;BLOCKED&quot;
    }

    // ✅ FIX: Pre-load API BLOCKED slots into usedSlotRanges so the slot picker
    // treats them as occupied — matching the UI behaviour where blocked windows
    // are never selectable. Runs once per room before any slot selection logic.
    def usedSlotRangesKeyForBlocked = &quot;usedSlotRanges_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
    def apiBlockedSlots = timeSlots.findAll { slot -&gt;
        slot?.slotType == &quot;BLOCKED&quot; &amp;&amp;
        slot?.resourceId == currentRoomId
    }
    if (apiBlockedSlots) {
        def existingRangesStr = vars.get(usedSlotRangesKeyForBlocked) ?: &quot;&quot;
        def existingRanges = existingRangesStr
            ? existingRangesStr.split(&quot;;&quot;).collect { it.trim() }.findAll { it }
            : []
        apiBlockedSlots.each { blockedSlot -&gt;
            def bStart = getTimeMinutes(blockedSlot?.startTime?.context?.contextZoneDate ?: &quot;&quot;)
            def bEnd   = getTimeMinutes(blockedSlot?.endTime?.context?.contextZoneDate ?: &quot;&quot;)
            if (bStart &gt;= 0 &amp;&amp; bEnd &gt; bStart) {
                def rangeStr = &quot;${bStart}:${bEnd}&quot;
                if (!existingRanges.contains(rangeStr)) {
                    existingRanges.add(rangeStr)
                    log.info(&quot;🚫 [API BLOCKED] Registered ${formatMinutesToTime(bStart)}-${formatMinutesToTime(bEnd)} for Room ${currentRoomId}&quot;)
                }
            }
        }
        vars.put(usedSlotRangesKeyForBlocked, existingRanges.join(&quot;;&quot;))
    }
    // ── END FIX ──────────────────────────────────────────────────────────────

    def smartSlotRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
    def smartSlotNoRoomsMode = (smartSlotRoomCount == 0)
    if (!smartSlotNoRoomsMode &amp;&amp; (!currentRoomId || currentRoomId.trim().isEmpty())) {
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)
        vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)
        vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
        vars.put(&quot;currentVacantSlotEndTime&quot;, &quot;&quot;)
        return
    }
    if (smartSlotNoRoomsMode) {
        log.info(&quot;[Smart Slot Selector] No-rooms mode - proceeding with slot selection without room filter&quot;)
    }

    def windowDayNum = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;

    // ✅ FIX: Use roomStartTime/roomEndTime as the slot selection window instead of
    // activityStartTime_N/activityEndTime_N. The room times already have roomBufferMinutes
    // applied (e.g. day=08:00-16:00 with 30min buffer → room=08:30-15:30), so slots
    // inside the buffer zone are excluded at the filtering stage before any slot is
    // selected. Fall back to the full day window only when roomStartTime is not set
    // (e.g. no-rooms mode where resourceId is null).
    //
    // ✅ FIX (SmartSlot wrong date): Strip any date prefix from roomStartTime/End before
    // using as the window boundary. If Next Room restored a full ISO datetime (e.g.
    // 2026-07-03T07:30:00) instead of a time-only string, the T-prefix causes the log
    // to show the wrong day and can affect parseTimeToMinutes if it inspects the date.
    // Stripping to HH:mm:ss makes the window purely time-based and date-neutral.
    def stripDate = { String s -&gt;
        if (!s) return s
        return s.contains(&quot;T&quot;) ? s.substring(s.indexOf(&quot;T&quot;) + 1) : s
    }
    def roomStartTimeRaw = vars.get(&quot;roomStartTime&quot;) ?: &quot;&quot;
    def roomEndTimeRaw   = vars.get(&quot;roomEndTime&quot;)   ?: &quot;&quot;
    def roomStartTimeStr = stripDate(roomStartTimeRaw)
    def roomEndTimeStr   = stripDate(roomEndTimeRaw)
    def dayStartTimeRaw  = vars.get(&quot;activityStartTime_&quot; + windowDayNum) ?: &quot;08:00&quot;
    def dayEndTimeRaw    = vars.get(&quot;activityEndTime_&quot;   + windowDayNum) ?: &quot;18:30&quot;
    def dayStartTimeStr  = stripDate(dayStartTimeRaw)
    def dayEndTimeStr    = stripDate(dayEndTimeRaw)

    // Use room window when available; fall back to day window for no-rooms mode
    def windowStartStr = (roomStartTimeStr &amp;&amp; !smartSlotNoRoomsMode) ? roomStartTimeStr : dayStartTimeStr
    def windowEndStr   = (roomEndTimeStr   &amp;&amp; !smartSlotNoRoomsMode) ? roomEndTimeStr   : dayEndTimeStr

    int windowStartMins = parseTimeToMinutes(windowStartStr)
    int windowEndMins   = parseTimeToMinutes(windowEndStr)
    if (windowStartMins &lt; 0) windowStartMins = 480
    if (windowEndMins   &lt; 0) windowEndMins   = 1110

    // Build full date+time strings for the log using the correct activityDate_ for this day
    def logDate = (vars.get(&quot;activityDate_&quot; + windowDayNum) ?: &quot;&quot;).take(10)
    def logWindowStart = logDate ? &quot;${logDate}T${windowStartStr}&quot; : windowStartStr
    def logWindowEnd   = logDate ? &quot;${logDate}T${windowEndStr}&quot;   : windowEndStr
    def logRoomStart   = logDate ? &quot;${logDate}T${roomStartTimeStr}&quot; : roomStartTimeStr
    def logRoomEnd     = logDate ? &quot;${logDate}T${roomEndTimeStr}&quot;   : roomEndTimeStr
    def logDayStart    = logDate ? &quot;${logDate}T${dayStartTimeStr}&quot;  : dayStartTimeStr
    def logDayEnd      = logDate ? &quot;${logDate}T${dayEndTimeStr}&quot;    : dayEndTimeStr
    log.info(&quot;[SmartSlot] Window: ${logWindowStart}-${logWindowEnd} (room=${logRoomStart}-${logRoomEnd}, day=${logDayStart}-${logDayEnd}, noRoomsMode=${smartSlotNoRoomsMode})&quot;)

    def targetDateStr = vars.get(&quot;activityDate_&quot; + windowDayNum) ?: &quot;&quot;
    def targetDate = targetDateStr.length() &gt;= 10 ? targetDateStr.substring(0, 10) : &quot;&quot;
    int actualDuration = defaultDuration.toString().toInteger()

    def roomSlots = validSlots.findAll { slot -&gt;
        def slotTimeStr = slot?.startTime?.context?.contextZoneDate ?: &quot;&quot;
        if (!slotTimeStr) return false
        def slotDate = slotTimeStr.length() &gt;= 10 ? slotTimeStr.substring(0, 10) : &quot;&quot;
        if (targetDate &amp;&amp; slotDate &amp;&amp; slotDate != targetDate) return false
        int slotMins = getTimeMinutes(slotTimeStr)
        if (slotMins &lt; 0) return false
        return slotMins &gt;= windowStartMins &amp;&amp; (slotMins + actualDuration) &lt;= windowEndMins
    }

    def selectedSlot = null
    def selectedDuration = defaultDuration.toInteger()

    def activityTimingsUdvName = currentActivityType.toLowerCase() + &quot;Timings&quot;
    def activityTimingsRaw = vars.get(activityTimingsUdvName)?.trim()

    if (activityTimingsRaw) {
        def allowedTimeMins = activityTimingsRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it ==~ /^\d{2}:\d{2}$/ }.collect { t -&gt;
            def parts = t.split(&quot;:&quot;)
            parts[0].toInteger() * 60 + parts[1].toInteger()
        }

        def usedTimingsKey = &quot;usedTimings_${currentActivityType}_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
        def usedTimingsStr = vars.get(usedTimingsKey) ?: &quot;&quot;
        def usedTimingsMins = usedTimingsStr ? usedTimingsStr.split(&quot;,&quot;).collect { it.trim().toInteger() } : []

        def availableTimeMins = allowedTimeMins.findAll { t -&gt; !usedTimingsMins.contains(t) }

        if (availableTimeMins.isEmpty()) {
            log.info(&quot;⚠️ [${activityTimingsUdvName}] All configured timings exhausted for Day ${dayIndex} Room ${roomIndex} - stopping ${currentActivityType} loop&quot;)
            vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
            vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
            vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)
            vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
            vars.put(&quot;currentVacantSlotEndTime&quot;, &quot;&quot;)
            return
        } else {
            roomSlots = roomSlots.findAll { slot -&gt;
                int slotMins = getTimeMinutes(slot?.startTime?.context?.contextZoneDate ?: &quot;&quot;)
                availableTimeMins.contains(slotMins)
            }
            if (roomSlots.size() == 0) {
                log.info(&quot;⚠️ [${activityTimingsUdvName}] Times ${availableTimeMins.collect { h -&gt; (int)(h/60) + &apos;:&apos; + String.format(&apos;%02d&apos;, h%60) }} not available in API slots for Day ${dayIndex} Room ${roomIndex} - stopping ${currentActivityType} loop&quot;)
                vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
                vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)
                vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
                vars.put(&quot;currentVacantSlotEndTime&quot;, &quot;&quot;)
                return
            }
            log.info(&quot;[${activityTimingsUdvName}] Filtering to ${availableTimeMins.size()} available time(s): ${availableTimeMins.collect { h -&gt; (int)(h/60) + &apos;:&apos; + String.format(&apos;%02d&apos;, h%60) }} | ${roomSlots.size()} matching slot(s) from API&quot;)
        }
    }

    if (roomSlots.size() == 0) {
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        def hasTimingsRestrictionMain = vars.get(currentActivityType.toLowerCase() + &quot;Timings&quot;)?.trim()
        if (!hasTimingsRestrictionMain) { vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;) }
    }

    if (roomSlots.size() &gt; 0) {

        if (skipOtherActivity) {
            log.info(&quot;[${currentActivityType}] Skipping - vacantSlotDurations is empty or 0&quot;)
            vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
            vars.put(&quot;currentActivityDuration&quot;, &quot;0&quot;)
            return
        }

        def usedSlotRangesKey = &quot;usedSlotRanges_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
        def usedSlotRangesStr = vars.get(usedSlotRangesKey) ?: &quot;&quot;
        def usedSlotRanges = []
        if (usedSlotRangesStr) {
            usedSlotRanges = usedSlotRangesStr.split(&quot;;&quot;).collect { rangeStr -&gt;
                def parts = rangeStr.split(&quot;:&quot;)
                if (parts.size() == 2) return [start: parts[0].toInteger(), end: parts[1].toInteger()]
                return null
            }.findAll { it != null }
        }

        globalReservedBlockedRanges.each { range -&gt;
            def blockedRange = [start: range[0], end: range[1]]
            if (!usedSlotRanges.any { it.start == blockedRange.start &amp;&amp; it.end == blockedRange.end }) {
                usedSlotRanges.add(blockedRange)
            }
        }

        def overlapsWithUsed = { int slotStart, int slotDuration -&gt;
            int slotEnd = slotStart + slotDuration
            def freshRangesStr = vars.get(usedSlotRangesKey) ?: &quot;&quot;
            def freshRanges = []
            if (freshRangesStr) {
                freshRanges = freshRangesStr.split(&quot;;&quot;).collect { rangeStr -&gt;
                    def parts = rangeStr.split(&quot;:&quot;)
                    if (parts.size() == 2) return [start: parts[0].toInteger(), end: parts[1].toInteger()]
                    return null
                }.findAll { it != null }
            }
            // Same-type-only: also block against THIS activity type&apos;s own previous
            // bookings (other types&apos; bookings are intentionally NOT included here,
            // so different types can share the same time range)
            def ownTypeRangesStr = vars.get(usedActivityRangesKey) ?: &quot;&quot;
            if (ownTypeRangesStr) {
                ownTypeRangesStr.split(&quot;;&quot;).each { rangeStr -&gt;
                    def parts = rangeStr.split(&quot;:&quot;)
                    if (parts.size() == 2) freshRanges.add([start: parts[0].toInteger(), end: parts[1].toInteger()])
                }
            }
            globalReservedBlockedRanges.each { range -&gt; freshRanges.add([start: range[0], end: range[1]]) }
            for (def usedRange : freshRanges) {
                if (!(slotEnd &lt;= usedRange.start || slotStart &gt;= usedRange.end)) return true
            }
            return false
        }

        def durationOptions = vacantSlotsDurationRaw.contains(&quot;,&quot;) ?
            vacantSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim().toInteger() } : [vacantSlotsDurationRaw.toInteger()]

        def allValidDurationsStr = vars.get(&quot;allValidDurations&quot;)?.trim()
        if (allValidDurationsStr) {
            durationOptions = allValidDurationsStr.split(&quot;,&quot;).collect { it.trim().toInteger() }.findAll { it &gt; 0 }
        }

        def minDuration = durationOptions.min()
        def maxDuration = durationOptions.max()

        def availableSlots = roomSlots.findAll { slot -&gt;
            def slotStart = getTimeMinutes(slot?.startTime?.context?.contextZoneDate ?: &quot;&quot;)
            if (slotStart &lt; 0) return false
            if (slotStart + minDuration &gt; windowEndMins) return false
            return !isSlotInBlockedRange(slotStart, minDuration) &amp;&amp; !overlapsWithUsed(slotStart, minDuration)
        }

        if (availableSlots.size() &gt; 0) {
            selectedSlot = availableSlots[rand.nextInt(availableSlots.size())]
            def selectedSlotTime = getTimeMinutes(selectedSlot?.startTime?.context?.contextZoneDate ?: &quot;&quot;)

            def maxRetries = availableSlots.size()
            def retryCount = 0
            def foundValidSlot = false
            def latestRanges = []

            while (!foundValidSlot &amp;&amp; retryCount &lt; maxRetries) {
                def latestRangesStr = vars.get(usedSlotRangesKey) ?: &quot;&quot;
                latestRanges = []
                if (latestRangesStr) {
                    latestRanges = latestRangesStr.split(&quot;;&quot;).collect { rangeStr -&gt;
                        def parts = rangeStr.split(&quot;:&quot;)
                        if (parts.size() == 2) return [start: parts[0].toInteger(), end: parts[1].toInteger()]
                        return null
                    }.findAll { it != null }
                }
                def ownTypeRangesStrRetry = vars.get(usedActivityRangesKey) ?: &quot;&quot;
                if (ownTypeRangesStrRetry) {
                    ownTypeRangesStrRetry.split(&quot;;&quot;).each { rangeStr -&gt;
                        def parts = rangeStr.split(&quot;:&quot;)
                        if (parts.size() == 2) latestRanges.add([start: parts[0].toInteger(), end: parts[1].toInteger()])
                    }
                }
                globalReservedBlockedRanges.each { range -&gt; latestRanges.add([start: range[0], end: range[1]]) }

                def slotEndCheck = selectedSlotTime + minDuration
                def alreadyUsed = latestRanges.any { range -&gt; !(slotEndCheck &lt;= range.start || selectedSlotTime &gt;= range.end) }

                if (alreadyUsed) {
                    availableSlots = availableSlots.findAll { slot -&gt;
                        getTimeMinutes(slot?.startTime?.context?.contextZoneDate ?: &quot;&quot;) != selectedSlotTime
                    }
                    if (availableSlots.size() &gt; 0) {
                        selectedSlot = availableSlots[rand.nextInt(availableSlots.size())]
                        selectedSlotTime = getTimeMinutes(selectedSlot?.startTime?.context?.contextZoneDate ?: &quot;&quot;)
                        retryCount++
                    } else {
                        selectedSlot = null
                        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                        break
                    }
                } else {
                    foundValidSlot = true
                }
            }

            if (!foundValidSlot &amp;&amp; selectedSlot != null) {
                selectedSlot = null
                vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
            }

            if (selectedSlot) {
                def maxAvailableTime = windowEndMins - selectedSlotTime
                def nextBlockStart = windowEndMins
                latestRanges.each { range -&gt;
                    if (range.start &gt; selectedSlotTime &amp;&amp; range.start &lt; nextBlockStart) nextBlockStart = range.start
                }
                maxAvailableTime = Math.min(maxAvailableTime, nextBlockStart - selectedSlotTime)

                def fittingDurations = durationOptions.findAll { it &lt;= maxAvailableTime }

                if (fittingDurations.size() == 0) {
                    selectedSlot = null
                    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                    vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
                } else {
                    def topicDuration = fittingDurations[rand.nextInt(fittingDurations.size())]
                    selectedDuration = topicDuration
                    def slotEnd = selectedSlotTime + topicDuration

                    def hasOverlap = latestRanges.any { range -&gt; !(slotEnd &lt;= range.start || selectedSlotTime &gt;= range.end) }

                    if (hasOverlap) {
                        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                    } else {
                        def activityCountKey = currentActivityType + &quot;Count_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
                        def activityNum = (vars.get(activityCountKey)?.toInteger() ?: 0) + 1
                        vars.put(activityCountKey, activityNum.toString())

                        log.info(&quot;✅ #${activityNum} ${currentActivityType.toUpperCase()} at ${formatMinutesToTime(selectedSlotTime)}-${formatMinutesToTime(slotEnd)} (${topicDuration}m) | ${vars.get(&apos;currentRoomName&apos;)}&quot;)

                        def currentRanges = vars.get(usedActivityRangesKey) ?: &quot;&quot;
                        vars.put(usedActivityRangesKey, currentRanges ? currentRanges + &quot;;&quot; + selectedSlotTime + &quot;:&quot; + slotEnd : selectedSlotTime + &quot;:&quot; + slotEnd)

                        def actTimingsUdvName2 = currentActivityType.toLowerCase() + &quot;Timings&quot;
                        if (vars.get(actTimingsUdvName2)?.trim()) {
                            def usedTimingsKey2 = &quot;usedTimings_${currentActivityType}_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
                            def existing2 = vars.get(usedTimingsKey2) ?: &quot;&quot;
                            vars.put(usedTimingsKey2, existing2 ? existing2 + &quot;,&quot; + selectedSlotTime : selectedSlotTime.toString())
                            log.info(&quot;[${actTimingsUdvName2}] Marked ${formatMinutesToTime(selectedSlotTime)} as used for Day ${dayIndex} Room ${roomIndex}&quot;)
                        }
                    }
                }
            }
        } else {
            // Gap fill runs even when all API slots are BLOCKED — those are Logistics
            // buffer windows (Start+30min / End-30min offsets) registered in usedSlotRanges.
            // Gap fill calculates free time BETWEEN those blocked ranges and books there.
            vars.put(&quot;gapFillActive&quot;, &quot;true&quot;)
            def latestRangesForGapFill = []
            def latestRangesStrForGapFill = vars.get(usedSlotRangesKey) ?: &quot;&quot;
            if (latestRangesStrForGapFill) {
                latestRangesForGapFill = latestRangesStrForGapFill.split(&quot;;&quot;).collect { rangeStr -&gt;
                    def parts = rangeStr.split(&quot;:&quot;)
                    if (parts.size() == 2) return [start: parts[0].toInteger(), end: parts[1].toInteger()]
                    return null
                }.findAll { it != null }
            }
            def ownTypeRangesStrGapFill = vars.get(usedActivityRangesKey) ?: &quot;&quot;
            if (ownTypeRangesStrGapFill) {
                ownTypeRangesStrGapFill.split(&quot;;&quot;).each { rangeStr -&gt;
                    def parts = rangeStr.split(&quot;:&quot;)
                    if (parts.size() == 2) latestRangesForGapFill.add([start: parts[0].toInteger(), end: parts[1].toInteger()])
                }
            }

            def allOccupied = []
            latestRangesForGapFill.each { allOccupied.add([start: it.start, end: it.end]) }
            globalReservedBlockedRanges.each { allOccupied.add([start: it[0], end: it[1]]) }
            allOccupied.sort { it.start }

            def gaps = []
            def currentPos = windowStartMins
            allOccupied.each { occupied -&gt;
                if (occupied.start &gt; currentPos &amp;&amp; (occupied.start - currentPos) &gt;= minDuration) {
                    gaps.add([start: currentPos, end: occupied.start, size: occupied.start - currentPos])
                }
                currentPos = Math.max(currentPos, occupied.end)
            }
            if (currentPos &lt; windowEndMins &amp;&amp; (windowEndMins - currentPos) &gt;= minDuration) {
                gaps.add([start: currentPos, end: windowEndMins, size: windowEndMins - currentPos])
            }

            if (gaps.size() &gt; 0) {
                def sortedDurations = durationOptions.sort { -it }
                def selectedGap = null
                def topicDuration = minDuration

                def actTimingsUdvNameGap = currentActivityType.toLowerCase() + &quot;Timings&quot;
                def actTimingsRawGap = vars.get(actTimingsUdvNameGap)?.trim()
                if (actTimingsRawGap) {
                    def usedTimingsKeyGap = &quot;usedTimings_${currentActivityType}_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
                    def usedTimingsStrGap = vars.get(usedTimingsKeyGap) ?: &quot;&quot;
                    def usedTimingsMinsGap = usedTimingsStrGap ? usedTimingsStrGap.split(&quot;,&quot;).collect { it.trim().toInteger() } : []
                    def allowedTimeMinsGap = actTimingsRawGap.split(&quot;,&quot;).collect { it.trim() }.findAll { it ==~ /^\d{2}:\d{2}$/ }.collect { t -&gt;
                        def parts = t.split(&quot;:&quot;)
                        parts[0].toInteger() * 60 + parts[1].toInteger()
                    }.findAll { !usedTimingsMinsGap.contains(it) }
                    gaps = gaps.findAll { g -&gt; allowedTimeMinsGap.any { t -&gt; t &gt;= g.start &amp;&amp; t + minDuration &lt;= g.end } }
                    log.info(&quot;[${actTimingsUdvNameGap}] Gap fill filtered to ${gaps.size()} gap(s) matching allowed times&quot;)
                }

                for (def tryDuration : sortedDurations) {
                    def fittingGaps = gaps.findAll { it.size &gt;= tryDuration }
                    if (fittingGaps.size() &gt; 0) {
                        selectedGap = fittingGaps[rand.nextInt(fittingGaps.size())]
                        topicDuration = tryDuration
                        break
                    }
                }

                if (selectedGap) {
                    // If timings UDV is active, the allowed time within the gap is the actual slot start
                    // (gap may start earlier; we must honour the configured timing, e.g. 10:30)
                    def _gapTimingsUdvName = currentActivityType.toLowerCase() + &quot;Timings&quot;
                    def _gapTimingsRaw = vars.get(_gapTimingsUdvName)?.trim()
                    def _usedTimingsKeyGapStart = &quot;usedTimings_${currentActivityType}_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
                    def _usedTimingsStrGapStart = vars.get(_usedTimingsKeyGapStart) ?: &quot;&quot;
                    def _usedTimingsMinsGapStart = _usedTimingsStrGapStart ? _usedTimingsStrGapStart.split(&quot;,&quot;).collect { it.trim().toInteger() } : []
                    def selectedSlotTime = selectedGap.start
                    if (_gapTimingsRaw) {
                        def _allowedInGap = _gapTimingsRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it ==~ /^\d{2}:\d{2}$/ }.collect { t -&gt;
                            def parts = t.split(&quot;:&quot;); parts[0].toInteger() * 60 + parts[1].toInteger()
                        }.findAll { t -&gt; !_usedTimingsMinsGapStart.contains(t) &amp;&amp; t &gt;= selectedGap.start &amp;&amp; t + topicDuration &lt;= selectedGap.end }
                        if (_allowedInGap.size() &gt; 0) {
                            selectedSlotTime = _allowedInGap[rand.nextInt(_allowedInGap.size())]
                        }
                    }
                    selectedDuration = topicDuration
                    def slotEnd = selectedSlotTime + topicDuration

                    def activityCountKey = currentActivityType + &quot;Count_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
                    def activityNum = (vars.get(activityCountKey)?.toInteger() ?: 0) + 1
                    vars.put(activityCountKey, activityNum.toString())

                    log.info(&quot;✅ #${activityNum} ${currentActivityType.toUpperCase()} (gap) at ${formatMinutesToTime(selectedSlotTime)}-${formatMinutesToTime(slotEnd)} (${topicDuration}m) | ${vars.get(&apos;currentRoomName&apos;)}&quot;)

                    def currentRanges = vars.get(usedActivityRangesKey) ?: &quot;&quot;
                    vars.put(usedActivityRangesKey, currentRanges ? currentRanges + &quot;;&quot; + selectedSlotTime + &quot;:&quot; + slotEnd : selectedSlotTime + &quot;:&quot; + slotEnd)

                    def actTimingsUdvNameGapTrack = currentActivityType.toLowerCase() + &quot;Timings&quot;
                    if (vars.get(actTimingsUdvNameGapTrack)?.trim()) {
                        def usedTimingsKeyGapTrack = &quot;usedTimings_${currentActivityType}_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
                        def existing3 = vars.get(usedTimingsKeyGapTrack) ?: &quot;&quot;
                        vars.put(usedTimingsKeyGapTrack, existing3 ? existing3 + &quot;,&quot; + selectedSlotTime : selectedSlotTime.toString())
                        log.info(&quot;[${actTimingsUdvNameGapTrack}] Marked ${formatMinutesToTime(selectedSlotTime)} as used (gap fill) for Day ${dayIndex} Room ${roomIndex}&quot;)
                    }

                    def eventDateStr = vars.get(&quot;activityDate_&quot; + (vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;)) ?: &quot;&quot;
                    selectedSlot = [
                        startTime: [context: [contextZoneDate: formatMinutesToDateTime(selectedSlotTime, eventDateStr)]],
                        endTime: [context: [contextZoneDate: formatMinutesToDateTime(slotEnd, eventDateStr)]]
                    ]
                } else {
                    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                    def hasTimingsRestriction = vars.get(currentActivityType.toLowerCase() + &quot;Timings&quot;)?.trim()
                    if (!hasTimingsRestriction) { vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;) }
                }
            } else {
                vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                def hasTimingsRestriction2 = vars.get(currentActivityType.toLowerCase() + &quot;Timings&quot;)?.trim()
                if (!hasTimingsRestriction2) { vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;) }
            }
        }
    }

    if (selectedSlot) {
        vars.put(&quot;skipActivity&quot;, &quot;false&quot;)
        def startTimeStr = selectedSlot?.startTime?.context?.contextZoneDate ?: &quot;&quot;

        def endTimeStr = &quot;&quot;
        if (startTimeStr) {
            try {
                def formatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)
                def startDT = LocalDateTime.parse(startTimeStr, formatter)
                def endDT = startDT.plusMinutes(selectedDuration)
                endTimeStr = endDT.format(formatter)
            } catch (Exception e) {
                endTimeStr = selectedSlot?.endTime?.context?.contextZoneDate ?: startTimeStr
            }
        }

        def resourceId = currentRoomId
        def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
        def noRoomsMode = (selectedRoomCount == 0)

        if (!currentRoomId || currentRoomId.trim().isEmpty()) {
            if (!noRoomsMode) {
                // Logistics path: rooms expected but missing — skip
                vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
                vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)
                vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
                vars.put(&quot;currentVacantSlotEndTime&quot;, &quot;&quot;)
                vars.put(&quot;currentActivityDuration&quot;, defaultDuration)
                return
            }
            // Agenda-only path (no logistics): proceed with resourceId = null
            log.info(&quot;[Slot Selector] No rooms available (agenda-only mode) — proceeding with resourceId=null&quot;)
            vars.put(&quot;selectedRoomName&quot;, &quot;&quot;)
            vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)
            vars.put(&quot;currentVacantSlotStartTime&quot;, startTimeStr)
            vars.put(&quot;currentVacantSlotEndTime&quot;, endTimeStr)
            vars.put(&quot;currentActivityDuration&quot;, selectedDuration.toString())
            return
        }

        def roomValidated = false
        def roomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;UNKNOWN&quot;

        for (int i = 1; i &lt;= selectedRoomCount; i++) {
            if (vars.get(&quot;selectedRoomId_&quot; + i) == currentRoomId) {
                roomValidated = true
                roomName = vars.get(&quot;selectedRoomName_&quot; + i) ?: roomName
                break
            }
        }

        if (!roomValidated) {
            vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
            vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)
            vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
            vars.put(&quot;currentVacantSlotEndTime&quot;, &quot;&quot;)
            vars.put(&quot;currentActivityDuration&quot;, defaultDuration)
            return
        }

        vars.put(&quot;selectedRoomName&quot;, roomName)
        vars.put(&quot;currentVacantSlotId&quot;, resourceId)
        vars.put(&quot;currentVacantSlotStartTime&quot;, startTimeStr)
        vars.put(&quot;currentVacantSlotEndTime&quot;, endTimeStr)
        vars.put(&quot;currentActivityDuration&quot;, selectedDuration.toString())
    } else {
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
    }

} catch (Exception e) {
    log.error(&quot;Exception in Smart Slot Selector: &quot; + e.message)
    e.printStackTrace()
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
}

def finalResourceId = vars.get(&quot;currentVacantSlotId&quot;) ?: &quot;&quot;
def finalStartTime = vars.get(&quot;currentVacantSlotStartTime&quot;) ?: &quot;&quot;
def finalSkipActivity = vars.get(&quot;skipActivity&quot;)
def finalSelectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
def finalNoRoomsMode = (finalSelectedRoomCount == 0)

if (finalSkipActivity != &quot;true&quot;) {
    // In no-rooms mode, resourceId is intentionally null/empty — do NOT skip based on it
    if (!finalNoRoomsMode &amp;&amp; (!finalResourceId || finalResourceId.trim().isEmpty())) {
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)
    }
    if (!finalStartTime || finalStartTime.trim().isEmpty()) {
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
    }
}

if (vars.get(&quot;skipActivity&quot;) != &quot;true&quot;) {
    def slotKey = &quot;Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
    def currentTotal = vars.get(&quot;totalSlotsUsed_&quot; + slotKey)?.toInteger() ?: 0
    def activityDuration = vars.get(&quot;currentActivityDuration&quot;)?.toInteger() ?: 30
    def slotDuration = (defaultDuration ?: &quot;30&quot;).toInteger()
    int slotsUsed = slotDuration &gt; 0 ? (int) Math.ceil(activityDuration / slotDuration) : 1
    vars.put(&quot;totalSlotsUsed_&quot; + slotKey, (currentTotal + slotsUsed).toString())
}
</stringProp>
                                      <stringProp name="scriptLanguage">groovy</stringProp>
