                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Active Customer PostProcessor" enabled="true">
                  <stringProp name="script">

def tenant = new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString())._embedded?.tenants?.getAt(0)

vars.put(&quot;customerId&quot;, tenant?.uniqueId ?: &quot;&quot;)
vars.put(&quot;activeCustomer&quot;, tenant?.customerName ?: &quot;&quot;)

// Update sampler label with selected customer
def customerName = vars.get(&quot;activeCustomer&quot;) ?: &quot;&quot;
if (customerName) {
	prev.setSampleLabel(prev.getSampleLabel() + &quot; - &quot; + customerName)
}

log.info(&quot;Customer: ${customerName} | ID: ${vars.get(&apos;customerId&apos;)}&quot;)

log.info(&quot;----- Terminated: Extracted Active Customer -----&quot;)</stringProp>
