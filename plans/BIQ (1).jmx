                                  <stringProp name="HTTPSampler.method">POST</stringProp>
                                  <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
                                  <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                                  <boolProp name="HTTPSampler.use_keepalive">false</boolProp>
                                  <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                                  <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                                  <stringProp name="HTTPSampler.connect_timeout">30000</stringProp>
                                  <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
                                </HTTPSamplerProxy>
                                <hashTree>
                                  <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Presenter PreProcessor - Accept only AllianceIT Emails" enabled="true">
                                    <stringProp name="script">

def rand = java.util.concurrent.ThreadLocalRandom.current()
def activityType = vars.get(&quot;activityType&quot;) ?: &quot;unknown&quot;

def presentersUdv = vars.get(&apos;presenters&apos;)?.trim()

def presenterOptions = presentersUdv.split(&apos;,&apos;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt;= 0 }.collect { it.toInteger() }
if (presenterOptions.isEmpty()) {
    log.info(&quot;Presenters UDV has no valid values - defaulting to 0&quot;)
    presenterOptions = [0]
}
int desiredCount = presenterOptions[rand.nextInt(presenterOptions.size())]

int totalPresenters = (vars.get(&apos;presenterId_matchNr&apos;) ?: &apos;0&apos;) as int

int presentersToUse = Math.min(totalPresenters, desiredCount)

def allPresenterPairs = []

for (int i = 1; i &lt;= totalPresenters; i++) {
    def presenterId = vars.get(&quot;presenterId_&quot; + i)
    def presenterName = vars.get(&quot;presenterName_&quot; + i) ?: &quot;Presenter ${i}&quot;
    def presenterDataStr = vars.get(&quot;presenterData_&quot; + i) ?: &quot;{}&quot;
    def presenterEmail = vars.get(&quot;presenterEmail_&quot; + i) ?: &quot;&quot;

if (presenterId &amp;&amp; presenterEmail.toLowerCase().contains(&quot;allianceit.com&quot;)) {
    allPresenterPairs.add([
        id: presenterId,
        name: presenterName,
        data: presenterDataStr
    ])
} else if (presenterId) {
    log.info(&quot;SKIPPED presenter: ${presenterName} (email: ${presenterEmail}) - not allianceit.com&quot;)
}

}

Collections.shuffle(allPresenterPairs)
presentersToUse = Math.min(allPresenterPairs.size(), presentersToUse)

// Deduplicate by presenter uniqueId before building payload
def seenPresenterIds = [] as Set
def selectedPresenters = allPresenterPairs.findAll { seenPresenterIds.add(it.id) }.take(presentersToUse)

for (int i = 0; i &lt; selectedPresenters.size(); i++) {
    vars.put(&quot;selectedPresenterId_&quot; + (i + 1), selectedPresenters[i].id)
    vars.put(&quot;selectedPresenterName_&quot; + (i + 1), selectedPresenters[i].name)
    vars.put(&quot;selectedPresenterData_&quot; + (i + 1), selectedPresenters[i].data)
}
vars.put(&quot;selectedPresenterCount&quot;, selectedPresenters.size().toString())

def presenterListJson = selectedPresenters.collect { &quot;\&quot;${it.id}\&quot;&quot; }.join(&quot;,\n        &quot;)
vars.put(&quot;dynamicPresenterBody&quot;, &quot;&quot;&quot;{
    &quot;uniqueIds&quot;: [
        ${presenterListJson}
    ]
}&quot;&quot;&quot;)
log.info(&quot;----- Presenters to add: ${selectedPresenters.size()} (deduplicated) -----&quot;)
</stringProp>
