                  <stringProp name="script">// Loop runs until a targetAction (CONFIRM, HOLD, WAITLIST) is performed — no fixed iteration count.
// Safety ceiling of 10 prevents infinite looping if targetAction is never reachable.
def safetyCeiling = 5
vars.put(&quot;stateActionLoopCount&quot;, safetyCeiling.toString())
vars.put(&quot;stateActionIteration&quot;, &quot;0&quot;)
vars.put(&quot;exitStateActionLoop&quot;, &quot;false&quot;)
log.info(&quot;State Action Loop: safety ceiling set to ${safetyCeiling}. Loop will exit early once a targetAction is performed.&quot;)</stringProp>
