                              <hashTree>
                                <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                                  <collectionProp name="HeaderManager.headers">
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-customerid</stringProp>
                                      <stringProp name="Header.value">${customerId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                                      <stringProp name="Header.value">${categoryTypeId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                                      <stringProp name="Header.value">${categoryId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                                      <stringProp name="Header.value">${baseTimezone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                                      <stringProp name="Header.value">${clientTimeZone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Context-Timezone</stringProp>
                                      <stringProp name="Header.value">${baseTimezone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-eventid</stringProp>
                                      <stringProp name="Header.value">${requestId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-activityday-resource</stringProp>
                                      <stringProp name="Header.value">${activityDayResourceId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X_cloud_user</stringProp>
                                      <stringProp name="Header.value">${currentUser}</stringProp>
                                    </elementProp>
                                  </collectionProp>
                                </HeaderManager>
                                <hashTree/>
                                <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Room ID Extractor" enabled="true">
                                  <stringProp name="JSONPostProcessor.referenceNames">roomId</stringProp>
                                  <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.resourceTimeSlots[*].resources[*].uniqueId</stringProp>
                                  <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                                  <stringProp name="JSONPostProcessor.defaultValues">NOT_FOUND</stringProp>
                                </JSONPostProcessor>
                                <hashTree/>
                                <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Room Name Extractor" enabled="true">
                                  <stringProp name="JSONPostProcessor.referenceNames">roomName</stringProp>
                                  <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.resourceTimeSlots[*].resources[*].data.name</stringProp>
                                  <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                                  <stringProp name="JSONPostProcessor.defaultValues">NOT_FOUND</stringProp>
                                </JSONPostProcessor>
                                <hashTree/>
                                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Prepare Room Selection" enabled="true">
                                  <stringProp name="script">// Prepare room selection - create shuffle and adjust room count
// This only runs ONCE per Activity Day (when RoomIndex == 1)

def dayIndex = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def extractedRoomCount = vars.get(&quot;roomId_matchNr&quot;)?.toInteger() ?: 0
def roomsPickedCount = vars.get(&quot;_roomsPickedCount&quot;)?.toInteger() ?: 0  // 0 means no cap

log.info(&quot;Day ${dayIndex}: Available ${extractedRoomCount} vacant rooms | rooms cap: ${roomsPickedCount == 0 ? &quot;none&quot; : roomsPickedCount}&quot;)

if (extractedRoomCount == 0) {
    log.warn(&quot;Day ${dayIndex}: No vacant rooms available&quot;)
    vars.put(&quot;TotalRoomsToCreate&quot;, &quot;0&quot;)
    return
}

// ============================================================
// allowedRooms FILTER
// ============================================================
def allowedRoomsRaw = vars.get(&quot;allowedRooms&quot;)?.trim() ?: &quot;&quot;

def isUUID = { String val -&gt;
    val?.contains(&quot;-&quot;) &amp;&amp; val.trim().length() &gt;= 30
}

if (allowedRoomsRaw) {
    // Parse allowed list into separate UUID and name lists
    def allowedEntries = allowedRoomsRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it }
    def allowedUUIDs   = allowedEntries.findAll { isUUID(it) }.collect { it.toUpperCase() }
    def allowedNames   = allowedEntries.findAll { !isUUID(it) }.collect { it.toLowerCase() }

    log.info(&quot;Day ${dayIndex}: allowedRooms filter active — UUIDs: ${allowedUUIDs}, Names: ${allowedNames}&quot;)

    // Walk all extracted rooms and keep only those that match
    def matchedIndices = []
    for (int i = 1; i &lt;= extractedRoomCount; i++) {
        def roomId   = vars.get(&quot;roomId_&quot; + i)   ?: &quot;&quot;
        def roomName = vars.get(&quot;roomName_&quot; + i) ?: &quot;&quot;

        boolean matchById   = allowedUUIDs &amp;&amp; allowedUUIDs.contains(roomId.toUpperCase())
        boolean matchByName = allowedNames &amp;&amp; allowedNames.contains(roomName.trim().toLowerCase())

        if (matchById || matchByName) {
            matchedIndices.add(i)
            def matchType = matchById ? &quot;UUID&quot; : &quot;Name&quot;
            log.info(&quot;  ✅ MATCH [${matchType}] Room [${i}]: ${roomName} (${roomId})&quot;)
        } else {
            log.info(&quot;  ⛔ SKIP Room [${i}]: ${roomName} (${roomId})&quot;)
        }
    }

    // No matches — skip room creation, continue test
    if (matchedIndices.isEmpty()) {
        def availableRoomNames = (1..extractedRoomCount).collect { i -&gt; vars.get(&quot;roomName_&quot; + i) ?: &quot;Room ${i}&quot; }.join(&quot;, &quot;)
        log.warn(&quot;========================================&quot;)
        log.warn(&quot;SKIPPING ROOMS: allowedRooms did not match any vacant room for Day ${dayIndex}.&quot;)
        log.warn(&quot;allowedRooms requested: ${allowedRoomsRaw}&quot;)
        log.warn(&quot;Vacant rooms available: ${availableRoomNames}&quot;)
        log.warn(&quot;Room creation skipped — test will continue with remaining steps.&quot;)
        log.warn(&quot;========================================&quot;)
        vars.put(&quot;TotalRoomsToCreate&quot;, &quot;0&quot;)
        vars.put(&quot;shuffledRoomIndices_Day${dayIndex}&quot;, &quot;&quot;)
        vars.put(&quot;_skipRoomReason&quot;, &quot;allowedRooms &apos;${allowedRoomsRaw}&apos; did not match any vacant room. Available: ${availableRoomNames}&quot;)
        return
    }

    // ============================================================
    // Apply rooms UDV as a cap on matched allowedRooms
    //
    //   roomsPickedCount &gt;= matchedIndices.size() → create ALL matched (cap exceeds available)
    //   roomsPickedCount &lt; matchedIndices.size() → pick roomsPickedCount randomly from matched
    //
    // Note: rooms=0/empty is already handled in the Activity Day sampler
    //       (TotalRoomsToCreate=0, so this block is never reached in that case)
    // ============================================================
    def rand = java.util.concurrent.ThreadLocalRandom.current()
    Collections.shuffle(matchedIndices, rand)  // always shuffle for randomness

    def finalIndices
    if (roomsPickedCount &gt;= matchedIndices.size()) {
        // Cap exceeds matched — create all matched rooms
        finalIndices = matchedIndices
        log.info(&quot;Day ${dayIndex}: rooms cap ${roomsPickedCount} &gt;= matched ${matchedIndices.size()} — creating ALL ${matchedIndices.size()} matched room(s)&quot;)
    } else {
        // Cap is less than matched — pick only roomsPickedCount rooms from shuffled matched list
        finalIndices = matchedIndices.take(roomsPickedCount)
        log.info(&quot;Day ${dayIndex}: rooms cap ${roomsPickedCount} &lt; matched ${matchedIndices.size()} — creating ${roomsPickedCount} room(s) from matched list&quot;)
    }

    vars.put(&quot;TotalRoomsToCreate&quot;, finalIndices.size().toString())
    vars.put(&quot;shuffledRoomIndices_Day${dayIndex}&quot;, finalIndices.join(&quot;,&quot;))

    log.info(&quot;Day ${dayIndex}: Final rooms to create: ${finalIndices.size()} — indices: ${finalIndices}&quot;)

} else {
    // ============================================================
    // ORIGINAL BEHAVIOR — no allowedRooms, rooms UDV controls count
    // ============================================================
    def requestedRooms = roomsPickedCount
    def finalCount = requestedRooms

    if (requestedRooms &gt; extractedRoomCount) {
        log.info(&quot;Day ${dayIndex}: Limiting rooms from ${requestedRooms} to ${extractedRoomCount}&quot;)
        finalCount = extractedRoomCount
    }

    vars.put(&quot;TotalRoomsToCreate&quot;, finalCount.toString())

    def rand = java.util.concurrent.ThreadLocalRandom.current()
    def availableIndices = (1..extractedRoomCount).collect { it }
    Collections.shuffle(availableIndices, rand)
    vars.put(&quot;shuffledRoomIndices_Day${dayIndex}&quot;, availableIndices.join(&quot;,&quot;))

    log.info(&quot;Day ${dayIndex}: No allowedRooms filter — creating ${finalCount} room(s) from ${extractedRoomCount} vacant&quot;)
}</stringProp>
                                  <stringProp name="scriptLanguage">groovy</stringProp>
                                  <stringProp name="parameters"></stringProp>
                                  <stringProp name="filename"></stringProp>
                                  <stringProp name="cacheKey">true</stringProp>
                                </JSR223PostProcessor>
                                <hashTree/>
                                <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                                <hashTree/>
                              </hashTree>
                            </hashTree>
                            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Select Current Room (${currentRoomIndex})" enabled="true">
                              <stringProp name="script">SampleResult.setIgnore()

// Make visible for debugging
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)

import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

// Select room based on current room index
def roomIndex = vars.get(&quot;currentRoomIndex&quot;)?.toInteger() ?: 1
def totalRooms = vars.get(&quot;TotalRoomsToCreate&quot;)?.toInteger() ?: 1
def dayIndex = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;

// Get extracted room count (from Get Vacant Rooms - only called for first room)
def extractedRoomCount = vars.get(&quot;roomId_matchNr&quot;)?.toInteger() ?: 0

// Get room type from lookup values - NO hardcoded values
def rand = java.util.concurrent.ThreadLocalRandom.current()
def roomTypeCount = vars.get(&quot;roomType_count&quot;)?.toInteger() ?: 0
def roomType = &quot;&quot;

// Skip room creation if no ROOM_TYPE lookup values found
if (roomTypeCount == 0) {
    log.warn(&quot;Day ${dayIndex}: No ROOM_TYPE lookup values found - skipping room creation&quot;)
    vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
    return
}

if (roomTypeCount &gt; 0) {
    if (roomIndex == 1) {
        // First room: Must be Main Room (find from lookup)
        for (int i = 1; i &lt;= roomTypeCount; i++) {
            def lookupValue = vars.get(&quot;roomType_&quot; + i)
            if (lookupValue?.toLowerCase()?.contains(&quot;main&quot;)) {
                roomType = lookupValue
                break
            }
        }
        // If no Main Room found in lookup, use first available
        if (!roomType) {
            roomType = vars.get(&quot;roomType_1&quot;) ?: &quot;&quot;
        }
    } else {
        // Other rooms: Pick randomly from non-Main Room types
        def otherTypes = []
        for (int i = 1; i &lt;= roomTypeCount; i++) {
            def lookupValue = vars.get(&quot;roomType_&quot; + i)
            if (lookupValue &amp;&amp; !lookupValue.toLowerCase().contains(&quot;main&quot;)) {
                otherTypes.add(lookupValue)
            }
        }
        if (otherTypes.size() &gt; 0) {
            roomType = otherTypes[rand.nextInt(otherTypes.size())]
        } else {
            // If only Main Room exists in lookup, pick randomly from all
            def randomIdx = rand.nextInt(roomTypeCount) + 1
            roomType = vars.get(&quot;roomType_&quot; + randomIdx) ?: &quot;&quot;
        }
    }
}

// Skip if no vacant rooms found
if (extractedRoomCount == 0) {
    log.warn(&quot;Day ${dayIndex}: No vacant rooms found - skipping room creation&quot;)
    vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
    return
}

// ROOM SELECTION - use shuffled list created during first room iteration
def selectedRoomId = &quot;&quot;
def selectedRoomName = &quot;&quot;

// Get shuffled indices (created when RoomIndex == 1 in Get Vacant Rooms PostProcessor)
def shuffledIndicesStr = vars.get(&quot;shuffledRoomIndices_Day${dayIndex}&quot;)

// Safety check: if shuffledRoomIndices is empty/null (no match or 0 rooms), skip creation

if (!shuffledIndicesStr) {
    // No shuffled indices means Prepare Room Selection aborted or found 0 rooms — do NOT fallback
    log.warn(&quot;Day ${dayIndex}: shuffledRoomIndices is empty — skipping room creation for Room ${roomIndex}&quot;)
    vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
    return
}

if (shuffledIndicesStr) {
    def shuffledIndices = shuffledIndicesStr.split(&quot;,&quot;).collect { it.toInteger() }

    // Pick room based on roomIndex from shuffled list
    if (roomIndex &lt;= shuffledIndices.size()) {
        def selectedIndex = shuffledIndices[roomIndex - 1]
        selectedRoomId = vars.get(&quot;roomId_&quot; + selectedIndex)
        selectedRoomName = vars.get(&quot;roomName_&quot; + selectedIndex) ?: &quot;&quot;
    } else {
        log.warn(&quot;Day ${dayIndex}: roomIndex ${roomIndex} exceeds shuffled list size ${shuffledIndices.size()} — skipping&quot;)
        vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
        return
    }
}

// Skip if roomId is empty
if (!selectedRoomId || selectedRoomId == &quot;NOT_FOUND&quot;) {
    log.warn(&quot;Day ${dayIndex} Room ${roomIndex}: No valid roomId found - skipping&quot;)
    vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
    return
}

// DYNAMIC TIME OFFSET - random start/end times per room
def activityStart = vars.get(&quot;activityStartTime&quot;) ?: &quot;&quot;
def activityEnd = vars.get(&quot;activityEndTime&quot;) ?: &quot;&quot;

// Clean up original times - remove milliseconds and Z suffix
def cleanTime = { String timeStr -&gt;
    if (!timeStr) return timeStr
    return timeStr.replace(&quot;Z&quot;, &quot;&quot;).replaceAll(/\\.[0-9]+/, &quot;&quot;)
}

def roomStartTime = cleanTime(activityStart)
def roomEndTime = cleanTime(activityEnd)

// Parse roomBufferMinutes variable (e.g., &quot;30,60&quot;)
// INDEPENDENT RANDOM buffer (per room, per side):
//   - Every time this sampler runs (i.e. for EACH room), the start offset and
//     end offset are EACH picked independently at random from the comma list.
//     They may land on the same value or different ones, and every room
//     gets its own independent pair of draws. E.g. with &quot;30,60&quot; across 3 rooms
//     you might see Room1=(30,60), Room2=(60,60), Room3=(30,30).
//       roomStart = activityStart + startBuffer
//       roomEnd   = activityEnd   - endBuffer
// The buffer zones (activityStart→roomStart and roomEnd→activityEnd) are
// registered as blocked ranges in usedSlotRanges so agenda activities
// are never scheduled inside them.
def timeOffsetRaw = vars.get(&quot;roomBufferMinutes&quot;)?.trim() ?: &quot;0&quot;
def timeOffsets = timeOffsetRaw.split(&quot;,&quot;)
    .collect { it.trim() }
    .findAll { it.isInteger() }
    .collect { it.toInteger() }
    .findAll { it &gt;= 0 }

if (timeOffsets.isEmpty()) {
    timeOffsets = [0]
}

int startBuffer = 0
int endBuffer = 0

if (activityStart &amp;&amp; activityEnd) {
    try {
        def formatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)

        def startStr = activityStart.replace(&quot;Z&quot;, &quot;&quot;).replaceAll(/\.[0-9]+/, &quot;&quot;)
        def endStr   = activityEnd.replace(&quot;Z&quot;, &quot;&quot;).replaceAll(/\.[0-9]+/, &quot;&quot;)

        def startDt = LocalDateTime.parse(startStr, formatter)
        def endDt   = LocalDateTime.parse(endStr, formatter)

        def totalDurationMins = java.time.Duration.between(startDt, endDt).toMinutes()
        def minRoomDuration   = 30 // minimum viable room window after both buffers applied

        // Independent picks — start and end buffer are each drawn separately,
        // so they can match or differ for this room
        startBuffer = timeOffsets[java.util.concurrent.ThreadLocalRandom.current().nextInt(timeOffsets.size())]
        endBuffer   = timeOffsets[java.util.concurrent.ThreadLocalRandom.current().nextInt(timeOffsets.size())]

        // Guard: never let the combined buffer collapse the room window below minRoomDuration
        if ((startBuffer + endBuffer) &gt; (totalDurationMins - minRoomDuration)) {
            log.warn(&quot;[RoomBuffer] Room ${roomIndex}: startBuffer(${startBuffer})+endBuffer(${endBuffer}) too large for ${totalDurationMins}min day window - clamping both to 0&quot;)
            startBuffer = 0
            endBuffer = 0
        }

        def newStartDt = startDt.plusMinutes(startBuffer)
        def newEndDt   = endDt.minusMinutes(endBuffer)

        def outputFormatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)
        roomStartTime = newStartDt.format(outputFormatter)
        roomEndTime   = newEndDt.format(outputFormatter)

        log.info(&quot;[RoomBuffer] Room ${roomIndex}: start+${startBuffer}min / end-${endBuffer}min (independently picked) | Day: ${startStr} to ${endStr} | Room: ${roomStartTime} to ${roomEndTime}&quot;)
    } catch (Exception e) {
        log.warn(&quot;[RoomBuffer] Error applying buffer: ${e.message}&quot;)
    }
}

// Persist chosen buffer values for downstream reference (Register Room Buffer Zones, agenda slot selectors)
vars.put(&quot;chosenRoomBufferMinutes&quot;, &quot;${startBuffer},${endBuffer}&quot;)

// Set current room variables
vars.put(&quot;roomId&quot;, selectedRoomId)
vars.put(&quot;currentRoomName&quot;, selectedRoomName)
vars.put(&quot;roomType&quot;, roomType)
vars.put(&quot;logisticsRoomType&quot;, roomType)
vars.put(&quot;roomStartTime&quot;, roomStartTime)
vars.put(&quot;roomEndTime&quot;, roomEndTime)
vars.put(&quot;skipRoomCreation&quot;, &quot;false&quot;)

// ✅ FIX: Persist this room&apos;s buffer-adjusted start/end time keyed by its REAL
// roomId (same pattern already used for buffer zones). Without this, roomStartTime/
// roomEndTime stay global vars that get overwritten by every room created afterward,
// so by the time the Activities phase runs, every room except the very last one
// created uses the wrong window and can schedule activities into another room&apos;s
// buffer zone (visible as overlapping/UNAVAILABLE-adjacent bookings in the Agenda).
//
// ✅ FIX 2 (SmartSlot wrong date): Also store TIME-ONLY values per day+room so the
// Agenda Next Room restore returns pure HH:mm:ss strings instead of full ISO datetimes.
// Full ISO datetimes carry the Logistics day&apos;s date (e.g. 2026-07-03T07:30:00), which
// leaks into the SmartSlot window log/filter and causes all Day-1/Day-2 slots to show
// Day-3 dates. Stripping the date prefix here ensures the restored window is date-neutral
// (time-only) and SmartSlot uses the correct activityDate_ for the date portion.
if (selectedRoomId) {
    System.setProperty(&quot;jmeter.roomTime.Day&quot; + dayIndex + &quot;_&quot; + selectedRoomId + &quot;_start&quot;, roomStartTime ?: &quot;&quot;)
    System.setProperty(&quot;jmeter.roomTime.Day&quot; + dayIndex + &quot;_&quot; + selectedRoomId + &quot;_end&quot;, roomEndTime ?: &quot;&quot;)

    // Store time-only (HH:mm:ss) variant used by Agenda Next Room restore
    def toTimeOnly = { String iso -&gt;
        if (!iso) return &quot;&quot;
        return iso.contains(&quot;T&quot;) ? iso.substring(iso.indexOf(&quot;T&quot;) + 1) : iso
    }
    System.setProperty(&quot;jmeter.roomTimeOnly.Day&quot; + dayIndex + &quot;_&quot; + selectedRoomId + &quot;_start&quot;, toTimeOnly(roomStartTime))
    System.setProperty(&quot;jmeter.roomTimeOnly.Day&quot; + dayIndex + &quot;_&quot; + selectedRoomId + &quot;_end&quot;,   toTimeOnly(roomEndTime))
}

// Logistics Room Notes - random note for each room
def logisticsRoomNotesOptions = [
    &quot;Ensure projector and screen are set up before the session&quot;,
    &quot;Extra power strips required for laptop charging&quot;,
    &quot;Blinds to be closed for projector visibility&quot;,
    &quot;Reserved seating for VIP guests at the front&quot;,
    &quot;Signage to be placed outside the room&quot;,
    &quot;Whiteboard markers and eraser needed&quot;,
    &quot;Print and place agenda copies at each seat&quot;,
    &quot;Wireless microphone and speaker system required&quot;,
    &quot;Place welcome kits at each seat&quot;,
    &quot;Room lighting to be adjusted for presentation mode&quot;,
    &quot;Do not disturb sign to be placed during the session&quot;
]
def noteIndex = (roomIndex - 1) % logisticsRoomNotesOptions.size()
vars.put(&quot;logisticsRoomNotes&quot;, logisticsRoomNotesOptions[noteIndex])

// Store created room for Agenda section - PER DAY to avoid overwrites
// Using SYSTEM PROPERTIES for guaranteed cross-module persistence
def roomIdx = vars.get(&quot;RoomIndex&quot;)?.toInteger() ?: 1
def dayIdx = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;

// Build property names with prefix to avoid conflicts
String propNameId = &quot;jmeter.room.Day${dayIdx}_${roomIdx}_id&quot;.toString()
String propNameName = &quot;jmeter.room.Day${dayIdx}_${roomIdx}_name&quot;.toString()
String propNameCount = &quot;jmeter.roomCount.Day${dayIdx}&quot;.toString()

// Store values using SYSTEM properties (Java-level global)
String roomIdValue = selectedRoomId ?: &quot;&quot;
String roomNameValue = selectedRoomName ?: &quot;&quot;
String roomCountValue = roomIdx.toString()

System.setProperty(propNameId, roomIdValue)
System.setProperty(propNameName, roomNameValue)
System.setProperty(propNameCount, roomCountValue)

// VERIFY immediately after storage
String verifyId = System.getProperty(propNameId)
String verifyCount = System.getProperty(propNameCount)
log.info(&quot;VERIFY STORAGE - propNameId=&apos;${propNameId}&apos; stored=&apos;${roomIdValue}&apos; read=&apos;${verifyId}&apos;&quot;)
log.info(&quot;VERIFY STORAGE - propNameCount=&apos;${propNameCount}&apos; stored=&apos;${roomCountValue}&apos; read=&apos;${verifyCount}&apos;&quot;)

// Also store in vars for local access
vars.put(&quot;createdRoom_Day${dayIdx}_${roomIdx}_id&quot;.toString(), roomIdValue)
vars.put(&quot;createdRoom_Day${dayIdx}_${roomIdx}_name&quot;.toString(), roomNameValue)
vars.put(&quot;createdRoomCount_Day${dayIdx}&quot;.toString(), roomCountValue)

log.info(&quot;Stored for Agenda - Day ${dayIdx} Room [${roomIdx}]: ${selectedRoomName} (${selectedRoomId})&quot;)
log.info(&quot;  Props: ${propNameId} = &apos;${verifyId}&apos;&quot;)
log.info(&quot;  Props: ${propNameCount} = &apos;${verifyCount}&apos;&quot;)

// Debug output
def debugInfo = &quot;&quot;&quot;
Day: ${dayIndex}
RoomIndex (current): ${roomIndex}
TotalRooms: ${totalRooms}
SelectedRoomId: ${selectedRoomId}
SelectedRoomName: ${selectedRoomName}
RoomType: ${roomType}
LogisticsRoomNotes: ${vars.get(&quot;logisticsRoomNotes&quot;)}
ShuffledIndices: ${vars.get(&quot;shuffledRoomIndices_Day&quot; + dayIndex)}
ExtractedRoomCount: ${vars.get(&quot;roomId_matchNr&quot;)}
&quot;&quot;&quot;
SampleResult.setResponseData(debugInfo, &quot;UTF-8&quot;)

log.info(&quot;Day ${dayIndex} - Room ${roomIndex}/${totalRooms}: ${selectedRoomName} [${roomType}]&quot;)</stringProp>
                              <stringProp name="scriptLanguage">groovy</stringProp>
                              <stringProp name="parameters"></stringProp>
                              <stringProp name="filename"></stringProp>
                              <stringProp name="cacheKey">true</stringProp>
                            </JSR223Sampler>
                            <hashTree/>
                            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Register Room Buffer Zones" enabled="true">
                              <stringProp name="script">SampleResult.setIgnore()

def dayIndex  = vars.get(&quot;ActivityDayCount&quot;) ?: vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def roomIndex = vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;

def usedKey = &quot;usedSlotRanges_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex

def parseToMins = { String ts -&gt;
    if (!ts) return -1
    try {
        def tp = ts.contains(&quot;T&quot;) ? ts.substring(11, 16) : ts.trim()
        def p = tp.split(&quot;:&quot;)
        return p[0].toInteger() * 60 + p[1].toInteger()
    } catch (Exception e) { return -1 }
}

def minsToTime = { int m -&gt; String.format(&quot;%02d:%02d&quot;, (int)(m/60), m%60) }

def dayStart  = parseToMins(vars.get(&quot;activityStartTime_&quot; + dayIndex) ?: &quot;&quot;)
def dayEnd    = parseToMins(vars.get(&quot;activityEndTime_&quot;   + dayIndex) ?: &quot;&quot;)
def roomStart = parseToMins(vars.get(&quot;roomStartTime&quot;) ?: &quot;&quot;)
def roomEnd   = parseToMins(vars.get(&quot;roomEndTime&quot;)   ?: &quot;&quot;)

// Only apply if buffer actually shrinks the window
if (dayStart &lt; 0 || dayEnd &lt; 0 || roomStart &lt; 0 || roomEnd &lt; 0) {
    log.info(&quot;[RoomBuffer] Skipping - could not parse day/room times&quot;)
    return
}

def existing = vars.get(usedKey) ?: &quot;&quot;
def newRanges = []

// Block START buffer zone: day start → room start
if (roomStart &gt; dayStart) {
    newRanges &lt;&lt; (dayStart + &quot;:&quot; + roomStart)
    log.info(&quot;[RoomBuffer] Blocking START buffer: ${minsToTime(dayStart)}-${minsToTime(roomStart)} (Day${dayIndex} Room${roomIndex})&quot;)
}

// Block END buffer zone: room end → day end
if (dayEnd &gt; roomEnd) {
    newRanges &lt;&lt; (roomEnd + &quot;:&quot; + dayEnd)
    log.info(&quot;[RoomBuffer] Blocking END buffer: ${minsToTime(roomEnd)}-${minsToTime(dayEnd)} (Day${dayIndex} Room${roomIndex})&quot;)
}

if (newRanges) {
    def combined = existing ? existing + &quot;;&quot; + newRanges.join(&quot;;&quot;) : newRanges.join(&quot;;&quot;)
    vars.put(usedKey, combined)
    log.info(&quot;[RoomBuffer] usedSlotRanges updated for Day${dayIndex} Room${roomIndex}: ${combined}&quot;)

    // ✅ FIX: Also persist buffer zones in props (not vars) keyed by roomId so they
    // survive across samplers. vars are scoped to the thread-local context and may
    // not be visible when Next Room runs in a different sampler. props are global
    // JMeter properties guaranteed to persist for the full test duration.
    def currentRoomId = vars.get(&quot;roomId&quot;) ?: &quot;&quot;
    if (currentRoomId) {
        def bufferPropKey = &quot;jmeter.roomBuffer.Day&quot; + dayIndex + &quot;_&quot; + currentRoomId
        def existingBuffer = System.getProperty(bufferPropKey) ?: &quot;&quot;
        def bufferRanges = newRanges.findAll { r -&gt;
            !existingBuffer.split(&quot;;&quot;).contains(r)
        }
        if (bufferRanges) {
            def newBuffer = existingBuffer ? existingBuffer + &quot;;&quot; + bufferRanges.join(&quot;;&quot;) : bufferRanges.join(&quot;;&quot;)
            System.setProperty(bufferPropKey, newBuffer)
            log.info(&quot;[RoomBuffer] Persisted buffer zones in props for roomId=${currentRoomId} (Day${dayIndex}): ${newBuffer}&quot;)
        }
    }
} else {
    log.info(&quot;[RoomBuffer] No buffer zones to block (room window matches day window exactly)&quot;)
}</stringProp>
                              <stringProp name="scriptLanguage">groovy</stringProp>
                              <stringProp name="parameters"></stringProp>
                              <stringProp name="filename"></stringProp>
                              <stringProp name="cacheKey">true</stringProp>
                            </JSR223Sampler>
                            <hashTree/>
                            <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ If (Room Valid)" enabled="true">
                              <stringProp name="IfController.condition">${__groovy(vars.get(&quot;skipRoomCreation&quot;) != &quot;true&quot; &amp;&amp; vars.get(&quot;roomId&quot;) != null &amp;&amp; vars.get(&quot;roomId&quot;) != &quot;&quot; &amp;&amp; vars.get(&quot;roomId&quot;) != &quot;NOT_FOUND&quot;)}</stringProp>
                              <boolProp name="IfController.useExpression">true</boolProp>
                              <boolProp name="IfController.evaluateAll">false</boolProp>
                            </IfController>
                            <hashTree>
                              <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Create Room - ${currentRoomName} #${RoomIndex}" enabled="true">
                                <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
                                <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                                  <collectionProp name="Arguments.arguments">
                                    <elementProp name="" elementType="HTTPArgument">
                                      <boolProp name="HTTPArgument.always_encode">false</boolProp>
                                      <stringProp name="Argument.value">{&#xd;
    &quot;resource&quot;: {&#xd;
        &quot;uniqueId&quot;: &quot;${roomId}&quot;&#xd;
    },&#xd;
    &quot;activityDayId&quot;: &quot;${activityid}&quot;,&#xd;
    &quot;requestDate&quot;: {&#xd;
        &quot;isoDate&quot;: &quot;${activityDate}&quot;&#xd;
    },&#xd;
    &quot;startTime&quot;: {&#xd;
        &quot;isoDate&quot;: &quot;${roomStartTime}&quot;&#xd;
    },&#xd;
    &quot;endTime&quot;: {&#xd;
        &quot;isoDate&quot;: &quot;${roomEndTime}&quot;&#xd;
    }&#xd;
}</stringProp>
                                      <stringProp name="Argument.metadata">=</stringProp>
                                    </elementProp>
                                  </collectionProp>
                                </elementProp>
                                <stringProp name="HTTPSampler.domain"></stringProp>
                                <stringProp name="HTTPSampler.port"></stringProp>
                                <stringProp name="HTTPSampler.protocol"></stringProp>
                                <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                                <stringProp name="HTTPSampler.path">/${contextname}/api/events/${requestId}/eventresources</stringProp>
                                <stringProp name="HTTPSampler.method">POST</stringProp>
                                <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
                                <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                                <boolProp name="HTTPSampler.use_keepalive">false</boolProp>
                                <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                                <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                                <stringProp name="HTTPSampler.connect_timeout">30000</stringProp>
                                <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
                              </HTTPSamplerProxy>
                              <hashTree>
                                <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                                  <collectionProp name="HeaderManager.headers">
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-customerid</stringProp>
                                      <stringProp name="Header.value">${customerId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                                      <stringProp name="Header.value">${categoryTypeId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                                      <stringProp name="Header.value">${categoryId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                                      <stringProp name="Header.value">${baseTimezone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                                      <stringProp name="Header.value">${clientTimeZone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Context-Timezone</stringProp>
                                      <stringProp name="Header.value">${baseTimezone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-eventid</stringProp>
                                      <stringProp name="Header.value">${requestId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X_cloud_user</stringProp>
                                      <stringProp name="Header.value">${currentUser}</stringProp>
                                    </elementProp>
                                  </collectionProp>
                                </HeaderManager>
                                <hashTree/>
                                <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Activity Day Resource ID Extractor" enabled="true">
                                  <stringProp name="JSONPostProcessor.referenceNames">activityDayResourceId</stringProp>
                                  <stringProp name="JSONPostProcessor.jsonPathExprs">$.activityDayResourceId</stringProp>
                                  <stringProp name="JSONPostProcessor.match_numbers"></stringProp>
                                </JSONPostProcessor>
                                <hashTree/>
                                <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                                <hashTree/>
                              </hashTree>
                              <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Assign (${roomType}) to ${currentRoomName}" enabled="true">
                                <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
                                <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                                  <collectionProp name="Arguments.arguments">
                                    <elementProp name="" elementType="HTTPArgument">
                                      <boolProp name="HTTPArgument.always_encode">false</boolProp>
                                      <stringProp name="Argument.value">${dynamicFormPayload}</stringProp>
                                      <stringProp name="Argument.metadata">=</stringProp>
                                    </elementProp>
                                  </collectionProp>
                                </elementProp>
                                <stringProp name="HTTPSampler.domain"></stringProp>
                                <stringProp name="HTTPSampler.port"></stringProp>
                                <stringProp name="HTTPSampler.protocol"></stringProp>
                                <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                                <stringProp name="HTTPSampler.path">/${contextname}/api/forms/${currentFormId}/data</stringProp>
                                <stringProp name="HTTPSampler.method">POST</stringProp>
                                <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
                                <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                                <boolProp name="HTTPSampler.use_keepalive">false</boolProp>
                                <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                                <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                                <stringProp name="HTTPSampler.connect_timeout">30000</stringProp>
                                <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
                              </HTTPSamplerProxy>
                              <hashTree>
                                <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                                  <collectionProp name="HeaderManager.headers">
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-customerid</stringProp>
                                      <stringProp name="Header.value">${customerId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                                      <stringProp name="Header.value">${categoryTypeId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                                      <stringProp name="Header.value">${categoryId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                                      <stringProp name="Header.value">${baseTimezone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                                      <stringProp name="Header.value">${clientTimeZone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X-Cloud-Context-Timezone</stringProp>
                                      <stringProp name="Header.value">${baseTimezone}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-eventid</stringProp>
                                      <stringProp name="Header.value">${requestId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">x-cloud-activityday-resource</stringProp>
                                      <stringProp name="Header.value">${activityDayResourceId}</stringProp>
                                    </elementProp>
                                    <elementProp name="" elementType="Header">
                                      <stringProp name="Header.name">X_cloud_user</stringProp>
                                      <stringProp name="Header.value">${currentUser}</stringProp>
                                    </elementProp>
                                  </collectionProp>
                                </HeaderManager>
                                <hashTree/>
                                <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Dynamic Payload Builder PreProcessor" enabled="true">
                                  <stringProp name="script">

// Dynamic payload entry

// Clear stale existingFormData from previous modules
vars.put(&quot;existingFormData&quot;, &quot;{}&quot;)

def formName = vars.get(&quot;currentFormName&quot;)

// Get room name for TEXT field (Main Room or Breakout Room X)
def roomNameForText = vars.get(&quot;currentRoomName&quot;)
def roomNameUsed = false

def rand = java.util.concurrent.ThreadLocalRandom.current()

// Multi-select configuration from User Defined Variables
def minSelection = props.get(&quot;fn_parseMultiDropDownRange&quot;)(vars, null).min
def maxSelection = props.get(&quot;fn_parseMultiDropDownRange&quot;)(vars, null).max

// Helper function to generate random selection count
def getRandomSelectionCount = { int availableCount -&gt;
    def maxPossible = Math.min(availableCount, maxSelection)
    def minPossible = Math.min(minSelection, maxPossible)
    return minPossible + rand.nextInt((maxPossible - minPossible) + 1)
}

// Load shared function: generateRandomNumber
def generateRandomNumber(int min, int max) { return props.get(&quot;fn_generateRandomNumber&quot;)(min, max) }

// Load shared function: generateFutureDate
def generateFutureDate = { props.get(&quot;fn_generateFutureDate&quot;)(vars) }

// Load shared function: generateFutureTime
def generateFutureTime(int hoursOffset) { return props.get(&quot;fn_generateFutureTime&quot;)(vars, hoursOffset) }
// Reset future time day offset for this form
props.get(&quot;fn_resetFutureTimeDayOffset&quot;)(vars)
// STEP 1: Get formUIConfig
def formUIConfigStr = vars.get(&quot;currentFormUIConfig&quot;)

if (!formUIConfigStr) {
    log.warn(&quot;formUIConfig not found - skipping&quot;)
    vars.put(&quot;dynamicFormPayload&quot;, &quot;{}&quot;)
    return
}
// STEP 2: Get and Parse fieldMappings
def fieldMappingsStr = vars.get(&quot;currentFieldMappings&quot;)
def fieldMappingsMap = props.get(&quot;fn_parseFieldMappings&quot;)(fieldMappingsStr)
// STEP 3: Parse formUIConfig and Extract All Fields
def allFields = props.get(&quot;fn_extractAllFields&quot;)(formUIConfigStr)
// STEP 4: Initialize Form Data and Default Values
def formData = [:]

// Default text values for auto-generation
def defaultTexts = props.get(&quot;fn_defaultTextFields&quot;)

// Default textarea values for auto-generation
def textareaValues = props.get(&quot;fn_defaultTextAreas&quot;)
// STEP 4.5: Build Dependent Controls Map
def _depResult = props.get(&quot;fn_buildDependentControlsMap&quot;)(allFields)
def dependentControlsMap = _depResult.map
def dependentFieldsSet = _depResult.fieldSet

// FIX: Two-pass ordering — process parent/standalone fields first, dependent fields second.
def nonDependentFields = allFields.findAll { f -&gt; !dependentFieldsSet.contains(f.dataMapping ?: f.formControlName) }
def dependentFields    = allFields.findAll { f -&gt;  dependentFieldsSet.contains(f.dataMapping ?: f.formControlName) }
def orderedFields = nonDependentFields + dependentFields
log.info(&quot;PayloadBuilder: field order — ${nonDependentFields.size()} parent/standalone + ${dependentFields.size()} dependent&quot;)

// Helper: Check if dependent field should be shown
def shouldShowDependentField(String depFieldName, Map formDataSoFar) {
    props.get(&quot;fn_shouldShowDependentField&quot;)(depFieldName, formDataSoFar, dependentControlsMap, vars)
}

// Get existing form data (stored from Get Form API)
def existingFormDataStr = vars.get(&quot;existingFormData&quot;)
def existingFormData = existingFormDataStr ? new groovy.json.JsonSlurper().parseText(existingFormDataStr) : [:]

// STEP 5: Process Each Field (ordered: parents first, dependent children second)
orderedFields.each { field -&gt;

    // Extract field properties
    def fieldName = field.dataMapping ?: field.formControlName
    def fieldType = field.formControlType
    def fieldLabel = field.fieldLabel ?: fieldName
    def isMultiple = field.isMultiple ?: false
    def lookupName = field.lookupName
    def isHidden = field.hide ?: false
    def isDisabled = field.disabled ?: false 

    // CHECK: Skip if field already has MEANINGFUL value in existing data
    def existingValue = existingFormData[fieldName]
    def isNumericField = fieldType in [&quot;NUMBER&quot;, &quot;CURRENCY&quot;, &quot;DECIMAL&quot;]
    def isBooleanField = fieldType == &quot;CHECKBOX&quot;
    def isEmptyNumeric = isNumericField &amp;&amp; (existingValue == 0 || existingValue == 0.0 || existingValue == &quot;0&quot;)
    def isEmptyBoolean = isBooleanField &amp;&amp; (existingValue == false || existingValue == &quot;false&quot;)

    if (existingValue != null &amp;&amp; existingValue.toString().trim() != &quot;&quot; &amp;&amp; !isEmptyNumeric &amp;&amp; !isEmptyBoolean) {
        formData[fieldName] = existingValue
        return
    }

    // Extract Resource/Master Type IDs
    def resourceTypeId = field.resourceTypeId ?: field.resourceType?.id ?:
                         field.resourceType?.uniqueId ?:
                         (field.resourceType instanceof String ? field.resourceType : null)
    def masterTypeId = field.masterTypeId ?: field.masterType?.id ?:
                       field.masterType?.uniqueId ?:
                       (field.masterType instanceof String ? field.masterType : null)

    // Get aliasName from fieldMappings
    def mappingInfo = fieldMappingsMap[fieldName]
    def aliasName = mappingInfo?.aliasName
    // Skip Hidden Fields
    if (isHidden) {
        return
    }

    // Skip fields based on hiddenRoles (check against selected role only)
    def hiddenRoles = field.hiddenRoles ?: []
    if (hiddenRoles) {
        def userRole = vars.get(&quot;roleId&quot;) ?: &quot;&quot;

        if (hiddenRoles.contains(userRole)) {
            log.info(&quot;Skipping field &apos;${fieldName}&apos; - user role &apos;${userRole}&apos; is in hiddenRoles: ${hiddenRoles}&quot;)
            return
        }
    }

     // Skip fields based on readOnlyRoles (check against selected role only)
    def readOnlyRoles = field.readOnlyRoles ?: []
    if (readOnlyRoles) {

        if (readOnlyRoles.contains(userRole)) {
            log.info(&quot;Skipping field &apos;${fieldName}&apos; - user role &apos;${userRole}&apos; is in readOnlyRoles: ${readOnlyRoles}&quot;)
            return
        }
    }

    if (isDisabled) {
        return
    }
    // Check Dependent Field Visibility
    if (dependentFieldsSet.contains(fieldName)) {
        if (!shouldShowDependentField(fieldName, formData)) {
            return
        }
    }

    def value = null
    def skipField = false
    // PRIORITY 1: Get Value from JMeter Variable (via alias)
    // For SELECT fields with isMultiple=true and lookupName, skip alias to use multi-select logic
    def skipAliasForMultiSelect = (fieldType == &quot;SELECT&quot; &amp;&amp; isMultiple &amp;&amp; lookupName)

    if (aliasName &amp;&amp; !skipAliasForMultiSelect) {
        value = vars.get(aliasName)

        if (value != null &amp;&amp; value != &quot;&quot;) {
            // Smart handling based on isMultiple from form config
            // SKIP comma-splitting for TEXTAREA fields - they can legitimately contain commas
            if (fieldType != &quot;TEXTAREA&quot; &amp;&amp; value instanceof String &amp;&amp; value.contains(&quot;,&quot;)) {
                if (isMultiple) {
                    // isMultiple = true  to  Convert to array
                    value = value.split(&quot;,&quot;).collect { it.trim() }.toList()
                } else {
                    // isMultiple = false  to  Take FIRST value only
                    value = value.split(&quot;,&quot;)[0].trim()
                }
            } else {
                // Single value
                if (isMultiple) {
                    value = [value]
                }
            }
        }
    }
    // PRIORITY 2: Auto-generate if No Alias or No Value
    if (isNumericField &amp;&amp; (value == &quot;0&quot; || value == 0 || value == 0.0)) value = null
    if (value == null || value == &quot;&quot;) {
        switch(fieldType) {

            // TEXT Field
            case &quot;TEXT&quot;:
                // Use roomNameForText for first TEXT field (for room creation)
                if (roomNameForText &amp;&amp; !roomNameUsed &amp;&amp; !isMultiple) {
                    value = roomNameForText
                    roomNameUsed = true
                } else if (isMultiple) {
                    def count = getRandomSelectionCount(defaultTexts.length)
                    def values = []
                    for (int j = 0; j &lt; count; j++) {
                        values.add(defaultTexts[rand.nextInt(defaultTexts.length)])
                    }
                    value = values
                } else {
                    value = defaultTexts[rand.nextInt(defaultTexts.length)]
                }
                break

            // TEXTAREA Field
            case &quot;TEXTAREA&quot;:
                value = textareaValues[rand.nextInt(textareaValues.length)]
                break

            // NUMBER Field
            case &quot;NUMBER&quot;:
                value = props.get(&quot;fn_randomNumber1to5&quot;)()
                break

            // CURRENCY Field
            case &quot;CURRENCY&quot;:
                value = props.get(&quot;fn_randomNumber1to5&quot;)()
                break

            // CLOUD_DATE Field
            case &quot;CLOUD_DATE&quot;:
                value = generateFutureDate()
                break

            // CLOUD_TIME Field
            case &quot;CLOUD_TIME&quot;:
                if (fieldName.toLowerCase().contains(&quot;start&quot;)) {
                    value = generateFutureTime(9)
                } else if (fieldName.toLowerCase().contains(&quot;end&quot;)) {
                    value = generateFutureTime(18)
                } else {
                    value = generateFutureTime(rand.nextInt(9) + 8)
                }
                break

            // SELECT Field
            case &quot;SELECT&quot;:
                // Check for TIMEZONE enumType
                if ((field.enumType ?: &quot;&quot;) == &quot;TIMEZONE&quot;) {
                    value = vars.get(&quot;requestTimeZone&quot;) ?: &quot;&quot;
                } else if ((field.enumType ?: &quot;&quot;) == &quot;RESOURCE&quot; &amp;&amp; resourceTypeId) {
                    // FIX: SELECT fields with enumType=RESOURCE (e.g. Briefing Manager, Technical Manager)
                    def rtCountStr = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_count&quot;)
                    if (rtCountStr &amp;&amp; rtCountStr.isInteger() &amp;&amp; rtCountStr.toInteger() &gt; 0) {
                        def rtCount = rtCountStr.toInteger()
                        if (isMultiple) {
                            def selectCount = getRandomSelectionCount(rtCount)
                            def selectedValues = []
                            def indices = (1..rtCount).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def resourceId = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                if (resourceId) selectedValues.add(props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, resourceId))
                            }
                            if (selectedValues) { value = selectedValues }
                        } else {
                            def randomIndex = rand.nextInt(rtCount) + 1
                            def resourceId = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                            value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, resourceId)
                        }
                        if (!value) {
                            log.warn(&quot;SELECT[RESOURCE] field &apos;${fieldName}&apos; - no resource value found for typeId: ${resourceTypeId} - SKIPPING&quot;)
                            skipField = true
                        }
                    } else {
                        log.warn(&quot;SELECT[RESOURCE] field &apos;${fieldName}&apos; - no resources fetched for typeId: ${resourceTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                } else if (lookupName) {
                    // Check if this is ROOM_TYPE and we already have a roomType set
                    if (lookupName == &quot;ROOM_TYPE&quot;) {
                        def existingRoomType = vars.get(&quot;roomType&quot;)
                        if (existingRoomType) {
                            value = existingRoomType
                            break
                        }
                    }

                    // Convert SNAKE_CASE to camelCase
                    def words = lookupName.toLowerCase().split(&apos;_&apos;)
                    def camelCaseName = words[0] + words.drop(1).collect { it.capitalize() }.join(&apos;&apos;)

                    if (isMultiple) {
                        // Multi-select: pick random values based on minSelection/maxSelection
                        def countStr = vars.get(camelCaseName + &quot;_count&quot;)

                        if (countStr &amp;&amp; countStr.isInteger()) {
                            def count = countStr.toInteger()
                            def selectCount = getRandomSelectionCount(count)
                            def selectedValues = []
                            def indices = (1..count).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def val = vars.get(camelCaseName + &quot;_&quot; + idx)
                                if (val) selectedValues.add(val)
                            }
                            if (selectedValues) {
                                value = selectedValues

                            } else {
                                log.warn(&quot;No lookup values for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                                skipField = true
                            }
                        } else {
                            log.warn(&quot;No lookup count for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                            skipField = true
                        }
                    } else {
                        // Single select: pick one random value
                        def countStr = vars.get(camelCaseName + &quot;_count&quot;)
                        if (countStr &amp;&amp; countStr.isInteger()) {
                            def count = countStr.toInteger()
                            def randomIndex = rand.nextInt(count) + 1
                            value = vars.get(camelCaseName + &quot;_&quot; + randomIndex)

                        } else {
                            value = vars.get(camelCaseName)
                            if (value) {

                            } else {
                                log.warn(&quot;No lookup value for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                                skipField = true
                            }
                        }
                    }
                } else {
                    log.warn(&quot;No lookupName defined - SKIPPING field&quot;)
                    skipField = true
                }
                break

            // CHECKBOX Field
            case &quot;CHECKBOX&quot;:
                value = rand.nextBoolean()
                break

            // RESOURCE Field
            case &quot;RESOURCE&quot;:
                if (resourceTypeId) {

                    def rtCountStr = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_count&quot;)
                    if (rtCountStr &amp;&amp; rtCountStr.isInteger() &amp;&amp; rtCountStr.toInteger() &gt; 0) {
                        def rtCount = rtCountStr.toInteger()

                        if (isMultiple) {
                            // Multi-select resources
                            def selectCount = getRandomSelectionCount(rtCount)
                            def selectedValues = []
                            def indices = (1..rtCount).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def resourceId = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                if (resourceId) selectedValues.add(props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, resourceId))
                            }
                            if (selectedValues) {
                                value = selectedValues

                            }
                        } else {
                            // Single select resource
                            def randomIndex = rand.nextInt(rtCount) + 1
                            def resourceId = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                            value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, resourceId)
                        }
                    } else {
                        log.warn(&quot;No resources fetched for resourceTypeId: ${resourceTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                } else {
                    log.warn(&quot;RESOURCE/AUTOCOMPLETE field without resourceTypeId - SKIPPING&quot;)
                    skipField = true
                }
                break

            // MASTER Field
            case &quot;MASTER&quot;:
                if (masterTypeId) {

                    def mtCountStr = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_count&quot;)
                    if (mtCountStr &amp;&amp; mtCountStr.isInteger() &amp;&amp; mtCountStr.toInteger() &gt; 0) {
                        def mtCount = mtCountStr.toInteger()

                        if (isMultiple) {
                            // Multi-select masters
                            def selectCount = getRandomSelectionCount(mtCount)
                            def selectedValues = []
                            def indices = (1..mtCount).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def masterId = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                def formatted = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, masterId)
                                if (formatted != null) selectedValues.add(formatted)
                            }
                            if (selectedValues) {
                                value = selectedValues

                            }
                        } else {
                            // Single select master — format per isComplexObject
                            def randomIndex = rand.nextInt(mtCount) + 1
                            def masterId = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                            value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, masterId)
                        }
                    } else {
                        log.warn(&quot;No masters fetched for masterTypeId: ${masterTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                } else {
                    log.warn(&quot;MASTER field without masterTypeId - SKIPPING&quot;)
                    skipField = true
                }
                break

            // Unknown Field Type
            default:
                log.warn(&quot;Unknown field type &apos;${fieldType}&apos; - SKIPPING field&quot;)
                skipField = true
        }
    }
    // STEP 6: Add to formData with Proper Type Handling
    if (!skipField &amp;&amp; value != null &amp;&amp; value != &quot;&quot;) {
        if ((fieldType == &quot;CLOUD_DATE&quot; || fieldType == &quot;CLOUD_TIME&quot;) &amp;&amp; !(value instanceof Map)) {
            // Wrap date/time in isoDate format
            formData[fieldName] = [&quot;isoDate&quot;: value]
        } else if (fieldType == &quot;CHECKBOX&quot;) {
            // Ensure boolean type
            formData[fieldName] = (value instanceof String) ? value.toLowerCase() == &quot;true&quot; : value
        } else if (fieldType == &quot;NUMBER&quot;) {
            // Ensure integer type
            formData[fieldName] = (value instanceof String &amp;&amp; value.isInteger()) ? value.toInteger() : value
        } else if (fieldType == &quot;MASTER&quot; &amp;&amp; isMultiple &amp;&amp; !(value instanceof List)) {
            // FIX: Wrap single master Map in array for multi-select master fields
            formData[fieldName] = [value]
        } else if (isMultiple &amp;&amp; !(value instanceof List)) {
            // Wrap single value in array for other multi-select fields
            formData[fieldName] = [value]
        } else {
            formData[fieldName] = value
        }
    }
}
// STEP 7: Build Complete Payload
def payload = [
    &quot;moduleId&quot; : vars.get(&quot;currentModuleId&quot;) ?: vars.get(&quot;moduleId&quot;),
    &quot;formId&quot;   : vars.get(&quot;currentFormId&quot;) ?: vars.get(&quot;formId&quot;),
    &quot;journeyId&quot;: vars.get(&quot;currentJourneyId&quot;),
    &quot;pageId&quot;   : vars.get(&quot;currentPageId&quot;),
    &quot;id&quot;       : vars.get(&quot;activityDayResourceId&quot;),
    &quot;data&quot;     : formData
]

// Convert to JSON and store
def payloadJson = groovy.json.JsonOutput.prettyPrint(groovy.json.JsonOutput.toJson(payload))
vars.put(&quot;dynamicFormPayload&quot;, payloadJson)
// ============ FIELD TRACKING ============
// Store processed field keys for cross-user comparison (shared via props)
// FIX: Scope by requestId to prevent processedFields bleeding across different requests
def _trackModuleName = vars.get(&quot;currentModuleName&quot;) ?: vars.get(&quot;currentActivityModuleName&quot;) ?: vars.get(&quot;newRequestModuleName&quot;) ?: &quot;unknown&quot;
def _trackFormName = vars.get(&quot;currentFormName&quot;) ?: vars.get(&quot;requestFormName&quot;) ?: &quot;unknown&quot;
def _trackRequestId = vars.get(&quot;requestId&quot;) ?: &quot;unknown&quot;
def _trackKey = &quot;processedFields_&quot; + _trackRequestId + &quot;_&quot; + _trackModuleName + &quot;_&quot; + _trackFormName
def _existingTracked = props.get(_trackKey) ?: (new HashSet())
for (def k : formData.keySet()) { _existingTracked.add(k) }
props.put(_trackKey, _existingTracked)
log.info(&quot;Field Tracking: Stored ${formData.size()} fields for &apos;${_trackKey}&apos; (total tracked: ${_existingTracked.size()})&quot;)
</stringProp>
                                  <stringProp name="scriptLanguage">groovy</stringProp>
                                  <stringProp name="parameters"></stringProp>
                                  <stringProp name="filename"></stringProp>
                                  <stringProp name="cacheKey">true</stringProp>
                                </JSR223PreProcessor>
                                <hashTree/>
                                <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                                <hashTree/>
                              </hashTree>
