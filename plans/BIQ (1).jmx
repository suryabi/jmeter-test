                                    <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ Add Zoom To Topic " enabled="false">
                                      <stringProp name="IfController.condition">${__groovy(def actType = (vars.get(&apos;loopActivityType&apos;) ?: vars.get(&apos;activityType&apos;) ?: &apos;&apos;).toLowerCase(); def topicType = (vars.get(&apos;topicTypeName&apos;) ?: &apos;&apos;).toLowerCase(); def zoomLink = vars.get(&apos;zoom&apos;) ?: &apos;&apos;; def activityId = vars.get(&apos;activityId&apos;) ?: &apos;&apos;; def selectedAction = (vars.get(&apos;selectedAction&apos;) ?: &apos;&apos;).toUpperCase(); def zoomAllowed = (vars.get(&apos;zoomAllowedActions&apos;) ?: &apos;CONFIRM&apos;).toUpperCase(); def isAllowed = zoomAllowed.contains(selectedAction); actType == topicType &amp;&amp; zoomLink.trim() &amp;&amp; !zoomLink.contains(&apos;null&apos;) &amp;&amp; activityId.trim() &amp;&amp; isAllowed)}</stringProp>
