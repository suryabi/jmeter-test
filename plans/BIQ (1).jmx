<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.4.1">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="BIQ - EIQ" enabled="true">
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <stringProp name="TestPlan.comments"></stringProp>
      <stringProp name="TestPlan.user_define_classpath"></stringProp>
    </TestPlan>
    <hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="BIQ Request flow" enabled="true">
        <stringProp name="ThreadGroup.num_threads">1</stringProp>
        <stringProp name="ThreadGroup.ramp_time">1</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <stringProp name="ThreadGroup.duration"></stringProp>
        <stringProp name="ThreadGroup.delay"></stringProp>
      </ThreadGroup>
      <hashTree>
        <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Request Variables" enabled="true">
          <collectionProp name="Arguments.arguments">
            <elementProp name="requestStartDate" elementType="Argument">
              <stringProp name="Argument.name">requestStartDate</stringProp>
              <stringProp name="Argument.value">2026-12-01</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DATE, REQUIRED, LABEL=creationWindowStart. Select the start date for request creation</stringProp>
            </elementProp>
            <elementProp name="requestEndDate" elementType="Argument">
              <stringProp name="Argument.name">requestEndDate</stringProp>
              <stringProp name="Argument.value">2026-12-01</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DATE, REQUIRED, LABEL=creationWindowEnd. Select the end date for request creation. Must be on or after the start date</stringProp>
            </elementProp>
            <elementProp name="requestsPerDay" elementType="Argument">
              <stringProp name="Argument.name">requestsPerDay</stringProp>
              <stringProp name="Argument.value">1</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">LABEL=requestsPerDay. The number of requests to create per day (e.g., 1,2,3). One value is selected randomly. Empty = defaults to 1</stringProp>
            </elementProp>
            <elementProp name="requestDays" elementType="Argument">
              <stringProp name="Argument.name">requestDays</stringProp>
              <stringProp name="Argument.value">1</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">LABEL=noOfDaysInRequest. The number of days a request should span (e.g., 1,2,3). One value is selected randomly. Empty = defaults to 1</stringProp>
            </elementProp>
            <elementProp name="allowWeekends" elementType="Argument">
              <stringProp name="Argument.name">allowWeekends</stringProp>
              <stringProp name="Argument.value">false</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">BOOLEAN, HIDE. Flag to allow/disallow request creation on weekends. (Default = false)</stringProp>
            </elementProp>
            <elementProp name="requestStartTimes" elementType="Argument">
              <stringProp name="Argument.name">requestStartTimes</stringProp>
              <stringProp name="Argument.value">07:00, 07:30, 08:00, 08:30, 09:00</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">REQUIRED, LABEL=requestDayStartTime. Request start time (HH:mm, e.g., 07:00,08:00). One value is selected randomly</stringProp>
            </elementProp>
            <elementProp name="requestDurations" elementType="Argument">
              <stringProp name="Argument.name">requestDurations</stringProp>
              <stringProp name="Argument.value">420, 480, 540, 600</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">REQUIRED, LABEL=requestDayDuration. Request duration in minutes (e.g., 420,480). One value is selected randomly. Minimum: 30 </stringProp>
            </elementProp>
            <elementProp name="categoryType" elementType="Argument">
              <stringProp name="Argument.name">categoryType</stringProp>
              <stringProp name="Argument.value">CATEGORY_TYPE_BRIEFINGS</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, REQUIRED, HIDE. Select the category type to use</stringProp>
            </elementProp>
            <elementProp name="parentCategory" elementType="Argument">
              <stringProp name="Argument.name">parentCategory</stringProp>
              <stringProp name="Argument.value">72DCAF42-C7C0-4006-8F31-7952185E5D61</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, REQUIRED, LABEL=location. Select the location where requests will be created</stringProp>
            </elementProp>
            <elementProp name="category" elementType="Argument">
              <stringProp name="Argument.name">category</stringProp>
              <stringProp name="Argument.value">D06189A1-69AF-4D17-AC5B-480F7589D427</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, REQUIRED, LABEL=requestType. Select the request type to create</stringProp>
            </elementProp>
            <elementProp name="targetActions" elementType="Argument">
              <stringProp name="Argument.name">targetActions</stringProp>
              <stringProp name="Argument.value">CONFIRM, HOLD, WAITLIST</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, MULTI. Actions to perform after SUBMIT. Processing stops after the first selected action is performed. Empty = all available actions are allowed</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
          </collectionProp>
          <stringProp name="TestPlan.comments">CONFIRM, HOLD, WAITLIST</stringProp>
        </Arguments>
        <hashTree/>
        <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Customer Variables" enabled="true">
          <collectionProp name="Arguments.arguments">
            <elementProp name="defaultUser" elementType="Argument">
              <stringProp name="Argument.name">defaultUser</stringProp>
              <stringProp name="Argument.value">supportuser@allianceit.com</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">REQUIRED. Support user for fetching Master data APIs</stringProp>
            </elementProp>
            <elementProp name="users" elementType="Argument">
              <stringProp name="Argument.name">users</stringProp>
              <stringProp name="Argument.value">admin@allianceit.com</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Users to process requests, in order (e.g., sales@allianceit.com, admin@allianceit.com). Empty = uses defaultUser </stringProp>
            </elementProp>
            <elementProp name="customerName" elementType="Argument">
              <stringProp name="Argument.name">customerName</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Specify a customer name for the request (e.g. AllianceIT). If it already exists, request creation is skipped. Empty = selects a unique random customer</stringProp>
            </elementProp>
            <elementProp name="checkDuplicateCustomer" elementType="Argument">
              <stringProp name="Argument.name">checkDuplicateCustomer</stringProp>
              <stringProp name="Argument.value">true</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">BOOLEAN. Check for duplicate customer names. Enabled = unique customer name; Disabled = allow duplicates</stringProp>
            </elementProp>
            <elementProp name="duplicateCustomerFromDate" elementType="Argument">
              <stringProp name="Argument.name">duplicateCustomerFromDate</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DATE. Start date for duplicate customer. Empty = checks all requests for the selected request type</stringProp>
            </elementProp>
            <elementProp name="duplicateCustomerToDate" elementType="Argument">
              <stringProp name="Argument.name">duplicateCustomerToDate</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DATE. End date for duplicate customer. Empty = checks all requests for the selected request type</stringProp>
            </elementProp>
            <elementProp name="clientTimeZone" elementType="Argument">
              <stringProp name="Argument.name">clientTimeZone</stringProp>
              <stringProp name="Argument.value">Asia/Calcutta</stringProp>
              <stringProp name="Argument.desc">Time zone of the user creating the request (e.g., Asia/Calcutta)</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
          </collectionProp>
        </Arguments>
        <hashTree/>
