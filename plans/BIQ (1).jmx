                      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Set Activity Day Date &amp; Time" enabled="true">
                        <stringProp name="script">// Current day index
def dayIndex = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;

// Pick values for this day
def eventDate = vars.get(&quot;activityDate_&quot; + dayIndex) ?: &quot;&quot;
def startTime = vars.get(&quot;activityStartTime_&quot; + dayIndex) ?: &quot;&quot;
def endTime = vars.get(&quot;activityEndTime_&quot; + dayIndex) ?: &quot;&quot;

// Store generic variables for API usage
vars.put(&quot;eventDate&quot;, eventDate)
vars.put(&quot;eventStartTime&quot;, startTime)
vars.put(&quot;eventEndTime&quot;, endTime)

// Debug logging
log.info(&quot;Using Activity Day ${dayIndex}&quot;)
log.info(&quot;Event Date: ${eventDate}&quot;)
log.info(&quot;Start Time: ${startTime}&quot;)
log.info(&quot;End Time: ${endTime}&quot;)</stringProp>
                        <stringProp name="scriptLanguage">groovy</stringProp>
                        <stringProp name="parameters"></stringProp>
                        <stringProp name="filename"></stringProp>
                        <stringProp name="cacheKey">true</stringProp>
                      </JSR223PreProcessor>
                      <hashTree/>
                      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Check Existing Event Resources" enabled="true">
                        <stringProp name="script">

try {
    def response = prev.getResponseDataAsString()
    def resourceCount = 0

    if (response &amp;&amp; response.trim()) {
        def json = new groovy.json.JsonSlurper().parseText(response)

        // Response is array of eventDates, each may have nested resources[]
        // Example: [{eventDateId:..., resources:[{resourceId:..., resource:{data:{name:&quot;Room1&quot;}}}]}, ...]
        // When no rooms: [{eventDateId:..., eventDate:...}] (no resources field)

        if (json instanceof List) {
            json.each { eventDate -&gt;
                def resources = eventDate.resources ?: []
                resourceCount += resources.size()
            }
        } else if (json instanceof Map) {
            // HAL or other format
            def eventDates = json._embedded?.eventResources ?: json._embedded?.eventResourceModels ?: 
                             json.content ?: []
            eventDates.each { eventDate -&gt;
                def resources = eventDate.resources ?: []
                resourceCount += resources.size()
            }
            if (json.totalElements != null &amp;&amp; resourceCount == 0) {
                resourceCount = json.totalElements
            }
        }
    }

    vars.put(&quot;existingEventResourceCount&quot;, resourceCount.toString())
    log.info(&quot;Existing event resources (rooms): ${resourceCount}&quot;)

    if (resourceCount &gt; 0) {
        log.info(&quot;Rooms already exist in Logistics - will SKIP room creation&quot;)
    } else {
        log.info(&quot;No rooms found in Logistics - will CREATE rooms&quot;)
    }
} catch (Exception e) {
    log.warn(&quot;Error checking existing event resources: ${e.message}&quot;)
    vars.put(&quot;existingEventResourceCount&quot;, &quot;0&quot;)
}</stringProp>
                        <stringProp name="scriptLanguage">groovy</stringProp>
                        <stringProp name="parameters"></stringProp>
                        <stringProp name="filename"></stringProp>
                        <stringProp name="cacheKey">true</stringProp>
                      </JSR223PostProcessor>
                      <hashTree/>
                      <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                      <hashTree/>
                    </hashTree>
                    <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ If (No Rooms Exist)" enabled="true">
                      <stringProp name="IfController.condition">${__groovy((vars.get(&quot;existingEventResourceCount&quot;) ?: &quot;0&quot;).toInteger() == 0)}</stringProp>
                      <boolProp name="IfController.useExpression">true</boolProp>
                      <boolProp name="IfController.evaluateAll">false</boolProp>
                    </IfController>
                    <hashTree>
                      <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ While (Create Rooms Per Activity Day)" enabled="true">
                        <stringProp name="WhileController.condition">${__groovy(vars.get(&quot;ActivityDayCount&quot;).toInteger() &lt;= vars.get(&quot;TotalActivityDays&quot;).toInteger())}</stringProp>
                      </WhileController>
                      <hashTree>
                        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="───── Logistics (${ActivityDayCount}/${TotalActivityDays}) ─────" enabled="true">
                          <stringProp name="script">// Set current activity day variables from indexed variables
def dayIndex = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def totalDays = vars.get(&quot;RequestTotalActivityDays&quot;) ?: &quot;1&quot;

vars.put(&quot;activityid&quot;, vars.get(&quot;activityid_&quot; + dayIndex) ?: &quot;&quot;)
vars.put(&quot;activityDate&quot;, vars.get(&quot;activityDate_&quot; + dayIndex) ?: &quot;&quot;)
vars.put(&quot;activityStartTime&quot;, vars.get(&quot;activityStartTime_&quot; + dayIndex) ?: &quot;&quot;)
vars.put(&quot;activityEndTime&quot;, vars.get(&quot;activityEndTime_&quot; + dayIndex) ?: &quot;&quot;)

// Parse rooms variable and pick random count
// If allowedRooms is set, still pick the random count from rooms UDV — it becomes a CAP
// The Prepare Room Selection PostProcessor will apply the cap against matched allowedRooms
def rand = java.util.concurrent.ThreadLocalRandom.current()
def roomsRaw = vars.get(&quot;rooms&quot;)?.trim() ?: &quot;&quot;
def allowedRoomsCheck = vars.get(&quot;allowedRooms&quot;)?.trim() ?: &quot;&quot;
def roomCount = 0

if (roomsRaw &amp;&amp; roomsRaw != &quot;0&quot;) {
    def roomOptions = roomsRaw.split(&quot;,&quot;)
        .collect { it.trim() }
        .findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }
        .collect { it.toInteger() }

    if (roomOptions.size() &gt; 0) {
        roomCount = roomOptions[rand.nextInt(roomOptions.size())]
    }
}

// Store picked count and whether rooms was explicitly zero/empty
// _roomsIsZero = true means rooms=0 or empty → no rooms should be created regardless of allowedRooms
def roomsIsZero = (roomsRaw.isEmpty() || roomsRaw == &quot;0&quot; || roomCount == 0)
vars.put(&quot;_roomsPickedCount&quot;, roomCount.toString())
vars.put(&quot;_roomsIsZero&quot;, roomsIsZero.toString())

if (allowedRoomsCheck) {
    if (roomsIsZero) {
        // rooms is 0 or empty — no rooms to create even if allowedRooms is set
        vars.put(&quot;TotalRoomsToCreate&quot;, &quot;0&quot;)
        log.info(&quot;allowedRooms is set but rooms=0/empty — no rooms will be created&quot;)
    } else {
        // allowedRooms is set and rooms &gt; 0 — use sentinel to keep While loop open
        // Prepare Room Selection will apply _roomsPickedCount as cap
        vars.put(&quot;TotalRoomsToCreate&quot;, &quot;999&quot;)
        log.info(&quot;allowedRooms is set (&apos;${allowedRoomsCheck}&apos;) — rooms cap: ${roomCount}&quot;)
    }
} else {
    vars.put(&quot;TotalRoomsToCreate&quot;, roomCount.toString())
}
vars.put(&quot;RoomIndex&quot;, &quot;1&quot;)

def activityDate = vars.get(&quot;activityDate&quot;) ?: &quot;&quot;

// Make visible
SampleResult.setResponseData(&quot;Activity Day: ${dayIndex}/${totalDays}\nDate: ${activityDate}\nRooms: ${roomCount}&quot;, &quot;UTF-8&quot;)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)

log.info(&quot;───── Logistics Day ${dayIndex}/${totalDays} (${activityDate}) - Rooms: ${roomCount} ─────&quot;)</stringProp>
