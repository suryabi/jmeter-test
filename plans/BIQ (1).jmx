                                  <hashTree/>
                                  <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ If (Slot Available AND Payload Valid AND Room Valid)" enabled="true">
                                    <stringProp name="IfController.condition">${__groovy(
// COMPREHENSIVE VALIDATION - v16
// Supports two modes:
//   - Rooms mode (selectedRoomCount &gt; 0): resourceId must be non-empty and match a selected room
//   - Agenda-only mode (selectedRoomCount == 0): resourceId is null - skip room validation
try {
    // Check 1: skipActivity flag
    if (vars.get(&quot;skipActivity&quot;) == &quot;true&quot;) {
        return false
    }

    // Check 2: Payload exists and not empty
    def payload = vars.get(&quot;createActivityPayload&quot;) ?: &quot;&quot;
    if (!payload?.trim()) {
        return false
    }

    // Check 3: Parse JSON and extract resourceId
    def jsonSlurper = new groovy.json.JsonSlurper()
    def payloadObj = jsonSlurper.parseText(payload)
    def resourceId = payloadObj?.resourceId ?: &quot;&quot;

    def ifcRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
    def noRoomsMode = (ifcRoomCount == 0)

    if (!noRoomsMode) {
        // Rooms mode: resourceId must be present and match a selected room
        if (!resourceId || resourceId.trim().isEmpty()) {
            return false
        }

        // Check 4: Validate resourceId matches one of our selected rooms
        def validRoom = false
        for (int i = 1; i &lt;= ifcRoomCount; i++) {
            def selectedRoomId = vars.get(&quot;selectedRoomId_&quot; + i) ?: &quot;&quot;
            if (selectedRoomId == resourceId) {
                validRoom = true
                break
            }
        }

        if (!validRoom) {
            return false
        }
    }
    // Agenda-only mode (noRoomsMode): resourceId is null - skip room validation

    // Check 5: Validate moduleId exists
    def moduleId = payloadObj?.moduleId ?: &quot;&quot;
    if (!moduleId || moduleId.trim().isEmpty()) {
        return false
    }

    // All checks passed
    return true
} catch (Exception e) {
    return false
}
)}</stringProp>
                                    <boolProp name="IfController.useExpression">true</boolProp>
                                    <boolProp name="IfController.evaluateAll">false</boolProp>
                                  </IfController>
                                  <hashTree>
                                    <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Create - ${activityType} #${activityLoopCounter}" enabled="true">
                                      <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
                                      <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                                        <collectionProp name="Arguments.arguments">
                                          <elementProp name="" elementType="HTTPArgument">
                                            <boolProp name="HTTPArgument.always_encode">false</boolProp>
                                            <stringProp name="Argument.value">${createActivityPayload}</stringProp>
                                            <stringProp name="Argument.metadata">=</stringProp>
                                          </elementProp>
                                        </collectionProp>
                                      </elementProp>
                                      <stringProp name="HTTPSampler.domain"></stringProp>
                                      <stringProp name="HTTPSampler.port"></stringProp>
                                      <stringProp name="HTTPSampler.protocol"></stringProp>
                                      <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                                      <stringProp name="HTTPSampler.path">/${contextname}/api/activities</stringProp>
                                      <stringProp name="HTTPSampler.method">POST</stringProp>
                                      <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
                                      <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                                      <boolProp name="HTTPSampler.use_keepalive">false</boolProp>
                                      <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                                      <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                                      <stringProp name="HTTPSampler.connect_timeout">30000</stringProp>
                                      <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
                                    </HTTPSamplerProxy>
                                    <hashTree>
                                      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Final Room Validation" enabled="true">
                                        <stringProp name="script">
def payload = vars.get(&quot;createActivityPayload&quot;) ?: &quot;&quot;
def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
def noRoomsMode = (selectedRoomCount == 0)

if (!payload?.trim()) {
    log.error(&quot;🔒 FINAL BLOCK: Empty payload - disabling request&quot;)
    sampler.setEnabled(false)
    return
}

// No-rooms mode: payload is valid as-is (resourceId=null), fire the request
if (noRoomsMode) {
    return
}

// Rooms mode: validate resourceId matches currentRoomId and a selected room
try {
    def payloadObj = new groovy.json.JsonSlurper().parseText(payload)
    def resourceIdStr = payloadObj?.resourceId ?: &quot;&quot;
    def currentRoomId = vars.get(&quot;currentRoomId&quot;) ?: &quot;&quot;

    if (!resourceIdStr) {
        log.error(&quot;🔒 FINAL BLOCK: resourceId empty in rooms mode - disabling&quot;)
        sampler.setEnabled(false)
        return
    }
    if (resourceIdStr != currentRoomId) {
        log.error(&quot;🔒 FINAL BLOCK: resourceId mismatch payload=${resourceIdStr} room=${currentRoomId}&quot;)
        sampler.setEnabled(false)
        return
    }
    def validRoom = (1..selectedRoomCount).any { i -&gt; (vars.get(&quot;selectedRoomId_&quot; + i) ?: &quot;&quot;) == resourceIdStr }
    if (!validRoom) {
        log.error(&quot;🔒 FINAL BLOCK: resourceId ${resourceIdStr} not in selected rooms&quot;)
        sampler.setEnabled(false)
    }
} catch (Exception e) {
    log.error(&quot;🔒 FINAL BLOCK: Exception - ${e.message}&quot;)
    sampler.setEnabled(false)
}</stringProp>
                                        <stringProp name="scriptLanguage">groovy</stringProp>
                                        <stringProp name="parameters"></stringProp>
                                        <stringProp name="filename"></stringProp>
                                        <stringProp name="cacheKey">true</stringProp>
                                      </JSR223PreProcessor>
                                      <hashTree/>
                                      <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                                        <collectionProp name="HeaderManager.headers">
                                          <elementProp name="" elementType="Header">
                                            <stringProp name="Header.name">x-cloud-customerid</stringProp>
                                            <stringProp name="Header.value">${customerId}</stringProp>
                                          </elementProp>
                                          <elementProp name="" elementType="Header">
                                            <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                                            <stringProp name="Header.value">${categoryTypeId}</stringProp>
                                          </elementProp>
                                          <elementProp name="" elementType="Header">
                                            <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                                            <stringProp name="Header.value">${categoryId}</stringProp>
                                          </elementProp>
                                          <elementProp name="" elementType="Header">
                                            <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                                            <stringProp name="Header.value">${baseTimezone}</stringProp>
                                          </elementProp>
                                          <elementProp name="" elementType="Header">
                                            <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                                            <stringProp name="Header.value">${clientTimeZone}</stringProp>
                                          </elementProp>
                                          <elementProp name="" elementType="Header">
                                            <stringProp name="Header.name">X-Cloud-Context-Timezone</stringProp>
                                            <stringProp name="Header.value">${baseTimezone}</stringProp>
                                          </elementProp>
                                          <elementProp name="" elementType="Header">
                                            <stringProp name="Header.name">x-cloud-eventid</stringProp>
                                            <stringProp name="Header.value">${requestId}</stringProp>
                                          </elementProp>
                                          <elementProp name="" elementType="Header">
                                            <stringProp name="Header.name">X_cloud_user</stringProp>
                                            <stringProp name="Header.value">${currentUser}</stringProp>
                                          </elementProp>
                                        </collectionProp>
                                      </HeaderManager>
                                      <hashTree/>
                                      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Final Safety Check " enabled="true">
                                        <stringProp name="script">

def payload = ctx.getVariables().get(&quot;createActivityPayload&quot;) ?: &quot;&quot;
def currentDay = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;?&quot;
def loopCounter = vars.get(&quot;activityLoopCounter&quot;) ?: &quot;?&quot;

if (!payload?.trim()) {
    log.error(&quot;🛡️ ABORT: Payload is empty - this should NOT happen after If Controller&quot;)
    sampler.setProperty(&quot;HTTPSampler.postBodyRaw&quot;, false)
    return
}

def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
def noRoomsMode = (selectedRoomCount == 0)

// No-rooms mode (agenda/catering without rooms): resourceId is intentionally null - skip room validation
if (noRoomsMode) {
    log.info(&quot;🛡️ No-rooms mode: skipping resourceId validation, firing request as-is&quot;)
    return
}

try {
    def jsonSlurper = new groovy.json.JsonSlurper()
    def payloadObj = jsonSlurper.parseText(payload)
    def resourceId = payloadObj?.resourceId ?: &quot;&quot;
    def moduleId = payloadObj?.moduleId ?: &quot;&quot;
    def startTime = payloadObj?.startTime?.isoDate ?: &quot;&quot;
    def endTime = payloadObj?.endTime?.isoDate ?: &quot;&quot;
    def activityType = payloadObj?.activityType ?: &quot;unknown&quot;

    def currentRoomName = &quot;Unknown&quot;
    def validRoom = false
    for (int i = 1; i &lt;= selectedRoomCount; i++) {
        def selectedRoomId = vars.get(&quot;selectedRoomId_&quot; + i) ?: &quot;&quot;
        if (selectedRoomId == resourceId) {
            currentRoomName = vars.get(&quot;selectedRoomName_&quot; + i) ?: &quot;Room ${i}&quot;
            validRoom = true
            break
        }
    }

    if (!resourceId || resourceId.trim().isEmpty()) {
        log.error(&quot;🛡️ BLOCKED: Empty resourceId in rooms mode - skipping activity&quot;)
        vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
        return
    }

    if (!validRoom) {
        log.error(&quot;🛡️ BLOCKED: Invalid room - skipping activity&quot;)
        vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
        return
    }

} catch (Exception e) {
    log.error(&quot;🛡️ ERROR: &quot; + e.message)
    vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
}</stringProp>
                                        <stringProp name="scriptLanguage">groovy</stringProp>
                                        <stringProp name="parameters"></stringProp>
                                        <stringProp name="filename"></stringProp>
                                        <stringProp name="cacheKey">true</stringProp>
                                      </JSR223PreProcessor>
                                      <hashTree/>
                                      <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Activity Id Extractor" enabled="true">
                                        <stringProp name="JSONPostProcessor.referenceNames">activityId</stringProp>
                                        <stringProp name="JSONPostProcessor.jsonPathExprs">$.activityId</stringProp>
                                        <stringProp name="JSONPostProcessor.match_numbers"></stringProp>
                                      </JSONPostProcessor>
                                      <hashTree/>
                                      <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                                      <hashTree/>
                                      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Activity Creation Response Handler" enabled="true">
                                        <stringProp name="script">

def responseCode = prev.getResponseCode()
def activityId = vars.get(&quot;activityId&quot;) ?: &quot;&quot;
def currentDay = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;?&quot;
def currentDate = vars.get(&quot;activityDate_&quot; + currentDay) ?: &quot;Unknown&quot;
def loopCounter = vars.get(&quot;activityLoopCounter&quot;) ?: &quot;?&quot;

def payload = vars.get(&quot;createActivityPayload&quot;) ?: &quot;&quot;
def activityType = &quot;unknown&quot;
def currentRoomName = &quot;Unknown Room&quot;
def resourceId = &quot;&quot;

if (payload?.trim()) {
    try {
        def jsonSlurper = new groovy.json.JsonSlurper()
        def payloadObj = jsonSlurper.parseText(payload)
        activityType = payloadObj?.activityType ?: vars.get(&quot;loopActivityType&quot;) ?: &quot;unknown&quot;
        resourceId = payloadObj?.resourceId ?: &quot;&quot;

        def selectedRoomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
        for (int i = 1; i &lt;= selectedRoomCount; i++) {
            if (vars.get(&quot;selectedRoomId_&quot; + i) == resourceId) {
                currentRoomName = vars.get(&quot;selectedRoomName_&quot; + i) ?: &quot;Room ${i}&quot;
                break
            }
        }
    } catch (Exception e) {
        activityType = vars.get(&quot;loopActivityType&quot;) ?: &quot;unknown&quot;
        currentRoomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown Room&quot;
    }
}

if (responseCode == &quot;200&quot; &amp;&amp; activityId) {
    def currentCount = (vars.get(&quot;activityLoopCounter&quot;)?.toInteger() ?: 0) + 1
    vars.put(&quot;activityLoopCounter&quot;, currentCount.toString())
    vars.put(&quot;activityAttemptCounter&quot;, &quot;0&quot;)  // reset per successful activity

    // If all planned activities are done, signal the WhileController to stop
    // BEFORE the next iteration starts (so last sampler = Get By Id, not Get Vacant Slots)
    def loopCount = vars.get(&quot;currentActivityLoopCount&quot;)?.toInteger() ?: 0
    if (loopCount &gt; 0 &amp;&amp; currentCount &gt; loopCount) {
        vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
        log.info(&quot;[${activityType}] All ${loopCount} activities done - stopping loop after Get By Id&quot;)
    }

    // Also stop if all configured timings are now used
    def timingsUdvName = activityType.toLowerCase() + &quot;Timings&quot;
    def timingsRaw = vars.get(timingsUdvName)?.trim()
    if (timingsRaw) {
        def dayIndex  = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
        def roomIndex = vars.get(&quot;roomLoopCounter&quot;)  ?: &quot;1&quot;
        def usedKey   = &quot;usedTimings_${activityType}_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
        def usedStr   = vars.get(usedKey) ?: &quot;&quot;
        def totalTimings = timingsRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it ==~ /^\\d{2}:\\d{2}$/ }.size()
        def usedCount    = usedStr ? usedStr.split(&quot;,&quot;).size() : 0
        if (totalTimings &gt; 0 &amp;&amp; usedCount &gt;= totalTimings) {
            vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
            log.info(&quot;[${activityType}] All ${totalTimings} timings used - stopping loop after Get By Id&quot;)
        }
    }
} else {
    log.error(&quot;❌ FAILED: &quot; + activityType + &quot; #&quot; + loopCounter + &quot; | Room: &quot; + currentRoomName)
    log.error(&quot;Response Code: &quot; + responseCode)
    if (!activityId) {
        log.error(&quot;No activityId returned in response&quot;)
    }
}</stringProp>
