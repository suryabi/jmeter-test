              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">COLS=6. Min and max range for all multi-entry forms (e.g. 1,3 = 1 to 3, 2 = exactly 2). Fallback when no form-specific range is set. 0 or empty = skip. Negative = error</stringProp>
            </elementProp>
