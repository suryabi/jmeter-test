                                      <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Restore Form Context" enabled="true">
                                        <stringProp name="script">SampleResult.setIgnore()

def savedFormId = vars.get(&quot;savedFormId_beforeDoc&quot;) ?: &quot;&quot;
def savedUIConfig = vars.get(&quot;savedFormUIConfig_beforeDoc&quot;) ?: &quot;&quot;
def savedFieldMappings = vars.get(&quot;savedFieldMappings_beforeDoc&quot;) ?: &quot;&quot;
if (savedFormId) {
    vars.put(&quot;formId&quot;, savedFormId)
    vars.put(&quot;currentFormUIConfig&quot;, savedUIConfig)
    vars.put(&quot;currentFieldMappings&quot;, savedFieldMappings)
    log.info(&quot;[Topic Doc] Restored formId=${savedFormId}&quot;)
}</stringProp>
