                                  </stringProp>
                                  <stringProp name="scriptLanguage">groovy</stringProp>
                                  <stringProp name="parameters"></stringProp>
                                  <stringProp name="filename"></stringProp>
                                  <stringProp name="cacheKey">true</stringProp>
                                </JSR223PostProcessor>
                                <hashTree/>
                                <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                                <hashTree/>
                                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Check Zoom Room PostProcessor" enabled="true">
                                  <stringProp name="script">
// Check if the current room has a virtualconnection link in the event resources response.
// Match by BOTH resourceId AND activityDayId (current day) to avoid false positives
// when the same room exists on multiple days with different link states.
// Sets zoomRoom = &quot;true&quot; only if the exact day+room entry has a non-empty virtualconnection href.

vars.put(&quot;zoomRoom&quot;, &quot;false&quot;)

def currentRoomId  = vars.get(&quot;roomId&quot;)     ?: &quot;&quot;
def currentDayId   = vars.get(&quot;activityid&quot;) ?: &quot;&quot;

if (!currentRoomId) {
    log.warn(&quot;[Check Zoom Room] roomId is empty - skipping zoom check&quot;)
    return
}
if (!currentDayId) {
    log.warn(&quot;[Check Zoom Room] activityid (eventDateId) is empty - skipping zoom check&quot;)
    return
}

def responseData = vars.get(&quot;getRoomResponse&quot;) ?: &quot;&quot;
if (!responseData) {
    log.warn(&quot;[Check Zoom Room] getRoomResponse is empty - skipping&quot;)
    return
}

try {
    def json = new groovy.json.JsonSlurper().parseText(responseData)
    def embedded = json.get(&quot;_embedded&quot;)
    def eventDates = embedded ? (embedded.get(&quot;eventDates&quot;) ?: []) : []

    def matchedResource = null
    for (def eventDate : eventDates) {
        // Only look inside the eventDate that matches the current day
        def edId = eventDate.get(&quot;eventDateId&quot;) ?: &quot;&quot;
        if (!edId.equalsIgnoreCase(currentDayId)) continue

        def resources = eventDate.get(&quot;resources&quot;) ?: []
        for (def resource : resources) {
            def resId = resource.get(&quot;resourceId&quot;) ?: &quot;&quot;
            if (resId.equalsIgnoreCase(currentRoomId)) {
                matchedResource = resource
                break
            }
        }
        break
    }

    if (!matchedResource) {
        log.info(&quot;[Check Zoom Room] No resource found for roomId=${currentRoomId} on day=${currentDayId} - skipping Add Zoom&quot;)
        return
    }

    def links = matchedResource.get(&quot;_links&quot;) ?: [:]
    def vcLink = links.get(&quot;virtualconnection&quot;) ?: [:]
    def virtualConnectionHref = vcLink.get(&quot;href&quot;) ?: &quot;&quot;

    if (virtualConnectionHref &amp;&amp; !virtualConnectionHref.trim().isEmpty()) {
        vars.put(&quot;zoomRoom&quot;, &quot;true&quot;)
        log.info(&quot;[Check Zoom Room] Room ${vars.get(&apos;currentRoomName&apos;)} on day=${currentDayId} HAS virtualconnection - Add Zoom will proceed&quot;)
    } else {
        log.info(&quot;[Check Zoom Room] Room ${vars.get(&apos;currentRoomName&apos;)} on day=${currentDayId} has NO virtualconnection link - skipping Add Zoom&quot;)
    }
} catch (Exception e) {
    log.error(&quot;[Check Zoom Room] Error parsing Get Room response: &quot; + e.message)
}
                                  </stringProp>
