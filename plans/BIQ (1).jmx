                        <hashTree>
                          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Generate PDF for Upload" enabled="true">
                            <stringProp name="script">SampleResult.setIgnore()

def rand = new java.util.Random()
def customerName = vars.get(&quot;customerName&quot;) ?: &quot;Customer&quot;

// ============ Increment document type index (1-based) ============
def currentIdx = (vars.get(&quot;currentDocTypeIndex&quot;) ?: &quot;0&quot;).toInteger() + 1
vars.put(&quot;currentDocTypeIndex&quot;, currentIdx.toString())

def docTypeCount = (vars.get(&quot;documentTypeCount&quot;) ?: &quot;0&quot;).toInteger()
def docTypeId = vars.get(&quot;docType_${currentIdx}_id&quot;) ?: &quot;&quot;
def docTypeName = vars.get(&quot;docType_${currentIdx}_name&quot;) ?: &quot;&quot;

if (!docTypeId) {
    log.warn(&quot;No document type at index ${currentIdx} - skipping&quot;)
    return
}

// Store current type for Dynamic Document Param Builder PreProcessor
vars.put(&quot;currentDocTypeId&quot;, docTypeId)
vars.put(&quot;currentDocTypeName&quot;, docTypeName)
vars.put(&quot;uploadTypeName&quot;, docTypeName)

log.info(&quot;=== DOCUMENT [${currentIdx}/${docTypeCount}]: ${docTypeName} ===&quot;)

// ============ Generate PDF File ============
def folder = new File(&quot;generated_docs&quot;)
folder.mkdirs()

def todayDate = new Date().format(&quot;yyyyMMdd&quot;)
def displayDate = new Date().format(&quot;yyyy-MM-dd&quot;)
def uniqueId = String.format(&quot;%03d&quot;, rand.nextInt(1000))
def safeName = docTypeName.replaceAll(&quot;[^a-zA-Z0-9]&quot;, &quot;_&quot;)

def fileName = &quot;${safeName}_${todayDate}_${uniqueId}.pdf&quot;
def filePath = &quot;${folder.absolutePath}/${fileName}&quot;

def streamText = &quot;&quot;&quot;BT
/F1 24 Tf 100 700 Td (${docTypeName} - ${customerName}) Tj
/F1 12 Tf 0 -40 Td (Date: ${displayDate}) Tj
ET&quot;&quot;&quot;

def content = &quot;&quot;&quot;%PDF-1.4
1 0 obj &lt;&lt; /Type /Catalog /Pages 2 0 R &gt;&gt; endobj
2 0 obj &lt;&lt; /Type /Pages /Kids [3 0 R] /Count 1 &gt;&gt; endobj
3 0 obj &lt;&lt; /Type /Page /Parent 2 0 R /MediaBox [0 0 612 792] /Resources &lt;&lt; /Font &lt;&lt; /F1 &lt;&lt; /Type /Font /Subtype /Type1 /BaseFont /Helvetica &gt;&gt; &gt;&gt; &gt;&gt; /Contents 4 0 R &gt;&gt; endobj
4 0 obj &lt;&lt; /Length ${streamText.length()} &gt;&gt; stream
${streamText}
endstream endobj
xref
0 5
0000000000 65535 f 
0000000009 00000 n 
0000000058 00000 n 
0000000115 00000 n 
0000000270 00000 n 
trailer &lt;&lt; /Size 5 /Root 1 0 R &gt;&gt;
startxref
360
%%EOF&quot;&quot;&quot;

new File(filePath).text = content

vars.put(&quot;documentFilePath&quot;, filePath)
vars.put(&quot;documentFileName&quot;, fileName)
vars.put(&quot;documentMimeType&quot;, &quot;application/pdf&quot;)

log.info(&quot;PDF: ${fileName}&quot;)</stringProp>
                            <stringProp name="scriptLanguage">groovy</stringProp>
                            <stringProp name="parameters"></stringProp>
                            <stringProp name="filename"></stringProp>
                            <stringProp name="cacheKey">true</stringProp>
                          </JSR223Sampler>
                          <hashTree/>
                          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Upload Document - ${uploadTypeName}" enabled="true">
                            <elementProp name="HTTPsampler.Files" elementType="HTTPFileArgs">
                              <collectionProp name="HTTPFileArgs.files">
                                <elementProp name="${documentFilePath}" elementType="HTTPFileArg">
                                  <stringProp name="File.path">${documentFilePath}</stringProp>
                                  <stringProp name="File.paramname">file</stringProp>
                                  <stringProp name="File.mimetype">${documentMimeType}</stringProp>
                                </elementProp>
                              </collectionProp>
                            </elementProp>
                            <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
                              <collectionProp name="Arguments.arguments"/>
                            </elementProp>
                            <stringProp name="HTTPSampler.domain"></stringProp>
                            <stringProp name="HTTPSampler.port"></stringProp>
                            <stringProp name="HTTPSampler.protocol"></stringProp>
                            <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                            <stringProp name="HTTPSampler.path">/${contextname}/api/forms/${formId}/documents</stringProp>
                            <stringProp name="HTTPSampler.method">POST</stringProp>
                            <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
                            <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                            <boolProp name="HTTPSampler.use_keepalive">false</boolProp>
                            <boolProp name="HTTPSampler.DO_MULTIPART_POST">true</boolProp>
                            <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                            <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
                            <stringProp name="HTTPSampler.connect_timeout">30000</stringProp>
                            <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
                          </HTTPSamplerProxy>
                          <hashTree>
                            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Dynamic Document Param Builder" enabled="true">
                              <stringProp name="script">
import org.apache.jmeter.protocol.http.util.HTTPArgument

// ============ Remove Content-Type for multipart ============
def hm = sampler.getHeaderManager()
if (hm != null) {
    for (int i = hm.size() - 1; i &gt;= 0; i--) {
        if (hm.get(i).getName().equalsIgnoreCase(&quot;Content-Type&quot;)) {
            hm.remove(i)
        }
    }
}

def rand = java.util.concurrent.ThreadLocalRandom.current()
def customerName = vars.get(&quot;customerName&quot;) ?: &quot;Customer&quot;

// ============ Clear existing arguments ============
sampler.getArguments().clear()

// ============ JSON data map to collect all form fields ============
def dataMap = new LinkedHashMap()

// ============ Default text values (same as Journey) ============
def defaultTexts = props.get(&quot;fn_defaultTextFields&quot;)

def textareaValues = props.get(&quot;fn_defaultTextAreas&quot;)

// Load shared function: generateRandomNumber
def generateRandomNumber = { int min, int max -&gt; props.get(&quot;fn_generateRandomNumber&quot;)(min, max) }

// Load shared function: generateFutureDate
def generateFutureDate = { props.get(&quot;fn_generateFutureDate&quot;)(vars) }

// ============ STEP 1: Parse formUIConfig ============
def formUIConfigStr = vars.get(&quot;currentFormUIConfig&quot;)
if (!formUIConfigStr) {
    log.warn(&quot;formUIConfig not found - skipping document params&quot;)
    return
}

// STEP 2: Get and Parse fieldMappings (same as Journey)
def fieldMappingsStr = vars.get(&quot;currentFieldMappings&quot;)
def fieldMappingsMap = props.get(&quot;fn_parseFieldMappings&quot;)(fieldMappingsStr)

// STEP 3: Parse formUIConfig and extract all fields
def allFields = props.get(&quot;fn_extractAllFields&quot;)(formUIConfigStr)
def _docDepResult = props.get(&quot;fn_buildDependentControlsMap&quot;)(allFields)
def docDependentFieldsSet = _docDepResult.fieldSet
def docLookupParentFieldMap = props.get(&quot;fn_buildLookupParentFieldMap&quot;)(allFields)
def docOrderedFields = allFields.findAll { f -&gt; !docDependentFieldsSet.contains(f.dataMapping ?: f.formControlName) } +
    allFields.findAll { f -&gt;  docDependentFieldsSet.contains(f.dataMapping ?: f.formControlName) }

// STEP 4: Process each field and collect into dataMap (parents before dependents)
docOrderedFields.each { field -&gt;
    def fieldName = field.dataMapping ?: field.formControlName
    def fieldType = field.formControlType ?: &quot;&quot;
    def fieldLabel = field.fieldLabel ?: fieldName
    def enumType = field.enumType ?: &quot;&quot;
    def isHidden = field.hide ?: false
    def isDisabled = field.disabled ?: false
    def isMultiple = field.isMultiple ?: false
    def lookupName = field.lookupName
    def lookupContext = props.get(&quot;fn_resolveFieldLookupContext&quot;)(field, log)
    def lookupMode = props.get(&quot;fn_resolveFieldLookupMode&quot;)(field)

    // Skip hidden/disabled
    if (isHidden || isDisabled) return

    // Skip hiddenRoles / readOnlyRoles
    // FIX: moved userRole outside the hiddenRoles block so readOnlyRoles check can also access it
    def userRole = vars.get(&quot;roleId&quot;) ?: &quot;&quot;
    def hiddenRoles = field.hiddenRoles ?: []
    if (hiddenRoles &amp;&amp; hiddenRoles.contains(userRole)) return

    def readOnlyRoles = field.readOnlyRoles ?: []
    if (readOnlyRoles &amp;&amp; readOnlyRoles.contains(userRole)) return

    // Get aliasName from fieldMappings
    def mappingInfo = fieldMappingsMap[fieldName]
    def aliasName = mappingInfo?.aliasName

    def value = null

    // PRIORITY 1: alias (skip for lookup SELECT — use fn_pickLookupValue with lookupContext from form template)
    if (aliasName &amp;&amp; !(fieldType == &quot;SELECT&quot; &amp;&amp; lookupName)) {
        value = vars.get(aliasName)
    }

    // PRIORITY 2: Auto-generate if no alias value
    // FIX: removed undefined isNumericField guard that caused NullPointerException (server-side NPE at addFormData line 41)
    if (value == null || value == &quot;&quot;) {

        // ========== SPECIAL: SELECT with enumType=DOCUMENT → documentType (from documenttypes API) ==========
        if (fieldType == &quot;SELECT&quot; &amp;&amp; enumType == &quot;DOCUMENT&quot;) {
            def docTypeId = vars.get(&quot;currentDocTypeId&quot;) ?: &quot;&quot;

            if (docTypeId) {
                // Add documentType into the JSON data map (value from documenttypes API)
                dataMap.put(&quot;documentType&quot;, docTypeId)
                            }
            return  // Already added to dataMap, skip normal flow

        // ========== SPECIAL: SELECT with enumType=TIMEZONE ==========
        } else if (fieldType == &quot;SELECT&quot; &amp;&amp; enumType == &quot;TIMEZONE&quot;) {
            value = vars.get(&quot;requestTimeZone&quot;) ?: &quot;&quot;

        // ========== SELECT (normal, same as Journey) ==========
        } else if (fieldType == &quot;SELECT&quot;) {
            if (lookupName) {
                def minSel = props.get(&quot;fn_parseMultiDropDownRange&quot;)(vars, null).min
                def maxSel = props.get(&quot;fn_parseMultiDropDownRange&quot;)(vars, null).max
                def pickCount = { int available -&gt;
                    def maxPossible = Math.min(available, maxSel)
                    def minPossible = Math.min(minSel, maxPossible)
                    return minPossible + rand.nextInt((maxPossible - minPossible) + 1)
                }
                def pickOptions = null
                if (lookupMode) {
                    pickOptions = [lookupMode: lookupMode]
                    if (lookupMode == &quot;child&quot;) {
                        def parentFN = docLookupParentFieldMap[fieldName]
                        if (parentFN) pickOptions.parentFieldValues = dataMap[parentFN]
                    }
                }
                value = props.get(&quot;fn_pickLookupValue&quot;)(vars, lookupName, lookupContext, isMultiple, pickCount, rand, fieldName, log, pickOptions)
            }

        // ========== TEXT → &quot;{docTypeName} for {customerName}&quot; ==========
        } else if (fieldType == &quot;TEXT&quot;) {
            def docTypeName = vars.get(&quot;currentDocTypeName&quot;) ?: &quot;Document&quot;
            value = &quot;${docTypeName} for ${customerName}&quot;

        // ========== TEXTAREA (same as Journey) ==========
        } else if (fieldType == &quot;TEXTAREA&quot;) {
            value = textareaValues[rand.nextInt(textareaValues.length)]

        // ========== NUMBER / CURRENCY ==========
        } else if (fieldType == &quot;NUMBER&quot; || fieldType == &quot;CURRENCY&quot;) {
            value = props.get(&quot;fn_randomNumber1to5&quot;)().toString()

        // ========== CLOUD_DATE ==========
        } else if (fieldType == &quot;CLOUD_DATE&quot;) {
            value = generateFutureDate()

        // ========== CLOUD_TIME ==========
        } else if (fieldType == &quot;CLOUD_TIME&quot;) {
            def hour = fieldName.toLowerCase().contains(&quot;start&quot;) ? 9 :
                       fieldName.toLowerCase().contains(&quot;end&quot;) ? 18 :
                       rand.nextInt(9) + 8
            def calendar = Calendar.getInstance()
            calendar.add(Calendar.DAY_OF_MONTH, rand.nextInt(30) + 1)
            calendar.set(Calendar.HOUR_OF_DAY, hour)
            calendar.set(Calendar.MINUTE, 0)
            calendar.set(Calendar.SECOND, 0)
            value = calendar.getTime().format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)

        // ========== CHECKBOX ==========
        } else if (fieldType == &quot;CHECKBOX&quot;) {
            value = rand.nextBoolean().toString()

        // ========== RESOURCE ==========
        } else if (fieldType == &quot;RESOURCE&quot;) {
            def resourceTypeId = field.resourceTypeId ?: field.resourceType?.id ?: field.resourceType?.uniqueId
            if (resourceTypeId) {
                def rtCountStr = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_count&quot;)
                if (rtCountStr &amp;&amp; rtCountStr.isInteger() &amp;&amp; rtCountStr.toInteger() &gt; 0) {
                    def rtCount = rtCountStr.toInteger()
                    def randomIndex = rand.nextInt(rtCount) + 1
                    def resourceId = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                    value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, resourceId)
                }
            }

        // ========== MASTER ==========
        } else if (fieldType == &quot;MASTER&quot;) {
            def masterTypeId = field.masterTypeId ?: field.masterType?.id ?: field.masterType?.uniqueId
            if (masterTypeId) {
                def mtCountStr = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_count&quot;)
                if (mtCountStr &amp;&amp; mtCountStr.isInteger() &amp;&amp; mtCountStr.toInteger() &gt; 0) {
                    def mtCount = mtCountStr.toInteger()
                    def randomIndex = rand.nextInt(mtCount) + 1
                    def masterId = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                    value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, masterId)
                }
            }

        } else {
            // unhandled type - skipped
        }
    }

    // Collect into dataMap if value exists
    if (value != null &amp;&amp; !(value instanceof String &amp;&amp; value.toString().trim() == &quot;&quot;)) {
        dataMap.put(fieldName, (value instanceof Map || value instanceof List) ? value : value.toString())
            }
}

// ============ STEP 5: Add &quot;data&quot; as JSON form field (application/json) ============

def dataJson = groovy.json.JsonOutput.toJson(dataMap)
def dataArg = new HTTPArgument(&quot;data&quot;, dataJson)
dataArg.setAlwaysEncoded(false)
dataArg.setContentType(&quot;application/json&quot;)
sampler.getArguments().addArgument(dataArg)</stringProp>
