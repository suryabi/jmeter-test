                    <stringProp name="script">SampleResult.setIgnore()

log.info(&quot;----- Collecting ALL Rooms from Logistics (All Days) -----&quot;)

def totalDays = vars.get(&quot;TotalActivityDays&quot;)?.toInteger() ?: 2

def allRoomIds = [] as Set
def totalRoomsCollected = 0

for (int day = 1; day &lt;= totalDays; day++) {
    String countPropName = &quot;jmeter.roomCount.Day${day}&quot;.toString()
    String countFromSys = System.getProperty(countPropName)
    String countFromVars = vars.get(&quot;createdRoomCount_Day${day}&quot;.toString())
    def dayRoomCount = (countFromSys ?: countFromVars)?.toInteger() ?: 0
    log.info(&quot;  Day ${day}: ${dayRoomCount} rooms (sys=&apos;${countFromSys}&apos; vars=&apos;${countFromVars}&apos; propName=&apos;${countPropName}&apos;)&quot;)

    for (int i = 1; i &lt;= dayRoomCount; i++) {
        String idPropName = &quot;jmeter.room.Day${day}_${i}_id&quot;.toString()
        String namePropName = &quot;jmeter.room.Day${day}_${i}_name&quot;.toString()
        String idFromSys = System.getProperty(idPropName)
        String idFromVars = vars.get(&quot;createdRoom_Day${day}_${i}_id&quot;.toString())
        def resolvedId = idFromSys ?: idFromVars ?: &quot;&quot;
        def roomName = System.getProperty(namePropName) ?: vars.get(&quot;createdRoom_Day${day}_${i}_name&quot;.toString()) ?: &quot;Room&quot;

        log.info(&quot;    Reading ${idPropName}: sys=&apos;${idFromSys}&apos; vars=&apos;${idFromVars}&apos; final=&apos;${resolvedId}&apos;&quot;)

        if (resolvedId &amp;&amp; !allRoomIds.contains(resolvedId)) {
            allRoomIds.add(resolvedId)
            totalRoomsCollected++
            log.info(&quot;    Room [${totalRoomsCollected}]: ${roomName} (${resolvedId})&quot;)
        }
    }
}

if (allRoomIds.isEmpty()) {
    log.info(&quot;No rooms found in Logistics - skipping&quot;)
    vars.put(&quot;selectedRoomCount&quot;, &quot;0&quot;)
    SampleResult.setResponseMessage(&quot;No rooms from Logistics&quot;)
    return
}

vars.put(&quot;selectedRoomCount&quot;, totalRoomsCollected.toString())

def roomListJson = allRoomIds.collect { &quot;\&quot;${it}\&quot;&quot; }.join(&quot;,\n&quot;)
vars.put(&quot;dynamicRoomBody&quot;, &quot;&quot;&quot;{
    &quot;uniqueIds&quot;: [
        ${roomListJson}
    ]
}&quot;&quot;&quot;)

SampleResult.setResponseMessage(&quot;${totalRoomsCollected} total rooms from ${totalDays} days&quot;)
log.info(&quot;----- ${totalRoomsCollected} total unique rooms collected -----&quot;)</stringProp>
