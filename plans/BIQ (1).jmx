                                <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Validate Room (Single Pass)" enabled="true">
                                  <stringProp name="script">SampleResult.setIgnore()

def activityType = vars.get(&quot;activityType&quot;) ?: &quot;unknown&quot;

vars.put(&quot;roomProcessedForActivityType_&quot; + activityType, &quot;true&quot;)

def dayIdx = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def totalRooms = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
def roomIdx = vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;
for (int r = 1; r &lt;= totalRooms; r++) {
    def rKey = &quot;usedSlotRanges_Day&quot; + dayIdx + &quot;_Room&quot; + r
    def rRanges = vars.get(rKey) ?: &quot;(empty)&quot;
    def rName = vars.get(&quot;selectedRoomName_&quot; + r) ?: &quot;Room ${r}&quot;
    def rId = vars.get(&quot;selectedRoomId_&quot; + r)?.take(12) ?: &quot;?&quot;
    def slotCount = rRanges == &quot;(empty)&quot; ? 0 : rRanges.split(&quot;;&quot;).size()
    def marker = (r.toString() == roomIdx) ? &quot; ◄◄ CURRENT&quot; : &quot;&quot;
        if (slotCount &gt; 0 &amp;&amp; slotCount &lt;= 5) {
            }
}
def currentRoomId = vars.get(&quot;currentRoomId&quot;) ?: &quot;&quot;
def currentRoomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown&quot;
def counter = vars.get(&quot;currentRoomCounter&quot;) ?: vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;
def totalRoomsCheck = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
def noRoomsMode = (totalRoomsCheck == 0)

if (!currentRoomId || currentRoomId.trim().isEmpty()) {
    if (!noRoomsMode) {
        log.error(&quot;[Validate Room] CRITICAL: currentRoomId is empty!&quot;)
        vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        return
    }
    // Agenda-only mode: no room is expected — proceed with null resourceId
    log.info(&quot;[Validate Room] Agenda-only mode - no room, proceeding with resourceId=null&quot;)
}

vars.put(&quot;skipActivity&quot;, &quot;false&quot;)
vars.put(&quot;stopRoomActivityLoop&quot;, &quot;false&quot;)

def dayIndex = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def roomCount = vars.get(&quot;selectedRoomCount&quot;) ?: &quot;?&quot;
def activityDate = vars.get(&quot;activityDate_&quot; + dayIndex)?.take(10) ?: &quot;Unknown&quot;

SampleResult.setResponseMessage(&quot;${activityType} - ${currentRoomName}&quot;)</stringProp>
                                  <stringProp name="scriptLanguage">groovy</stringProp>
                                  <stringProp name="parameters"></stringProp>
                                  <stringProp name="filename"></stringProp>
                                  <stringProp name="cacheKey">true</stringProp>
                                </JSR223Sampler>
                                <hashTree/>
                                <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Calculate Activities Count" enabled="true">
                                  <stringProp name="script">SampleResult.setIgnore()

def moduleName = vars.get(&quot;currentActivityModuleName&quot;) ?: &quot;unknown&quot;
def selectedDay = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def dayIndex = vars.get(&quot;currentDayIndex&quot;) ?: &quot;1&quot;
def currentRoomCounter = vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;

def roomNameFromIndex = vars.get(&quot;selectedRoomName_&quot; + currentRoomCounter)
final String currentRoomName = roomNameFromIndex ?: (vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown Room&quot;)

def typeFromLoop = vars.get(&quot;loopActivityType&quot;)
def typeFromVar = vars.get(&quot;activityType&quot;)
final String activityType = (typeFromLoop ?: typeFromVar ?: &quot;unknown&quot;).trim()

def blockedTypeName = (vars.get(&quot;blockedActivityType&quot;) ?: &quot;blocked&quot;).toLowerCase()

def zoomAllowedActions = vars.get(&quot;zoomAllowedActions&quot;) ?: &quot;CONFIRM&quot;

vars.put(&quot;blockedTypeName&quot;, blockedTypeName)
vars.put(&quot;zoomAllowedActions&quot;, zoomAllowedActions)

vars.put(&quot;loopActivityType&quot;, activityType)
vars.put(&quot;calcActivityType&quot;, activityType)  // Extra backup

vars.put(&quot;activityLoopCounter&quot;, &quot;1&quot;)
vars.put(&quot;activityAttemptCounter&quot;, &quot;0&quot;)  

def parseUDV = { String value, int defaultVal -&gt;
    if (!value || value.trim() == &quot;&quot;) return defaultVal
    try {
        def options = value.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt;= 0 }.collect { it.toInteger() }
        if (options.isEmpty()) {
            log.info(&quot;parseUDV: No valid values found (must be &gt;= 0), using default: ${defaultVal}&quot;)
            return defaultVal
        }
        return options[java.util.concurrent.ThreadLocalRandom.current().nextInt(options.size())]
    } catch (Exception e) {
        log.warn(&quot;parseUDV: Error parsing value &apos;${value}&apos;, using default: ${defaultVal}&quot;)
        return defaultVal
    }
}

def parseActivityCountUDV = { String raw -&gt;
    if (!raw || raw.trim() == &quot;&quot; || raw.trim() == &quot;0&quot;) return [isPercent: false, value: 0]
    def trimmed = raw.trim()
    def isExplicitPercent = trimmed.endsWith(&quot;%&quot;)
    def numStr = isExplicitPercent ? trimmed[0..-2].trim() : trimmed
    if (!numStr.contains(&quot;,&quot;) &amp;&amp; numStr.isInteger()) {
        def num = numStr.toInteger()
        if (isExplicitPercent || (num &gt;= 1 &amp;&amp; num &lt;= 100)) {
            return [isPercent: true, value: Math.min(100, Math.max(1, num))]
        }
    }
    def options = trimmed.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt;= 0 }.collect { it.toInteger() }
    if (options.isEmpty()) return [isPercent: false, value: 0]
    def picked = options[java.util.concurrent.ThreadLocalRandom.current().nextInt(options.size())]
    return [isPercent: false, value: picked]
}

def priorityRaw = vars.get(&quot;activityTypesPriority&quot;) ?: &quot;&quot;
def priorityOrder = priorityRaw.split(&quot;,&quot;).collect { it.trim().toLowerCase() }.findAll { it }

int reservedPosition = priorityOrder.indexOf(blockedTypeName) + 1

int currentPosition = priorityOrder.indexOf(activityType.toLowerCase()) + 1
if (currentPosition == 0) currentPosition = priorityOrder.size() + 1  // Not in list = last

def vacantSlotsDurationRaw = vars.get(&quot;vacantSlotDurations&quot;)?.trim()
int vacantSlotDuration = 0  // Default to 0 if empty (will skip activity)
try {
    if (vacantSlotsDurationRaw &amp;&amp; vacantSlotsDurationRaw != &quot;0&quot;) {
        def options = vacantSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() }
        if (options) {
            vacantSlotDuration = options.min()  // Use MINIMUM to allow more activities
        } else {
            vacantSlotDuration = 0
            log.info(&quot;[vacantSlotDurations] No valid values (must be &gt; 0) - will skip activity&quot;)
        }
    }
} catch (Exception e) {
    vacantSlotDuration = 0
}

def roomIndex = vars.get(&quot;roomLoopCounter&quot;) ?: &quot;1&quot;
def reservedSlotsKey = &quot;reservedSlots_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
def storedReservedSlots = vars.get(reservedSlotsKey)

def reservedSlotsPerRoomRaw = vars.get(&quot;blockedSlots&quot;)?.trim()
int reservedSlotsPerRoom = 0

def skipActivityTypesRaw = vars.get(&quot;skipActivityTypes&quot;)?.trim()?.toLowerCase() ?: &quot;&quot;
def skipBlockedSlots = skipActivityTypesRaw.split(&quot;,&quot;).collect { it.trim() }.contains(&quot;blocked&quot;)

// Determine if blocked slots should be skipped:
// Case 1: &apos;blocked&apos; is in skipActivityTypes UDV
// Case 2: blockedSlots UDV is empty or 0 (no valid positive integers)
def blockedSlotsOptions = reservedSlotsPerRoomRaw ? reservedSlotsPerRoomRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() } : []
def skipDueToEmptyOrZero = blockedSlotsOptions.isEmpty()

if (skipBlockedSlots || skipDueToEmptyOrZero) {
    reservedSlotsPerRoom = 0
    vars.put(reservedSlotsKey, &quot;0&quot;)
    vars.remove(&quot;reservedMinutes_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex)
    vars.remove(&quot;reservedDurations_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex)
    vars.remove(&quot;reservedBlockedTimes_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex)
    if (skipBlockedSlots) {
        log.info(&quot;Blocked slots skipped - &apos;blocked&apos; found in skipActivityTypes&quot;)
    } else {
        log.info(&quot;Blocked slots skipped - blockedSlots is empty or 0&quot;)
    }
} else if (storedReservedSlots) {
    reservedSlotsPerRoom = storedReservedSlots.toInteger()
} else {
    try {
        if (blockedSlotsOptions) {
            reservedSlotsPerRoom = blockedSlotsOptions[java.util.concurrent.ThreadLocalRandom.current().nextInt(blockedSlotsOptions.size())]
        }
    } catch (Exception e) {
        reservedSlotsPerRoom = 0
    }
    vars.put(reservedSlotsKey, reservedSlotsPerRoom.toString())
}

def reservedSlotsDurationRaw = vars.get(&quot;blockedDurations&quot;)?.trim()
def reservedDurationOptions = []
try {
    if (reservedSlotsDurationRaw) {
        reservedDurationOptions = reservedSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() }
    }
    if (reservedDurationOptions.isEmpty()) {
        reservedDurationOptions = [0]  // Default to 0 (skip)
        log.info(&quot;[blockedDurations] Empty or no valid values - defaulting to 0 (skip)&quot;)
    }
} catch (Exception e) {
    reservedDurationOptions = [0]
}

def reservedMinutesKey = &quot;reservedMinutes_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
def reservedDurationsKey = &quot;reservedDurations_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
def reservedBlockedTimesKey = &quot;reservedBlockedTimes_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
def storedReservedMinutes = vars.get(reservedMinutesKey)
def storedReservedDurations = vars.get(reservedDurationsKey)
def storedBlockedTimes = vars.get(reservedBlockedTimesKey)

int reservedMinutes = 0
def reservedSlotDurations = []
def reservedBlockedRanges = [] // List of [startMins, endMins] pairs
def rand = java.util.concurrent.ThreadLocalRandom.current()

def isBlockedActivityType = activityType?.trim()?.toLowerCase() == &quot;blocked&quot;

if (skipBlockedSlots || skipDueToEmptyOrZero) {
    reservedMinutes = 0
    reservedSlotDurations = []
    reservedBlockedRanges = []
} else if (storedReservedMinutes &amp;&amp; storedReservedDurations) {

    reservedMinutes = storedReservedMinutes.toInteger()
    reservedSlotDurations = storedReservedDurations.split(&quot;,&quot;).collect { it.trim().toInteger() }

    if (storedBlockedTimes) {
        storedBlockedTimes.split(&quot;,&quot;).each { range -&gt;
            def parts = range.split(&quot;-&quot;)
            if (parts.size() == 2) {
                reservedBlockedRanges.add([parts[0].trim().toInteger(), parts[1].trim().toInteger()])
            }
        }
    }
} else if (reservedSlotsPerRoom &gt; 0) {
    for (int i = 0; i &lt; reservedSlotsPerRoom; i++) {
        int slotDuration = reservedDurationOptions[rand.nextInt(reservedDurationOptions.size())]
        reservedSlotDurations.add(slotDuration)
        reservedMinutes += slotDuration
    }
    vars.put(reservedMinutesKey, reservedMinutes.toString())
    vars.put(reservedDurationsKey, reservedSlotDurations.join(&quot;,&quot;))
}

if (reservedMinutes &gt; 0) {
    vars.put(&quot;selectedReservedMinutes_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex, reservedMinutes.toString())
}

int reservedSlotsAdjusted = vacantSlotDuration &gt; 0 ? (int) Math.ceil((double) reservedMinutes / vacantSlotDuration) : 0

// ✅ FIX: Use roomStartTime/roomEndTime so slot count calculation respects the
// buffer window. Using the full day window overcounts available slots and allows
// activities to be scheduled inside the buffer zones.
def _rStart = vars.get(&quot;roomStartTime&quot;) ?: &quot;&quot;
def _rEnd   = vars.get(&quot;roomEndTime&quot;)   ?: &quot;&quot;
def dayStartTimeStr = (_rStart) ?: (vars.get(&quot;activityStartTime_&quot; + selectedDay) ?: &quot;&quot;)
def dayEndTimeStr   = (_rEnd)   ?: (vars.get(&quot;activityEndTime_&quot;   + selectedDay) ?: &quot;&quot;)

def parseTimeToMinutes = { timeStr -&gt;
    if (!timeStr) return -1
    try {
        def timePart = timeStr.contains(&quot;T&quot;) ? timeStr.substring(11, 16) : timeStr
        if (timePart.length() &gt;= 5) {
            def parts = timePart.split(&quot;:&quot;)
            return parts[0].toInteger() * 60 + parts[1].toInteger()
        }
    } catch (Exception e) {
        log.warn(&quot;timeToMins: Error parsing time &apos;${timeStr}&apos; — ${e.message}&quot;)
    }
    return -1
}

def minsToTime = { int mins -&gt;
    int h = (int)(mins / 60)
    int m = mins % 60
    return String.format(&quot;%02d:%02d&quot;, h, m)
}

int dayStartMins = parseTimeToMinutes(dayStartTimeStr)
int dayEndMins = parseTimeToMinutes(dayEndTimeStr)
int dayDurationMins = dayEndMins - dayStartMins

int totalSlotsPerDay = (dayDurationMins &gt; 0 &amp;&amp; vacantSlotDuration &gt; 0) ? (int)(dayDurationMins / vacantSlotDuration) : 18

def priorityStr = vars.get(&quot;activityTypesPriority&quot;) ?: &quot;&quot;
def priorityList = priorityStr.split(&quot;,&quot;).collect { it.trim().toLowerCase() }
def blockedPosition = priorityList.indexOf(blockedTypeName)
def currentTypePosition = priorityList.indexOf(activityType?.trim()?.toLowerCase())

def isAfterBlocked = false
if (blockedPosition &gt;= 0) {
    if (currentTypePosition &lt; 0) {
        isAfterBlocked = true
    } else if (currentTypePosition &gt; blockedPosition) {
        isAfterBlocked = true
    } else {
        isAfterBlocked = false
    }
} else {
}

def blockedGenerated = vars.get(&quot;blockedRangesGenerated_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex) == &quot;true&quot;
def shouldGenerateBlocked = !skipBlockedSlots &amp;&amp;
                            isAfterBlocked &amp;&amp;
                            !blockedGenerated &amp;&amp;
                            (reservedSlotDurations &amp;&amp; reservedSlotDurations.size() &gt; 0) &amp;&amp;
                            (reservedBlockedRanges.size() == 0)

if (shouldGenerateBlocked) {
    vars.put(&quot;blockedRangesGenerated_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex, &quot;true&quot;)

    def usedSlotRangesKey = &quot;usedSlotRanges_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex
    def existingUsedRanges = []
    def existingUsedStr = vars.get(usedSlotRangesKey) ?: &quot;&quot;
    if (existingUsedStr) {
        existingUsedStr.split(&quot;;&quot;).each { rangeStr -&gt;
            def parts = rangeStr.split(&quot;:&quot;)
            if (parts.size() == 2) {
                existingUsedRanges.add([parts[0].toInteger(), parts[1].toInteger()])
            }
        }
    }

    def allDurations = []
    if (vacantSlotsDurationRaw?.contains(&quot;,&quot;)) {
        allDurations = vacantSlotsDurationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() }
    } else if (vacantSlotDuration &gt; 0) {
        allDurations = [vacantSlotDuration]
    }

    def gcd = { int a, int b -&gt; while (b != 0) { int t = b; b = a % b; a = t }; return a }
    int slotAlignment = allDurations.size() &gt; 0 ? allDurations.inject { a, b -&gt; gcd(a, b) } : 30
    slotAlignment = Math.max(15, Math.min(slotAlignment, 30))

    def allPossibleSlots = []
    for (int t = dayStartMins; t + reservedSlotDurations.min() &lt;= dayEndMins; t += slotAlignment) {
        allPossibleSlots.add(t)
    }

    Collections.shuffle(allPossibleSlots, rand)

    def blockedTimesStrings = []
    def usedRanges = [] // Track used ranges to prevent overlaps

    for (int i = 0; i &lt; reservedSlotDurations.size(); i++) {
        int slotDur = reservedSlotDurations[i]
        boolean placed = false

        for (def candidateStart : allPossibleSlots) {
            int candidateEnd = candidateStart + slotDur

            if (candidateEnd &gt; dayEndMins) continue

            boolean overlaps = usedRanges.any { existing -&gt;
                !(candidateEnd &lt;= existing[0] || candidateStart &gt;= existing[1])
            }

            if (!overlaps &amp;&amp; existingUsedRanges.size() &gt; 0) {
                overlaps = existingUsedRanges.any { existing -&gt;
                    !(candidateEnd &lt;= existing[0] || candidateStart &gt;= existing[1])
                }
            }

            if (!overlaps) {
                reservedBlockedRanges.add([candidateStart, candidateEnd])
                blockedTimesStrings.add(candidateStart + &quot;-&quot; + candidateEnd)
                usedRanges.add([candidateStart, candidateEnd])
                placed = true
                break
            }
        }

        if (!placed) {
            log.warn(&quot;Could not place blocked slot ${i + 1} (${slotDur} mins) - no non-overlapping position available&quot;)
            log.warn(&quot;Already placed: ${usedRanges.collect { minsToTime(it[0]) + &apos;-&apos; + minsToTime(it[1]) }}&quot;)
            log.warn(&quot;Candidates tried: ${allPossibleSlots.size()}, Day bounds: ${minsToTime(dayStartMins)}-${minsToTime(dayEndMins)}&quot;)
        }
    }

    if (reservedBlockedRanges.size() &lt; reservedSlotDurations.size()) {
        log.error(&quot;❌ BLOCKED SLOT GENERATION INCOMPLETE: Only ${reservedBlockedRanges.size()}/${reservedSlotDurations.size()} slots placed!&quot;)
        log.error(&quot;Day bounds: ${minsToTime(dayStartMins)} - ${minsToTime(dayEndMins)} (${dayDurationMins} mins)&quot;)
        log.error(&quot;Durations needed: ${reservedSlotDurations}&quot;)
        log.error(&quot;Already placed ranges: ${reservedBlockedRanges.collect { minsToTime(it[0]) + &apos;-&apos; + minsToTime(it[1]) }}&quot;)
    }

    reservedBlockedRanges.sort { a, b -&gt; a[0] &lt;=&gt; b[0] }
    blockedTimesStrings = reservedBlockedRanges.collect { it[0] + &quot;-&quot; + it[1] }

    def blockedTimesValue = blockedTimesStrings.join(&quot;,&quot;)
    vars.put(reservedBlockedTimesKey, blockedTimesValue)

    def blockedRoomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown&quot;
    def blockedDayCount = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
    def blockedTotalDays = vars.get(&quot;duration&quot;) ?: &quot;1&quot;
    def blockedDisplay = reservedBlockedRanges.collect { minsToTime(it[0]) + &quot;-&quot; + minsToTime(it[1]) + &quot;(&quot; + (it[1]-it[0]) + &quot;m)&quot; }.join(&quot;, &quot;)
    log.info(&quot;🔒 BLOCKED: ${reservedBlockedRanges.size()} slots reserved for ${blockedRoomName} | ${blockedDisplay} | Day ${blockedDayCount}/${blockedTotalDays}&quot;)
}

if (reservedBlockedRanges?.size() &gt; 0 &amp;&amp; activityType?.trim()?.toLowerCase() != blockedTypeName) {

    def blockedLogKey = &quot;blockedDetailsShown_Day&quot; + dayIndex + &quot;_Room&quot; + currentRoomCounter
    def alreadyShown = vars.get(blockedLogKey) == &quot;true&quot;

    if (!alreadyShown) {

        for (int i = 0; i &lt; reservedBlockedRanges.size(); i++) {
            def range = reservedBlockedRanges[i]
            String startTime = minsToTime(range[0])
            String endTime = minsToTime(range[1])
            int slotDur = range[1] - range[0]
        }

        vars.put(blockedLogKey, &quot;true&quot;)
    }
}

def slotKey = &quot;Day&quot; + dayIndex + &quot;_Room&quot; + currentRoomCounter
int totalSlotsUsed = vars.get(&quot;totalSlotsUsed_&quot; + slotKey)?.toInteger() ?: 0

boolean subtractReserved = false

if (!skipBlockedSlots) {
    def existingBlockedTimes = vars.get(reservedBlockedTimesKey)
    if (existingBlockedTimes?.trim()) {
        subtractReserved = true
    } else if (reservedPosition &gt; 0 &amp;&amp; currentPosition &gt; reservedPosition) {
        subtractReserved = true
    }
}

vars.put(&quot;applyBlockedRanges_Day&quot; + dayIndex + &quot;_Room&quot; + roomIndex, subtractReserved.toString())

int availableSlots = totalSlotsPerDay - totalSlotsUsed

if (subtractReserved) {
    availableSlots = Math.max(0, availableSlots - reservedSlotsAdjusted)
} else {
    availableSlots = Math.max(0, availableSlots)
}

vars.put(&quot;availableSlotsFor_&quot; + slotKey, availableSlots.toString())

int loopCount = 0
String loopCountSource = &quot;&quot;

if (activityType.toLowerCase() == blockedTypeName) {
    loopCount = 0
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    loopCountSource = &quot;blocked type - time ranges reserved (no activities created)&quot;
} else {
    def activityTypeLower = activityType.toLowerCase()
    def udvNameNew = &quot;${activityTypeLower}s&quot;  // New format: topics, caterings
    def udvNameOld = &quot;${activityTypeLower}sPerRoom&quot;  // Old format: topicsPerRoom
    def udvName = udvNameNew
    def udvValue = vars.get(udvNameNew)

    if (!udvValue) {
        udvName = udvNameOld
        udvValue = vars.get(udvNameOld)
    }

    if (!udvValue) {
        loopCount = 0
        loopCountSource = &quot;No UDV found for ${activityTypeLower}s - skipping&quot;
    } else {
        def parsed = parseActivityCountUDV(udvValue)
        if (parsed.isPercent) {
            slotKey = &quot;Day${dayIndex}_Room${roomIndex}&quot;
            int availSlotsForActivity = vars.get(&quot;availableSlotsFor_&quot; + slotKey)?.toInteger() ?: 0
            double rawActivityCount = availSlotsForActivity * parsed.value / 100.0
            loopCount = (int) Math.round(rawActivityCount)
            loopCountSource = &quot;${udvName}=${udvValue} (${parsed.value}% of ${availSlotsForActivity} available slots = ${loopCount})&quot;
            log.info(&quot;Activity ${activityType}: ${parsed.value}% of ${availSlotsForActivity} available slots = ${loopCount}&quot;)
            if (loopCount == 0 &amp;&amp; rawActivityCount &gt; 0) {
                log.warn(&quot;[${udvName}] Percentage rounds to 0: ${parsed.value}% of ${availSlotsForActivity} available slot(s) = ${String.format(&apos;%.2f&apos;, rawActivityCount)}, rounded down to 0 - no ${activityType} will be created for Day ${dayIndex}, Room ${roomIndex}. Increase &apos;${udvName}&apos; percentage or available slots if activities are expected.&quot;)
            }
        } else {
            loopCount = parsed.value
            loopCountSource = &quot;${udvName}=${parsed.value}&quot;
        }
    }
}

loopCount = Math.min(50, Math.max(0, loopCount))

if (loopCount &gt; 0) {
    def timingsUdvName = activityType.toLowerCase() + &quot;Timings&quot;
    def timingsRaw = vars.get(timingsUdvName)?.trim()
    if (timingsRaw) {
        def timingsMins = timingsRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it ==~ /^\d{2}:\d{2}$/ }.collect { t -&gt;
            def parts = t.split(&quot;:&quot;)
            parts[0].toInteger() * 60 + parts[1].toInteger()
        }
        def anyInWindow = timingsMins.any { t -&gt; t &gt;= dayStartMins &amp;&amp; t &lt; dayEndMins }
        if (!anyInWindow) {
            log.warn(&quot;[${timingsUdvName}] All configured times ${timingsMins.collect { h -&gt; (int)(h/60) + &apos;:&apos; + String.format(&apos;%02d&apos;, h%60) }} are OUTSIDE day window (${minsToTime(dayStartMins)}-${minsToTime(dayEndMins)}) - skipping ${activityType} (loopCount forced to 0)&quot;)
            loopCount = 0
        } else {
            def usedTimingsKey = &quot;usedTimings_${activityType.toLowerCase()}_Day${dayIndex}_Room${roomIndex}&quot;
            def usedTimingsStr = vars.get(usedTimingsKey) ?: &quot;&quot;
            def usedTimingsMins = usedTimingsStr ? usedTimingsStr.split(&quot;,&quot;).collect { it.trim().toInteger() } : []
            def availableTimingSlots = timingsMins.findAll { t -&gt; t &gt;= dayStartMins &amp;&amp; t &lt; dayEndMins &amp;&amp; !usedTimingsMins.contains(t) }.size()
            if (loopCount &gt; availableTimingSlots) {
                log.info(&quot;[${timingsUdvName}] Capping loopCount from ${loopCount} to ${availableTimingSlots} (only ${availableTimingSlots} timing slot(s) available in window)&quot;)
                loopCount = availableTimingSlots
            }
        }
    }
}

vars.put(&quot;currentActivityLoopCount&quot;, loopCount.toString())

SampleResult.setResponseMessage(&quot;Day &quot; + selectedDay + &quot;, Room &quot; + currentRoomCounter + &quot;: &quot; + loopCount + &quot; &quot; + activityType + &quot;(s)&quot;)</stringProp>
                                  <stringProp name="scriptLanguage">groovy</stringProp>
                                  <stringProp name="parameters"></stringProp>
                                  <stringProp name="filename"></stringProp>
                                  <stringProp name="cacheKey">true</stringProp>
                                </JSR223Sampler>
                                <hashTree/>
                                <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ While (Create Activities)" enabled="true">
                                  <stringProp name="WhileController.condition">${__groovy(vars.get(&quot;skipActivityModule&quot;) != &quot;true&quot; &amp;&amp; vars.get(&quot;stopRoomActivityLoop&quot;) != &quot;true&quot; &amp;&amp; vars.get(&quot;activityLoopCounter&quot;)?.toInteger() &lt;= vars.get(&quot;currentActivityLoopCount&quot;)?.toInteger())}</stringProp>
                                </WhileController>
                                <hashTree>
                                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Next Activity" enabled="true">
                                    <stringProp name="script">SampleResult.setIgnore()

def attempts = (vars.get(&quot;activityAttemptCounter&quot;)?.toInteger() ?: 0) + 1
vars.put(&quot;activityAttemptCounter&quot;, attempts.toString())

def maxAttempts = (vars.get(&quot;currentActivityLoopCount&quot;)?.toInteger() ?: 10) * 3
if (attempts &gt; maxAttempts) {
    log.warn(&quot;Max attempts reached (${attempts}/${maxAttempts}) - stopping loop&quot;)
    vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
    vars.put(&quot;gapFillActive&quot;, &quot;false&quot;)  
}

vars.put(&quot;skipActivity&quot;, &quot;false&quot;)

vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
vars.put(&quot;currentVacantSlotEndTime&quot;, &quot;&quot;)
vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)

def currentRoomId = vars.get(&quot;currentRoomId&quot;) ?: &quot;&quot;
def selectedRoomCountCheck = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0

if (!currentRoomId || currentRoomId.trim().isEmpty()) {
    if (selectedRoomCountCheck &gt; 0) {
        log.error(&quot;[Activity Loop Start] CRITICAL: No valid room ID - skipping ALL remaining activities for this room&quot;)
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)  // Stop the entire activity loop for this room
    } else {
        // Agenda-only mode: no room expected, continue with null resourceId
        log.info(&quot;[Activity Loop Start] Agenda-only mode - no room, proceeding with resourceId=null&quot;)
    }
}

def loopType = vars.get(&quot;loopActivityType&quot;)
def moduleType = vars.get(&quot;activityType&quot;)
def activityType = loopType ?: moduleType ?: &quot;unknown&quot;
def loopCount = vars.get(&quot;currentActivityLoopCount&quot;) ?: &quot;?&quot;
def currentRoomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown&quot;
def counter = vars.get(&quot;activityLoopCounter&quot;)?.toInteger() ?: 0

SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setResponseMessage(activityType + &quot; #&quot; + (counter + 1) + &quot;/&quot; + loopCount + &quot; (attempt &quot; + attempts + &quot;)&quot;)</stringProp>
                                    <stringProp name="scriptLanguage">groovy</stringProp>
