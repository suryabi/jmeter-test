            <elementProp name="logisticsModuleType" elementType="Argument">
              <stringProp name="Argument.name">logisticsModuleType</stringProp>
              <stringProp name="Argument.value">LOGISTICS</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, HIDE. Module type of Logistics</stringProp>
            </elementProp>
            <elementProp name="agendaModuleType" elementType="Argument">
              <stringProp name="Argument.name">agendaModuleType</stringProp>
              <stringProp name="Argument.value">CALENDAR_LISTING, CALENDER, LISTING</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, MULTI, HIDE. Module types treated as Agenda (first match per module pass)</stringProp>
            </elementProp>
            <elementProp name="virtualConnectionModuleType" elementType="Argument">
              <stringProp name="Argument.name">virtualConnectionModuleType</stringProp>
              <stringProp name="Argument.value">VIRTUAL_CONNECTION</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, HIDE. Module type of Virtual Connection</stringProp>
