                                <stringProp name="Header.value">${categoryId}</stringProp>
                              </elementProp>
                              <elementProp name="" elementType="Header">
                                <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                                <stringProp name="Header.value">${baseTimezone}</stringProp>
                              </elementProp>
                              <elementProp name="" elementType="Header">
