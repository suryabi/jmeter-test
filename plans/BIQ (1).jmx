// Returns a random integer between 1 and 5 inclusive — used as the default value for all NUMBER/CURRENCY form fields.
def _fn_randomNumber1to5 = { -&gt; java.util.concurrent.ThreadLocalRandom.current().nextInt(1, 6) }   // range 1-5
props.put(&quot;fn_randomNumber1to5&quot;, _fn_randomNumber1to5)

// Normalizes dropdown text from API responses: fixes double-encoded non-breaking spaces and trims whitespace for reliable comparison.
def _fn_normalizeDropdownText = { String raw -&gt;
    if (!raw) return raw
    return raw.replace(&quot;\u00c2\u00a0&quot;, &quot;\u00a0&quot;).trim()
}
props.put(&quot;fn_normalizeDropdownText&quot;, _fn_normalizeDropdownText)

// Converts a SNAKE_CASE lookup name (e.g. CUSTOMER_SECTOR) to camelCase (e.g. customerSector) for JMeter variable lookups.
def _fn_lookupNameToCamelCase = { String lookupName -&gt;
    if (!lookupName) return &quot;&quot;
    def words = lookupName.toLowerCase().split(&apos;_&apos;)
    return words[0] + words.drop(1).collect { it.capitalize() }.join(&apos;&apos;)
}
props.put(&quot;fn_lookupNameToCamelCase&quot;, _fn_lookupNameToCamelCase)

// Normalizes lookupContext to &quot;category&quot; or &quot;tenant&quot;, determining which scoped API endpoint was used to fetch the lookup values.
def _fn_normalizeLookupContext = { String lookupContext -&gt;
    def normalized = lookupContext?.trim()?.toLowerCase()
    if (normalized in [&quot;category&quot;, &quot;location&quot;]) return &quot;category&quot;
    return &quot;tenant&quot;
}
props.put(&quot;fn_normalizeLookupContext&quot;, _fn_normalizeLookupContext)

// Recursively searches a nested JSON object up to 8 levels deep to find a lookupContext value, handling all possible API nesting patterns.
def _fn_deepFindLookupContext = { obj, depth = 0 -&gt;
    if (obj == null || depth &gt; 8) return null
    def deepFind = props.get(&quot;fn_deepFindLookupContext&quot;)
    if (obj instanceof Map) {
        if (obj.lookupContext != null &amp;&amp; obj.lookupContext.toString().trim() != &quot;&quot;) {
            return obj.lookupContext
        }
        for (entry in obj.entrySet()) {
            def k = entry.key
            def v = entry.value
            if (k?.toString()?.equalsIgnoreCase(&quot;lookupContext&quot;) &amp;&amp; v != null &amp;&amp; v.toString().trim() != &quot;&quot;) {
                return v
            }
            if (v instanceof Map || v instanceof List) {
                def found = deepFind(v, depth + 1)
                if (found) return found
            }
        }
    } else if (obj instanceof List) {
        for (item in obj) {
            def found = deepFind(item, depth + 1)
            if (found) return found
        }
    }
    return null
}
props.put(&quot;fn_deepFindLookupContext&quot;, _fn_deepFindLookupContext)

// Resolves the effective lookupContext for a form field by checking all known nesting paths (top-level, attributes, fieldAttributes, lookup, deep search).
def _fn_resolveFieldLookupContext = { field, logRef = null -&gt;
    if (!field) return &quot;tenant&quot;
    def raw = field.lookupContext
    if (!raw &amp;&amp; field.attributes instanceof Map) {
        raw = field.attributes.lookupContext ?: field.attributes.get(&quot;lookupContext&quot;)
    }
    if (!raw &amp;&amp; field.attributes instanceof List) {
        def attr = field.attributes.find {
            def name = it?.name ?: it?.attributeName ?: it?.key ?: it?.code
            name?.toString()?.equalsIgnoreCase(&quot;lookupContext&quot;)
        }
        raw = attr?.value ?: attr?.attributeValue
    }
    if (!raw &amp;&amp; field.fieldAttributes instanceof Map) {
        raw = field.fieldAttributes.lookupContext ?: field.fieldAttributes.get(&quot;lookupContext&quot;)
    }
    if (!raw &amp;&amp; field.formFieldAttributes instanceof Map) {
        raw = field.formFieldAttributes.lookupContext ?: field.formFieldAttributes.get(&quot;lookupContext&quot;)
    }
    if (!raw &amp;&amp; field.lookupType instanceof Map) {
        raw = field.lookupType.lookupContext
    }
    if (!raw &amp;&amp; field.lookup instanceof Map) {
        raw = field.lookup.lookupContext
    }
    if (!raw) {
        raw = props.get(&quot;fn_deepFindLookupContext&quot;)(field)
    }
    def resolved = props.get(&quot;fn_normalizeLookupContext&quot;)(raw ?: &quot;tenant&quot;)
    if (!raw &amp;&amp; field.lookupName &amp;&amp; logRef) {
        logRef.warn(&quot;lookupContext missing for field ${field.dataMapping ?: field.formControlName} lookupName=${field.lookupName} — defaulting to tenant&quot;)
    }
    return resolved
}
props.put(&quot;fn_resolveFieldLookupContext&quot;, _fn_resolveFieldLookupContext)

// Checks whether a given value (or list of values) exists in the stored lookup options for a field — used to validate before submitting.
def _fn_valueInLookupStore = { varsRef, lookupName, lookupContext, valueCandidate -&gt;
    if (!lookupName || valueCandidate == null) return false
    def ctx = props.get(&quot;fn_normalizeLookupContext&quot;)(lookupContext)
    def base = props.get(&quot;fn_lookupVarBase&quot;)(lookupName, ctx)
    def allStr = varsRef.get(base + &quot;_all&quot;) ?: &quot;&quot;
    if (!allStr &amp;&amp; ctx == &quot;tenant&quot;) {
        def legacy = props.get(&quot;fn_lookupNameToCamelCase&quot;)(lookupName)
        allStr = varsRef.get(legacy + &quot;_all&quot;) ?: &quot;&quot;
    }
    if (!allStr) return false
    def allowed = allStr.split(&quot;,&quot;).collect { props.get(&quot;fn_normalizeDropdownText&quot;)(it.trim()) } as Set
    def matches = { v -&gt;
        def s = props.get(&quot;fn_normalizeDropdownText&quot;)(v?.toString() ?: &quot;&quot;)
        s &amp;&amp; allowed.contains(s)
    }
    if (valueCandidate instanceof List) return valueCandidate.every { matches(it) }
    return matches(valueCandidate)
}
props.put(&quot;fn_valueInLookupStore&quot;, _fn_valueInLookupStore)

// Builds the JMeter variable prefix for a lookup (e.g. &quot;tenant_customerSector&quot;) used to retrieve stored count/values.
def _fn_lookupVarBase = { String lookupName, String lookupContext -&gt;
    def camel = props.get(&quot;fn_lookupNameToCamelCase&quot;)(lookupName)
    def ctx = props.get(&quot;fn_normalizeLookupContext&quot;)(lookupContext)
    return ctx + &quot;_&quot; + camel
}
props.put(&quot;fn_lookupVarBase&quot;, _fn_lookupVarBase)

// Extracts the row ID from a lookup API response object, checking id, uniqueId, and lookupValueId fields.
def _fn_resolveLookupRowId = { lookup -&gt;
    def id = lookup?.id ?: lookup?.uniqueId ?: lookup?.lookupValueId
    return id != null ? id.toString().trim() : null
}
props.put(&quot;fn_resolveLookupRowId&quot;, _fn_resolveLookupRowId)

// Extracts the parent ID from a lookup row (parentId or nested parent.id/uniqueId); returns null if absent or &quot;null&quot;.
def _fn_resolveLookupRowParentId = { lookup -&gt;
    def pid = lookup?.parentId
    if ((pid == null || pid.toString().trim() == &quot;&quot;) &amp;&amp; lookup?.parent instanceof Map) {
        pid = lookup.parent.id ?: lookup.parent.uniqueId
    }
    if (pid == null || pid.toString().trim() == &quot;&quot; || pid.toString().equalsIgnoreCase(&quot;null&quot;)) return null
    return pid.toString().trim()
}
props.put(&quot;fn_resolveLookupRowParentId&quot;, _fn_resolveLookupRowParentId)

// Returns the lookupMode (&quot;parent&quot; or &quot;child&quot;) from a form field definition, checking top-level and attributes map.
def _fn_resolveFieldLookupMode = { field -&gt;
    if (!field) return null
    def raw = field.lookupMode
    if (!raw &amp;&amp; field.attributes instanceof Map) raw = field.attributes.lookupMode
    if (!raw) return null
    def mode = raw.toString().trim().toLowerCase()
    return (mode == &quot;parent&quot; || mode == &quot;child&quot;) ? mode : null
}
props.put(&quot;fn_resolveFieldLookupMode&quot;, _fn_resolveFieldLookupMode)

// Reads isComplexObject from form template metadata (top-level or attributes map).
// When true, SELECT/MASTER/RESOURCE values are sent as {uniqueId: id}; when false, as a bare id string.
def _fn_resolveIsComplexObject = { field -&gt;
    if (!field) return false
    def raw = field.isComplexObject
    if (raw == null &amp;&amp; field.attributes instanceof Map) raw = field.attributes.isComplexObject
    if (raw == null) return false
    if (raw instanceof Boolean) return raw
    return raw.toString().equalsIgnoreCase(&quot;true&quot;)
}
props.put(&quot;fn_resolveIsComplexObject&quot;, _fn_resolveIsComplexObject)

// Reads isNestedEnum — a single SELECT field that renders multiple cascading enum levels internally.
def _fn_resolveIsNestedEnum = { field -&gt;
    if (!field) return false
    def raw = field.isNestedEnum
    if (raw == null &amp;&amp; field.attributes instanceof Map) raw = field.attributes.isNestedEnum
    if (raw == null) return false
    if (raw instanceof Boolean) return raw
    return raw.toString().equalsIgnoreCase(&quot;true&quot;)
}
props.put(&quot;fn_resolveIsNestedEnum&quot;, _fn_resolveIsNestedEnum)

// Formats a master/resource reference id per form template isComplexObject (applies to enumType MASTER and RESOURCE).
def _fn_formatReferenceFieldValue = { field, uniqueId -&gt;
    if (!uniqueId) return null
    if (props.get(&quot;fn_resolveIsComplexObject&quot;)(field)) return [&quot;uniqueId&quot;: uniqueId]
    return uniqueId
}
props.put(&quot;fn_formatReferenceFieldValue&quot;, _fn_formatReferenceFieldValue)

// Extracts a reference uniqueId from a stored form value (bare string or {uniqueId:...} map).
def _fn_resolveReferenceIdFromValue = { val -&gt;
    if (val == null) return null
    if (val instanceof Map) return (val.uniqueId ?: val.id)?.toString()
    if (val instanceof List &amp;&amp; val) {
        def first = val[0]
        return (first instanceof Map) ? (first.uniqueId ?: first.id)?.toString() : first?.toString()?.trim()
    }
    def s = val.toString().trim()
    return s ?: null
}
props.put(&quot;fn_resolveReferenceIdFromValue&quot;, _fn_resolveReferenceIdFromValue)

// Builds a root→leaf id chain by picking a deepest leaf from a flat reference dataset (mastersFor_* or resourcesFor_*).
def _fn_buildLeafFirstReferenceChain = { varsRef, varBase, neededLevels, randRef, logFn, logLabel -&gt;
    def countStr = varsRef.get(varBase + &quot;_count&quot;)
    if (!countStr?.isInteger() || countStr.toInteger() &lt;= 0) return []
    def total = countStr.toInteger()
    def allIndices = (1..total).toList()
    def allIds = new HashSet()
    allIndices.each { idx -&gt; def id = varsRef.get(varBase + &quot;_&quot; + idx + &quot;_id&quot;); if (id) allIds.add(id) }
    if (!allIds) return []
    def idToParentId = [:]
    def childCount = [:]
    allIndices.each { idx -&gt;
        def id = varsRef.get(varBase + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
        def pid = varsRef.get(varBase + &quot;_&quot; + idx + &quot;_parentId&quot;) ?: &quot;&quot;
        if (id) idToParentId[id] = pid
        if (id &amp;&amp; pid &amp;&amp; allIds.contains(pid)) childCount[pid] = (childCount[pid] ?: 0) + 1
    }
    def leafIds = allIds.findAll { id -&gt; !childCount.containsKey(id) }
    if (!leafIds) return []
    def depthOf = [:]
    def depthFn
    depthFn = { String nid -&gt;
        if (depthOf.containsKey(nid)) return depthOf[nid]
        def pid = idToParentId[nid]
        def d = (pid &amp;&amp; allIds.contains(pid)) ? depthFn(pid) + 1 : 1
        depthOf[nid] = d
        return d
    }
    def needed = (neededLevels ?: 1) as int
    def fullDepthLeaves = leafIds.findAll { depthFn(it) &gt;= needed }
    def chosenLeaves = fullDepthLeaves
    if (!chosenLeaves) {
        def maxDepth = leafIds.collect { depthFn(it) }.max()
        chosenLeaves = leafIds.findAll { depthFn(it) == maxDepth }
        logFn?.warn(&quot;${logLabel} ${varBase} — no leaf reaches needed ${needed} levels; deepest available is ${maxDepth} — using deepest leaves only&quot;)
    }
    def leafId = chosenLeaves[randRef.nextInt(chosenLeaves.size())]
    def ancestry = [leafId]
    def cur = leafId
    def safety = 0
    while (true) {
        def p = idToParentId[cur]
        if (!p || !allIds.contains(p) || safety &gt; 50) break
        ancestry &lt;&lt; p
        cur = p
        safety++
    }
    def chain = ancestry.reverse()
    logFn?.info(&quot;${logLabel} leaf-first chain for ${varBase}: depth=${chain.size()} (needed ${needed}), leaf=${leafId}&quot;)
    return chain
}
props.put(&quot;fn_buildLeafFirstReferenceChain&quot;, _fn_buildLeafFirstReferenceChain)

// Builds a map of child field → parent field name from dependentControls, used for resolving child lookup filtering.
// FIX: Some form APIs never populate dependentControls for cascading lookup fields (e.g. a 4-level
// Parent Topic → Topic → Sub-Topic → Micro Topic hierarchy) — they only mark lookupMode=&quot;parent&quot;/&quot;child&quot;
// on each field without declaring the parent→child link anywhere. When that happened this map stayed
// empty for those fields, so &quot;child&quot;-mode fields (e.g. Micro Topic) had no parentFieldValues/parentRowId
// to filter candidate rows against, fn_filterLookupRowsByMode found zero candidates, and the field was
// silently skipped from the payload (skipField=true) — leaving it required/empty in the UI even though
// Parent Topic/Topic/Sub-Topic were filled correctly. This now falls back to (1) explicit parent-reference
// attributes some APIs put on the CHILD field itself, then (2) inferring the parent by field order: the
// nearest preceding field in the form whose lookupMode is &quot;parent&quot; or &quot;child&quot; is treated as the immediate
// parent of the next &quot;child&quot; field in sequence — this reconstructs N-level cascades (not just 2-level),
// as long as the API returns fields in form layout order (which matches how they render in the UI).
def _fn_buildLookupParentFieldMap = { allFieldsList -&gt;
    def map = [:]
    // PRIMARY: parent field explicitly declares its dependent children via dependentControls
    (allFieldsList ?: []).each { field -&gt;
        def parentFN = field.dataMapping ?: field.formControlName
        (field.dependentControls ?: []).each { dep -&gt;
            def childFN = dep?.formControlName
            if (childFN) map[childFN] = parentFN
        }
    }
    // FALLBACK 1: child field declares its own parent directly, under one of several possible API attribute names
    (allFieldsList ?: []).each { field -&gt;
        def childFN = field.dataMapping ?: field.formControlName
        if (!childFN || map.containsKey(childFN)) return
        def attrs = (field.attributes instanceof Map) ? field.attributes : [:]
        def explicitParent = field.parentControlName ?: field.parentFormControlName ?: field.parentFieldName ?: field.parentDataMapping ?: field.dependsOn ?:
            attrs.parentControlName ?: attrs.parentFormControlName ?: attrs.parentFieldName ?: attrs.dependsOn
        if (explicitParent) {
            map[childFN] = explicitParent.toString()
            log.info(&quot;fn_buildLookupParentFieldMap: parent &apos;${explicitParent}&apos; for child field &apos;${childFN}&apos; resolved via explicit attribute (no dependentControls present)&quot;)
        }
    }
    // FALLBACK 2: infer by field order + lookupMode chain when no explicit linkage metadata exists at all
    def lastHierarchyField = null
    (allFieldsList ?: []).each { field -&gt;
        def fn = field.dataMapping ?: field.formControlName
        if (!fn) return
        def mode = props.get(&quot;fn_resolveFieldLookupMode&quot;)(field)
        if (mode == &quot;child&quot; &amp;&amp; !map.containsKey(fn) &amp;&amp; lastHierarchyField) {
            map[fn] = lastHierarchyField
            log.info(&quot;fn_buildLookupParentFieldMap: INFERRED parent &apos;${lastHierarchyField}&apos; for child field &apos;${fn}&apos; by field order (no dependentControls/explicit attribute found)&quot;)
        }
        if (mode == &quot;parent&quot; || mode == &quot;child&quot;) lastHierarchyField = fn
    }
    return map
}
props.put(&quot;fn_buildLookupParentFieldMap&quot;, _fn_buildLookupParentFieldMap)

// Retrieves stored lookup rows (as parsed objects) from JMeter vars for a given lookup name and context; falls back to legacy unprefixed vars if needed.
def _fn_getLookupRows = { varsRef, lookupName, lookupContext -&gt;
    def ctx = props.get(&quot;fn_normalizeLookupContext&quot;)(lookupContext)
    def base = props.get(&quot;fn_lookupVarBase&quot;)(lookupName, ctx)
    def rowsJson = varsRef.get(base + &quot;_rows&quot;)
    if (!rowsJson &amp;&amp; ctx == &quot;tenant&quot;) {
        def legacy = props.get(&quot;fn_lookupNameToCamelCase&quot;)(lookupName)
        rowsJson = varsRef.get(legacy + &quot;_rows&quot;)
        if (!rowsJson) base = legacy
    }
    if (rowsJson) {
        try {
            return new groovy.json.JsonSlurper().parseText(rowsJson) ?: []
        } catch (Exception ignored) { }
    }
    def countStr = varsRef.get(base + &quot;_count&quot;)
    if (!(countStr &amp;&amp; countStr.isInteger() &amp;&amp; countStr.toInteger() &gt; 0)) return []
    def count = countStr.toInteger()
    return (1..count).collect { idx -&gt;
        [id: null, parentId: null, value: varsRef.get(base + &quot;_&quot; + idx)]
    }.findAll { it.value }
}
props.put(&quot;fn_getLookupRows&quot;, _fn_getLookupRows)

// Given a list of parent field values, returns the set of row IDs that match those values — used to filter child lookup options.
def _fn_lookupParentIdsForValues = { rows, parentFieldValues -&gt;
    def vals = []
    if (parentFieldValues instanceof List) vals = parentFieldValues
    else if (parentFieldValues != null &amp;&amp; parentFieldValues.toString().trim() != &quot;&quot;) vals = [parentFieldValues]
    if (!vals) return [] as Set
    def normSet = vals.collect { props.get(&quot;fn_normalizeDropdownText&quot;)(it?.toString() ?: &quot;&quot;) }.findAll { it } as Set
    // FIX: match the selected parent value at ANY depth in the hierarchy, not just root-level rows.
    // Previously this skipped any row that itself had a parentId (e.g. &quot;Cruise&quot; under Hospitality),
    // which broke child lookups beyond 2 levels even when valid child rows existed for that node.
    //
    // FIX 2: When the same lookup dataset is shared across hierarchy levels (Topic and Sub-Topic
    // served from the same list), a text-matched row ID might belong to a leaf node that has no
    // children at all — causing the child field to find zero candidates and be skipped.
    // Build a set of IDs that actually appear as a parentId somewhere in the dataset so we only
    // accept a matched row as a valid parent when it genuinely has children below it.
    def allRows = rows ?: []
    def rowsWithChildren = allRows.collect { it?.parentId?.toString() }.findAll { it } as Set
    def ids = [] as Set
    allRows.each { row -&gt;
        def nv = props.get(&quot;fn_normalizeDropdownText&quot;)(row?.value?.toString() ?: &quot;&quot;)
        if (nv &amp;&amp; normSet.contains(nv) &amp;&amp; row?.id) {
            def rid = row.id.toString()
            // Prefer rows that are known parents (have at least one child); fall back to all
            // matches only when none of the matched rows appear as a parentId anywhere.
            if (rowsWithChildren.contains(rid)) ids.add(rid)
        }
    }
    // Fallback: if no matched row has children (flat dataset or leaf-level match), return all
    // matched IDs so the caller can still attempt a child lookup rather than silently failing.
    if (!ids) {
        allRows.each { row -&gt;
            def nv = props.get(&quot;fn_normalizeDropdownText&quot;)(row?.value?.toString() ?: &quot;&quot;)
            if (nv &amp;&amp; normSet.contains(nv) &amp;&amp; row?.id) ids.add(row.id.toString())
        }
    }
    return ids
}
props.put(&quot;fn_lookupParentIdsForValues&quot;, _fn_lookupParentIdsForValues)

// Filters lookup rows by mode: &quot;parent&quot; returns only top-level rows (no parentId), &quot;child&quot; returns rows whose parentId matches selected parent values.
def _fn_filterLookupRowsByMode = { rows, lookupMode, parentFieldValues = null, parentRowId = null -&gt;
    def mode = lookupMode?.toString()?.trim()?.toLowerCase()
    if (!mode || mode == &quot;parent&quot;) {
        return (rows ?: []).findAll { row -&gt; !row?.parentId }
    }
    if (mode == &quot;child&quot;) {
        // FIX: prefer an exact row-ID match (tracked from the parent field&apos;s actual selection)
        // over text matching. Text matching breaks when the same display name appears at
        // more than one place in the hierarchy (e.g. &quot;Veteran&apos;s Program&quot; as both a Sub-Topic
        // and a Micro Topic) — IDs are always unique, so this removes that ambiguity.
        def parentIds
        if (parentRowId) {
            parentIds = (parentRowId instanceof List ? parentRowId : [parentRowId]).collect { it.toString() } as Set
        } else {
            parentIds = props.get(&quot;fn_lookupParentIdsForValues&quot;)(rows, parentFieldValues)
        }
        if (!parentIds) return []
        // FIX: When using text-based parent matching (no parentRowId), exclude parent ROWS
        // themselves from child candidates (row.id in parentIds), NOT children that share the
        // same display label. The old label-match exclusion dropped legitimate same-name children
        // (e.g. level 5 &quot;Retail Brand Compliance&quot; with one level-6 child also named
        // &quot;Retail Brand Compliance&quot;) leaving required nested fields empty.
        def excludeSelfAsChild = !parentRowId
        return (rows ?: []).findAll { row -&gt;
            if (!(row?.parentId &amp;&amp; parentIds.contains(row.parentId.toString()))) return false
            if (excludeSelfAsChild &amp;&amp; row?.id &amp;&amp; parentIds.contains(row.id.toString())) return false
            return true
        }
    }
    return rows ?: []
}
props.put(&quot;fn_filterLookupRowsByMode&quot;, _fn_filterLookupRowsByMode)

// FIX: A field can be correctly linked to its parent (lookupParentFieldMap now resolves this even
// without dependentControls — see fn_buildLookupParentFieldMap above) and still end up empty if the
// VALUE picked for it has zero rows underneath it for a deeper required field. e.g. Topic and Sub-Topic
// both legitimately exist named &quot;Private Cloud Appliance&quot;, the picker correctly lands on that exact
// Sub-Topic row, but that particular Sub-Topic row happens to have no Micro Topic rows under it — so
// Micro Topic is left required/empty no matter how many times the run is repeated, even though every
// linkage is now correct. This computes, for a given field, the set of its own row IDs that have at
// least one valid descendant all the way down the chain (recursively) — so the picker can avoid
// dead-end branches instead of discovering the dead end one level too late.
def _fn_computeValidLookupIdsForField = { varsRef, fieldName, lookupChildFieldsMap, fieldLookupInfo -&gt;
    def myInfo = fieldLookupInfo?.get(fieldName)
    if (!myInfo?.lookupName) return null
    def myRows = props.get(&quot;fn_getLookupRows&quot;)(varsRef, myInfo.lookupName, myInfo.lookupContext) ?: []
    def childFields = lookupChildFieldsMap?.get(fieldName)
    if (!childFields) {
        // Leaf of the chain — every one of my rows is trivially valid (nothing required below it).
        return myRows.collect { it?.id?.toString() }.findAll { it } as Set
    }
    // FIX: When any child field shares the same lookupName as the current field (Topic, Sub-Topic,
    // and Micro Topic all served from the same dataset), the parentId-based valid-path computation
    // is meaningless — parentId values in childRows point into the same pool as myRows, so the
    // intersection always produces wrong results (empty or incorrect set).
    // In that case return null to signal &quot;no restriction applicable&quot; — the parentRowId/
    // parentFieldValues filter in fn_filterLookupRowsByMode already handles level-scoping correctly.
    def hasSharedDataset = childFields.any { childFN -&gt;
        def childInfo = fieldLookupInfo?.get(childFN)
        childInfo?.lookupName &amp;&amp; childInfo.lookupName == myInfo.lookupName
    }
    if (hasSharedDataset) return null
    Set validParentIds = null
    childFields.each { childFN -&gt;
        def childInfo = fieldLookupInfo?.get(childFN)
        if (!childInfo?.lookupName) return
        def childRows = props.get(&quot;fn_getLookupRows&quot;)(varsRef, childInfo.lookupName, childInfo.lookupContext) ?: []
        def childValidIds = props.get(&quot;fn_computeValidLookupIdsForField&quot;)(varsRef, childFN, lookupChildFieldsMap, fieldLookupInfo)
        def theseParentIds = childRows.findAll { row -&gt;
            row?.parentId &amp;&amp; (childValidIds == null || childValidIds.contains(row.id?.toString()))
        }.collect { it.parentId.toString() } as Set
        validParentIds = (validParentIds == null) ? theseParentIds : (validParentIds.intersect(theseParentIds))
    }
    if (validParentIds == null) return null
    // Guard: if the intersection produced an empty set, treat it as no restriction (null) rather
    // than zeroing out all candidates — an empty validParentIds means the dataset structure did
    // not yield any IDs we can trust, not that literally no rows are valid.
    if (validParentIds.isEmpty()) return null
    return myRows.collect { it?.id?.toString() }.findAll { it &amp;&amp; validParentIds.contains(it) } as Set
}
props.put(&quot;fn_computeValidLookupIdsForField&quot;, _fn_computeValidLookupIdsForField)

// Stores parsed lookup values into JMeter vars (count, indexed values, rows JSON, _all CSV) for each lookup type code, skipping inactive rows.
def _fn_storeLookupValues = { varsRef, lookupValuesList, contextKey, logRef -&gt;
    def lookupMap = [:]
    def rowsMap = [:]
    def skippedInactive = 0
    (lookupValuesList ?: []).each { lookup -&gt;
        def active = lookup?.isActive
        if (active == false || active?.toString()?.equalsIgnoreCase(&quot;false&quot;)) {
            skippedInactive++
            return
        }
        def code = lookup.lookupType?.code
        def value = lookup.value
        if (code &amp;&amp; value != null &amp;&amp; value.toString().trim() != &quot;&quot;) {
            def normalizedValue = props.get(&quot;fn_normalizeDropdownText&quot;)(value.toString())
            def rowId = props.get(&quot;fn_resolveLookupRowId&quot;)(lookup)
            def rowParentId = props.get(&quot;fn_resolveLookupRowParentId&quot;)(lookup)
            if (!lookupMap.containsKey(code)) lookupMap[code] = []
            if (!rowsMap.containsKey(code)) rowsMap[code] = []
            lookupMap[code].add(normalizedValue)
            rowsMap[code].add([id: rowId, parentId: rowParentId, value: normalizedValue])
        }
    }
    def ctx = props.get(&quot;fn_normalizeLookupContext&quot;)(contextKey)
    rowsMap.each { code, rows -&gt;
        def values = lookupMap[code] ?: []
        def base = props.get(&quot;fn_lookupVarBase&quot;)(code, ctx)
        def rowsJson = groovy.json.JsonOutput.toJson(rows)
        varsRef.put(base + &quot;_rows&quot;, rowsJson)
        varsRef.put(base + &quot;_all&quot;, values.join(&quot;,&quot;))
        varsRef.put(base + &quot;_count&quot;, String.valueOf(values.size()))
        values.eachWithIndex { val, idx -&gt; varsRef.put(base + &quot;_&quot; + (idx + 1), val) }
        // Backward compat: tenant lookups also mirror unprefixed vars (e.g. customerSector_count)
        if (ctx == &quot;tenant&quot;) {
            def camel = props.get(&quot;fn_lookupNameToCamelCase&quot;)(code)
            varsRef.put(camel + &quot;_rows&quot;, rowsJson)
            varsRef.put(camel + &quot;_all&quot;, values.join(&quot;,&quot;))
            varsRef.put(camel + &quot;_count&quot;, String.valueOf(values.size()))
            values.eachWithIndex { val, idx -&gt; varsRef.put(camel + &quot;_&quot; + (idx + 1), val) }
        }
    }
    varsRef.put(ctx + &quot;LookupValues&quot;, groovy.json.JsonOutput.toJson(lookupMap))
    if (skippedInactive &gt; 0) {
        logRef.info(&quot;Stored ${lookupMap.size()} lookup type(s) for context &apos;${ctx}&apos; (skipped ${skippedInactive} inactive rows)&quot;)
    }
    return lookupMap
}
props.put(&quot;fn_storeLookupValues&quot;, _fn_storeLookupValues)

// Picks one or more random lookup values for a form field, applying parent/child mode filtering and respecting the multi-select count function.
def _fn_pickLookupValue = { varsRef, lookupName, lookupContext, isMultiple, selectionCountFn, randRef, fieldName = null, logRef = null, pickOptions = null -&gt;
    if (lookupName == &quot;ROOM_TYPE&quot;) {
        def existingRoomType = varsRef.get(&quot;roomType&quot;)
        if (existingRoomType) return existingRoomType
    }
    def logFn = logRef ?: log
    def ctx = props.get(&quot;fn_normalizeLookupContext&quot;)(lookupContext)
    def lookupMode = pickOptions?.lookupMode?.toString()?.trim()?.toLowerCase()
    def base = props.get(&quot;fn_lookupVarBase&quot;)(lookupName, ctx)
    def allRows = props.get(&quot;fn_getLookupRows&quot;)(varsRef, lookupName, ctx)
    if (!allRows &amp;&amp; ctx == &quot;tenant&quot;) {
        def legacy = props.get(&quot;fn_lookupNameToCamelCase&quot;)(lookupName)
        def legacyCount = varsRef.get(legacy + &quot;_count&quot;)
        if (legacyCount &amp;&amp; legacyCount.isInteger() &amp;&amp; legacyCount.toInteger() &gt; 0) base = legacy
    }
    def parentFieldValues = pickOptions?.parentFieldValues
    def parentRowId = pickOptions?.parentRowId
    def candidates = lookupMode
        ? props.get(&quot;fn_filterLookupRowsByMode&quot;)(allRows, lookupMode, parentFieldValues, parentRowId)
        : allRows
    // FIX: avoid picking a row that has zero rows underneath it for a deeper required field
    // (e.g. a Sub-Topic with no Micro Topic options) — restrict to rows with a valid descendant
    // path when that info is available, but never let this filter zero-out every candidate;
    // fall back to the unrestricted set and warn, so a genuine data gap still surfaces clearly
    // rather than silently failing the whole field.
    if (pickOptions?.restrictToIds != null &amp;&amp; candidates) {
        def restricted = candidates.findAll { it?.id &amp;&amp; pickOptions.restrictToIds.contains(it.id.toString()) }
        if (restricted) {
            candidates = restricted
        } else {
            logFn.warn(&quot;fn_pickLookupValue: none of the ${candidates.size()} candidate(s) for &apos;${lookupName}&apos; field=${fieldName ?: &apos;n/a&apos;} have a valid path to all required deeper fields — proceeding unrestricted (likely a genuine data gap further down the hierarchy)&quot;)
        }
    }
    if (lookupMode == &quot;child&quot; &amp;&amp; !candidates &amp;&amp; allRows) {
        def parentIds = parentRowId
            ? ((parentRowId instanceof List ? parentRowId : [parentRowId]).collect { it.toString() } as Set)
            : props.get(&quot;fn_lookupParentIdsForValues&quot;)(allRows, parentFieldValues)
        if (parentIds) {
            def recovered = (allRows ?: []).findAll { row -&gt;
                row?.parentId &amp;&amp; parentIds.contains(row.parentId.toString())
            }
            if (recovered) {
                logFn.warn(&quot;fn_pickLookupValue: recovered ${recovered.size()} parent-linked child row(s) for &apos;${lookupName}&apos; field=${fieldName ?: &apos;n/a&apos;} (same-label children retained)&quot;)
                candidates = recovered
            }
        }
    }
    if (lookupMode == &quot;child&quot; &amp;&amp; !candidates) {
        logFn.warn(&quot;fn_pickLookupValue: no child rows for ${lookupName} context=${ctx} field=${fieldName ?: &apos;n/a&apos;} (parent selections=${parentFieldValues})&quot;)
        return null
    }
    if (lookupMode == &quot;parent&quot; &amp;&amp; !candidates) {
        logFn.warn(&quot;fn_pickLookupValue: no parent rows (parentId null) for ${lookupName} context=${ctx} field=${fieldName ?: &apos;n/a&apos;}&quot;)
        return null
    }
    if (!candidates) {
        def countStr = varsRef.get(base + &quot;_count&quot;)
        if (!(countStr &amp;&amp; countStr.isInteger() &amp;&amp; countStr.toInteger() &gt; 0)) {
            logFn.warn(&quot;fn_pickLookupValue: no values for lookupName=${lookupName} context=${ctx} (checked ${base}_count)&quot;)
            return null
        }
        def count = countStr.toInteger()
        if (isMultiple) {
            def selectCount = selectionCountFn(count)
            def selectedValues = []
            def indices = (1..count).toList()
            Collections.shuffle(indices)
            indices.take(selectCount).each { idx -&gt;
                def val = varsRef.get(base + &quot;_&quot; + idx)
                if (val) selectedValues.add(val)
            }
            return selectedValues ?: null
        }
        def randomIndex = randRef.nextInt(count) + 1
        return varsRef.get(base + &quot;_&quot; + randomIndex)
    }
    if (isMultiple) {
        def selectCount = selectionCountFn(candidates.size())
        def shuffled = candidates.toList()
        Collections.shuffle(shuffled)
        def selectedRows = shuffled.take(selectCount).findAll { it?.value }
        def selectedValues = selectedRows.collect { it.value }
        // FIX: remember the row ID(s) actually selected, keyed by fieldName, so a dependent
        // child field can filter its children by exact parent ID instead of re-matching by text.
        if (fieldName) {
            def ids = selectedRows.collect { it?.id }.findAll { it }
            if (ids) varsRef.put(fieldName + &quot;__rowId&quot;, ids.join(&quot;,&quot;))
        }
        return selectedValues ?: null
    }
    def pickedRow = candidates[randRef.nextInt(candidates.size())]
    if (fieldName &amp;&amp; pickedRow?.id) {
        varsRef.put(fieldName + &quot;__rowId&quot;, pickedRow.id.toString())
    }
    return pickedRow?.value
}
props.put(&quot;fn_pickLookupValue&quot;, _fn_pickLookupValue)

// Generates a 4-digit random number (1000–9999) — used for short ID or reference fields.
def _fn_random4 = { java.util.concurrent.ThreadLocalRandom.current().nextInt(1000, 10000) }       // 4 digits (1000-9999)
props.put(&quot;fn_random4&quot;, _fn_random4)

// Generates a 5-digit random number (10000–99999) — used for medium-length ID or numeric fields.
def _fn_random5 = { java.util.concurrent.ThreadLocalRandom.current().nextInt(10000, 100000) }     // 5 digits (10000-99999)
props.put(&quot;fn_random5&quot;, _fn_random5)

// Generates a 6-digit random number (100000–999999) — used for longer ID or code fields.
def _fn_random6 = { java.util.concurrent.ThreadLocalRandom.current().nextInt(100000, 1000000) }   // 6 digits (100000-999999)
props.put(&quot;fn_random6&quot;, _fn_random6)

// Generates a realistic 10-digit phone number starting with 7, 8, or 9.
def _fn_generatePhone = {
    def rand = java.util.concurrent.ThreadLocalRandom.current()
    def validStartDigits = [7, 8, 9]
    def digit = validStartDigits[rand.nextInt(validStartDigits.size())]
    def rest = rand.nextLong(100000000L, 1000000000L)
    return String.valueOf(digit) + String.valueOf(rest)
}
props.put(&quot;fn_generatePhone&quot;, _fn_generatePhone)

// Extracts the allowed email domain from the form&apos;s DOMAIN_EMAIL validator (e.g. allianceit.com); defaults to gmail.com if not found.
def _fn_extractEmailDomain = { varsRef -&gt;
    def emailDomain = &quot;gmail.com&quot;
    try {
        def formUIConfigStr = varsRef.get(&quot;currentFormUIConfig&quot;)
        if (formUIConfigStr) {
            def formUIConfig = new groovy.json.JsonSlurper().parseText(formUIConfigStr)
            def configItems = formUIConfig.config ?: []
            configItems.each { item -&gt;
                if (item.validators) {
                    item.validators.each { validator -&gt;
                        if (validator.toString().startsWith(&quot;DOMAIN_EMAIL:&quot;)) {
                            emailDomain = validator.toString().split(&quot;:&quot;)[1]
                        }
                    }
                }
            }
        }
    } catch (Exception e) {
        log.warn(&quot;Error parsing formUIConfig for email domain: &quot; + e.message)
    }
    return emailDomain
}
props.put(&quot;fn_extractEmailDomain&quot;, _fn_extractEmailDomain)

// Returns the full flat list of all customer names.
def _fn_getCustomers = { varsRef -&gt;
    return props.get(&quot;fn_allCustomers&quot;)
}
props.put(&quot;fn_getCustomers&quot;, _fn_getCustomers)

// Resolves a display name from a stored indexed list by matching on ID, then stores it in the output variable (e.g. resolves categoryId → categoryName).
def _fn_lookupNameById = { varsRef, idVar, countVar, idPrefix, namePrefix, outputVar, defaultName, logRef -&gt;
    def currentId = varsRef.get(idVar) ?: &quot;&quot;
    def count = varsRef.get(countVar)?.toInteger() ?: 0
    def resolvedName = defaultName

    for (int i = 1; i &lt;= count; i++) {
        if (varsRef.get(idPrefix + i) == currentId) {
            resolvedName = varsRef.get(namePrefix + i) ?: defaultName
            break
        }
    }

    varsRef.put(outputVar, resolvedName)
    logRef.info(&quot;fn_lookupNameById | ${outputVar}: ${resolvedName}&quot;)
}
props.put(&quot;fn_lookupNameById&quot;, _fn_lookupNameById)

// Deletes the temporary PDF file generated during document upload, cleaning up the local filesystem after the upload sampler completes.
def _fn_documentCleanup = { varsRef, logRef -&gt;
    def filePath = varsRef.get(&quot;documentFilePath&quot;)
    if (filePath) {
        new File(filePath).delete()
        logRef.info(&quot;Cleaned up: ${filePath}&quot;)
    }
}
props.put(&quot;fn_documentCleanup&quot;, _fn_documentCleanup)

// Appends a label to the current sampler&apos;s display name (e.g. adds iteration count or status suffix for clarity in View Results Tree).
def _fn_appendSamplerLabel = { p, label -&gt;
    if (label) {
        p.setSampleLabel(p.getSampleLabel() + &quot; - &quot; + label)
    }
}
props.put(&quot;fn_appendSamplerLabel&quot;, _fn_appendSamplerLabel)

// Normalizes formUIConfig to a JSON string regardless of whether the API returned it as a String or a Map object.
def _fn_normalizeFormUIConfig = { rawConfig -&gt;
    if (rawConfig == null) return &quot;{}&quot;
    if (rawConfig instanceof String) return rawConfig
    return groovy.json.JsonOutput.toJson(rawConfig)
}
props.put(&quot;fn_normalizeFormUIConfig&quot;, _fn_normalizeFormUIConfig)

// Resolves the min/max entry count for a multi-entry form: API config wins, then formN/formNRange pairs, then multiFormRange.
// Only applies when isMultiEntry = true (enforced by the caller).
def _fn_multiFormEntries = { configMin, configMax, v, formIdentifier = null, formUniqueId = null -&gt;
    def logLabel = formUniqueId ?: formIdentifier ?: &quot;unknown&quot;

    // Priority 1: API config minEntries/maxEntries — always wins if present
    if (configMin != null &amp;&amp; configMax != null) {
        log.info(&quot;fn_multiFormEntries: Using API config min=&quot; + configMin + &quot; max=&quot; + configMax + &quot; for &apos;&quot; + logLabel + &quot;&apos;&quot;)
        return [configMin, configMax]
    }

    if (formUniqueId) {
        // Priority 2: Scan formN / formNRange pairs (e.g. form1 + form1Range)
        // Empty formN = unused slot. 0 or empty formNRange = hard skip when formN matches.
        def matchedFormKey = null
        def matchedFormRange = null

        v.entrySet()
         .findAll { it.key ==~ /^form\d+$/ }
         .sort { a, b -&gt; (a.key.replaceFirst(/^form/, &quot;&quot;) as int) &lt;=&gt; (b.key.replaceFirst(/^form/, &quot;&quot;) as int) }
         .each { entry -&gt;
             if (matchedFormKey) return

             def formUuid = entry.value?.toString()?.trim()
             if (!formUuid) return

             if (formUuid.equalsIgnoreCase(formUniqueId)) {
                 def suffix = entry.key.replaceFirst(/^form/, &quot;&quot;)
                 matchedFormKey = entry.key
                 matchedFormRange = v.get(&quot;form&quot; + suffix + &quot;Range&quot;)?.toString()?.trim()
             }
         }

        if (matchedFormKey != null) {
            def rangeKey = matchedFormKey + &quot;Range&quot;
            if (!matchedFormRange || matchedFormRange == &quot;0&quot;) {
                log.info(&quot;fn_multiFormEntries: &apos;&quot; + rangeKey + &quot;&apos; is 0/empty for &apos;&quot; + formUniqueId + &quot;&apos; (&quot; + formIdentifier + &quot;) via &apos;&quot; + matchedFormKey + &quot;&apos; — skipping form&quot;)
                return [0, 0]
            }
            log.info(&quot;fn_multiFormEntries: Using &apos;&quot; + matchedFormKey + &quot;&apos; + &apos;&quot; + rangeKey + &quot;&apos;=&apos;&quot; + matchedFormRange + &quot;&apos; for &apos;&quot; + formUniqueId + &quot;&apos; (&quot; + formIdentifier + &quot;)&quot;)
            return props.get(&quot;fn_parseEntryRange&quot;)(matchedFormRange, rangeKey)
        }

        log.info(&quot;fn_multiFormEntries: No formN/formNRange match for &apos;&quot; + formUniqueId + &quot;&apos; (&quot; + formIdentifier + &quot;) — falling back to multiFormRange&quot;)
    }

    // Priority 3: Fallback to global multiFormRange UDV
    log.info(&quot;fn_multiFormEntries: Falling back to multiFormRange for &apos;&quot; + logLabel + &quot;&apos;&quot;)
    return props.get(&quot;fn_parseMultiFormRange&quot;)(v)
}
props.put(&quot;fn_multiFormEntries&quot;, _fn_multiFormEntries)

// Stop execution if abort flag is already set
// Checks the skipEventCreation flag and disables the current sampler if set, preventing further request creation steps from executing.
def _fn_checkAbort = { v, p -&gt;
    if (v.get(&quot;_abortTest&quot;) == &quot;true&quot;) {
        p.setSuccessful(false)
        p.setResponseMessage(&quot;SKIPPED: Test aborting — &quot; + (v.get(&quot;_abortReason&quot;) ?: &quot;previous validation failed&quot;))
        return true
    }
    return false
}
props.put(&quot;fn_checkAbort&quot;, _fn_checkAbort)

// Abort test when required value is not found
// Logs a critical error and stops the test when a required API value (e.g. category, customer) could not be found in the response.
def _fn_abortNotFound = { varsRef, prevRef, varName, value, available, ctxRef -&gt;
    log.error(&quot;========================================&quot;)
    log.error(&quot;${varName} &apos;${value}&apos; not found in API response&quot;)
    log.error(&quot;Available: ${available}&quot;)
    log.error(&quot;========================================&quot;)
    prevRef.setSuccessful(false)
    prevRef.setResponseMessage(&quot;ABORTING: ${varName} &apos;${value}&apos; not found. Available: ${available}&quot;)
    varsRef.put(&quot;_abortTest&quot;, &quot;true&quot;)
    varsRef.put(&quot;_abortReason&quot;, &quot;${varName} &apos;${value}&apos; not found in API response. Available: ${available}&quot;)
    ctxRef.getEngine().stopTest()
}
props.put(&quot;fn_abortNotFound&quot;, _fn_abortNotFound)

// multi-entry range
// Parses the multiFormRange UDV (e.g. &quot;1,3&quot;) into [min, max] integers for multi-entry form count resolution; throws on negative values.
def _fn_parseMultiFormRange = { v -&gt;
    def raw = v.get(&quot;multiFormRange&quot;)?.trim()
    if (!raw || raw == &quot;0&quot;) return [0, 0]
    def parts = raw.split(&quot;,&quot;)*.trim()
    if (parts.size() &gt; 2) {
        log.warn(&quot;multiFormRange &apos;${raw}&apos; has too many values (${parts.size()}) — expected exactly 2 (min,max). Using [0,0].&quot;)
        return [0, 0]
    }
    def minVal = parts[0].isInteger() ? parts[0].toInteger() : 0
    def maxVal = parts.size() &gt; 1 ? (parts[1].isInteger() ? parts[1].toInteger() : 0) : minVal
    if (minVal &lt; 0 || maxVal &lt; 0) {
        def errorMsg = &quot;multiFormRange &apos;${raw}&apos; is invalid — negative values are not allowed. Use positive integers only (e.g. 1,3) or leave empty to skip.&quot;
        log.error(errorMsg)
        throw new IllegalArgumentException(errorMsg)
    }
    if (minVal &gt; maxVal) {
        log.warn(&quot;multiFormRange &apos;${raw}&apos; is invalid — min (${minVal}) &gt; max (${maxVal}). Expected format: min,max e.g. 1,3. Using [0,0].&quot;)
        return [0, 0]
    }
    return [minVal, maxVal]
}
props.put(&quot;fn_parseMultiFormRange&quot;, _fn_parseMultiFormRange)

// Parses a form-specific entry range UDV (e.g. &quot;2,4&quot; or &quot;3&quot;) into [min, max]; returns [0,0] to skip for empty, zero, negative, non-numeric, or out-of-order values.
def _fn_parseEntryRange = { String raw, String paramName -&gt;
    if (!raw || raw.trim() == &quot;0&quot;) return [0, 0]
    def parts = raw.split(&quot;,&quot;)*.trim()
    // more than 2 values — skip
    if (parts.size() &gt; 2) {
        log.warn(&quot;fn_parseEntryRange: &apos;&quot; + paramName + &quot;&apos; has more than 2 values &apos;&quot; + raw + &quot;&apos; — skipping form&quot;)
        return [0, 0]
    }
    // non-numeric — skip
    if (!parts.every { it.isInteger() }) {
        log.warn(&quot;fn_parseEntryRange: &apos;&quot; + paramName + &quot;&apos; has non-numeric value &apos;&quot; + raw + &quot;&apos; — skipping form&quot;)
        return [0, 0]
    }
    def minVal = parts[0].toInteger()
    def maxVal = parts.size() &gt; 1 ? parts[1].toInteger() : minVal
    // negative values — skip
    if (minVal &lt; 0 || maxVal &lt; 0) {
        log.warn(&quot;fn_parseEntryRange: &apos;&quot; + paramName + &quot;&apos; has negative value &apos;&quot; + raw + &quot;&apos; — skipping form&quot;)
        return [0, 0]
    }
    // min &gt; max — skip
    if (minVal &gt; maxVal) {
        log.warn(&quot;fn_parseEntryRange: &apos;&quot; + paramName + &quot;&apos; min (&quot; + minVal + &quot;) &gt; max (&quot; + maxVal + &quot;) in &apos;&quot; + raw + &quot;&apos; — skipping form&quot;)
        return [0, 0]
    }
    return [minVal, maxVal]
}
props.put(&quot;fn_parseEntryRange&quot;, _fn_parseEntryRange)

// Parses the multiDropDownRange UDV into {min, max} for controlling how many options are picked in multi-select dropdowns; throws on negative values.
def _fn_parseMultiDropDownRange = { v, defaultRange -&gt;
    def raw = v.get(&quot;multiDropDownRange&quot;)?.trim()
    if (!raw || raw == &quot;0&quot;) return [min: 0, max: 0]
    def parts = raw.split(&quot;,&quot;)*.trim()
    def minVal = parts[0].isInteger() ? parts[0].toInteger() : 0
    def maxVal = parts.size() &gt; 1 ? (parts[1].isInteger() ? parts[1].toInteger() : 0) : minVal
    if (minVal &lt; 0 || maxVal &lt; 0) {
        def errorMsg = &quot;multiDropDownRange &apos;${raw}&apos; is invalid — negative values are not allowed. Use positive integers only (e.g. 1,3) or leave empty to skip.&quot;
        log.error(errorMsg)
        throw new IllegalArgumentException(errorMsg)
    }
    return [min: minVal, max: maxVal]
}
props.put(&quot;fn_parseMultiDropDownRange&quot;, _fn_parseMultiDropDownRange)


// Parses the secondaryOpportunities UDV into {min, max, source}; falls back to multiDropDownRange if not set.
def _fn_parseSecondaryOpportunities = { v -&gt;
    def raw = v.get(&quot;secondaryOpportunities&quot;)?.trim()
    def source = &quot;secondaryOpportunities&quot;
    if (!raw || raw == &quot;0&quot;) {
        // Fallback to multiDropDownRange
        def fallback = props.get(&quot;fn_parseMultiDropDownRange&quot;)(v, null)
        return [min: fallback.min, max: fallback.max, source: &quot;multiDropDownRange (fallback)&quot;]
    }
    def parts = raw.split(&quot;,&quot;)*.trim()
    if (parts.size() &gt; 2) {
        log.warn(&quot;secondaryOpportunities &apos;${raw}&apos; has too many values — expected 1 or 2 (e.g. 2 or 2,5). Using [0,0].&quot;)
        return [min: 0, max: 0, source: source]
    }
    def minVal = parts[0].isInteger() ? parts[0].toInteger() : 0
    def maxVal = parts.size() &gt; 1 ? (parts[1].isInteger() ? parts[1].toInteger() : 0) : minVal
    if (minVal &lt; 0 || maxVal &lt; 0) {
        def errorMsg = &quot;secondaryOpportunities &apos;${raw}&apos; is invalid — negative values not allowed. Use positive integers (e.g. 2,5).&quot;
        log.error(errorMsg)
        throw new IllegalArgumentException(errorMsg)
    }
    if (minVal &gt; maxVal) {
        log.warn(&quot;secondaryOpportunities &apos;${raw}&apos; is invalid — min (${minVal}) &gt; max (${maxVal}). Using [0,0].&quot;)
        return [min: 0, max: 0, source: source]
    }
    return [min: minVal, max: maxVal, source: source]
}
props.put(&quot;fn_parseSecondaryOpportunities&quot;, _fn_parseSecondaryOpportunities)

log.info(&quot;Common Utility Function initialized&quot;)</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Common Function - Form Processing" enabled="true">
          <stringProp name="script">SampleResult.setIgnore()

// Parses the field mappings API response into a map of attributeName → {aliasName, displayText, dataType} for use by the payload builder.
def _fn_parseFieldMappings = { String fieldMappingsStr -&gt;
    def fmMap = [:]
    if (fieldMappingsStr) {
        try {
            def fmJson = new groovy.json.JsonSlurper().parseText(fieldMappingsStr)
            def mappings = fmJson._embedded?.fieldMappings ?: []
            mappings.each { mapping -&gt;
                def attrName = mapping.columnAttribute?.attributeName
                def aliasName = mapping.aliasName
                if (attrName &amp;&amp; aliasName) {
                    fmMap[attrName] = [
                        aliasName  : aliasName,
                        displayText: mapping.displayText,
                        dataType   : mapping.columnAttribute?.dataType
                    ]
                }
            }
        } catch (Exception e) {
            log.warn(&quot;fn_parseFieldMappings: Error parsing mapping entry — ${e.message}&quot;)
        }
    }
    return fmMap
}
props.put(&quot;fn_parseFieldMappings&quot;, _fn_parseFieldMappings)

// Flattens all form fields from a formUIConfig JSON string into a single list, expanding SECTION containers and including standalone FORMFIELD items.
def _fn_extractAllFields = { String fuiConfigStr -&gt;
    def fuiConfig = new groovy.json.JsonSlurper().parseText(fuiConfigStr)
    def fields = []
    def items = fuiConfig.config ?: []
    items.each { item -&gt;
        if (item.type == &quot;SECTION&quot;) {
            fields.addAll(item.formFields ?: [])
        } else if (item.type == &quot;FORMFIELD&quot;) {
            fields.add(item)
        }
    }
    return fields
}
props.put(&quot;fn_extractAllFields&quot;, _fn_extractAllFields)

// Builds a map of parent field → dependent child fields with hide conditions, used to skip fields that should not appear based on parent values.
// FIX: dcFieldSet previously only contained fields explicitly listed under another field&apos;s dependentControls.
// If the API never returns dependentControls for a cascading lookup chain (see fn_buildLookupParentFieldMap
// fix above for the full explanation), those fields were treated as &quot;standalone&quot; for ordering purposes —
// which is harmless for hide/show logic but meant nothing guaranteed the parent (e.g. Sub-Topic) ran before
// the child (e.g. Micro Topic) when an explicit link did exist some other way. Now any field whose
// lookupMode resolves to &quot;child&quot; is also added to dcFieldSet (independent of dependentControls/hide rules),
// so the two-pass field ordering in the PayloadBuilder always processes hierarchy parents before children.
def _fn_buildDependentControlsMap = { allFieldsList -&gt;
    def dcMap = [:]
    def dcFieldSet = [] as Set
    allFieldsList.each { field -&gt;
        def parentFN = field.dataMapping ?: field.formControlName
        def depControls = field.dependentControls ?: []
        if (depControls) {
            def depList = []
            depControls.each { dep -&gt;
                def depFN = dep.formControlName
                if (!depFN) return
                dcFieldSet.add(depFN)
                def hideR = dep.rules?.hide
                if (hideR) {
                    depList.add([fieldName: depFN, evalCondition: hideR.evalCondition, evalValue: hideR.evalValue])
                }
            }
            if (depList) { dcMap[parentFN] = depList }
        }
    }
    // FIX: also mark lookupMode=&quot;child&quot; fields as dependent for ordering, even without dependentControls
    allFieldsList.each { field -&gt;
        def fn = field.dataMapping ?: field.formControlName
        if (!fn || dcFieldSet.contains(fn)) return
        if (props.get(&quot;fn_resolveFieldLookupMode&quot;)(field) == &quot;child&quot;) {
            dcFieldSet.add(fn)
        }
    }
    return [map: dcMap, fieldSet: dcFieldSet]
}
props.put(&quot;fn_buildDependentControlsMap&quot;, _fn_buildDependentControlsMap)

// Returns true if a dependent field should be included in the payload — evaluates the parent field&apos;s hide condition against already-processed form data.
def _fn_shouldShowDependentField = { String depFN, Map formDataSoFar, Map dcMap, varsRef -&gt;
    def result = true
    dcMap.each { parentField, dependents -&gt;
        dependents.each { dep -&gt;
            if (dep.fieldName == depFN) {
                // First check formData (already processed fields), then fall back to JMeter vars
                def parentValue = formDataSoFar.containsKey(parentField)
                    ? formDataSoFar[parentField]
                    : (varsRef != null ? varsRef.get(parentField) : null)
                def shouldHide = false
                if (parentValue != null) {
                    def pVal = parentValue
                    def eVal = dep.evalValue
                    if (pVal instanceof Boolean || eVal instanceof Boolean) {
                        pVal = pVal?.toString()?.toLowerCase() == &quot;true&quot;
                        eVal = eVal?.toString()?.toLowerCase() == &quot;true&quot;
                    }
                    switch(dep.evalCondition) {
                        case &quot;==&quot;: shouldHide = (pVal == eVal); break
                        case &quot;!=&quot;: shouldHide = (pVal != eVal); break
                    }
                }
                // If parentValue still null (parent not yet processed and no var set),
                // treat as hidden to be safe — dependent field will be re-evaluated in pass 2
                if (parentValue == null) { result = false }
                if (shouldHide) { result = false }
            }
        }
    }
    return result
}
props.put(&quot;fn_shouldShowDependentField&quot;, _fn_shouldShowDependentField)

// Advances the form config index and maps indexed form variables (formId, formName, formIdentifier, entryCount, etc.) to their &quot;current&quot; equivalents for the active iteration.
def _fn_setCurrentFormVariables = { varsRef -&gt;
    // Increment Config Index
    def prevIndex = varsRef.get(&quot;configIndex&quot;) ?: &quot;0&quot;
    def configIndex = (prevIndex.toInteger() + 1).toString()
    varsRef.put(&quot;configIndex&quot;, configIndex)

    // Map Indexed Variables to Current Variables
    varsRef.put(&quot;currentJourneyId&quot;, varsRef.get(&quot;journeyId_&quot; + configIndex) ?: &quot;&quot;)
    varsRef.put(&quot;currentJourneyName&quot;, varsRef.get(&quot;journeyName_&quot; + configIndex) ?: &quot;&quot;)
    varsRef.put(&quot;currentPageId&quot;, varsRef.get(&quot;pageId_&quot; + configIndex) ?: &quot;&quot;)
    varsRef.put(&quot;currentPageName&quot;, varsRef.get(&quot;pageName_&quot; + configIndex) ?: &quot;&quot;)
    varsRef.put(&quot;currentModuleId&quot;, varsRef.get(&quot;moduleId_&quot; + configIndex) ?: &quot;&quot;)
    varsRef.put(&quot;currentFormId&quot;, varsRef.get(&quot;formId_&quot; + configIndex) ?: &quot;&quot;)
    varsRef.put(&quot;currentFormName&quot;, varsRef.get(&quot;formName_&quot; + configIndex) ?: &quot;&quot;)
    varsRef.put(&quot;currentFormIdentifier&quot;, varsRef.get(&quot;formIdentifier_&quot; + configIndex) ?: &quot;&quot;)
    varsRef.put(&quot;currentIsMultiEntry&quot;, varsRef.get(&quot;isMultiEntry_&quot; + configIndex) ?: &quot;false&quot;)

    // Calculate Entry Count for Multi-Entry Forms
    def isMultiEntry = varsRef.get(&quot;currentIsMultiEntry&quot;) == &quot;true&quot;
    def entryCount = 1

    if (isMultiEntry) {
        def minEntriesStr = varsRef.get(&quot;minEntries_&quot; + configIndex)
        def maxEntriesStr = varsRef.get(&quot;maxEntries_&quot; + configIndex)
        def minEntries = (minEntriesStr != null) ? minEntriesStr.toInteger() : 1
        def maxEntries = (maxEntriesStr != null) ? maxEntriesStr.toInteger() : 1
        entryCount = (minEntries == 0 &amp;&amp; maxEntries == 0) ? 0 : minEntries + new java.util.Random().nextInt((maxEntries - minEntries) + 1)
        varsRef.put(&quot;currentMinEntries&quot;, minEntries.toString())
        varsRef.put(&quot;currentMaxEntries&quot;, maxEntries.toString())
    }

    varsRef.put(&quot;entryCount&quot;, entryCount.toString())
    varsRef.put(&quot;entryIndex&quot;, &quot;0&quot;)
    varsRef.put(&quot;totalEntryCount&quot;, entryCount.toString())
    varsRef.put(&quot;currentEntryIndex&quot;, &quot;0&quot;)
}
props.put(&quot;fn_setCurrentFormVariables&quot;, _fn_setCurrentFormVariables)

// For multi-user flows, checks whether the current user has any new fields to fill; sets skipCurrentForm=true if all accessible fields were already submitted by a previous user.
def _fn_fieldDiffCheck = { varsRef, propsRef, logRef -&gt;

    def moduleName = varsRef.get(&quot;currentModuleName&quot;) ?: varsRef.get(&quot;currentActivityModuleName&quot;) ?: varsRef.get(&quot;newRequestModuleName&quot;) ?: &quot;unknown&quot;
    def formName   = varsRef.get(&quot;currentFormName&quot;) ?: varsRef.get(&quot;requestFormName&quot;) ?: &quot;unknown&quot;
    def userEmail  = varsRef.get(&quot;currentUser&quot;) ?: &quot;Unknown&quot;
    def userRole   = varsRef.get(&quot;roleId&quot;) ?: &quot;&quot;

    logRef.info(&quot;===== Field Diff Check: ${moduleName} / ${formName} | ${userEmail} (${userRole}) =====&quot;)

    // Default: do NOT skip
    varsRef.put(&quot;skipCurrentForm&quot;, &quot;false&quot;)

    // Only run diff check if form data exists (UPDATE path)
    def formDataId = varsRef.get(&quot;formDataId&quot;)
    if (formDataId == null || formDataId.trim() == &quot;&quot;) {
        logRef.info(&quot;Result: RUN (CREATE path)&quot;)
        return
    }

    // First user always runs UPDATE
    def isFirstUser = varsRef.get(&quot;isFirstUser&quot;) ?: &quot;true&quot;
    if (isFirstUser == &quot;true&quot;) {
        logRef.info(&quot;Result: RUN (first user bypass)&quot;)
        return
    }

    // STEP 1: Parse formUIConfig to get all fields
    def formUIConfigStr = varsRef.get(&quot;currentFormUIConfig&quot;)
    if (!formUIConfigStr) {
        logRef.warn(&quot;Result: RUN (no formUIConfig)&quot;)
        return
    }

    def allFields = propsRef.get(&quot;fn_extractAllFields&quot;)(formUIConfigStr)

    // STEP 2: Filter to get current user&apos;s accessible (writable) fields
    def accessibleFields = [] as Set
    allFields.each { field -&gt;
        def fieldName    = field.dataMapping ?: field.formControlName
        def isHidden     = field.hide ?: false
        def isDisabled   = field.disabled ?: false
        def hiddenRoles  = field.hiddenRoles ?: []
        def readOnlyRoles = field.readOnlyRoles ?: []

        if (isHidden || isDisabled) return
        if (hiddenRoles &amp;&amp; hiddenRoles.contains(userRole)) return
        if (readOnlyRoles &amp;&amp; readOnlyRoles.contains(userRole)) return
        if (fieldName) accessibleFields.add(fieldName)
    }

    // STEP 3: Check ONLY processedFields (what previous users filled in this same run)
    // FIX: existingFormData (API data) is intentionally ignored — old/pre-existing data
    // must NOT prevent a user from filling their fields in this run.
    def requestId           = varsRef.get(&quot;requestId&quot;) ?: &quot;unknown&quot;
    def formNameForTracking = varsRef.get(&quot;currentFormName&quot;) ?: varsRef.get(&quot;requestFormName&quot;) ?: &quot;unknown&quot;
    def trackKey            = &quot;processedFields_&quot; + requestId + &quot;_&quot; + moduleName + &quot;_&quot; + formNameForTracking
    def previouslyProcessed = propsRef.get(trackKey) ?: (new HashSet())

    def newFields           = [] as Set
    def alreadyFilledFields = [] as Set

    accessibleFields.each { fieldName -&gt;
        if (previouslyProcessed.contains(fieldName)) {
            alreadyFilledFields.add(fieldName)
            logRef.info(&quot;  Field &apos;${fieldName}&apos; already filled by previous user in this run - SKIP&quot;)
        } else {
            newFields.add(fieldName)
            logRef.info(&quot;  Field &apos;${fieldName}&apos; not yet filled in this run - NEW&quot;)
        }
    }

    // Log fields summary
    logRef.info(&quot;Accessible: ${accessibleFields.size()} fields - ${accessibleFields}&quot;)
    logRef.info(&quot;Already filled by prior users (this run): ${alreadyFilledFields.size()} fields - ${alreadyFilledFields}&quot;)
    logRef.info(&quot;New fields for this user: ${newFields.size()} fields - ${newFields}&quot;)
    logRef.info(&quot;Previously tracked (props): ${previouslyProcessed.size()} fields - ${previouslyProcessed}&quot;)

    // Decision
    if (accessibleFields.isEmpty()) {
        varsRef.put(&quot;skipCurrentForm&quot;, &quot;true&quot;)
        logRef.info(&quot;Result: SKIP (no accessible fields for role &apos;${userRole}&apos;)&quot;)
    } else if (newFields.isEmpty() &amp;&amp; previouslyProcessed.size() &gt; 0) {
        // Only skip if previouslyProcessed actually has entries - confirms prior user truly filled these fields
        varsRef.put(&quot;skipCurrentForm&quot;, &quot;true&quot;)
        logRef.info(&quot;Result: SKIP (all ${accessibleFields.size()} fields already filled by previous users in this run)&quot;)
        // Do NOT update processedFields — this user is skipping, nothing new was filled
    } else if (newFields.isEmpty() &amp;&amp; previouslyProcessed.size() == 0) {
        // previouslyProcessed is empty - means no prior user tracked these fields yet (possible trackKey mismatch or first time)
        // RUN to ensure this user fills its accessible fields
        varsRef.put(&quot;skipCurrentForm&quot;, &quot;false&quot;)
        logRef.info(&quot;Result: RUN (previouslyProcessed is empty - no prior tracking found, running to fill ${accessibleFields.size()} accessible fields)&quot;)
        accessibleFields.each { k -&gt; previouslyProcessed.add(k) }
        propsRef.put(trackKey, previouslyProcessed)
        logRef.info(&quot;Field Tracking (diffCheck): Saved ${previouslyProcessed.size()} fields for &apos;${trackKey}&apos;&quot;)
    } else if (newFields.size() == accessibleFields.size()) {
        varsRef.put(&quot;skipCurrentForm&quot;, &quot;false&quot;)
        logRef.info(&quot;Result: RUN (all ${newFields.size()} fields are new for this user)&quot;)
        // Save accessible fields so next user knows they are covered
        accessibleFields.each { k -&gt; previouslyProcessed.add(k) }
        propsRef.put(trackKey, previouslyProcessed)
        logRef.info(&quot;Field Tracking (diffCheck): Saved ${previouslyProcessed.size()} fields for &apos;${trackKey}&apos;&quot;)
    } else {
        varsRef.put(&quot;skipCurrentForm&quot;, &quot;false&quot;)
        logRef.info(&quot;Result: RUN (${newFields.size()} new of ${accessibleFields.size()} total for this user)&quot;)
        // Save accessible fields so next user knows they are covered
        accessibleFields.each { k -&gt; previouslyProcessed.add(k) }
        propsRef.put(trackKey, previouslyProcessed)
        logRef.info(&quot;Field Tracking (diffCheck): Saved ${previouslyProcessed.size()} fields for &apos;${trackKey}&apos;&quot;)
    }
}
props.put(&quot;fn_fieldDiffCheck&quot;, _fn_fieldDiffCheck)

// Activity State Action Selector - picks a random allowed state action from API response _links
// Pass &quot;prev&quot; so the function can read the HTTP response

// Sets formDataId, isPrimary, entry counters, and existingFormData for the current record in a ForEach multi-entry loop.
def _fn_setIsPrimaryAndFormDataId = { varsRef, logRef -&gt;
    def currentRecordId = varsRef.get(&quot;currentMultiEntryRecordId&quot;)
    def recordCount     = varsRef.get(&quot;multiEntryRecordCount&quot;)?.toInteger() ?: 0

    // Set formDataId to current record for Update call
    varsRef.put(&quot;formDataId&quot;, currentRecordId)

    // Find Current Record Index (1-based)
    def currentIndex = 0
    for (int i = 1; i &lt;= recordCount; i++) {
        if (varsRef.get(&quot;multiEntryRecordId_&quot; + i) == currentRecordId) {
            currentIndex = i
            break
        }
    }

    // Set Counter Variables for Sampler Name Display - Format: (1/3), (2/3), (3/3)
    varsRef.put(&quot;currentEntryIndex&quot;, String.valueOf(currentIndex))
    varsRef.put(&quot;totalEntryCount&quot;,   String.valueOf(recordCount))

    // Set isPrimary Flag - first record (index 1) = PRIMARY, rest are not
    boolean isPrimary = (currentIndex == 1)
    varsRef.put(&quot;isPrimary&quot;, String.valueOf(isPrimary))

    // Set correct existingFormData for this record
    def indexedExistingData = varsRef.get(&quot;existingFormData_&quot; + currentIndex)
    if (indexedExistingData) {
        varsRef.put(&quot;existingFormData&quot;, indexedExistingData)
        logRef.info(&quot;Loaded existingFormData for record ${currentIndex}&quot;)
    } else {
        varsRef.put(&quot;existingFormData&quot;, &quot;{}&quot;)
        logRef.info(&quot;No existingFormData for record ${currentIndex} - using empty&quot;)
    }

    logRef.info(&quot;Record ID: ${currentRecordId}&quot;)
    logRef.info(&quot;Record Index: ${currentIndex} of ${recordCount}&quot;)
    logRef.info(&quot;isPrimary: ${isPrimary}&quot;)
    logRef.info(&quot;Counter: (${currentIndex}/${recordCount})&quot;)
    logRef.info(&quot;----- Terminated: Multi-Entry Record Processor -----&quot;)
}
props.put(&quot;fn_setIsPrimaryAndFormDataId&quot;, _fn_setIsPrimaryAndFormDataId)

// Parses the Get Form Data API response: stores all record IDs and existing field data for ForEach iteration; sets formDataId=&quot;&quot; if no records exist (CREATE path).
def _fn_formPostProcessor = { varsRef, prevRef, logRef -&gt;

    def response      = prevRef.getResponseDataAsString()
    def json          = new groovy.json.JsonSlurper().parseText(response)
    def formDataArray = json._embedded?.formData ?: []
    def formDataCount = formDataArray.size()

    // Store count for conditional logic (0 = CREATE, &gt;0 = UPDATE)
    varsRef.put(&quot;formCount&quot;, formDataCount.toString())

    if (formDataCount &gt; 0) {
        // Clear Previous Multi-Entry Variables
        def prevRecordCount = (varsRef.get(&quot;multiEntryRecordCount&quot;) ?: &quot;0&quot;).toInteger()
        for (int i = 1; i &lt;= prevRecordCount + 5; i++) {
            varsRef.remove(&quot;multiEntryRecordId_&quot; + i)
        }
        if (prevRecordCount &gt; 0) logRef.info(&quot;Cleared previous record variables (1-&quot; + (prevRecordCount + 5) + &quot;)&quot;)

        // Store ALL Record IDs and existing data for ForEach iteration
        formDataArray.eachWithIndex { record, index -&gt;
            varsRef.put(&quot;multiEntryRecordId_&quot; + (index + 1), record.id?.toString() ?: &quot;&quot;)
            logRef.info(&quot;[${index + 1}] Record ID: ${record.id}&quot;)

            def recordData = record.data ?: [:]
            varsRef.put(&quot;existingFormData_&quot; + (index + 1), groovy.json.JsonOutput.toJson(recordData))
            logRef.info(&quot;[${index + 1}] Stored existing data: ${recordData.size()} fields&quot;)
        }

        // Store total count for ForEach
        varsRef.put(&quot;multiEntryRecordCount&quot;, formDataCount.toString())

        // Set first record as default (backward compatibility)
        varsRef.put(&quot;formDataId&quot;, formDataArray[0].id?.toString() ?: &quot;&quot;)
        def existingData = formDataArray[0].data ?: [:]
        varsRef.put(&quot;existingFormData&quot;, groovy.json.JsonOutput.toJson(existingData))
        logRef.info(&quot;Stored default existing form data: ${existingData.size()} fields&quot;)
        logRef.info(&quot;Total Records: ${formDataCount}&quot;)
        logRef.info(&quot;First Record ID: ${formDataArray[0].id}&quot;)
    } else {
        // Form Data NOT FOUND - will CREATE new form
        varsRef.put(&quot;formDataId&quot;,           &quot;&quot;)
        varsRef.put(&quot;multiEntryRecordCount&quot;, &quot;0&quot;)
        varsRef.put(&quot;existingFormData&quot;,      &quot;{}&quot;)
    }

    logRef.info(&quot;----- Terminated: Get Form Data Extractor -----&quot;)
}
props.put(&quot;fn_formPostProcessor&quot;, _fn_formPostProcessor)

// Pretty-prints the Get Form Config API response for View Results Tree; also parses and stores the formUIConfig JSON and sets the isDocumentForm flag.
def _fn_beautifyFormConfig = { varsRef, prevRef, logRef -&gt;

// UI Config JSON Beautifier

try {
    def response = prevRef.getResponseDataAsString()
    def json = new groovy.json.JsonSlurper().parseText(response)

    // Parse the stringified formUIConfig into actual JSON
    if (json.formUIConfig) {
        if (json.formUIConfig instanceof String) {
            json.formUIConfig = new groovy.json.JsonSlurper().parseText(json.formUIConfig)
        }
        // Update currentFormUIConfig variable with parsed JSON
        varsRef.put(&quot;currentFormUIConfig&quot;, groovy.json.JsonOutput.toJson(json.formUIConfig))

        // Check if any field has enumType=DOCUMENT - mark as document form
        def configObj = json.formUIConfig
        def allFormFields = []
        (configObj.config ?: []).each { item -&gt;
            if (item.type == &quot;SECTION&quot;) allFormFields.addAll(item.formFields ?: [])
            else if (item.type == &quot;FORMFIELD&quot;) allFormFields.add(item)
        }
        def isDocForm = allFormFields.any { it.formControlType == &quot;SELECT&quot; &amp;&amp; it.enumType == &quot;DOCUMENT&quot; }
        varsRef.put(&quot;isDocumentForm&quot;, isDocForm.toString())
            }

    // Beautify and store
    def beautified = groovy.json.JsonOutput.prettyPrint(groovy.json.JsonOutput.toJson(json))
    prevRef.setResponseData(beautified, &quot;UTF-8&quot;)

} catch (Exception e) {
    logRef.warn(&quot;Could not beautify JSON: &quot; + e.getMessage())
}
}
props.put(&quot;fn_beautifyFormConfig&quot;, _fn_beautifyFormConfig)

// Scans the form&apos;s UI config to find all RESOURCE and MASTER type fields; stores their type IDs and names as indexed variables for the resource/master fetch loop.
def _fn_resourceMasterExtractor = { varsRef, logRef -&gt;

def formName = varsRef.get(&quot;currentFormName&quot;)

// Clear Previous ResourceType and MasterType Variables
def prevRtCount = varsRef.get(&quot;resourceTypeIds_count&quot;)?.toInteger() ?: 0
def prevMtCount = varsRef.get(&quot;masterTypeIds_count&quot;)?.toInteger() ?: 0

// Clear previous resourceTypeId variables and their associated resources
for (int i = 1; i &lt;= prevRtCount + 5; i++) {
    def rtId = varsRef.get(&quot;resourceTypeId_&quot; + i)
    if (rtId) {
        // Clear resources fetched for this resourceTypeId
        def resCount = varsRef.get(&quot;resourcesFor_&quot; + rtId + &quot;_count&quot;)?.toInteger() ?: 0
        for (int j = 0; j &lt;= resCount; j++) {
            varsRef.remove(&quot;resourcesFor_&quot; + rtId + &quot;_&quot; + j + &quot;_id&quot;)
            varsRef.remove(&quot;resourcesFor_&quot; + rtId + &quot;_&quot; + j + &quot;_name&quot;)
            varsRef.remove(&quot;resourcesFor_&quot; + rtId + &quot;_&quot; + j + &quot;_parentId&quot;)
        }
        varsRef.remove(&quot;resourcesFor_&quot; + rtId + &quot;_count&quot;)
    }
    varsRef.remove(&quot;resourceTypeId_&quot; + i)
    varsRef.remove(&quot;resourceTypeName_&quot; + i)
}

// Clear previous masterTypeId variables and their associated masters
for (int i = 1; i &lt;= prevMtCount + 5; i++) {
    def mtId = varsRef.get(&quot;masterTypeId_&quot; + i)
    if (mtId) {
        // Clear masters fetched for this masterTypeId
        def masCount = varsRef.get(&quot;mastersFor_&quot; + mtId + &quot;_count&quot;)?.toInteger() ?: 0
        for (int j = 0; j &lt;= masCount; j++) {
            varsRef.remove(&quot;mastersFor_&quot; + mtId + &quot;_&quot; + j + &quot;_id&quot;)
            varsRef.remove(&quot;mastersFor_&quot; + mtId + &quot;_&quot; + j + &quot;_name&quot;)
        }
        varsRef.remove(&quot;mastersFor_&quot; + mtId + &quot;_count&quot;)
    }
    varsRef.remove(&quot;masterTypeId_&quot; + i)
    varsRef.remove(&quot;masterTypeName_&quot; + i)
}

// Reset counts
varsRef.put(&quot;resourceTypeIds_count&quot;, &quot;0&quot;)
varsRef.put(&quot;masterTypeIds_count&quot;, &quot;0&quot;)

// STEP 1: Get formUIConfig
def formUIConfigStr = varsRef.get(&quot;currentFormUIConfig&quot;)

if (!formUIConfigStr) {
    logRef.warn(&quot;formUIConfig not found - skipping resource/master extraction&quot;)
    varsRef.put(&quot;resourceTypeIds_count&quot;, &quot;0&quot;)
    varsRef.put(&quot;masterTypeIds_count&quot;, &quot;0&quot;)
    return
}
// STEP 2: Parse formUIConfig
def allFields = props.get(&quot;fn_extractAllFields&quot;)(formUIConfigStr)
// STEP 4: Extract resourceTypeIds and masterTypeIds

// Maps to group fields by type ID
def resourceTypeMap = [:]  // resourceTypeId  to  list of field info
def masterTypeMap = [:]    // masterTypeId  to  list of field info

// Direct field-to-type mappings for payload builder
def fieldResourceMap = [:]  // fieldName  to  resourceTypeId
def fieldMasterMap = [:]    // fieldName  to  masterTypeId

allFields.each { field -&gt;
    def fieldName = field.dataMapping ?: field.formControlName
    def fieldLabel = field.fieldLabel ?: fieldName
    def fieldType = field.formControlType
    def isMultiple = field.isMultiple ?: false

    // Check for resourceTypeId (multiple property paths)
    def resourceTypeId = field.resourceTypeId ?:
                         field.resourceType?.id ?:
                         field.resourceType?.uniqueId ?:
                         (field.resourceType instanceof String ? field.resourceType : null)

    // Log resourceType details
    if (field.resourceType != null) {
        logRef.info(&quot;To  resourceType found: ${field.resourceType}&quot;)
        logRef.info(&quot;To  resourceType.class: ${field.resourceType?.getClass()?.getName()}&quot;)
        if (field.resourceType instanceof Map) {
            logRef.info(&quot;To  resourceType keys: ${field.resourceType.keySet()}&quot;)
        }
    }
    if (field.resourceTypeId != null) {
        logRef.info(&quot;To  resourceTypeId: ${field.resourceTypeId}&quot;)
    }

    // Store resourceTypeId if found
    if (resourceTypeId &amp;&amp; resourceTypeId instanceof String) {
        // Extract fetchType and map to API query param
        def fetchType = field.fetchType ?: &quot;&quot;
        def apiFetchType = &quot;&quot;

        switch(fetchType) {
            case &quot;fetchHierarchy&quot;:
                apiFetchType = &quot;HIERARCHY_LEVEL&quot;
                break
            case &quot;fetchHigherLevel&quot;:
                apiFetchType = &quot;HIGHER_LEVEL&quot;
                break
            case &quot;default&quot;:
                apiFetchType = &quot;SAME_LEVEL&quot;
                break
            default:
                apiFetchType = &quot;SAME_LEVEL&quot;
        }

        if (!resourceTypeMap.containsKey(resourceTypeId)) {
            resourceTypeMap[resourceTypeId] = []
        }
        resourceTypeMap[resourceTypeId].add([
            fieldName : fieldName,
            fieldLabel: fieldLabel,
            fieldType : fieldType,
            isMultiple: isMultiple,
            fetchType : apiFetchType
        ])
        fieldResourceMap[fieldName] = resourceTypeId
    }

    // Check for masterTypeId (multiple property paths)
    def masterTypeId = field.masterTypeId ?:
                       field.masterType?.id ?:
                       field.masterType?.uniqueId ?:
                       (field.masterType instanceof String ? field.masterType : null)

    // Log masterType details
    if (field.masterType != null) {
        logRef.info(&quot;To  masterType found: ${field.masterType}&quot;)
        logRef.info(&quot;To  masterType.class: ${field.masterType?.getClass()?.getName()}&quot;)
        if (field.masterType instanceof Map) {
            logRef.info(&quot;To  masterType keys: ${field.masterType.keySet()}&quot;)
        }
    }
    if (field.masterTypeId != null) {
        logRef.info(&quot;To  masterTypeId: ${field.masterTypeId}&quot;)
    }

    // Store masterTypeId if found
    if (masterTypeId &amp;&amp; masterTypeId instanceof String) {
        if (!masterTypeMap.containsKey(masterTypeId)) {
            masterTypeMap[masterTypeId] = []
        }
        masterTypeMap[masterTypeId].add([
            fieldName : fieldName,
            fieldLabel: fieldLabel,
            fieldType : fieldType,
            isMultiple: isMultiple
        ])
        fieldMasterMap[fieldName] = masterTypeId
        //  to  masterTypeId: ${masterTypeId}&quot;)
    }
}

// STEP 5: Store resourceTypeIds as Indexed Variables
def rtIndex = 0

resourceTypeMap.each { rtId, fields -&gt;
    rtIndex++
    varsRef.put(&quot;resourceTypeId_&quot; + rtIndex, rtId)

    // Store first field&apos;s label as resource type name
    def resourceTypeName = fields[0].fieldLabel ?: &quot;Resource&quot;
    varsRef.put(&quot;resourceTypeName_&quot; + rtIndex, resourceTypeName)

    // Store fetchType for this resourceType
    def fetchType = fields[0].fetchType ?: &quot;&quot;
    varsRef.put(&quot;resourceTypeFetchType_&quot; + rtIndex, fetchType)

    logRef.info(&quot;Stored resourceTypeId_${rtIndex}: ${rtId} (${resourceTypeName}) - fetchType: ${fetchType}&quot;)
}

varsRef.put(&quot;resourceTypeIds_count&quot;, rtIndex.toString())

// STEP 6: Store masterTypeIds as Indexed Variables
def mtIndex = 0

masterTypeMap.each { mtId, fields -&gt;
    mtIndex++
    varsRef.put(&quot;masterTypeId_&quot; + mtIndex, mtId)

    // Store first field&apos;s label as master type name for readable sampler naming
    def masterTypeName = fields[0].fieldLabel ?: &quot;Master&quot;
    varsRef.put(&quot;masterTypeName_&quot; + mtIndex, masterTypeName)

    logRef.info(&quot;Stored masterTypeId_${mtIndex}: ${mtId} (${masterTypeName})&quot;)
}

varsRef.put(&quot;masterTypeIds_count&quot;, mtIndex.toString())

// STEP 7: Store Field-to-Type Mappings for Payload Builder
varsRef.put(&quot;fieldResourceMap&quot;, groovy.json.JsonOutput.toJson(fieldResourceMap))
varsRef.put(&quot;fieldMasterMap&quot;, groovy.json.JsonOutput.toJson(fieldMasterMap))

// Log Summary
logRef.info(&quot;SUMMARY: ${rtIndex} resourceTypeId(s), ${mtIndex} masterTypeId(s)&quot;)

logRef.info(&quot;----- Terminated: Resource/Master Type Extractor -----&quot;)
}
props.put(&quot;fn_resourceMasterExtractor&quot;, _fn_resourceMasterExtractor)


// Stores the raw field mappings API response in currentFieldMappings for use by the payload builder to map attributeNames to their aliasNames.
def _fn_fieldMappingsPostProcessor = { varsRef, prevRef, logRef -&gt;

// Get Current Form Name
def formName = varsRef.get(&quot;currentFormName&quot;)

// Parse and Store JSON Response
def response = prevRef.getResponseDataAsString()
varsRef.put(&quot;currentFieldMappings&quot;, response)

// Extract Field Mappings Array
def json = new groovy.json.JsonSlurper().parseText(response)
def fieldMappings = json._embedded?.fieldMappings ?: []

fieldMappings.each { mapping -&gt;
    def attrName = mapping.columnAttribute?.attributeName   // e.g., textField30
    def aliasName = mapping.aliasName                       // e.g., oppStatus
    def displayText = mapping.displayText                   // e.g., Status
    def dataType = mapping.columnAttribute?.dataType        // e.g., VARCHAR2(2000 BYTE)
}
}
props.put(&quot;fn_fieldMappingsPostProcessor&quot;, _fn_fieldMappingsPostProcessor)

log.info(&quot;Common Function - Form Processing initialized&quot;)</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
        </JSR223Sampler>
        <hashTree/>
