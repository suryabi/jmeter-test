                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Tenant Lookup Values PostProcessor" enabled="true">
                  <stringProp name="script">

def response = prev.getResponseDataAsString()
if (!response || response.trim().isEmpty()) {
    log.warn(&quot;Tenant Lookup Values PostProcessor: empty or no response (HTTP ${prev.getResponseCode()}) — skipping JSON parse&quot;)
    vars.put(&quot;lookupValues&quot;, &quot;{}&quot;)
    log.info(&quot;----- Terminated: Tenant Lookup Values PostProcessor -----&quot;)
    return
}
try {
    def json = new groovy.json.JsonSlurper().parseText(response)
    def lookupValues = json._embedded?.lookupValues ?: []
    def lookupMap = props.get(&quot;fn_storeLookupValues&quot;)(vars, lookupValues, &quot;tenant&quot;, log)
    vars.put(&quot;lookupValues&quot;, vars.get(&quot;tenantLookupValues&quot;) ?: &quot;{}&quot;)
    log.info(&quot;Tenant lookups: HTTP ${prev.getResponseCode()} | rows=${lookupValues.size()} | types=${lookupMap?.size() ?: 0}&quot;)
} catch (Exception e) {
    log.warn(&quot;Tenant Lookup Values PostProcessor: failed to parse response — ${e.message}&quot;)
    vars.put(&quot;lookupValues&quot;, &quot;{}&quot;)
}
log.info(&quot;----- Terminated: Tenant Lookup Values PostProcessor -----&quot;)</stringProp>
