                                      <stringProp name="ConstantTimer.delay">300</stringProp>
                                    </ConstantTimer>
                                    <hashTree/>
                                  </hashTree>
                                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Build Activity Payload" enabled="true">
                                    <stringProp name="script">SampleResult.setIgnore()

vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)

if (vars.get(&quot;skipActivity&quot;) == &quot;true&quot;) {
    SampleResult.setResponseMessage(&quot;Skipped - no slot&quot;)
    return
}

def selectedDay  = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def dayIdx       = vars.get(&quot;currentDayIndex&quot;)  ?: &quot;1&quot;
def roomIdx      = vars.get(&quot;roomLoopCounter&quot;)  ?: &quot;1&quot;

def calcType  = vars.get(&quot;calcActivityType&quot;)
def loopType  = vars.get(&quot;loopActivityType&quot;)
def varType   = vars.get(&quot;activityType&quot;)
def activityType = (calcType ?: loopType ?: varType ?: &quot;unknown&quot;).trim()

def moduleId     = vars.get(&quot;currentActivityModuleId&quot;) ?: &quot;&quot;
def startTimeStr = vars.get(&quot;currentVacantSlotStartTime&quot;) ?: &quot;&quot;
def endTimeStr   = vars.get(&quot;currentVacantSlotEndTime&quot;)   ?: &quot;&quot;

def roomCount    = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0
def noRoomsMode  = (roomCount == 0)
def resourceId   = noRoomsMode ? null : (vars.get(&quot;currentRoomId&quot;) ?: &quot;&quot;)

// --- basic guards ---
if (!startTimeStr) {
    log.warn(&quot;[Build Payload] Missing startTime - skipping&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    SampleResult.setResponseMessage(&quot;SKIPPED - no startTime&quot;)
    return
}
if (!moduleId) {
    log.warn(&quot;[Build Payload] Missing moduleId - skipping&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    SampleResult.setResponseMessage(&quot;SKIPPED - no moduleId&quot;)
    return
}
if (!noRoomsMode &amp;&amp; !resourceId) {
    log.warn(&quot;[Build Payload] Rooms mode but resourceId empty - skipping&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    SampleResult.setResponseMessage(&quot;SKIPPED - no resourceId&quot;)
    return
}

// --- duration ---
def durationStr = vars.get(&quot;currentActivityDuration&quot;)?.trim()
if (!durationStr || !durationStr.isInteger() || durationStr.toInteger() &lt;= 0) {
    def opts = (vars.get(&quot;vacantSlotDurations&quot;) ?: &quot;&quot;).split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }
    durationStr = opts ? opts[new java.util.Random().nextInt(opts.size())] : &quot;30&quot;
    log.warn(&quot;[Build Payload] currentActivityDuration missing/invalid - picked ${durationStr} from vacantSlotDurations&quot;)
}
def activityDurationMins = durationStr.toInteger()

// --- dates ---
def activityDate = vars.get(&quot;activityDate_&quot; + selectedDay) ?: &quot;&quot;
def activityDateIso = activityDate.contains(&quot;T&quot;) ? activityDate : activityDate + &quot;T00:00:00&quot;

if (!endTimeStr &amp;&amp; startTimeStr) {
    try {
        def fmt = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)
        endTimeStr = java.time.LocalDateTime.parse(startTimeStr, fmt).plusMinutes(activityDurationMins).format(fmt)
    } catch (Exception e) {
        endTimeStr = startTimeStr
    }
}

// --- build payload using JsonOutput for proper formatting and null handling ---
def payloadMap = [
    &quot;startTime&quot;   : [&quot;isoDate&quot;: startTimeStr],
    &quot;endTime&quot;     : [&quot;isoDate&quot;: endTimeStr],
    &quot;activityDate&quot;: [&quot;isoDate&quot;: activityDateIso],
    &quot;duration&quot;    : activityDurationMins,
    &quot;resourceId&quot;  : noRoomsMode ? null : resourceId,
    &quot;activityType&quot;: activityType,
    &quot;source&quot;      : &quot;RC&quot;,
    &quot;moduleId&quot;    : moduleId
]

def payloadJson = groovy.json.JsonOutput.prettyPrint(groovy.json.JsonOutput.toJson(payloadMap))
vars.put(&quot;createActivityPayload&quot;, payloadJson)
log.info(&quot;[Build Payload] ${activityType} | room=${noRoomsMode ? &apos;null&apos; : resourceId} | ${startTimeStr}-${endTimeStr} | duration=${activityDurationMins}min | moduleId=${moduleId}&quot;)
SampleResult.setResponseMessage(&quot;Payload built: ${activityType}&quot;)</stringProp>
