def originalName = sampler.getName()

// Get current iteration and safety ceiling (set by State Action loop setup)
def currentIteration = vars.get(&quot;stateActionIteration&quot;) ?: &quot;1&quot;
def totalIterations   = vars.get(&quot;stateActionLoopCount&quot;) ?: &quot;5&quot;

//sampler.setName(&quot;${originalName} - (${currentIteration}/${totalIterations})&quot;)
sampler.setName(&quot;${originalName}&quot;)</stringProp>
