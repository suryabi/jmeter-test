// Populates Attendee form fields.
def _fn_attendeePreProcessor = { varsRef, logRef -&gt;
    // For multi-entry CREATE forms, always use fresh data from PreProcessors
    def isCreatePath = (varsRef.get(&quot;currentFormDataId&quot;) == null || varsRef.get(&quot;currentFormDataId&quot;) == &quot;&quot;)
    if (isCreatePath) {
        varsRef.put(&quot;existingFormData&quot;, &quot;{}&quot;)
    }

    def totalUsers = (varsRef.get(&quot;randomUserCount&quot;) ?: &quot;50&quot;).toInteger()

    // ============ userIndex for picking attendee name ============
    def userIndex = (varsRef.get(&quot;randomUserIndex&quot;) ?: &quot;1&quot;).toInteger()
    if (userIndex &gt; totalUsers) {
        userIndex = ((userIndex - 1) % totalUsers) + 1
    }

    def rand = java.util.concurrent.ThreadLocalRandom.current()

    // ============ Company ============
    varsRef.put(&quot;company&quot;, varsRef.get(&quot;customerName&quot;))

    // ============ Attendee Information ============
    def attendeeFirstName = varsRef.get(&quot;randomUser_${userIndex}_firstName&quot;) ?: &quot;John&quot;
    def attendeeLastName  = varsRef.get(&quot;randomUser_${userIndex}_lastName&quot;)  ?: &quot;Doe&quot;
    def rawGender         = varsRef.get(&quot;randomUser_${userIndex}_gender&quot;)    ?: &quot;male&quot;

    // ============ Map gender to proper salutation prefix ============
    def attendeePrefix
    switch (rawGender.toLowerCase().trim()) {
        case &quot;female&quot;:
            attendeePrefix = [&quot;Ms&quot;, &quot;Mrs&quot;][rand.nextInt(2)]
            break
        default:
            attendeePrefix = &quot;Mr&quot;
            break
    }

    // ============ Email - using shared function ============
    def emailDomain = props.get(&quot;fn_extractEmailDomain&quot;)(varsRef)
    varsRef.put(&quot;email&quot;, attendeeFirstName.toLowerCase() + &quot;.&quot; + attendeeLastName.toLowerCase() + &quot;@&quot; + emailDomain)

    // ============ Business Title ============
    varsRef.put(&quot;businessTitle&quot;, props.get(&quot;fn_getRandomBusinessTitle&quot;)())

    // ============ Gift Type ============
    String[] giftTypes = [
        &quot;Welcome Package&quot;, &quot;Gift Card&quot;, &quot;Welcome Kit&quot;, &quot;Leather Notebook&quot;, &quot;Chocolates&quot;, &quot;Sunglasses&quot;, &quot;Watch&quot;, &quot;Cookies&quot;, &quot;Headphones&quot;, &quot;Travel Adapter&quot;,
        &quot;Smart Pen&quot;, &quot;Event Tickets&quot;, &quot;Champagne&quot;, &quot;Signed Book&quot;, &quot;Fitness Tracker&quot;, &quot;Concert Tickets&quot;, &quot;AirPods&quot;, &quot;Webcam&quot;, &quot;Branded Polo Shirt&quot;
    ]
    varsRef.put(&quot;giftType&quot;, giftTypes[rand.nextInt(giftTypes.length)])

    // ============ Boolean Fields ============
    varsRef.put(&quot;isTechnical&quot;,   rand.nextBoolean().toString())
    varsRef.put(&quot;decisionMaker&quot;, rand.nextBoolean().toString())
    varsRef.put(&quot;influencer&quot;,    rand.nextBoolean().toString())
    varsRef.put(&quot;isRemote&quot;,      rand.nextBoolean().toString())
    varsRef.put(&quot;translator&quot;,    rand.nextBoolean().toString())

    // ============ NUMBER Fields (1-5 range) — using shared function ============
    def randomNumber1to5 = { -&gt; props.get(&quot;fn_randomNumber1to5&quot;)() }
    varsRef.put(&quot;attendeeNumberField1&quot;, String.valueOf(randomNumber1to5()))
    varsRef.put(&quot;attendeeNumberField2&quot;, String.valueOf(randomNumber1to5()))
    varsRef.put(&quot;attendeeNumberField3&quot;, String.valueOf(randomNumber1to5()))

    varsRef.put(&quot;firstName&quot;, attendeeFirstName)
    varsRef.put(&quot;lastName&quot;,  attendeeLastName)
    varsRef.put(&quot;prefix&quot;,    attendeePrefix)

    // ============ Increment randomUserIndex for next iteration ============
    def nextIndex = userIndex + 1
    varsRef.put(&quot;randomUserIndex&quot;, nextIndex.toString())

    logRef.info(&quot;========== Attendee PreProcessor ==========&quot;)
    logRef.info(&quot;userIndex:      &quot; + userIndex + &quot; / &quot; + totalUsers)
    logRef.info(&quot;nextUserIndex:  &quot; + nextIndex)
    logRef.info(&quot;===========================================&quot;)
}
props.put(&quot;fn_attendeePreProcessor&quot;, _fn_attendeePreProcessor)

// Reads the activity day regex match count and stores TotalActivityDays + ActivityDayCount=1 to drive the day-level ForEach loop.
def _fn_activityDayCounterExtractor = { varsRef, logRef -&gt;
    def totalDays = varsRef.get(&quot;activityid_matchNr&quot;)?.toInteger() ?: 0

    // Store Total Days for Day Loop
    varsRef.put(&quot;TotalActivityDays&quot;, totalDays.toString())
    varsRef.put(&quot;ActivityDayCount&quot;, &quot;1&quot;)

    // Log Extracted Days Summary
    if (totalDays == 0) {
        logRef.warn(&quot;[Activity Days Extractor] No activity days found&quot;)
    } else {
        def daysSummary = []
        for (int i = 1; i &lt;= totalDays; i++) {
            def dayDate  = varsRef.get(&quot;activityDate_&quot; + i) ?: &quot;N/A&quot;
            def dayStart = varsRef.get(&quot;activityStartTime_&quot; + i) ?: &quot;&quot;
            def dayEnd   = varsRef.get(&quot;activityEndTime_&quot; + i) ?: &quot;&quot;

            def dateStr  = dayDate?.take(10) ?: &quot;N/A&quot;
            def startStr = (dayStart?.length() &gt; 16) ? dayStart.substring(11, 16) : &quot;??&quot;
            def endStr   = (dayEnd?.length() &gt; 16) ? dayEnd.substring(11, 16) : &quot;??&quot;

            daysSummary.add(&quot;Day${i}:${dateStr}(${startStr}-${endStr})&quot;)
        }
        logRef.info(&quot;[Activity Days Extractor] Total: ${totalDays} | &quot; + daysSummary.join(&quot;, &quot;))
    }
}
props.put(&quot;fn_activityDayCounterExtractor&quot;, _fn_activityDayCounterExtractor)

// Splits a comma-separated raw action list string into a trimmed list of uppercase action tokens.
def _fn_parseActionList = { String raw -&gt;
    raw?.toUpperCase()?.split(&quot;,&quot;)?.collect { it.trim() }?.findAll { it } ?: []
}

// Reads allowed state actions from the API response _links and picks a random one that matches the configured targetActions list; sets skipRequestStateAction if none match.
def _fn_activityStateActionSelector = { varsRef, prevRef, logRef -&gt;

    def json = new groovy.json.JsonSlurper().parseText(prevRef.getResponseDataAsString())
    def links = json._links

    if (links == null) {
        logRef.error(&quot;No _links found in JSON response!&quot;)
        varsRef.put(&quot;skipActivityStateAction&quot;, &quot;true&quot;)
        return
    }

    def actionKeys = links.keySet()
    def includedActions = _fn_parseActionList(varsRef.get(&quot;targetActions&quot;))

    logRef.info(&quot;Available Actions: &quot; + actionKeys)
    logRef.info(&quot;Included State Actions (targetActions): &quot; + includedActions)

    def allowedActions = actionKeys.findAll { key -&gt;
        includedActions.isEmpty() || includedActions.contains(key.toUpperCase().trim())
    }

    if (!allowedActions.isEmpty()) {
        def random = java.util.concurrent.ThreadLocalRandom.current()
        def selectedAction = allowedActions[random.nextInt(allowedActions.size())]
        def selectedHref = links[selectedAction]?.href

        if (selectedHref) {
            varsRef.put(&quot;selectedAction&quot;, selectedAction)
            varsRef.put(&quot;selectedHref&quot;, selectedHref)
            varsRef.put(&quot;skipActivityStateAction&quot;, &quot;false&quot;)
            logRef.info(&quot;Selected Action: &quot; + selectedAction)
            logRef.info(&quot;Selected Href: &quot; + selectedHref)
        } else {
            logRef.warn(&quot;Selected action has no href value!&quot;)
            varsRef.put(&quot;skipActivityStateAction&quot;, &quot;true&quot;)
        }
    } else {
        logRef.info(&quot;All actions excluded for ${varsRef.get(&apos;activityType&apos;)} - skipping state action execution&quot;)
        varsRef.put(&quot;skipActivityStateAction&quot;, &quot;true&quot;)
        varsRef.put(&quot;selectedAction&quot;, &quot;&quot;)
    }

    logRef.info(&quot;----- Terminated: Activity State Action Selector -----&quot;)
}
props.put(&quot;fn_parseActionList&quot;, _fn_parseActionList)
props.put(&quot;fn_activityStateActionSelector&quot;, _fn_activityStateActionSelector)

// Builds the complete form submission payload by iterating all form fields, resolving values via alias/lookup/auto-generation, respecting dependent field conditions, and storing the result in dynamicFormPayload.
def _fn_dynamicPayloadBuilder = { varsRef, logRef -&gt;

// Dynamic payload entry

def formName = varsRef.get(&quot;currentFormName&quot;)

def rand = java.util.concurrent.ThreadLocalRandom.current()

// Multi-select configuration from User Defined Variables
def minSelection = props.get(&quot;fn_parseMultiDropDownRange&quot;)(varsRef, null).min
def maxSelection = props.get(&quot;fn_parseMultiDropDownRange&quot;)(varsRef, null).max

def currentEntryIndex = (varsRef.get(&quot;currentEntryIndex&quot;) ?: &quot;1&quot;).toInteger()

// Helper function to generate random selection count
def getRandomSelectionCount = { int availableCount -&gt;
    def maxPossible = Math.min(availableCount, maxSelection)
    def minPossible = Math.min(minSelection, maxPossible)
    return minPossible + rand.nextInt((maxPossible - minPossible) + 1)
}

// Load shared function: generateRandomNumber
def generateRandomNumber = { int min, int max -&gt; props.get(&quot;fn_generateRandomNumber&quot;)(min, max) }

// Load shared function: generateFutureDate
def generateFutureDate = { props.get(&quot;fn_generateFutureDate&quot;)(vars) }

// Load shared function: generateFutureTime
def generateFutureTime = { int hoursOffset -&gt; props.get(&quot;fn_generateFutureTime&quot;)(vars, hoursOffset) }
// Reset future time day offset for this form
props.get(&quot;fn_resetFutureTimeDayOffset&quot;)(vars)

// Get indexed value from comma-separated string for multi-entry forms
def getIndexedValue = { String csv -&gt; props.get(&quot;fn_getIndexedValue&quot;)(csv, currentEntryIndex) }

// STEP 1: Get formUIConfig
def formUIConfigStr = varsRef.get(&quot;currentFormUIConfig&quot;)

if (!formUIConfigStr) {
    logRef.warn(&quot;formUIConfig not found - skipping&quot;)
    varsRef.put(&quot;dynamicFormPayload&quot;, &quot;{}&quot;)
    return
}
// STEP 2: Get and Parse fieldMappings
def fieldMappingsStr = varsRef.get(&quot;currentFieldMappings&quot;)
def fieldMappingsMap = props.get(&quot;fn_parseFieldMappings&quot;)(fieldMappingsStr)

// STEP 3: Parse formUIConfig and Extract All Fields
def allFields = props.get(&quot;fn_extractAllFields&quot;)(formUIConfigStr)

// STEP 4: Initialize Form Data and Default Values
def formData = [:]

// Default text values for auto-generation
def defaultTexts = props.get(&quot;fn_defaultTextFields&quot;)

// Default textarea values for auto-generation
def textareaValues = props.get(&quot;fn_defaultTextAreas&quot;)

// STEP 4.5: Build Dependent Controls Map
def _depResult = props.get(&quot;fn_buildDependentControlsMap&quot;)(allFields)
def dependentControlsMap = _depResult.map
def dependentFieldsSet = _depResult.fieldSet
def lookupParentFieldMap = props.get(&quot;fn_buildLookupParentFieldMap&quot;)(allFields)

// FIX: reverse map (parent field → its dependent child fields) plus each field&apos;s own lookupName/context,
// used below to detect and avoid dead-end branches — e.g. picking a Sub-Topic row that has zero Micro
// Topic rows under it — before they get picked, not after the deeper field has already failed.
def lookupChildFieldsMap = [:]
lookupParentFieldMap.each { childFN, parentFN -&gt;
    if (!lookupChildFieldsMap.containsKey(parentFN)) lookupChildFieldsMap[parentFN] = []
    lookupChildFieldsMap[parentFN] &lt;&lt; childFN
}
def fieldLookupInfo = [:]
allFields.each { f -&gt;
    def fn = f.dataMapping ?: f.formControlName
    if (fn &amp;&amp; f.lookupName) {
        fieldLookupInfo[fn] = [lookupName: f.lookupName, lookupContext: props.get(&quot;fn_resolveFieldLookupContext&quot;)(f, logRef)]
    }
}

// FIX: Two-pass ordering — process parent/standalone fields first, dependent fields second.
// This ensures the parent field value is already in formData when shouldShowDependentField
// is called for dependent children, preventing false-positive inclusion when textField20=&quot;No&quot;.
def nonDependentFields = allFields.findAll { f -&gt; !dependentFieldsSet.contains(f.dataMapping ?: f.formControlName) }
def dependentFields    = allFields.findAll { f -&gt;  dependentFieldsSet.contains(f.dataMapping ?: f.formControlName) }
def orderedFields = nonDependentFields + dependentFields
logRef.info(&quot;PayloadBuilder: field order — ${nonDependentFields.size()} parent/standalone + ${dependentFields.size()} dependent&quot;)

// Helper: Check if dependent field should be shown
def shouldShowDependentField = { String depFieldName, Map formDataSoFar -&gt;
    props.get(&quot;fn_shouldShowDependentField&quot;)(depFieldName, formDataSoFar, dependentControlsMap, varsRef)
}

// Get existing form data (stored from Get Form API)
// FIX: Use props snapshot (existingFormData_snapshot) to protect against PreProcessors clearing existingFormData
def existingFormDataStr = props.get(&quot;existingFormData_snapshot_&quot; + (varsRef.get(&quot;requestId&quot;) ?: &quot;unknown&quot;) + &quot;_&quot; + (varsRef.get(&quot;currentFormId&quot;) ?: varsRef.get(&quot;formId&quot;) ?: &quot;unknown&quot;))
if (!existingFormDataStr) {
    existingFormDataStr = varsRef.get(&quot;existingFormData&quot;)
}
def existingFormData = existingFormDataStr ? new groovy.json.JsonSlurper().parseText(existingFormDataStr) : [:]

// FIX: For subsequent users, load processedFields to know what previous users already filled.
// Only fields NOT in processedFields should be generated. Fields already filled by a prior user
// in this same run must be preserved from existingFormData (not re-generated).
def isFirstUser = varsRef.get(&quot;isFirstUser&quot;) ?: &quot;true&quot;
def requestId = varsRef.get(&quot;requestId&quot;) ?: &quot;unknown&quot;
def moduleName = varsRef.get(&quot;currentModuleName&quot;) ?: varsRef.get(&quot;currentActivityModuleName&quot;) ?: varsRef.get(&quot;newRequestModuleName&quot;) ?: &quot;unknown&quot;
def formNameForTracking = varsRef.get(&quot;currentFormName&quot;) ?: varsRef.get(&quot;requestFormName&quot;) ?: &quot;unknown&quot;
def trackKey = &quot;processedFields_&quot; + requestId + &quot;_&quot; + moduleName + &quot;_&quot; + formNameForTracking
def previouslyProcessed = props.get(trackKey) ?: (new HashSet())
logRef.info(&quot;PayloadBuilder: isFirstUser=${isFirstUser}, processedFields=${previouslyProcessed.size()} for ${trackKey}&quot;)
logRef.info(&quot;PayloadBuilder: existingFormData fields=${existingFormData.size()}&quot;)

// FIX: cache for the leaf-first chain build (see masterTypeId branch in case &quot;SELECT&quot; below).
// Built once per masterTypeId on first encounter, then reused by every field (Parent Topic,
// Topic, Sub-Topic, Micro Topic, etc.) that shares that masterTypeId, so they all agree on the
// exact same real root-to-leaf branch instead of each independently guessing.
def _masterChainCacheByType = [:]
def _resourceChainCacheByType = [:]

// STEP 5: Process Each Field (ordered: parents first, dependent children second)
orderedFields.each { field -&gt;

    // Extract field properties
    def fieldName = field.dataMapping ?: field.formControlName
    def fieldType = field.formControlType
    def fieldLabel = field.fieldLabel ?: fieldName
    def isMultiple = field.isMultiple ?: false
    def lookupName = field.lookupName
    def lookupContext = props.get(&quot;fn_resolveFieldLookupContext&quot;)(field, logRef)
    def lookupMode = props.get(&quot;fn_resolveFieldLookupMode&quot;)(field)
    def isHidden = field.hide ?: false
    def isDisabled = field.disabled ?: false

    // FIX: For subsequent users — if this field was already filled by a previous user
    // in this same run, preserve the existing API value and do NOT re-generate.
    if (isFirstUser != &quot;true&quot; &amp;&amp; previouslyProcessed.contains(fieldName)) {
        def existingValue = existingFormData[fieldName]
        // FIX: Treat numeric 0 and boolean false as empty — fall through to regenerate
        def fieldTypeEarly = field.formControlType
        def isEmptyNumericEarly = (fieldTypeEarly in [&quot;NUMBER&quot;, &quot;CURRENCY&quot;, &quot;DECIMAL&quot;]) &amp;&amp; (existingValue == 0 || existingValue == 0.0 || existingValue == &quot;0&quot;)
        def isEmptyBooleanEarly = (fieldTypeEarly == &quot;CHECKBOX&quot;) &amp;&amp; (existingValue == false || existingValue == &quot;false&quot;)
        if (existingValue != null &amp;&amp; !isEmptyNumericEarly &amp;&amp; !isEmptyBooleanEarly) {
            // FIX: Date fields — API returns expanded timezone object (utcMs, zoneId, zoneDate, etc.)
            // but the form submission only accepts {&quot;isoDate&quot;: &quot;yyyy-MM-ddTHH:mm:ss&quot;}.
            // Normalize back to isoDate format when preserving date/time fields.
            if (fieldType in [&quot;CLOUD_DATE&quot;, &quot;CLOUD_TIME&quot;] &amp;&amp; existingValue instanceof Map) {
                def isoDate = null
                // Try to extract a clean ISO date string from the expanded API response
                if (existingValue.containsKey(&quot;isoDate&quot;)) {
                    // Already in correct format — just use it
                    isoDate = existingValue.isoDate
                } else if (existingValue.containsKey(&quot;zoneDate&quot;)) {
                    // Use zoneDate — strip timezone offset suffix
                    isoDate = existingValue.zoneDate?.replaceAll(/\+.*$/, &quot;&quot;)?.replaceAll(/Z$/, &quot;&quot;)
                } else if (existingValue.containsKey(&quot;client&quot;) &amp;&amp; existingValue.client?.clientZoneDate) {
                    isoDate = existingValue.client.clientZoneDate
                } else if (existingValue.containsKey(&quot;utcMs&quot;)) {
                    def epoch = existingValue.utcMs as long
                    isoDate = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;).format(new Date(epoch))
                }
                if (isoDate) {
                    // Normalize: strip milliseconds, Z suffix, timezone offset — keep yyyy-MM-ddTHH:mm:ss
                    isoDate = isoDate.replaceAll(/\.\d+Z?$/, &quot;&quot;).replaceAll(/\+\d{2}:\d{2}$/, &quot;&quot;).replaceAll(/Z$/, &quot;&quot;)
                    // For CLOUD_DATE fields: preserve only the date part (T00:00:00)
                    if (fieldType == &quot;CLOUD_DATE&quot; &amp;&amp; isoDate.contains(&quot;T&quot;)) {
                        isoDate = isoDate.substring(0, isoDate.indexOf(&quot;T&quot;)) + &quot;T00:00:00&quot;
                    }
                    formData[fieldName] = [&quot;isoDate&quot;: isoDate]
                    logRef.info(&quot;  PRESERVE field &apos;${fieldName}&apos; (date normalized to isoDate: ${isoDate})&quot;)
                } else {
                    formData[fieldName] = existingValue
                    logRef.warn(&quot;  PRESERVE field &apos;${fieldName}&apos; (date - could not normalize, using raw API value)&quot;)
                }
            } else {
                formData[fieldName] = existingValue
                logRef.info(&quot;  PRESERVE field &apos;${fieldName}&apos; - filled by previous user in this run&quot;)
            }
        } else {
            // existingValue is null OR is an empty numeric/boolean — fall through to regenerate
            logRef.info(&quot;  GENERATE field &apos;${fieldName}&apos; - in processedFields but value is null or empty (0/false), generating fresh value&quot;)
        }
        // Fall through to generate when: existingValue is null, or is 0/false (treated as unfilled)
        if (existingValue != null &amp;&amp; !isEmptyNumericEarly &amp;&amp; !isEmptyBooleanEarly) return
    }

    // For first user OR fields not yet processed: check existing API data (UPDATE path)
    def existingValue = existingFormData[fieldName]
    def isNumericField = fieldType in [&quot;NUMBER&quot;, &quot;CURRENCY&quot;, &quot;DECIMAL&quot;]
    def isBooleanField = fieldType == &quot;CHECKBOX&quot;
    def isEmptyNumeric = isNumericField &amp;&amp; (existingValue == 0 || existingValue == 0.0 || existingValue == &quot;0&quot;)
    def isEmptyBoolean = isBooleanField &amp;&amp; (existingValue == false || existingValue == &quot;false&quot;)
    // FIX: Treat empty complex objects {} as unfilled so resource/master fields get regenerated
    def isEmptyObject = (existingValue instanceof Map &amp;&amp; existingValue.isEmpty())

    // FIX: If this field&apos;s alias variable is comma-separated (indexed per-entry),
    // skip existingFormData so the correct indexed value is picked per entry via alias.
    // e.g. aliasName=&quot;opportunity&quot;, vars.opportunity=&quot;6183,7421&quot; -&gt; entry1=&quot;6183&quot;, entry2=&quot;7421&quot;
    def _earlyMappingInfo = fieldMappingsMap[fieldName]
    def _earlyAliasName = _earlyMappingInfo?.aliasName
    def _earlyAliasValue = _earlyAliasName ? varsRef.get(_earlyAliasName) : null
    boolean skipExistingForIndexedAlias = (_earlyAliasValue instanceof String &amp;&amp; _earlyAliasValue.contains(&quot;,&quot;) &amp;&amp; fieldType != &quot;TEXTAREA&quot;)
    // Any SELECT with lookupName is a lookup field (API often omits enumType=LOOKUP on formUIConfig)
    def isLookupSelect = lookupName != null &amp;&amp; lookupName.toString().trim() != &quot;&quot;

    if (!skipExistingForIndexedAlias &amp;&amp; !isLookupSelect &amp;&amp; isFirstUser == &quot;true&quot; &amp;&amp; existingValue != null &amp;&amp; existingValue.toString().trim() != &quot;&quot; &amp;&amp; !isEmptyNumeric &amp;&amp; !isEmptyBoolean &amp;&amp; !isEmptyObject) {
        // FIX: Also normalize date fields for first user on UPDATE path (re-fill scenario)
        if (fieldType in [&quot;CLOUD_DATE&quot;, &quot;CLOUD_TIME&quot;] &amp;&amp; existingValue instanceof Map) {
            def isoDate = null
            if (existingValue.containsKey(&quot;isoDate&quot;)) {
                isoDate = existingValue.isoDate
            } else if (existingValue.containsKey(&quot;zoneDate&quot;)) {
                isoDate = existingValue.zoneDate?.replaceAll(/\+.*$/, &quot;&quot;)?.replaceAll(/Z$/, &quot;&quot;)
            } else if (existingValue.containsKey(&quot;client&quot;) &amp;&amp; existingValue.client?.clientZoneDate) {
                isoDate = existingValue.client.clientZoneDate
            } else if (existingValue.containsKey(&quot;utcMs&quot;)) {
                def epoch = existingValue.utcMs as long
                isoDate = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;).format(new Date(epoch))
            }
            if (isoDate) {
                isoDate = isoDate.replaceAll(/\.\d+Z?$/, &quot;&quot;).replaceAll(/\+\d{2}:\d{2}$/, &quot;&quot;).replaceAll(/Z$/, &quot;&quot;)
                if (fieldType == &quot;CLOUD_DATE&quot; &amp;&amp; isoDate.contains(&quot;T&quot;)) {
                    isoDate = isoDate.substring(0, isoDate.indexOf(&quot;T&quot;)) + &quot;T00:00:00&quot;
                }
                formData[fieldName] = [&quot;isoDate&quot;: isoDate]
            } else {
                formData[fieldName] = existingValue
            }
        } else {
            formData[fieldName] = existingValue
        }
        return
    }

    // Extract Resource/Master Type IDs
    def resourceTypeId = field.resourceTypeId ?: field.resourceType?.id ?:
                         field.resourceType?.uniqueId ?:
                         (field.resourceType instanceof String ? field.resourceType : null)
    def masterTypeId = field.masterTypeId ?: field.masterType?.id ?:
                       field.masterType?.uniqueId ?:
                       (field.masterType instanceof String ? field.masterType : null)

    // Get aliasName from fieldMappings
    def mappingInfo = fieldMappingsMap[fieldName]
    def aliasName = mappingInfo?.aliasName
    // Skip Hidden Fields
    if (isHidden) {
        return
    }

    // Skip fields based on hiddenRoles (check against selected role only)
    def userRole = varsRef.get(&quot;roleId&quot;) ?: &quot;&quot;
    def hiddenRoles = field.hiddenRoles ?: []
    if (hiddenRoles) {
        if (hiddenRoles.contains(userRole)) {
            logRef.info(&quot;Skipping field &apos;${fieldName}&apos; - user role &apos;${userRole}&apos; is in hiddenRoles: ${hiddenRoles}&quot;)
            return
        }
    }

     // Skip fields based on readOnlyRoles (check against selected role only)
    def readOnlyRoles = field.readOnlyRoles ?: []
    if (readOnlyRoles) {

        if (readOnlyRoles.contains(userRole)) {
            logRef.info(&quot;Skipping field &apos;${fieldName}&apos; - user role &apos;${userRole}&apos; is in readOnlyRoles: ${readOnlyRoles}&quot;)
            return
        }
    }

    if (isDisabled) {
        return
    }
    // Check Dependent Field Visibility
    if (dependentFieldsSet.contains(fieldName)) {
        if (!shouldShowDependentField(fieldName, formData)) {
            return
        }
    }

    def value = null
    def skipField = false
    // PRIORITY 1: Get Value from JMeter Variable (via alias)
    // Lookup SELECT: always pick from tenant/category store (alias/unprefixed tenant vars must not override)
    def skipAliasForLookup = (fieldType == &quot;SELECT&quot; &amp;&amp; lookupName)
    def skipAliasForMultiSelect = (fieldType == &quot;SELECT&quot; &amp;&amp; isMultiple &amp;&amp; lookupName)

    if (aliasName &amp;&amp; !skipAliasForMultiSelect &amp;&amp; !skipAliasForLookup) {
        value = varsRef.get(aliasName)

        if (value != null &amp;&amp; value != &quot;&quot;) {
            // Smart handling based on isMultiple from form config
            // SKIP comma-splitting for TEXTAREA fields - they can legitimately contain commas
            if (fieldType != &quot;TEXTAREA&quot; &amp;&amp; value instanceof String &amp;&amp; value.contains(&quot;,&quot;)) {
                if (isMultiple) {
                    // isMultiple = true  to  Convert to array
                    value = value.split(&quot;,&quot;).collect { it.trim() }.toList()
                } else {
    				// isMultiple = false → Get indexed value
                	value = getIndexedValue(value)
                }
            } else {
                // Single value
                if (isMultiple) {
                    value = [value]
                }
            }
        }
    }
    // LOOKUP via alias: reject values not in the correct context store (e.g. tenant region_* vs category_region_*)
    if (value != null &amp;&amp; value != &quot;&quot; &amp;&amp; isLookupSelect) {
        if (!props.get(&quot;fn_valueInLookupStore&quot;)(varsRef, lookupName, lookupContext, value)) {
            logRef.warn(&quot;Alias &apos;${aliasName}&apos; value &apos;${value}&apos; not in ${lookupContext} store for ${lookupName} — re-picking from lookup API&quot;)
            value = null
        }
    }
    // PRIORITY 2: Auto-generate if No Alias or No Value
    if (isNumericField &amp;&amp; (value == &quot;0&quot; || value == 0 || value == 0.0)) value = null
    if (value == null || value == &quot;&quot;) {
        switch(fieldType) {

            // TEXT Field
            case &quot;TEXT&quot;:
                def nameAliases = (varsRef.get(&quot;meetingNameAliases&quot;) ?: &quot;NAME,TITLE,SUBJECT&quot;).toUpperCase().split(&quot;,&quot;).collect{it.trim()}
                def descAliases = (varsRef.get(&quot;meetingDescAliases&quot;) ?: &quot;DESCRIPTION,DESC&quot;).toUpperCase().split(&quot;,&quot;).collect{it.trim()}
                def aliasUpper = aliasName?.toUpperCase() ?: &quot;&quot;
                def isNameField = nameAliases.any { aliasUpper.contains(it) }
                def isDescField = descAliases.any { aliasUpper.contains(it) }
                if (isNameField) {
                    value = varsRef.get(&quot;meetingName&quot;) ?: defaultTexts[rand.nextInt(defaultTexts.length)]
                } else if (isDescField) {
                    value = varsRef.get(&quot;meetingDescription&quot;) ?: defaultTexts[rand.nextInt(defaultTexts.length)]
                } else if (isMultiple) {
                    def count = getRandomSelectionCount(defaultTexts.length)
                    def values = []
                    for (int j = 0; j &lt; count; j++) {
                        values.add(defaultTexts[rand.nextInt(defaultTexts.length)])
                    }
                    value = values
                } else {
                    value = defaultTexts[rand.nextInt(defaultTexts.length)]
                }
                break

            // TEXTAREA Field
            case &quot;TEXTAREA&quot;:
                def descAliasesTA = (varsRef.get(&quot;meetingDescAliases&quot;) ?: &quot;DESCRIPTION,DESC&quot;).toUpperCase().split(&quot;,&quot;).collect{it.trim()}
                def agendaAliases = (varsRef.get(&quot;meetingAgendaAliases&quot;) ?: &quot;AGENDA&quot;).toUpperCase().split(&quot;,&quot;).collect{it.trim()}
                def aliasUpperTA = aliasName?.toUpperCase() ?: &quot;&quot;
                def isDescFieldTA = descAliasesTA.any { aliasUpperTA.contains(it) }
                def isAgendaField = agendaAliases.any { aliasUpperTA.contains(it) }
                if (isDescFieldTA) {
                    value = varsRef.get(&quot;meetingDescription&quot;) ?: textareaValues[rand.nextInt(textareaValues.length)]
                } else if (isAgendaField) {
                    value = varsRef.get(&quot;meetingAgenda&quot;) ?: textareaValues[rand.nextInt(textareaValues.length)]
                } else {
                    value = textareaValues[rand.nextInt(textareaValues.length)]
                }
                break

            // NUMBER Field
            case &quot;NUMBER&quot;:
                value = props.get(&quot;fn_randomNumber1to5&quot;)()
                break

            // CURRENCY Field
            case &quot;CURRENCY&quot;:
                value = props.get(&quot;fn_randomNumber1to5&quot;)()
                break

            // CLOUD_DATE Field
            case &quot;CLOUD_DATE&quot;:
                value = generateFutureDate()
                break

            // CLOUD_TIME Field
            case &quot;CLOUD_TIME&quot;:
                def slotStartTime = varsRef.get(&quot;currentVacantSlotStartTime&quot;) ?: &quot;&quot;
                def slotEndTime = varsRef.get(&quot;currentVacantSlotEndTime&quot;) ?: &quot;&quot;
                def durationMinsStr = varsRef.get(&quot;currentActivityDuration&quot;)
                if (!durationMinsStr || !durationMinsStr.isInteger() || durationMinsStr.toInteger() &lt;= 0) {
                    def vacantRaw = varsRef.get(&quot;vacantSlotDurations&quot;)?.trim()
                    if (vacantRaw) {
                        def validDurs = vacantRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }
                        durationMinsStr = validDurs ? validDurs[0] : &quot;0&quot;
                    } else {
                        durationMinsStr = &quot;0&quot;
                    }
                }
                def durationMins = durationMinsStr.toInteger()
                def fieldLower = fieldName?.toLowerCase() ?: &quot;&quot;
                def aliasLower = aliasName?.toLowerCase() ?: &quot;&quot;
                def isStartField = fieldLower.contains(&quot;start&quot;) || aliasLower.contains(&quot;start&quot;)
                def isEndField = fieldLower.contains(&quot;end&quot;) || aliasLower.contains(&quot;end&quot;)
                if (isStartField &amp;&amp; slotStartTime) {
                    value = slotStartTime
                } else if (isEndField &amp;&amp; slotStartTime) {
                    try {
                        def formatter = java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)
                        def startDT = java.time.LocalDateTime.parse(slotStartTime, formatter)
                        def endDT = startDT.plusMinutes(durationMins)
                        value = endDT.format(formatter)
                    } catch (Exception e) {
                        logRef.warn(&quot;CLOUD_TIME: Could not calculate endTime: ${e.message}&quot;)
                        value = slotEndTime ?: generateFutureTime(18)
                    }
                } else if (slotStartTime) {
                    value = slotStartTime
                } else if (fieldLower.contains(&quot;start&quot;)) {
                    value = generateFutureTime(9)
                } else if (fieldLower.contains(&quot;end&quot;)) {
                    value = generateFutureTime(18)
                } else {
                    value = generateFutureTime(rand.nextInt(9) + 8)
                }
                break

            // SELECT Field
            case &quot;SELECT&quot;:
                // Check for TIMEZONE enumType
                if ((field.enumType ?: &quot;&quot;) == &quot;TIMEZONE&quot;) {
                    value = varsRef.get(&quot;requestTimeZone&quot;) ?: &quot;&quot;
                } else if ((field.enumType ?: &quot;&quot;) == &quot;RESOURCE&quot; &amp;&amp; resourceTypeId) {
                    // FIX: SELECT fields with enumType=RESOURCE (e.g. Briefing Manager, Technical Manager)
                    // These use resourceTypeId, not lookupName — must be looked up from resourcesFor_ variables.
                    // Value shape (bare id vs {uniqueId: id}) is controlled by form template isComplexObject.
                    // isNestedEnum: one control with internal cascading levels — pick deepest leaf from hierarchy.
                    def isNestedEnumResource = props.get(&quot;fn_resolveIsNestedEnum&quot;)(field)
                    def usedResourceChain = false
                    if (isNestedEnumResource) {
                        def chainKeyR = &quot;resource:&quot; + resourceTypeId
                        def chainR = _resourceChainCacheByType[chainKeyR]
                        if (chainR == null) {
                            chainR = props.get(&quot;fn_buildLeafFirstReferenceChain&quot;)(varsRef, &quot;resourcesFor_&quot; + resourceTypeId, 1, rand, logRef, &quot;SELECT[RESOURCE]&quot;)
                            _resourceChainCacheByType[chainKeyR] = chainR ?: []
                        }
                        if (chainR) {
                            def resourceId = chainR[chainR.size() - 1]
                            value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, resourceId)
                            if (fieldName &amp;&amp; resourceId) varsRef.put(fieldName + &quot;__rowId&quot;, resourceId)
                            usedResourceChain = true
                            logRef.info(&quot;SELECT[RESOURCE] nested enum: using chain leaf id=${resourceId} (chain depth=${chainR.size()}, isNestedEnum=true)&quot;)
                        }
                    }
                    if (!usedResourceChain) {
                    def rtCountStr = varsRef.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_count&quot;)
                    if (rtCountStr &amp;&amp; rtCountStr.isInteger() &amp;&amp; rtCountStr.toInteger() &gt; 0) {
                        def rtCount = rtCountStr.toInteger()
                        if (isMultiple) {
                            def selectCount = getRandomSelectionCount(rtCount)
                            def selectedValues = []
                            def indices = (1..rtCount).toList()
                            Collections.shuffle(indices)
                            indices.take(selectCount).each { idx -&gt;
                                def resourceId = varsRef.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                def formatted = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, resourceId)
                                if (formatted != null) selectedValues.add(formatted)
                            }
                            if (selectedValues) { value = selectedValues }
                        } else {
                            def randomIndex = rand.nextInt(rtCount) + 1
                            def resourceId = varsRef.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                            value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, resourceId)
                        }
                        if (!value) {
                            logRef.warn(&quot;SELECT[RESOURCE] field &apos;${fieldName}&apos; - no resource value found for typeId: ${resourceTypeId} - SKIPPING&quot;)
                            skipField = true
                        }
                    } else {
                        logRef.warn(&quot;SELECT[RESOURCE] field &apos;${fieldName}&apos; - no resources fetched for typeId: ${resourceTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                    }
                } else if (lookupName &amp;&amp; !masterTypeId) {
                    // FIX: Topic / Sub-Topic / Micro Topic are master-driven fields (masterTypeId),
                    // never lookup-driven. If the API metadata for one of these ever also carries a
                    // (stray/legacy) lookupName, masterTypeId must still win — the lookup pathway&apos;s
                    // dead-end protection is disabled for shared-dataset hierarchies (see
                    // fn_computeValidLookupIdsForField&apos;s hasSharedDataset check above, which returns
                    // null — &quot;no restriction&quot; — whenever Topic/Sub-Topic/Micro Topic share one lookup
                    // dataset), so routing a master field through it would silently re-introduce the
                    // dead-end/duplicate-uniqueId bug already fixed in the masterTypeId branch below.
                    // Requiring &quot;!masterTypeId&quot; here guarantees any field carrying a masterTypeId
                    // always falls through to the masterTypeId branch, regardless of lookupName.
                    def pickOptions = null
                    if (lookupMode) {
                        pickOptions = [lookupMode: lookupMode]
                        if (lookupMode == &quot;child&quot;) {
                            def parentFN = lookupParentFieldMap[fieldName]
                            if (parentFN) {
                                pickOptions.parentFieldValues = formData[parentFN]
                                // FIX: resolves a parent field&apos;s row ID, preferring the rowId stored
                                // when it was freshly picked this run; falling back to matching against
                                // the PARENT field&apos;s OWN lookup dataset (not the child&apos;s) when that
                                // wasn&apos;t set — e.g. because the parent value came from existing/saved
                                // form data instead of being freshly picked.
                                def resolveRowId = { fn, val -&gt;
                                    def stored = varsRef.get(fn + &quot;__rowId&quot;)
                                    if (stored) return stored
                                    if (!val) return null
                                    def info = fieldLookupInfo[fn]
                                    if (!info?.lookupName) return null
                                    def ownRows = props.get(&quot;fn_getLookupRows&quot;)(varsRef, info.lookupName, info.lookupContext)
                                    def ids = props.get(&quot;fn_lookupParentIdsForValues&quot;)(ownRows, val)
                                    return ids ? (ids.size() == 1 ? ids.iterator().next() : ids.toList()) : null
                                }
                                // FIX: collect the row ID for the inferred immediate parent AND every
                                // ancestor above it (walking lookupParentFieldMap up the chain), then
                                // accept a candidate whose parentId matches ANY of them — not just the
                                // immediate one. The order-of-fields inference used to build
                                // lookupParentFieldMap can occasionally skip a level (e.g. linking
                                // Sub-Topic directly to Parent Topic instead of Topic, when an
                                // intermediate field&apos;s lookupMode doesn&apos;t classify cleanly as
                                // parent/child). Widening the accepted ID set to the whole ancestor
                                // chain can only ADD valid matches, never exclude the correct one —
                                // so a perfectly valid option (e.g. a Sub-Topic that genuinely belongs
                                // under the selected Topic) is no longer wrongly zeroed out just
                                // because the wrong ancestor level was inferred as &quot;the&quot; parent.
                                def ancestorIds = [] as Set
                                def visited = [] as Set
                                def walkFN = fieldName
                                def walkVal = pickOptions.parentFieldValues
                                while (true) {
                                    def thisParentFN = lookupParentFieldMap[walkFN]
                                    if (!thisParentFN || visited.contains(thisParentFN)) break
                                    visited.add(thisParentFN)
                                    def rid = resolveRowId(thisParentFN, walkFN == fieldName ? walkVal : formData[thisParentFN])
                                    if (rid) {
                                        if (rid instanceof List) ancestorIds.addAll(rid.collect { it.toString() })
                                        else if (rid.toString().contains(&quot;,&quot;)) ancestorIds.addAll(rid.toString().split(&quot;,&quot;).collect { it.trim() })
                                        else ancestorIds.add(rid.toString())
                                    }
                                    walkFN = thisParentFN
                                }
                                if (ancestorIds) {
                                    pickOptions.parentRowId = ancestorIds.toList()
                                }
                            }
                        }
                    }
                    // FIX: if this field has further dependent fields below it in the hierarchy (e.g. Topic
                    // has Sub-Topic, Sub-Topic has Micro Topic), restrict candidates to rows that have a
                    // valid path all the way down — otherwise a correctly-linked but dead-end branch (a
                    // Sub-Topic row with zero Micro Topic rows under it) gets picked, and the deeper
                    // required field is left empty regardless of how many times the run is repeated.
                    if (lookupChildFieldsMap.containsKey(fieldName)) {
                        def validIds = props.get(&quot;fn_computeValidLookupIdsForField&quot;)(varsRef, fieldName, lookupChildFieldsMap, fieldLookupInfo)
                        // FIX: Only apply restrictToIds when non-null AND non-empty.
                        // An empty set means the valid-path computation found no Topic row IDs
                        // that appear as parentId in the child (Sub-Topic) dataset — this happens
                        // when Topic and Sub-Topic share the same lookupName/dataset, so Topic row
                        // IDs are never used as parentId values within that same dataset.
                        // Applying an empty restrictToIds zeroes out all candidates and causes
                        // skipField=true for Sub-Topic, which is the bug seen in the screenshot.
                        if (validIds != null &amp;&amp; !validIds.isEmpty()) {
                            pickOptions = pickOptions ?: [:]
                            pickOptions.restrictToIds = validIds
                        }
                    }
                    value = props.get(&quot;fn_pickLookupValue&quot;)(varsRef, lookupName, lookupContext, isMultiple, getRandomSelectionCount, rand, fieldName, logRef, pickOptions)
                    if (!value) {
                        logRef.warn(&quot;No lookup values for &apos;${lookupName}&apos; (lookupContext=${lookupContext}, lookupMode=${lookupMode ?: &apos;flat&apos;}) - SKIPPING field&quot;)
                        skipField = true
                    }
                } else if (masterTypeId) {
                    // FIX: SELECT fields that use a masterType (not a lookupName) — e.g. ParentTopic,
                    // Topic, SubTopic, MicroTopic in BriefingIQ — have formControlType=&quot;SELECT&quot; with
                    // a masterType object but NO lookupName. They fall here instead of case &quot;MASTER&quot;
                    // and were silently skipped. Re-route them into the same MASTER handling below.
                    logRef.info(&quot;SELECT field &apos;${fieldName}&apos; has masterTypeId=${masterTypeId} — routing to MASTER handler&quot;)

                    // ── Leaf-first chain build (replaces the old greedy per-level pick) ─────────
                    // FIX (root cause of &quot;Micro Topic not selected&quot;): the previous approach picked
                    // ParentTopic, then a child of it for Topic, then a child of THAT for Sub-Topic,
                    // each time only checking a few levels ahead with a heuristic. Whenever that
                    // heuristic undercounted remaining levels or the data was a hair shallower than
                    // expected, the deepest field (Micro Topic) could still land on a branch with
                    // zero children, and the &quot;reuse parent&apos;s own id&quot; fallback then produced a
                    // uniqueId duplicated across two hierarchy levels — which the API silently
                    // rejects, leaving Micro Topic empty/required in the UI.
                    // This rewrite removes the guesswork entirely: pick a genuine LEAF node (a row
                    // that no other row lists as its parentId) FIRST — guaranteed to be the deepest
                    // real node in some valid branch — then walk its real parentId chain back up to
                    // the root. Every field that shares this masterTypeId (Parent Topic, Topic,
                    // Sub-Topic, Micro Topic) then just reads its own depth out of that ONE fixed,
                    // already-validated chain. Because every id in the chain is a real, distinct row
                    // taken straight from the actual parent/child links, a dead end or a duplicate id
                    // across levels is no longer structurally possible. The chain is computed once
                    // per masterTypeId and cached in _masterChainCacheByType so all 4 fields agree
                    // on the exact same branch.
                    def chainKey2 = masterTypeId.toString()
                    def chain2 = _masterChainCacheByType[chainKey2]
                    if (chain2 == null) {
                        def mtCountStrC = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_count&quot;)
                        if (mtCountStrC &amp;&amp; mtCountStrC.isInteger() &amp;&amp; mtCountStrC.toInteger() &gt; 0) {
                            def mtCountC = mtCountStrC.toInteger()
                            def allIndicesC = (1..mtCountC).toList()
                            def allMasterIdsC = new HashSet()
                            allIndicesC.each { idx -&gt; def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;); if (mid) allMasterIdsC.add(mid) }
                            def masterIdToParentIdC = [:]
                            def childCountC = [:]
                            allIndicesC.each { idx -&gt;
                                def mid  = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                                def mpid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_parentId&quot;) ?: &quot;&quot;
                                if (mid) masterIdToParentIdC[mid] = mpid
                                if (mid &amp;&amp; mpid &amp;&amp; allMasterIdsC.contains(mpid)) childCountC[mpid] = (childCountC[mpid] ?: 0) + 1
                            }
                            // A leaf is any real node that no other node names as its parentId —
                            // i.e. the actual bottom of the tree, not a heuristic guess.
                            def leafIdsC = allMasterIdsC.findAll { mid -&gt; !childCountC.containsKey(mid) }
                            if (leafIdsC) {
                                // FIX: not every leaf is deep enough. A Sub-Topic with zero children
                                // (e.g. &quot;Object Oriented Programming&quot;) IS a leaf by this definition,
                                // but it only reaches depth 3 — one level shallower than a sibling
                                // branch like &quot;Cloud Computing&quot; whose leaf (a real Micro Topic) reaches
                                // depth 4. Picking the shallow leaf would leave Micro Topic short by
                                // one level again. Compute every leaf&apos;s real depth, work out how many
                                // levels this masterTypeId actually needs (the number of Parent Topic/
                                // Topic/Sub-Topic/Micro Topic-style fields sharing it), and restrict
                                // the random pick to leaves that reach that full depth. Only if NO
                                // leaf anywhere reaches it (the data itself is uniformly shallower than
                                // the form) do we fall back to the deepest leaves actually available.
                                def depthOfC = [:]
                                def depthFnC
                                depthFnC = { String nid -&gt;
                                    if (depthOfC.containsKey(nid)) return depthOfC[nid]
                                    def pid = masterIdToParentIdC[nid]
                                    def d = (pid &amp;&amp; allMasterIdsC.contains(pid)) ? depthFnC(pid) + 1 : 1
                                    depthOfC[nid] = d
                                    return d
                                }
                                def neededLevelsC = allFields.count { f -&gt;
                                    def fType = (f.formControlType ?: f.type ?: f.fieldType ?: f.controlType ?: &quot;&quot;).toString().toUpperCase()
                                    def fMtId = (f?.masterTypeId ?: f?.masterType?.uniqueId ?: f?.masterType?.id ?: (f?.masterType instanceof String ? f?.masterType : null))?.toString()
                                    (fType == &quot;MASTER&quot; || fType == &quot;SELECT&quot;) &amp;&amp; fMtId == masterTypeId
                                }
                                def fullDepthLeavesC = leafIdsC.findAll { depthFnC(it) &gt;= neededLevelsC }
                                def chosenLeavesC = fullDepthLeavesC
                                if (!chosenLeavesC) {
                                    def maxLeafDepthC = leafIdsC.collect { depthFnC(it) }.max()
                                    chosenLeavesC = leafIdsC.findAll { depthFnC(it) == maxLeafDepthC }
                                    logRef.warn(&quot;SELECT[MASTER] masterTypeId=${masterTypeId} — no leaf reaches the needed ${neededLevelsC} levels; deepest available is ${maxLeafDepthC} (data gap) — using deepest leaves only&quot;)
                                }
                                def leafIdC = chosenLeavesC[rand.nextInt(chosenLeavesC.size())]
                                def ancestryC = [leafIdC]
                                def curC = leafIdC
                                def safetyC = 0
                                while (true) {
                                    def pC = masterIdToParentIdC[curC]
                                    if (!pC || !allMasterIdsC.contains(pC) || safetyC &gt; 50) break
                                    ancestryC &lt;&lt; pC
                                    curC = pC
                                    safetyC++
                                }
                                chain2 = ancestryC.reverse() // root → leaf, every id real and distinct
                                logRef.info(&quot;SELECT[MASTER] leaf-first chain built for masterTypeId=${masterTypeId}: depth=${chain2.size()} (needed ${neededLevelsC}), leaf=${leafIdC}, candidates considered=${chosenLeavesC.size()}/${leafIdsC.size()} leaves&quot;)
                            } else {
                                logRef.warn(&quot;SELECT[MASTER] masterTypeId=${masterTypeId} — no leaf nodes found (data gap) — falling back to legacy per-level pick&quot;)
                                chain2 = []
                            }
                        } else {
                            logRef.warn(&quot;SELECT[MASTER] masterTypeId=${masterTypeId} — no masters fetched — falling back to legacy per-level pick&quot;)
                            chain2 = []
                        }
                        _masterChainCacheByType[chainKey2] = chain2
                    }

                    // This field&apos;s depth among all SELECT/MASTER fields sharing this masterTypeId,
                    // counted by how many such fields appear before it in the original field order
                    // (ParentTopic=0, Topic=1, SubTopic=2, MicroTopic=3, …).
                    def levelIdxC = 0
                    for (def f2 : allFields) {
                        def f2FN = (f2.dataMapping ?: f2.formControlName)?.toString()
                        if (f2FN == fieldName) break
                        def f2Type = (f2.formControlType ?: f2.type ?: f2.fieldType ?: f2.controlType ?: &quot;&quot;).toString().toUpperCase()
                        def f2MtId = (f2?.masterTypeId ?: f2?.masterType?.uniqueId ?: f2?.masterType?.id ?: (f2?.masterType instanceof String ? f2?.masterType : null))?.toString()
                        if ((f2Type == &quot;MASTER&quot; || f2Type == &quot;SELECT&quot;) &amp;&amp; f2MtId == masterTypeId) levelIdxC++
                    }

                    def usedChainC = false
                    if (chain2 &amp;&amp; chain2.size() &gt; 0) {
                        // ROOT CAUSE FIX (same as MASTER case below): BriefingIQ masters API returns
                        // a flat list starting at L2 — ParentTopic is an external category record NOT
                        // in the flat list. So chain2 has (N-1) nodes for N form fields. Using
                        // levelIdxC (0..N-1) directly overshoots by 1 for levels &gt;= chain2.size(),
                        // causing clamp collisions and falling to legacy every time for Micro Topic.
                        // Fix: compute chainOffsetC = form fields above flat-list root, subtract from
                        // levelIdxC before indexing into chain2.
                        def totalFormLevelsC = allFields.count { f -&gt;
                            def fType2 = (f.formControlType ?: f.type ?: f.fieldType ?: f.controlType ?: &quot;&quot;).toString().toUpperCase()
                            def fMtId2 = (f?.masterTypeId ?: f?.masterType?.uniqueId ?: f?.masterType?.id ?: (f?.masterType instanceof String ? f?.masterType : null))?.toString()
                            (fType2 == &quot;MASTER&quot; || fType2 == &quot;SELECT&quot;) &amp;&amp; fMtId2 == masterTypeId
                        }
                        def chainOffsetC = 0
                        def adjustedIdxC = 0
                        def clampedIdxC  = 0
                        def masterIdC = null
                        def alreadyUsedInChain = false
                        def isNestedEnumField = props.get(&quot;fn_resolveIsNestedEnum&quot;)(field)
                        if (isNestedEnumField || totalFormLevelsC == 1) {
                            // isNestedEnum (or sole master field): one control, multiple internal levels —
                            // store the deepest chain node; UI derives parent levels from that leaf.
                            masterIdC = chain2[chain2.size() - 1]
                            logRef.info(&quot;SELECT[MASTER] nested enum: using chain leaf id=${masterIdC} (chain depth=${chain2.size()}, isNestedEnum=${isNestedEnumField})&quot;)
                        } else {
                            chainOffsetC = Math.max(0, Math.min(levelIdxC, totalFormLevelsC - chain2.size()))
                            adjustedIdxC = levelIdxC - chainOffsetC
                            clampedIdxC  = Math.min(adjustedIdxC, chain2.size() - 1)
                            masterIdC = chain2[clampedIdxC]
                            if (clampedIdxC &lt; adjustedIdxC &amp;&amp; masterIdC) {
                                // Still clamped even after offset — data genuinely shallower than form.
                                for (int ci = 0; ci &lt; clampedIdxC; ci++) {
                                    if (chain2[ci] == masterIdC) { alreadyUsedInChain = true; break }
                                }
                                if (!alreadyUsedInChain) {
                                    allFields.each { f2 -&gt;
                                        def f2FN   = (f2.dataMapping ?: f2.formControlName)?.toString()
                                        if (!f2FN || f2FN == fieldName || alreadyUsedInChain) return
                                        def f2Type = (f2.formControlType ?: f2.type ?: f2.fieldType ?: f2.controlType ?: &quot;&quot;).toString().toUpperCase()
                                        def f2MtId = (f2?.masterTypeId ?: f2?.masterType?.uniqueId ?: f2?.masterType?.id ?: (f2?.masterType instanceof String ? f2?.masterType : null))?.toString()
                                        if ((f2Type == &quot;MASTER&quot; || f2Type == &quot;SELECT&quot;) &amp;&amp; f2MtId == masterTypeId &amp;&amp; formData.containsKey(f2FN)) {
                                            def fv = formData[f2FN]
                                            def usedId = props.get(&quot;fn_resolveReferenceIdFromValue&quot;)(fv)
                                            if (usedId &amp;&amp; usedId == masterIdC) alreadyUsedInChain = true
                                        }
                                    }
                                }
                                if (alreadyUsedInChain) {
                                    logRef.info(&quot;SELECT[MASTER] chain: field=&apos;${fieldName}&apos; level=${levelIdxC} offset=${chainOffsetC} adjusted=${adjustedIdxC} clamped=${clampedIdxC} id=${masterIdC} already used — falling through to legacy&quot;)
                                }
                            }
                        }
                        if (masterIdC &amp;&amp; !alreadyUsedInChain) {
                            value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, masterIdC)
                            if (fieldName) varsRef.put(fieldName + &quot;__rowId&quot;, masterIdC)
                            usedChainC = true
                            logRef.info(&quot;SELECT[MASTER] chain: field=&apos;${fieldName}&apos; level=${levelIdxC} offset=${chainOffsetC} adjusted=${adjustedIdxC} (clamped=${clampedIdxC}) → id=${masterIdC}&quot;)
                        }
                    }

                    if (!usedChainC) {
                    // ── Legacy greedy per-level pick — kept as a safety net for the rare case
                    // where no leaf node could be found at all (malformed/empty master dataset) ──
                    def mtCountStr2 = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_count&quot;)
                    if (mtCountStr2 &amp;&amp; mtCountStr2.isInteger() &amp;&amp; mtCountStr2.toInteger() &gt; 0) {
                        def mtCount2 = mtCountStr2.toInteger()
                        def allIndices2 = (1..mtCount2).toList()
                        def allMasterIds2 = new HashSet()
                        allIndices2.each { idx -&gt; def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;); if (mid) allMasterIds2.add(mid) }
                        def masterParentToChildren2 = [:]
                        allIndices2.each { idx -&gt;
                            def mid  = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                            def mpid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_parentId&quot;) ?: &quot;&quot;
                            if (mid &amp;&amp; mpid &amp;&amp; allMasterIds2.contains(mpid)) { if (!masterParentToChildren2.containsKey(mpid)) masterParentToChildren2[mpid] = new HashSet(); masterParentToChildren2[mpid].add(mid) }
                        }
                        def masterIdToParentId2 = [:]
                        allIndices2.each { idx -&gt; def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;; def mpid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_parentId&quot;) ?: &quot;&quot;; if (mid) masterIdToParentId2[mid] = mpid }
                        def parentMasterUniqueId2 = null
                        def parentMasterFN2 = lookupParentFieldMap[fieldName]
                        if (!parentMasterFN2) {
                            def prevMasterFN2 = null
                            for (def f2 : allFields) {
                                def f2FN = (f2.dataMapping ?: f2.formControlName)?.toString()
                                if (f2FN == fieldName) break
                                def f2Type = (f2.formControlType ?: f2.type ?: f2.fieldType ?: f2.controlType ?: &quot;&quot;).toString().toUpperCase()
                                def f2MtId = (f2?.masterTypeId ?: f2?.masterType?.uniqueId ?: f2?.masterType?.id ?: (f2?.masterType instanceof String ? f2?.masterType : null))?.toString()
                                if ((f2Type == &quot;MASTER&quot; || f2Type == &quot;SELECT&quot; || f2Type == &quot;LOOKUP&quot;) &amp;&amp; f2MtId == masterTypeId) prevMasterFN2 = f2FN
                            }
                            if (prevMasterFN2) { parentMasterFN2 = prevMasterFN2; logRef.info(&quot;SELECT[MASTER] parent inferred: parentFN=${parentMasterFN2} for field=${fieldName}&quot;) }
                        }
                        if (parentMasterFN2) {
                            def pv = formData[parentMasterFN2]
                            parentMasterUniqueId2 = props.get(&quot;fn_resolveReferenceIdFromValue&quot;)(pv)
                            // LOOKUP fields store a plain String value in formData and keep the row ID
                            // in a separate JMeter variable: fieldName + &quot;__rowId&quot;.
                            // If the Map path above yielded nothing, fall back to that variable.
                            if (!parentMasterUniqueId2) {
                                parentMasterUniqueId2 = varsRef.get(parentMasterFN2 + &quot;__rowId&quot;) ?: null
                                if (parentMasterUniqueId2) logRef.info(&quot;SELECT[MASTER] parent resolved via __rowId: ${parentMasterUniqueId2} for field=${fieldName}&quot;)
                            }
                        }
                        // Collect uniqueIds already selected for preceding MASTER/SELECT fields
                        // with the same masterTypeId — so Micro Topic never re-uses the exact
                        // same uniqueId that was already assigned to Topic or Sub-Topic.
                        // When the API returns only one L3 node per branch, the ancestor walk
                        // for Micro Topic lands on that same L3 node that Sub-Topic just used.
                        // The API rejects duplicate uniqueIds across hierarchy levels, showing
                        // &quot;Topic is required.&quot; even though candidateIndices is non-empty.
                        def alreadyUsedMasterIds2 = [] as Set
                        allFields.each { f2 -&gt;
                            def f2FN   = (f2.dataMapping ?: f2.formControlName)?.toString()
                            if (!f2FN || f2FN == fieldName) return
                            def f2Type = (f2.formControlType ?: f2.type ?: f2.fieldType ?: f2.controlType ?: &quot;&quot;).toString().toUpperCase()
                            def f2MtId = (f2?.masterTypeId ?: f2?.masterType?.uniqueId ?: f2?.masterType?.id ?: (f2?.masterType instanceof String ? f2?.masterType : null))?.toString()
                            if ((f2Type == &quot;MASTER&quot; || f2Type == &quot;SELECT&quot; || f2Type == &quot;LOOKUP&quot;) &amp;&amp; f2MtId == masterTypeId &amp;&amp; formData.containsKey(f2FN)) {
                                def fv = formData[f2FN]
                                def mid = props.get(&quot;fn_resolveReferenceIdFromValue&quot;)(fv)
                                if (mid) alreadyUsedMasterIds2.add(mid)
                                // LOOKUP fields store a plain String value; row ID is in __rowId var
                                def rowId2 = varsRef.get(f2FN + &quot;__rowId&quot;); if (rowId2) alreadyUsedMasterIds2.add(rowId2.toString())
                            }
                        }
                        def candidateIndices2
                        if (parentMasterUniqueId2) {
                            // CHILD level: find DIRECT children of parentMasterUniqueId2 only.
                            // Do NOT walk up to ancestors — ancestor siblings are invalid choices
                            // (the API requires each level to be a descendant of the level above,
                            // not a sibling). If the parent is a leaf (no children in the map),
                            // the data depth is exhausted and the only valid value is to reuse
                            // the parent&apos;s own ID (repeat the last level).
                            def childIds2 = masterParentToChildren2[parentMasterUniqueId2] ?: new HashSet()
                            def filtered2 = childIds2 ? allIndices2.findAll { idx -&gt;
                                def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                                childIds2.contains(mid)
                            } : []
                            def alreadyUsed2 = alreadyUsedMasterIds2
                            if (filtered2) {
                                // Prefer children not yet used at earlier levels
                                if (alreadyUsed2) {
                                    def deduped2 = filtered2.findAll { idx -&gt;
                                        def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                                        mid &amp;&amp; !alreadyUsed2.contains(mid)
                                    }
                                    if (deduped2) {
                                        logRef.info(&quot;SELECT[MASTER] dedup: ${filtered2.size()} → ${deduped2.size()} unused children for field=${fieldName}&quot;)
                                        filtered2 = deduped2
                                    } else {
                                        logRef.info(&quot;SELECT[MASTER] dedup: all ${filtered2.size()} children already used — keeping full child set for field=${fieldName}&quot;)
                                        // leave filtered2 as-is; the API accepts reuse when data is exhausted
                                    }
                                }
                                candidateIndices2 = filtered2
                            } else {
                                // No children found under the current parent.
                                // FIX: Before reusing the parent ID (which duplicates uniqueId across
                                // hierarchy levels and causes the API to silently reject the submission,
                                // showing &quot;Topic is required&quot;), try to find a grandparent sibling branch
                                // that DOES have children at this depth. This handles the case where the
                                // chain-build path was bypassed (e.g. masters not loaded at chain-build
                                // time) and the prior level picked a dead-end leaf node.
                                def grandParentId2 = masterIdToParentId2[parentMasterUniqueId2]
                                def rescueCandidates2 = []
                                if (grandParentId2 &amp;&amp; allMasterIds2.contains(grandParentId2)) {
                                    // Siblings of the current parent (children of grandparent)
                                    def siblingIds2 = masterParentToChildren2[grandParentId2] ?: new HashSet()
                                    siblingIds2.each { sib -&gt;
                                        if (sib != parentMasterUniqueId2 &amp;&amp; masterParentToChildren2.containsKey(sib)) {
                                            def sibChildrenIndices = allIndices2.findAll { idx -&gt;
                                                def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                                                masterParentToChildren2[sib]?.contains(mid)
                                            }
                                            rescueCandidates2.addAll(sibChildrenIndices)
                                        }
                                    }
                                }
                                if (rescueCandidates2) {
                                    logRef.info(&quot;SELECT[MASTER] dead-end rescue: parent id=${parentMasterUniqueId2} has no children — found ${rescueCandidates2.size()} candidates via sibling branches for field=${fieldName}&quot;)
                                    candidateIndices2 = rescueCandidates2
                                } else {
                                    // No sibling branch available — last resort: reuse parent ID.
                                    // The API may reject duplicate uniqueIds but there is no valid
                                    // alternative when the master data tree is shallower than the form.
                                    def reuseIdx = allIndices2.find { idx -&gt;
                                        (varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;) == parentMasterUniqueId2
                                    }
                                    if (reuseIdx != null) {
                                        logRef.info(&quot;SELECT[MASTER] leaf reuse: no children or siblings with children — reusing parent id=${parentMasterUniqueId2} for field=${fieldName}&quot;)
                                        candidateIndices2 = [reuseIdx]
                                    } else {
                                        logRef.warn(&quot;SELECT[MASTER] leaf reuse: parent id=${parentMasterUniqueId2} not found in masters for field=${fieldName} — unrestricted fallback&quot;)
                                        candidateIndices2 = allIndices2
                                    }
                                }
                            }
                            logRef.info(&quot;SELECT[MASTER] child-filter: ${candidateIndices2?.size()} candidates for field=${fieldName}&quot;)
                        } else {
                            def allRootNodes2 = allIndices2.findAll { idx -&gt; def mpid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_parentId&quot;) ?: &quot;&quot;; !mpid || !allMasterIds2.contains(mpid) }
                            def activeRootNodes2 = allRootNodes2.findAll { idx -&gt; varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_parentIsActive&quot;) != &quot;false&quot; }
                            candidateIndices2 = activeRootNodes2 ?: allRootNodes2 ?: allIndices2
                            logRef.info(&quot;SELECT[MASTER] root-filter: ${candidateIndices2.size()} root nodes for field=${fieldName}&quot;)
                        }

                        // ── Step 3: Valid-path pre-filter (mirrors case &quot;MASTER&quot; below) ───────────
                        def deeperMasterCount2 = allFields.count { f -&gt;
                            def fType = (f.formControlType ?: f.type ?: f.fieldType ?: f.controlType ?: &quot;&quot;).toString().toUpperCase()
                            def fMtId = (f?.masterTypeId ?: f?.masterType?.uniqueId ?: f?.masterType?.id ?: (f?.masterType instanceof String ? f?.masterType : null))?.toString()
                            def fFN   = (f.dataMapping ?: f.formControlName)?.toString()
                            (fType == &quot;MASTER&quot; || fType == &quot;SELECT&quot;) &amp;&amp; fMtId == masterTypeId &amp;&amp; fFN &amp;&amp; fFN != fieldName &amp;&amp;
                            !formData.containsKey(fFN)
                        }
                        if (deeperMasterCount2 &gt; 0 &amp;&amp; candidateIndices2) {
                            def hasValidPath2
                            hasValidPath2 = { String nodeId, int depth -&gt;
                                if (depth == 0) return true
                                def kids = masterParentToChildren2[nodeId]
                                if (!kids) return false
                                return kids.any { kid -&gt; hasValidPath2(kid, depth - 1) }
                            }
                            def pathFiltered2 = []
                            def effectiveDepth2 = deeperMasterCount2
                            while (effectiveDepth2 &gt;= 1 &amp;&amp; !pathFiltered2) {
                                pathFiltered2 = candidateIndices2.findAll { idx -&gt;
                                    def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                                    mid &amp;&amp; hasValidPath2(mid, effectiveDepth2)
                                }
                                if (!pathFiltered2) {
                                    logRef.info(&quot;SELECT[MASTER] path-filter: depth=${effectiveDepth2} yielded 0 for field=${fieldName}, retrying with depth=${effectiveDepth2 - 1}&quot;)
                                    effectiveDepth2--
                                }
                            }
                            if (pathFiltered2) {
                                logRef.info(&quot;SELECT[MASTER] path-filter: ${pathFiltered2.size()} of ${candidateIndices2.size()} have ${effectiveDepth2}-level path (requested ${deeperMasterCount2}) for field=${fieldName}&quot;)
                                candidateIndices2 = pathFiltered2
                            } else {
                                logRef.warn(&quot;SELECT[MASTER] path-filter: no path found at any depth for field=${fieldName} — leaving candidates unfiltered (data gap)&quot;)
                            }
                        }

                        if (!candidateIndices2) {
                            logRef.warn(&quot;SELECT[MASTER]: no candidates for field=${fieldName} — SKIPPING&quot;)
                            skipField = true
                        } else {
                            def pickedIdx2 = candidateIndices2[rand.nextInt(candidateIndices2.size())]
                            def masterId2  = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + pickedIdx2 + &quot;_id&quot;)
                            value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, masterId2)
                            if (fieldName &amp;&amp; masterId2) varsRef.put(fieldName + &quot;__rowId&quot;, masterId2)
                            if (!value) { logRef.warn(&quot;SELECT[MASTER]: null masterId for field=${fieldName} — SKIPPING&quot;); skipField = true }
                        }
                    } else {
                        logRef.warn(&quot;SELECT[MASTER] field &apos;${fieldName}&apos; — no masters fetched for masterTypeId=${masterTypeId} — SKIPPING&quot;)
                        skipField = true
                    }
                    }
                } else {
                    logRef.warn(&quot;No lookupName defined - SKIPPING field: &apos;&quot; + fieldName + &quot;&apos; (alias=&quot; + (aliasName ?: &quot;null&quot;) + &quot;)&quot;)
                    skipField = true
                }
                break

            // CHECKBOX Field
            case &quot;CHECKBOX&quot;:
                value = rand.nextBoolean()
                break

            // RESOURCE Field
            case &quot;RESOURCE&quot;:
                if (resourceTypeId) {
                    def isNestedEnumResourceM = props.get(&quot;fn_resolveIsNestedEnum&quot;)(field)
                    def usedResourceChainM = false
                    if (isNestedEnumResourceM) {
                        def chainKeyRM = &quot;resource:&quot; + resourceTypeId
                        def chainRM = _resourceChainCacheByType[chainKeyRM]
                        if (chainRM == null) {
                            chainRM = props.get(&quot;fn_buildLeafFirstReferenceChain&quot;)(varsRef, &quot;resourcesFor_&quot; + resourceTypeId, 1, rand, logRef, &quot;RESOURCE&quot;)
                            _resourceChainCacheByType[chainKeyRM] = chainRM ?: []
                        }
                        if (chainRM) {
                            def resourceIdLeaf = chainRM[chainRM.size() - 1]
                            value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, resourceIdLeaf)
                            if (fieldName &amp;&amp; resourceIdLeaf) varsRef.put(fieldName + &quot;__rowId&quot;, resourceIdLeaf)
                            usedResourceChainM = true
                            logRef.info(&quot;RESOURCE nested enum: using chain leaf id=${resourceIdLeaf} (chain depth=${chainRM.size()}, isNestedEnum=true)&quot;)
                        }
                    }
                    if (!usedResourceChainM) {

                    def rtCountStr = varsRef.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_count&quot;)
                    if (rtCountStr &amp;&amp; rtCountStr.isInteger() &amp;&amp; rtCountStr.toInteger() &gt; 0) {
                        def rtCount = rtCountStr.toInteger()

                        if (isMultiple) {
                            // Multi-select resources — format each id per isComplexObject
                            def selectCount = getRandomSelectionCount(rtCount)
                            //&quot;)
                            def selectedValues = []
                            def indices = (1..rtCount).toList()
                            Collections.shuffle(indices)
                            indices.take(selectCount).each { idx -&gt;
                                def resourceId = varsRef.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                def formatted = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, resourceId)
                                if (formatted != null) selectedValues.add(formatted)
                            }
                            if (selectedValues) {
                                value = selectedValues

                            }
                        } else {
                            // Single select resource — format per isComplexObject
                            def randomIndex = rand.nextInt(rtCount) + 1
                            def resourceId = varsRef.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                            value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, resourceId)
                        }
                    } else {
                        logRef.warn(&quot;No resources fetched for resourceTypeId: ${resourceTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                    }
                } else {
                    logRef.warn(&quot;RESOURCE/AUTOCOMPLETE field without resourceTypeId - SKIPPING&quot;)
                    skipField = true
                }
                break

            // MASTER Field
            case &quot;MASTER&quot;:
                if (masterTypeId) {

                    // ── Leaf-first chain (same fix as the SELECT/masterTypeId branch above) ────
                    // FIX: this dedicated &quot;case MASTER&quot; block is a SEPARATE code path from the
                    // SELECT-with-masterTypeId branch above — some BriefingIQ form configs define
                    // Parent Topic/Topic/Sub-Topic/Micro Topic with formControlType=&quot;MASTER&quot; rather
                    // than &quot;SELECT&quot;, which routes them here instead. This block still used the old
                    // greedy, level-by-level pick (see legacy fallback below), so it was exposed to
                    // the exact same dead-end/duplicate-uniqueId failure for Micro Topic even after
                    // that was fixed in the SELECT branch. Reuse the identical leaf-first, depth-
                    // biased chain build (and the shared _masterChainCacheByType cache) here too, so
                    // both code paths behave consistently and a field never lands on a value already
                    // used at another level.
                    def usedChainM = false
                    if (!isMultiple) {
                        def chainKeyM = masterTypeId.toString()
                        def chainM = _masterChainCacheByType[chainKeyM]
                        if (chainM == null) {
                            def mtCountStrM = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_count&quot;)
                            if (mtCountStrM &amp;&amp; mtCountStrM.isInteger() &amp;&amp; mtCountStrM.toInteger() &gt; 0) {
                                def mtCountM = mtCountStrM.toInteger()
                                def allIndicesM = (1..mtCountM).toList()
                                def allMasterIdsM = new HashSet()
                                allIndicesM.each { idx -&gt; def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;); if (mid) allMasterIdsM.add(mid) }
                                def masterIdToParentIdM = [:]
                                def childCountM = [:]
                                allIndicesM.each { idx -&gt;
                                    def mid  = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                                    def mpid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_parentId&quot;) ?: &quot;&quot;
                                    if (mid) masterIdToParentIdM[mid] = mpid
                                    if (mid &amp;&amp; mpid &amp;&amp; allMasterIdsM.contains(mpid)) childCountM[mpid] = (childCountM[mpid] ?: 0) + 1
                                }
                                def leafIdsM = allMasterIdsM.findAll { mid -&gt; !childCountM.containsKey(mid) }
                                if (leafIdsM) {
                                    def depthOfM = [:]
                                    def depthFnM
                                    depthFnM = { String nid -&gt;
                                        if (depthOfM.containsKey(nid)) return depthOfM[nid]
                                        def pid = masterIdToParentIdM[nid]
                                        def d = (pid &amp;&amp; allMasterIdsM.contains(pid)) ? depthFnM(pid) + 1 : 1
                                        depthOfM[nid] = d
                                        return d
                                    }
                                    def neededLevelsM = allFields.count { f -&gt;
                                        def fType = (f.formControlType ?: f.type ?: f.fieldType ?: f.controlType ?: &quot;&quot;).toString().toUpperCase()
                                        def fMtId = (f?.masterTypeId ?: f?.masterType?.uniqueId ?: f?.masterType?.id ?: (f?.masterType instanceof String ? f?.masterType : null))?.toString()
                                        (fType == &quot;MASTER&quot; || fType == &quot;SELECT&quot;) &amp;&amp; fMtId == masterTypeId
                                    }
                                    def fullDepthLeavesM = leafIdsM.findAll { depthFnM(it) &gt;= neededLevelsM }
                                    def chosenLeavesM = fullDepthLeavesM
                                    if (!chosenLeavesM) {
                                        def maxLeafDepthM = leafIdsM.collect { depthFnM(it) }.max()
                                        chosenLeavesM = leafIdsM.findAll { depthFnM(it) == maxLeafDepthM }
                                        logRef.warn(&quot;MASTER masterTypeId=${masterTypeId} — no leaf reaches the needed ${neededLevelsM} levels; deepest available is ${maxLeafDepthM} (data gap) — using deepest leaves only&quot;)
                                    }
                                    def leafIdM = chosenLeavesM[rand.nextInt(chosenLeavesM.size())]
                                    def ancestryM = [leafIdM]
                                    def curM = leafIdM
                                    def safetyM = 0
                                    while (true) {
                                        def pM = masterIdToParentIdM[curM]
                                        if (!pM || !allMasterIdsM.contains(pM) || safetyM &gt; 50) break
                                        ancestryM &lt;&lt; pM
                                        curM = pM
                                        safetyM++
                                    }
                                    chainM = ancestryM.reverse()
                                    logRef.info(&quot;MASTER leaf-first chain built for masterTypeId=${masterTypeId}: depth=${chainM.size()} (needed ${neededLevelsM}), leaf=${leafIdM}, candidates considered=${chosenLeavesM.size()}/${leafIdsM.size()} leaves&quot;)
                                } else {
                                    logRef.warn(&quot;MASTER masterTypeId=${masterTypeId} — no leaf nodes found (data gap) — falling back to legacy per-level pick&quot;)
                                    chainM = []
                                }
                            } else {
                                logRef.warn(&quot;MASTER masterTypeId=${masterTypeId} — no masters fetched — falling back to legacy per-level pick&quot;)
                                chainM = []
                            }
                            _masterChainCacheByType[chainKeyM] = chainM
                        }

                        def levelIdxM = 0
                        for (def f2 : allFields) {
                            def f2FN = (f2.dataMapping ?: f2.formControlName)?.toString()
                            if (f2FN == fieldName) break
                            def f2Type = (f2.formControlType ?: f2.type ?: f2.fieldType ?: f2.controlType ?: &quot;&quot;).toString().toUpperCase()
                            def f2MtId = (f2?.masterTypeId ?: f2?.masterType?.uniqueId ?: f2?.masterType?.id ?: (f2?.masterType instanceof String ? f2?.masterType : null))?.toString()
                            if ((f2Type == &quot;MASTER&quot; || f2Type == &quot;SELECT&quot;) &amp;&amp; f2MtId == masterTypeId) levelIdxM++
                        }

                        if (chainM &amp;&amp; chainM.size() &gt; 0) {
                            // ROOT CAUSE FIX: The BriefingIQ masters API returns a flat list that
                            // starts at L2 — the true L1 (ParentTopic) nodes are external category
                            // records NOT present in the flat list. This means when the form has N
                            // MASTER fields (ParentTopic=0, Topic=1, SubTopic=2, MicroTopic=3), the
                            // chain built from leaf-walking has only N-1 nodes (L2..LN), not N.
                            // Using levelIdxM (0..N-1) directly as the chain index therefore always
                            // overshoots by 1 for every field BELOW the first, causing clampedIdxM
                            // to land on the same chain node as the previous field (duplicate uniqueId)
                            // which triggers alreadyUsedInChainM=true and falls to the legacy path —
                            // where the dead-end / leaf-reuse problem then produces the empty Micro Topic.
                            //
                            // Fix: compute chainOffset = number of form-level fields that map ABOVE
                            // the flat-data root (i.e. virtual levels not represented in the chain).
                            // For most BriefingIQ configs this is exactly 1 (the ParentTopic field),
                            // but we derive it from the difference between total form fields and chain
                            // depth so it works for any configuration.
                            //
                            // totalFormLevelsM = number of MASTER/SELECT fields sharing masterTypeId
                            def totalFormLevelsM = allFields.count { f -&gt;
                                def fType2 = (f.formControlType ?: f.type ?: f.fieldType ?: f.controlType ?: &quot;&quot;).toString().toUpperCase()
                                def fMtId2 = (f?.masterTypeId ?: f?.masterType?.uniqueId ?: f?.masterType?.id ?: (f?.masterType instanceof String ? f?.masterType : null))?.toString()
                                (fType2 == &quot;MASTER&quot; || fType2 == &quot;SELECT&quot;) &amp;&amp; fMtId2 == masterTypeId
                            }
                            def chainOffsetM = 0
                            def adjustedIdxM = 0
                            def clampedIdxM  = 0
                            def masterIdM = null
                            def alreadyUsedInChainM = false
                            def isNestedEnumFieldM = props.get(&quot;fn_resolveIsNestedEnum&quot;)(field)
                            if (isNestedEnumFieldM || totalFormLevelsM == 1) {
                                masterIdM = chainM[chainM.size() - 1]
                                logRef.info(&quot;MASTER nested enum: using chain leaf id=${masterIdM} (chain depth=${chainM.size()}, isNestedEnum=${isNestedEnumFieldM})&quot;)
                            } else {
                            chainOffsetM = Math.max(0, Math.min(levelIdxM, totalFormLevelsM - chainM.size()))
                            adjustedIdxM = levelIdxM - chainOffsetM
                            clampedIdxM  = Math.min(adjustedIdxM, chainM.size() - 1)
                            masterIdM = chainM[clampedIdxM]
                            if (clampedIdxM &lt; adjustedIdxM &amp;&amp; masterIdM) {
                                // Still clamped even after offset — data genuinely shallower than form.
                                // Check if this id was already assigned to an earlier level.
                                for (int ci = 0; ci &lt; clampedIdxM; ci++) {
                                    if (chainM[ci] == masterIdM) { alreadyUsedInChainM = true; break }
                                }
                                if (!alreadyUsedInChainM) {
                                    allFields.each { f2 -&gt;
                                        def f2FN   = (f2.dataMapping ?: f2.formControlName)?.toString()
                                        if (!f2FN || f2FN == fieldName || alreadyUsedInChainM) return
                                        def f2Type = (f2.formControlType ?: f2.type ?: f2.fieldType ?: f2.controlType ?: &quot;&quot;).toString().toUpperCase()
                                        def f2MtId = (f2?.masterTypeId ?: f2?.masterType?.uniqueId ?: f2?.masterType?.id ?: (f2?.masterType instanceof String ? f2?.masterType : null))?.toString()
                                        if ((f2Type == &quot;MASTER&quot; || f2Type == &quot;SELECT&quot;) &amp;&amp; f2MtId == masterTypeId &amp;&amp; formData.containsKey(f2FN)) {
                                            def fv = formData[f2FN]
                                            def usedId = props.get(&quot;fn_resolveReferenceIdFromValue&quot;)(fv)
                                            if (usedId &amp;&amp; usedId == masterIdM) alreadyUsedInChainM = true
                                        }
                                    }
                                }
                                if (alreadyUsedInChainM) {
                                    logRef.info(&quot;MASTER chain: field=&apos;${fieldName}&apos; level=${levelIdxM} offset=${chainOffsetM} adjusted=${adjustedIdxM} clamped=${clampedIdxM} id=${masterIdM} already used — falling through to legacy&quot;)
                                }
                            }
                            }
                            if (masterIdM &amp;&amp; !alreadyUsedInChainM) {
                                value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, masterIdM)
                                if (fieldName) varsRef.put(fieldName + &quot;__rowId&quot;, masterIdM)
                                usedChainM = true
                                logRef.info(&quot;MASTER chain: field=&apos;${fieldName}&apos; level=${levelIdxM} offset=${chainOffsetM} adjusted=${adjustedIdxM} (clamped=${clampedIdxM}) → id=${masterIdM}&quot;)
                            }
                        }
                    }

                    if (!usedChainM) {
                    // ── Legacy logic — kept for isMultiple fields and as a safety net when no
                    // leaf node could be found at all (malformed/empty master dataset) ──────────
                    def mtCountStr = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_count&quot;)
                    if (mtCountStr &amp;&amp; mtCountStr.isInteger() &amp;&amp; mtCountStr.toInteger() &gt; 0) {
                        def mtCount = mtCountStr.toInteger()
                        def allIndices = (1..mtCount).toList()

                        // ── Step 1: Build allIds set and parentId→children map ───────────────────
                        // The BriefingIQ Topic API returns ALL levels (L1…L6) in ONE flat list.
                        // Root nodes (L1) have a parentId pointing to an external CATEGORY record
                        // that is NOT present in the flat list. This is how we identify root nodes.
                        def allMasterIds = new HashSet()
                        allIndices.each { idx -&gt;
                            def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                            if (mid) allMasterIds.add(mid)
                        }

                        // parentId → Set&lt;childId&gt;  (only for parent-child pairs both in the flat list)
                        def masterParentToChildren = [:]
                        allIndices.each { idx -&gt;
                            def mid  = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;)  ?: &quot;&quot;
                            def mpid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_parentId&quot;) ?: &quot;&quot;
                            if (mid &amp;&amp; mpid &amp;&amp; allMasterIds.contains(mpid)) {
                                if (!masterParentToChildren.containsKey(mpid))
                                    masterParentToChildren[mpid] = new HashSet()
                                masterParentToChildren[mpid].add(mid)
                            }
                        }

                        // ── Step 2: Determine candidates by hierarchy level ───────────────────────
                        // Resolve the parent field value already stored in formData (if any).
                        def parentMasterUniqueId = null
                        // FIX: lookupParentFieldMap is built only for LOOKUP fields (lookupMode=parent/child).
                        // MASTER fields never have lookupMode, so lookupParentFieldMap is always empty for them —
                        // causing parentMasterFN to be null for every MASTER field (including Micro Topic), which
                        // makes every level fall into the ROOT branch and pick L1 nodes instead of children.
                        // Fix: find the immediately preceding MASTER field with the same masterTypeId in allFields
                        // order to use as the parent, exactly mirroring how the UI cascades each dropdown level.
                        def parentMasterFN = lookupParentFieldMap[fieldName]
                        if (!parentMasterFN) {
                            // Walk allFields in order; find the last MASTER field with same masterTypeId before this one
                            def prevMasterFN = null
                            for (def f2 : allFields) {
                                def f2FN = (f2.dataMapping ?: f2.formControlName)?.toString()
                                if (f2FN == fieldName) break
                                def f2Type = (f2.formControlType ?: f2.type ?: f2.fieldType ?: f2.controlType ?: &quot;&quot;).toString().toUpperCase()
                                def f2MtId = (f2?.masterTypeId ?: f2?.masterType?.uniqueId ?: f2?.masterType?.id ?: (f2?.masterType instanceof String ? f2?.masterType : null))?.toString()
                                if ((f2Type == &quot;MASTER&quot; || f2Type == &quot;SELECT&quot; || f2Type == &quot;LOOKUP&quot;) &amp;&amp; f2MtId == masterTypeId) prevMasterFN = f2FN
                            }
                            if (prevMasterFN) {
                                parentMasterFN = prevMasterFN
                                logRef.info(&quot;MASTER parent inferred by field-order: parentFN=${parentMasterFN} for field=${fieldName}&quot;)
                            }
                        }
                        if (parentMasterFN) {
                            def parentVal = formData[parentMasterFN]
                            if (parentVal instanceof Map)             parentMasterUniqueId = (parentVal.uniqueId ?: parentVal.id)?.toString()
                            else if (parentVal instanceof List &amp;&amp; parentVal) parentMasterUniqueId = (parentVal[0]?.uniqueId ?: parentVal[0]?.id)?.toString()
                            // LOOKUP fields store a plain String in formData; actual row ID is in __rowId var
                            if (!parentMasterUniqueId) {
                                parentMasterUniqueId = varsRef.get(parentMasterFN + &quot;__rowId&quot;) ?: null
                                if (parentMasterUniqueId) logRef.info(&quot;MASTER parent resolved via __rowId: ${parentMasterUniqueId} for field=${fieldName}&quot;)
                            }
                        }

                        // Build a quick id-&gt;parentId lookup for ancestor-walking
                        def masterIdToParentId = [:]
                        allIndices.each { idx -&gt;
                            def mid  = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                            def mpid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_parentId&quot;) ?: &quot;&quot;
                            if (mid) masterIdToParentId[mid] = mpid
                        }

                        def candidateIndices
                        if (parentMasterUniqueId) {
                            // CHILD level: find DIRECT children of parentMasterUniqueId only.
                            // Do NOT walk up to ancestors — ancestor siblings are invalid choices
                            // for the next level. If the parent is a leaf, data depth is exhausted
                            // and the only valid value is to reuse the parent&apos;s own ID.
                            def childIds = masterParentToChildren[parentMasterUniqueId] ?: new HashSet()
                            def filtered = childIds ? allIndices.findAll { idx -&gt;
                                def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                                childIds.contains(mid)
                            } : []
                            if (filtered) {
                                candidateIndices = filtered
                                logRef.info(&quot;MASTER child-filter: ${filtered.size()} direct children of parent=${parentMasterUniqueId} for field=${fieldName}&quot;)
                            } else {
                                // No children found under the current parent.
                                // FIX: Before reusing the parent ID (which duplicates uniqueId across
                                // hierarchy levels and causes the API to silently reject the submission,
                                // showing &quot;Topic is required&quot;), try to find a grandparent sibling branch
                                // that DOES have children at this depth.
                                def grandParentIdM2 = masterIdToParentId[parentMasterUniqueId]
                                def rescueCandidatesM2 = []
                                if (grandParentIdM2 &amp;&amp; allMasterIds.contains(grandParentIdM2)) {
                                    def siblingIdsM2 = masterParentToChildren[grandParentIdM2] ?: new HashSet()
                                    siblingIdsM2.each { sib -&gt;
                                        if (sib != parentMasterUniqueId &amp;&amp; masterParentToChildren.containsKey(sib)) {
                                            def sibChildrenIndices = allIndices.findAll { idx -&gt;
                                                def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                                                masterParentToChildren[sib]?.contains(mid)
                                            }
                                            rescueCandidatesM2.addAll(sibChildrenIndices)
                                        }
                                    }
                                }
                                if (rescueCandidatesM2) {
                                    logRef.info(&quot;MASTER dead-end rescue: parent id=${parentMasterUniqueId} has no children — found ${rescueCandidatesM2.size()} candidates via sibling branches for field=${fieldName}&quot;)
                                    candidateIndices = rescueCandidatesM2
                                } else {
                                    def reuseIdx = allIndices.find { idx -&gt;
                                        (varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;) == parentMasterUniqueId
                                    }
                                    if (reuseIdx != null) {
                                        logRef.info(&quot;MASTER leaf reuse: no children or siblings with children — reusing parent id=${parentMasterUniqueId} for field=${fieldName}&quot;)
                                        candidateIndices = [reuseIdx]
                                    } else {
                                        filtered = allIndices.findAll { idx -&gt;
                                            def pid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_parentId&quot;) ?: &quot;&quot;
                                            pid == parentMasterUniqueId
                                        }
                                        candidateIndices = filtered ?: allIndices
                                        logRef.warn(&quot;MASTER leaf reuse: parent id=${parentMasterUniqueId} not found — fallback size=${candidateIndices.size()} for field=${fieldName}&quot;)
                                    }
                                }
                            }
                        } else {
                            // ROOT level — pick only nodes whose parentId is NOT in the flat list
                            // (i.e. their parent is an external category record — these are the true L2 roots).
                            // FIX: The API returns DUPLICATE root entries for the same topic — one linked to an
                            // ACTIVE parent category and one linked to an INACTIVE parent category. Both have
                            // external parentIds so both appear as roots, doubling every topic at this level.
                            // Filter: prefer roots whose parent.isActive=true; fall back to all roots only
                            // when no active-parent roots exist (e.g. a fully inactive category branch).
                            def allRootNodes = allIndices.findAll { idx -&gt;
                                def mpid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_parentId&quot;) ?: &quot;&quot;
                                !mpid || !allMasterIds.contains(mpid)
                            }
                            def activeRootNodes = allRootNodes.findAll { idx -&gt;
                                varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_parentIsActive&quot;) != &quot;false&quot;
                            }
                            def rootNodes = activeRootNodes ?: allRootNodes
                            if (rootNodes) {
                                candidateIndices = rootNodes
                                logRef.info(&quot;MASTER root-filter: ${rootNodes.size()} root nodes (${activeRootNodes.size()} active-parent) for field=${fieldName}&quot;)
                            } else {
                                candidateIndices = allIndices
                                logRef.warn(&quot;MASTER root-filter: no root nodes found for field=${fieldName} — unrestricted fallback&quot;)
                            }
                        }

                        // ── Step 3: Valid-path pre-filter ────────────────────────────────────────
                        // Count how many more MASTER fields (same masterTypeId) still need to be filled
                        // after this one. Keep only candidates that have a full descendant chain that deep.
                        def deeperMasterCount = allFields.count { f -&gt;
                            def fType = (f.formControlType ?: f.type ?: f.fieldType ?: f.controlType ?: &quot;&quot;).toString().toUpperCase()
                            def fMtId = (f?.masterTypeId ?: f?.masterType?.uniqueId ?: f?.masterType?.id ?: (f?.masterType instanceof String ? f?.masterType : null))?.toString()
                            def fFN   = (f.dataMapping ?: f.formControlName)?.toString()
                            fType == &quot;MASTER&quot; &amp;&amp; fMtId == masterTypeId &amp;&amp; fFN &amp;&amp; fFN != fieldName &amp;&amp;
                            !formData.containsKey(fFN)
                        }

                        if (deeperMasterCount &gt; 0) {
                            def hasValidPath   // recursive: does nodeId have a chain at least `depth` levels deep?
                            hasValidPath = { String nodeId, int depth -&gt;
                                if (depth == 0) return true
                                def kids = masterParentToChildren[nodeId]
                                if (!kids) return false
                                return kids.any { kid -&gt; hasValidPath(kid, depth - 1) }
                            }
                            // FIX: BriefingIQ returns topics in a flat list starting at L2 (root L1 nodes are
                            // external category records NOT included in the list). This means when the form has
                            // N MASTER fields (e.g. ParentTopic/Topic/SubTopic/MicroTopic all same masterTypeId),
                            // deeperMasterCount for the first field equals N-1 — but the actual maximum chain
                            // depth available in the flat list is only N-2 (L2-&gt;L3-&gt;...-&gt;LN). Requiring depth N-1
                            // from an L2 node always yields zero candidates, causing the filter to be skipped
                            // and random (often leaf) nodes to be picked for the first level.
                            // Fix: try the requested depth first; if no candidates match, reduce depth by 1 and
                            // retry, down to a minimum of 1 — so we always pick a node with at least one child,
                            // never a dead-end leaf, without over-constraining when data depth is shallower.
                            def pathFiltered = []
                            def effectiveDepth = deeperMasterCount
                            while (effectiveDepth &gt;= 1 &amp;&amp; !pathFiltered) {
                                pathFiltered = candidateIndices.findAll { idx -&gt;
                                    def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                                    mid &amp;&amp; hasValidPath(mid, effectiveDepth)
                                }
                                if (!pathFiltered) {
                                    logRef.info(&quot;MASTER path-filter: depth=${effectiveDepth} yielded 0 for field=${fieldName}, retrying with depth=${effectiveDepth - 1}&quot;)
                                    effectiveDepth--
                                }
                            }
                            if (pathFiltered) {
                                logRef.info(&quot;MASTER path-filter: ${pathFiltered.size()} of ${candidateIndices.size()} have ${effectiveDepth}-level path (requested ${deeperMasterCount}) for field=${fieldName}&quot;)
                                candidateIndices = pathFiltered
                            } else {
                                logRef.warn(&quot;MASTER path-filter: no path found at any depth for field=${fieldName} — skipping filter (data gap)&quot;)
                                // leave candidateIndices as-is
                            }
                        }

                        // ── Step 4: Dedup — prefer unused children over already-used ones ────────
                        if (candidateIndices) {
                            def alreadyUsedMasterIds = [] as Set
                            allFields.each { f2 -&gt;
                                def f2FN   = (f2.dataMapping ?: f2.formControlName)?.toString()
                                if (!f2FN || f2FN == fieldName) return
                                def f2Type = (f2.formControlType ?: f2.type ?: f2.fieldType ?: f2.controlType ?: &quot;&quot;).toString().toUpperCase()
                                def f2MtId = (f2?.masterTypeId ?: f2?.masterType?.uniqueId ?: f2?.masterType?.id ?: (f2?.masterType instanceof String ? f2?.masterType : null))?.toString()
                                if ((f2Type == &quot;MASTER&quot; || f2Type == &quot;SELECT&quot; || f2Type == &quot;LOOKUP&quot;) &amp;&amp; f2MtId == masterTypeId &amp;&amp; formData.containsKey(f2FN)) {
                                    def fv = formData[f2FN]
                                    if (fv instanceof Map) {
                                        def mid = (fv.uniqueId ?: fv.id)?.toString(); if (mid) alreadyUsedMasterIds.add(mid)
                                    } else if (fv instanceof List) {
                                        fv.each { item -&gt; if (item instanceof Map) { def mid = (item.uniqueId ?: item.id)?.toString(); if (mid) alreadyUsedMasterIds.add(mid) } }
                                    }
                                    // LOOKUP fields store plain String; row ID is in __rowId var
                                    def rowId = varsRef.get(f2FN + &quot;__rowId&quot;); if (rowId) alreadyUsedMasterIds.add(rowId.toString())
                                }
                            }
                            if (alreadyUsedMasterIds) {
                                def deduped = candidateIndices.findAll { idx -&gt;
                                    def mid = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;) ?: &quot;&quot;
                                    mid &amp;&amp; !alreadyUsedMasterIds.contains(mid)
                                }
                                if (deduped) {
                                    logRef.info(&quot;MASTER dedup: ${candidateIndices.size()} → ${deduped.size()} unused for field=${fieldName}&quot;)
                                    candidateIndices = deduped
                                } else {
                                    // All candidates already used (data depth exhausted at Step 2 leaf-reuse).
                                    // Keep the full set — the leaf-reuse node is the correct repeated value.
                                    logRef.info(&quot;MASTER dedup: all ${candidateIndices.size()} candidate(s) already used — keeping for leaf-reuse for field=${fieldName}&quot;)
                                }
                            }
                        }
                        if (!candidateIndices) {
                            logRef.warn(&quot;MASTER: candidateIndices is empty for field=${fieldName} masterTypeId=${masterTypeId} — SKIPPING field&quot;)
                            skipField = true
                        } else if (isMultiple) {
                            // Multi-select: pick 1..N unique items
                            def selectCount = getRandomSelectionCount(candidateIndices.size())
                            def shuffled = new ArrayList(candidateIndices)
                            Collections.shuffle(shuffled)
                            def selectedValues = []
                            shuffled.take(selectCount).each { idx -&gt;
                                def masterId = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                def formatted = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, masterId)
                                if (formatted != null) selectedValues &lt;&lt; formatted
                            }
                            if (selectedValues) value = selectedValues
                        } else {
                            // Single-select: pick one random candidate
                            def pickedIdx = candidateIndices[rand.nextInt(candidateIndices.size())]
                            def masterId  = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + pickedIdx + &quot;_id&quot;)
                            value = props.get(&quot;fn_formatReferenceFieldValue&quot;)(field, masterId)
                            if (fieldName &amp;&amp; masterId) varsRef.put(fieldName + &quot;__rowId&quot;, masterId)
                        }

                    } else {
                        logRef.warn(&quot;No masters fetched for masterTypeId: ${masterTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                    }
                } else {
                    logRef.warn(&quot;MASTER field without masterTypeId - SKIPPING&quot;)
                    skipField = true
                }
                break

            // Unknown Field Type
            default:
                logRef.warn(&quot;Unknown field type &apos;${fieldType}&apos; - SKIPPING field&quot;)
                skipField = true
        }
    }
    // STEP 6: Add to formData with Proper Type Handling
    if (!skipField &amp;&amp; value != null &amp;&amp; value != &quot;&quot;) {
        if ((fieldType == &quot;CLOUD_DATE&quot; || fieldType == &quot;CLOUD_TIME&quot;) &amp;&amp; !(value instanceof Map)) {
            // Wrap date/time in isoDate format
            formData[fieldName] = [&quot;isoDate&quot;: value]
        } else if (fieldType == &quot;CHECKBOX&quot;) {
            // Ensure boolean type
            formData[fieldName] = (value instanceof String) ? value.toLowerCase() == &quot;true&quot; : value
        } else if (fieldType == &quot;NUMBER&quot;) {
            // Ensure integer type
            formData[fieldName] = (value instanceof String &amp;&amp; value.isInteger()) ? value.toInteger() : value
        } else if ((fieldType == &quot;RESOURCE&quot; || fieldType == &quot;MASTER&quot;) &amp;&amp; isMultiple &amp;&amp; !(value instanceof List)) {
            // Wrap single complex object in array for multi-select resource/master fields
            formData[fieldName] = [value]
        } else if (isMultiple &amp;&amp; !(value instanceof List)) {
            // Wrap single value in array for other multi-select fields
            formData[fieldName] = [value]
        } else {
            formData[fieldName] = value
        }
    }
}
// STEP 7: Build Complete Payload
def payload = [
    &quot;moduleId&quot; : varsRef.get(&quot;currentModuleId&quot;) ?: varsRef.get(&quot;activityConfig_0_moduleId&quot;) ?: varsRef.get(&quot;currentActivityModuleId&quot;) ?: varsRef.get(&quot;moduleId&quot;),
    &quot;formId&quot;   : varsRef.get(&quot;currentFormId&quot;) ?: varsRef.get(&quot;activityConfig_0_formId&quot;) ?: varsRef.get(&quot;formId&quot;),
    &quot;journeyId&quot;: varsRef.get(&quot;currentJourneyId&quot;) ?: varsRef.get(&quot;activityJourneyId&quot;),
    &quot;pageId&quot;   : varsRef.get(&quot;currentPageId&quot;) ?: varsRef.get(&quot;activityPageId&quot;),
    &quot;data&quot;     : formData
]

// Convert to JSON and store
def payloadJson = groovy.json.JsonOutput.prettyPrint(groovy.json.JsonOutput.toJson(payload))
varsRef.put(&quot;dynamicFormPayload&quot;, payloadJson)
// ============ FIELD TRACKING ============
// Store processed field keys for cross-user comparison (shared via props)
// FIX: Scope by requestId to prevent processedFields bleeding across different requests
def _trackModuleName = varsRef.get(&quot;currentModuleName&quot;) ?: varsRef.get(&quot;currentActivityModuleName&quot;) ?: varsRef.get(&quot;newRequestModuleName&quot;) ?: &quot;unknown&quot;
def _trackFormName = varsRef.get(&quot;currentFormName&quot;) ?: varsRef.get(&quot;requestFormName&quot;) ?: &quot;unknown&quot;
def _trackRequestId = varsRef.get(&quot;requestId&quot;) ?: &quot;unknown&quot;
def _trackKey = &quot;processedFields_&quot; + _trackRequestId + &quot;_&quot; + _trackModuleName + &quot;_&quot; + _trackFormName
def _existingTracked = props.get(_trackKey) ?: (new HashSet())
formData.keySet().each { k -&gt; _existingTracked.add(k) }
props.put(_trackKey, _existingTracked)
logRef.info(&quot;Field Tracking: Stored ${formData.size()} fields for &apos;${_trackKey}&apos; (total tracked: ${_existingTracked.size()})&quot;)
}


// Assigns resource and master type IDs to form fields by matching stored resource/master variables to the current form&apos;s RESOURCE and MASTER field definitions.
def _fn_resourceMasterAssigner = { varsRef, logRef -&gt;

// Build Alias Map from Field Mappings
def fieldMappingsStr = varsRef.get(&quot;currentFieldMappings&quot;)
def aliasMap = [:]  // fieldName  to  aliasName

if (fieldMappingsStr) {
    try {
        def fieldMappingsJson = new groovy.json.JsonSlurper().parseText(fieldMappingsStr)
        def mappings = fieldMappingsJson._embedded?.fieldMappings ?: []

        mappings.each { mapping -&gt;
            def fieldName = mapping.columnAttribute?.attributeName
            def aliasName = mapping.aliasName
            if (fieldName &amp;&amp; aliasName) {
                aliasMap[fieldName] = aliasName
            }
        }
    } catch (Exception e) {
        logRef.warn(&quot;Error parsing fieldMappings: &quot; + e.message)
    }
}

// Build ResourceType/MasterType to Alias Mapping from FormUIConfig
def formUIConfigStr = varsRef.get(&quot;currentFormUIConfig&quot;)
def resourceTypeToAlias = [:]  // resourceTypeId  to  [alias: aliasName, isMultiple: boolean]
def masterTypeToAlias = [:]    // masterTypeId  to  [alias: aliasName, isMultiple: boolean]

if (formUIConfigStr) {
    try {
def allFields = props.get(&quot;fn_extractAllFields&quot;)(formUIConfigStr)
        allFields.each { field -&gt;
            def fieldName = field.dataMapping ?: field.formControlName
            def aliasName = aliasMap[fieldName]
            def isMultiple = field.isMultiple ?: false

            // Get resourceTypeId
            def resourceTypeId = field.resourceTypeId ?:
                                 field.resourceType?.id ?:
                                 field.resourceType?.uniqueId ?:
                                 (field.resourceType instanceof String ? field.resourceType : null)

            // Get masterTypeId
            def masterTypeId = field.masterTypeId ?:
                               field.masterType?.id ?:
                               field.masterType?.uniqueId ?:
                               (field.masterType instanceof String ? field.masterType : null)

            // Map resourceTypeId  to  [alias, isMultiple]
            if (resourceTypeId &amp;&amp; aliasName) {
                resourceTypeToAlias[resourceTypeId] = [alias: aliasName, isMultiple: isMultiple]
            }

            // Map masterTypeId  to  [alias, isMultiple]
            if (masterTypeId &amp;&amp; aliasName) {
                masterTypeToAlias[masterTypeId] = [alias: aliasName, isMultiple: isMultiple]
            }
        }
    } catch (Exception e) {
        logRef.warn(&quot;Error parsing formUIConfig: &quot; + e.message)
    }
}

// Assign Resources and Masters
def rtCount = varsRef.get(&quot;resourceTypeIds_count&quot;)?.toInteger() ?: 0
def mtCount = varsRef.get(&quot;masterTypeIds_count&quot;)?.toInteger() ?: 0

if (rtCount &gt; 0 || mtCount &gt; 0) {

        logRef.info(&quot;Entered: Dynamic Resource/Master Assigner&quot;)
    logRef.info(&quot;Form: &quot; + varsRef.get(&quot;currentFormName&quot;))

    def rand = java.util.concurrent.ThreadLocalRandom.current()

    // Multi-select configuration from User Defined Variables
    def minSelection = props.get(&quot;fn_parseMultiDropDownRange&quot;)(varsRef, null).min
    def maxSelection = props.get(&quot;fn_parseMultiDropDownRange&quot;)(varsRef, null).max

    // Helper function to generate random selection count
    def getRandomSelectionCount = { int availableCount -&gt;
        def maxPossible = Math.min(availableCount, maxSelection)
        def minPossible = Math.min(minSelection, maxPossible)
        return minPossible + rand.nextInt((maxPossible - minPossible) + 1)
    }

    // Resource Type Assignment
    if (rtCount &gt; 0) {
        logRef.info(&quot;Processing Resource Types (${rtCount} found)&quot;)

        for (int i = 1; i &lt;= rtCount; i++) {
            def rtName = varsRef.get(&quot;resourceTypeName_&quot; + i)
            def resourceTypeId = varsRef.get(&quot;resourceTypeId_&quot; + i)

            if (resourceTypeId) {
                // Get alias and isMultiple from mapping
                def mapping = resourceTypeToAlias[resourceTypeId]
                def varName = mapping?.alias
                def isMultiple = mapping?.isMultiple ?: false

                if (varName) {
                    def resCount = varsRef.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_count&quot;)?.toInteger() ?: 0

                    if (resCount &gt; 0) {
                        if (isMultiple) {
                            // Multi-select: pick multiple resources
                            def selectCount = getRandomSelectionCount(resCount)
                            def indices = (1..resCount).toList()
                            Collections.shuffle(indices, rand)
                            def selectedIds = []
                            indices.take(selectCount).each { idx -&gt;
                                def resId = varsRef.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                if (resId) selectedIds.add(resId)
                            }
                            varsRef.put(varName, selectedIds.join(&quot;,&quot;))
                            logRef.info(&quot;   ${rtName}  to  ${varName} (isMultiple=true, ${selectCount} selected) = ${selectedIds.join(&apos;, &apos;)}&quot;)
                        } else {
                            // Single-select: pick one random resource
                            def idx = rand.nextInt(resCount) + 1
                            def selectedResourceId = varsRef.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                            varsRef.put(varName, selectedResourceId)
                            logRef.info(&quot;   ${rtName}  to  ${varName} = ${selectedResourceId}&quot;)
                        }
                    } else {
                        logRef.warn(&quot;   ${rtName}  to  No resources found&quot;)
                    }
                } else {
                    logRef.warn(&quot;   ${rtName}  to  No alias mapping found&quot;)
                }
            }
        }
    }

    // Master Type Assignment
    if (mtCount &gt; 0) {
        logRef.info(&quot;Processing Master Types (${mtCount} found)&quot;)

        for (int i = 1; i &lt;= mtCount; i++) {
            def mtName = varsRef.get(&quot;masterTypeName_&quot; + i)
            def masterTypeId = varsRef.get(&quot;masterTypeId_&quot; + i)

            if (masterTypeId) {
                // Get alias and isMultiple from mapping
                def mapping = masterTypeToAlias[masterTypeId]
                def varName = mapping?.alias
                def isMultiple = mapping?.isMultiple ?: false

                if (varName) {
                    def masCount = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_count&quot;)?.toInteger() ?: 0

                    if (masCount &gt; 0) {
                        if (isMultiple) {
                            // Multi-select: pick multiple masters
                            def selectCount = getRandomSelectionCount(masCount)
                            def indices = (1..masCount).toList()
                            Collections.shuffle(indices, rand)
                            def selectedIds = []
                            indices.take(selectCount).each { idx -&gt;
                                def masId = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                if (masId) selectedIds.add(masId)
                            }
                            varsRef.put(varName, selectedIds.join(&quot;,&quot;))
                            logRef.info(&quot;   ${mtName}  to  ${varName} (isMultiple=true, ${selectCount} selected) = ${selectedIds.join(&apos;, &apos;)}&quot;)
                        } else {
                            // Single-select: pick one random master
                            def idx = rand.nextInt(masCount) + 1
                            def selectedMasterId = varsRef.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                            varsRef.put(varName, selectedMasterId)
                            logRef.info(&quot;   ${mtName}  to  ${varName} = ${selectedMasterId}&quot;)
                        }
                    } else {
                        logRef.warn(&quot;   ${mtName}  to  No masters found&quot;)
                    }
                } else {
                    logRef.warn(&quot;   ${mtName}  to  No alias mapping found&quot;)
                }
            }
        }
    }

        }
}
props.put(&quot;fn_resourceMasterAssigner&quot;, _fn_resourceMasterAssigner)


// Parses the Create Request API response to extract and store the new requestId, requestFormId, and initial request status for use in subsequent steps.
def _fn_createRequestStatusPostProcessor = { varsRef, prevRef, logRef -&gt;
    // Validate Previous Request Status
    if (prevRef.isSuccessful()) {
        // Request created successfully
        varsRef.put(&quot;requestCreated&quot;, &quot;true&quot;)
        varsRef.put(&quot;requestFailed&quot;, &quot;false&quot;)
        logRef.info(&quot;Status: SUCCESS&quot;)

        try {
            def responseData = new groovy.json.JsonSlurper().parseText(prevRef.getResponseDataAsString())
            def requestTimezone = responseData?.data?.timezone

            def currentBaseTimezone = varsRef.get(&quot;baseTimezone&quot;) ?: &quot;&quot;

            if (requestTimezone &amp;&amp; requestTimezone.toString().trim() != &quot;&quot;) {
                // Response HAS timezone  → use it
                varsRef.put(&quot;baseTimezone&quot;, requestTimezone.toString().trim())
                logRef.info(&quot;TIMEZONE: Using request-level timezone: &quot; + requestTimezone + &quot; (was: &quot; + currentBaseTimezone + &quot;)&quot;)
            } else {
                // Response has NO timezone (physical location) → keep parent category timezone
                logRef.info(&quot;TIMEZONE: Keeping parent category timezone: &quot; + currentBaseTimezone + &quot; (no timezone in response)&quot;)
            }
        } catch (Exception e) {
            logRef.warn(&quot;TIMEZONE: Could not parse response, keeping baseTimezone: &quot; + varsRef.get(&quot;baseTimezone&quot;) + &quot; | Error: &quot; + e.message)
        }

    } else {
        // Request failed - skip remaining steps
        varsRef.put(&quot;requestCreated&quot;, &quot;false&quot;)
        varsRef.put(&quot;requestFailed&quot;, &quot;true&quot;)
        logRef.info(&quot;Status: FAILED to Remaining steps will be skipped&quot;)
    }
}
props.put(&quot;fn_createRequestStatusPostProcessor&quot;, _fn_createRequestStatusPostProcessor)

// Reads the available state actions from the request API response, filters against targetActions, and stores the selected action in selectedAction; sets skipRequestStateAction if no match found.
def _fn_requestStateActionSelectorPostProcessor = { varsRef, prevRef, logRef -&gt;

    // Track State Action iteration
    def stateActionIteration = (varsRef.get(&quot;stateActionIteration&quot;)?.toInteger() ?: 0) + 1
    varsRef.put(&quot;stateActionIteration&quot;, stateActionIteration.toString())

    def totalIterations = varsRef.get(&quot;stateActionLoopCount&quot;) ?: &quot;0&quot;

    // STEP 1: Parse JSON Response
    def json = new groovy.json.JsonSlurper().parseText(prevRef.getResponseDataAsString())

    // Get current status from response and set sampler label
    def statusCode = json.status?.stateCode ?: &quot;UNKNOWN&quot;

    // Get original sampler name from HTTP Request
    def originalName = prevRef.getSampleLabel()

    prevRef.setSampleLabel(&quot;${originalName} - ${statusCode}&quot;)
    logRef.info(&quot;Current Request Status: ${statusCode}&quot;)

    def links = json._links

    if (links == null) {
        logRef.error(&quot;No _links found in JSON response!&quot;)
        varsRef.put(&quot;skipRequestStateAction&quot;, &quot;true&quot;)
        varsRef.put(&quot;selectedAction&quot;, &quot;&quot;)
        return
    }

    // STEP 2: Get All Available Actions
    def actionKeys = links.keySet()
    logRef.info(&quot;Available Actions: &quot; + actionKeys)

    def includedActions = props.get(&quot;fn_parseActionList&quot;)(varsRef.get(&quot;targetActions&quot;) ?: &quot;&quot;)
    logRef.info(&quot;Included State Actions (targetActions): &quot; + includedActions)
    logRef.info(&quot;Current Iteration: ${stateActionIteration}&quot;)

    // STEP 3: iteration 1 = SUBMIT (only if not already SUBMITTED); remaining = random from targetActions filter
    def selectedAction = null
    def selectedHref = null

    def alreadySubmitted = (statusCode?.toUpperCase()?.trim() == &quot;SUBMITTED&quot;)

    if (stateActionIteration == 1 &amp;&amp; !alreadySubmitted) {
        logRef.info(&quot;Iteration 1 - looking for hardcoded action: SUBMIT&quot;)
        def matchedKey = actionKeys.find { it.toUpperCase().trim() == &quot;SUBMIT&quot; }
        if (matchedKey) {
            selectedAction = matchedKey
            selectedHref = links[matchedKey]?.href
            if (!selectedHref) {
                logRef.warn(&quot;WARNING: SUBMIT found in _links but has no href - skipping iteration. Check DB configuration.&quot;)
                varsRef.put(&quot;skipRequestStateAction&quot;, &quot;true&quot;)
                varsRef.put(&quot;selectedAction&quot;, &quot;&quot;)
                return
            }
        } else {
            logRef.warn(&quot;WARNING: SUBMIT not found in _links ${actionKeys} - skipping iteration. Check DB configuration.&quot;)
            varsRef.put(&quot;skipRequestStateAction&quot;, &quot;true&quot;)
            varsRef.put(&quot;selectedAction&quot;, &quot;&quot;)
            varsRef.put(&quot;exitStateActionLoop&quot;, &quot;true&quot;)
            return
        }
    } else {
        // Already SUBMITTED (e.g. second user) or iteration &gt; 1 — go straight to targetActions
        if (alreadySubmitted &amp;&amp; stateActionIteration == 1) {
            logRef.info(&quot;Request already in SUBMITTED state — skipping SUBMIT, proceeding directly to targetActions.&quot;)
        }

        def allowedActions = actionKeys.findAll { key -&gt;
            includedActions.isEmpty() || includedActions.contains(key.toUpperCase().trim())
        }
        logRef.info(&quot;Allowed Actions from targetActions: &quot; + allowedActions)

        if (allowedActions.isEmpty()) {
            logRef.warn(&quot;WARNING: No matching actions found in _links ${actionKeys} for targetActions ${includedActions} - skipping iteration. Check DB configuration or targetActions UDV.&quot;)
            varsRef.put(&quot;skipRequestStateAction&quot;, &quot;true&quot;)
            varsRef.put(&quot;selectedAction&quot;, &quot;&quot;)
            varsRef.put(&quot;exitStateActionLoop&quot;, &quot;true&quot;)
            return
        }

        def random = java.util.concurrent.ThreadLocalRandom.current()
        selectedAction = allowedActions[random.nextInt(allowedActions.size())]
        selectedHref = links[selectedAction]?.href

        if (!selectedHref) {
            logRef.warn(&quot;WARNING: Selected action &apos;${selectedAction}&apos; has no href in _links - skipping iteration. Check DB configuration.&quot;)
            varsRef.put(&quot;skipRequestStateAction&quot;, &quot;true&quot;)
            varsRef.put(&quot;selectedAction&quot;, &quot;&quot;)
            return
        }

        // A targetAction was picked — signal loop to exit after this iteration
        logRef.info(&quot;targetAction &apos;${selectedAction}&apos; selected — loop will exit after this iteration.&quot;)
        varsRef.put(&quot;exitStateActionLoop&quot;, &quot;true&quot;)
    }

    // STEP 5: Set selected action
    varsRef.put(&quot;selectedAction&quot;, selectedAction)
    varsRef.put(&quot;selectedHref&quot;, selectedHref)
    varsRef.put(&quot;skipRequestStateAction&quot;, &quot;false&quot;)
    logRef.info(&quot;Selected Action: &quot; + selectedAction)
    logRef.info(&quot;Selected Href: &quot; + selectedHref)

    logRef.info(&quot;----- Terminated: State Action Selector (${stateActionIteration}/${totalIterations}) -----&quot;)
}
props.put(&quot;fn_requestStateActionSelectorPostProcessor&quot;, _fn_requestStateActionSelectorPostProcessor)

// Parses the New Request Config API response to extract and store journey, page, module, and form configuration variables (IDs, names, entry counts) as indexed variables for the form loop.
def _fn_newRequestConfigPostProcessor = { varsRef, prevRef, logRef -&gt;

    // STEP 1: Parse API Response
    def response = prevRef.getResponseDataAsString()
    def json = new groovy.json.JsonSlurper().parseText(response)

    // STEP 2: Extract Configs Array
    def configs = json._embedded?.configs ?: []

    // STEP 3: Process First Config
    if (configs.size() &gt; 0) {
        def config = configs[0]
        // Request-Specific Variables (for Create Request API)
        varsRef.put(&quot;requestModuleId&quot;, config.module?.uniqueId ?: &quot;&quot;)
        varsRef.put(&quot;requestJourneyId&quot;, config.journey?.uniqueId ?: &quot;&quot;)
        varsRef.put(&quot;requestPageId&quot;, config.page?.uniqueId ?: &quot;&quot;)
        varsRef.put(&quot;requestFormId&quot;, config.form?.uniqueId ?: &quot;&quot;)
        varsRef.put(&quot;requestFormName&quot;, config.form?.formName ?: &quot;&quot;)

        // Current Variables (for Dynamic Payload Builder)
        varsRef.put(&quot;currentJourneyId&quot;, config.journey?.uniqueId ?: &quot;&quot;)
        varsRef.put(&quot;currentPageId&quot;, config.page?.uniqueId ?: &quot;&quot;)
        varsRef.put(&quot;currentFormId&quot;, config.form?.uniqueId ?: &quot;&quot;)
        varsRef.put(&quot;currentFormName&quot;, config.form?.formName ?: &quot;&quot;)
        varsRef.put(&quot;currentIsMultiEntry&quot;, config.isMultiEntry?.toString() ?: &quot;false&quot;)

        // API Call Variables (for HTTP request paths &amp; payload)
        varsRef.put(&quot;moduleId&quot;, config.module?.uniqueId ?: &quot;&quot;)
        varsRef.put(&quot;formId&quot;, config.form?.uniqueId ?: &quot;&quot;)

        // Log Extracted Details
        logRef.info(&quot;Module ID: &quot; + varsRef.get(&quot;requestModuleId&quot;))
        logRef.info(&quot;Journey ID: &quot; + varsRef.get(&quot;requestJourneyId&quot;))
        logRef.info(&quot;Page ID: &quot; + varsRef.get(&quot;requestPageId&quot;))
        logRef.info(&quot;Form ID: &quot; + varsRef.get(&quot;requestFormId&quot;))
        //)

    } else {
        // No Config Found - Set Empty Variables
        logRef.warn(&quot;No configs found for New Request module&quot;)

        // Clear request variables
        varsRef.put(&quot;requestModuleId&quot;, &quot;&quot;)
        varsRef.put(&quot;requestJourneyId&quot;, &quot;&quot;)
        varsRef.put(&quot;requestPageId&quot;, &quot;&quot;)
        varsRef.put(&quot;requestFormId&quot;, &quot;&quot;)
        varsRef.put(&quot;requestFormName&quot;, &quot;&quot;)

        // Clear current variables
        varsRef.put(&quot;currentJourneyId&quot;, &quot;&quot;)
        varsRef.put(&quot;currentPageId&quot;, &quot;&quot;)
        varsRef.put(&quot;currentFormId&quot;, &quot;&quot;)
        varsRef.put(&quot;currentFormName&quot;, &quot;&quot;)

        // Clear API call variables
        varsRef.put(&quot;moduleId&quot;, &quot;&quot;)
        varsRef.put(&quot;formId&quot;, &quot;&quot;)
    }

    logRef.info(&quot;----- Terminated: Extract New Request Module Config -----&quot;)
}
props.put(&quot;fn_newRequestConfigPostProcessor&quot;, _fn_newRequestConfigPostProcessor)

// Parses the Activity Type Config API response to extract and store all form configs (primary + secondary), resource type IDs, and document form details as indexed variables for the activity form loop.
def _fn_activityTypeConfigPostProcessor = { varsRef, prevRef, logRef -&gt;

    // ACTIVITY TYPE CONFIG POST PROCESSOR
    // Extracts form, journey, and page details from module configs API response
    // Stores indexed variables for primary and secondary forms

    def activityType = varsRef.get(&quot;activityType&quot;) ?: &quot;unknown&quot;

    // STEP 1: Parse API Response
    def response = prevRef.getResponseDataAsString()
    def json = new groovy.json.JsonSlurper().parseText(response)

    // STEP 2: Extract Configs Array
    def configs = json._embedded?.configs ?: []
    def totalConfigs = configs.size()

    varsRef.put(&quot;activityConfigsCount&quot;, totalConfigs.toString())

    // ===== Form Entry UDV Cheat Sheet =====
    // Printed every time configs are loaded so tester knows which uniqueId to use in formN/formNRange pairs
    def multiEntryForms = configs.findAll { it.isMultiEntry &amp;&amp; it.form?.uniqueId }
    if (multiEntryForms) {
        logRef.info(&quot;====== Form Entry UDV Cheat Sheet ======&quot;)
        logRef.info(&quot;Pair formN (uniqueId) with formNRange (entry count):&quot;)
        logRef.info(&quot;  form1=&lt;uniqueId&gt;  form1Range=2,5&quot;)
        logRef.info(&quot;  Form UniqueId                              Form Name  (formIdentifier)&quot;)
        multiEntryForms.each { cfg -&gt;
            def uid        = cfg.form.uniqueId
            def typeName   = cfg.form?.formType?.formTypeName ?: cfg.form?.formName ?: cfg.form?.formIdentifier ?: uid
            def identifier = cfg.form?.formIdentifier ?: &quot;&quot;
            logRef.info(&quot;  &quot; + uid.padRight(42) + &quot; →  &quot; + typeName + &quot;  (&quot; + identifier + &quot;)&quot;)
        }
        logRef.info(&quot;formNRange examples:  2,4 = random 2 to 4  |  3 = exactly 3  |  0 = skip&quot;)
        logRef.info(&quot;If no formN matches — falls back to multiFormRange&quot;)
        logRef.info(&quot;=========================================&quot;)
    }

    // Clear document form vars from previous activity type
    varsRef.put(&quot;activityDocumentFormId&quot;, &quot;&quot;)
    varsRef.put(&quot;activityDocumentFormName&quot;, &quot;&quot;)
    varsRef.put(&quot;activityDocumentFormUIConfig&quot;, &quot;&quot;)

    // STEP 3: Handle Empty Response
    if (totalConfigs == 0) {
        logRef.warn(&quot;No configs found for ${activityType}&quot;)

        // Clear primary variables
        varsRef.put(&quot;formId&quot;, &quot;&quot;)
        varsRef.put(&quot;currentFormName&quot;, &quot;&quot;)
        varsRef.put(&quot;activityJourneyId&quot;, &quot;&quot;)
        varsRef.put(&quot;activityPageId&quot;, &quot;&quot;)
        varsRef.put(&quot;activityTotalEntries&quot;, &quot;0&quot;)
        varsRef.put(&quot;activitySecondaryConfigCount&quot;, &quot;0&quot;)
        varsRef.put(&quot;activityResourceTypeIds_count&quot;, &quot;0&quot;)
        varsRef.put(&quot;activityMasterTypeIds_count&quot;, &quot;0&quot;)

        // Clear ALL indexed ResourceType/MasterType variables to prevent stale data
        for (int i = 1; i &lt;= 20; i++) {
            varsRef.remove(&quot;activityResourceTypeId_&quot; + i)
            varsRef.remove(&quot;activityResourceTypeName_&quot; + i)
            varsRef.remove(&quot;activityMasterTypeId_&quot; + i)
            varsRef.remove(&quot;activityMasterTypeName_&quot; + i)
        }

        // Config exit
        return
    }

    // STEP 4: Extract Primary Config (Index 0)
    def primaryConfig = configs[0]

    // Journey Details
    varsRef.put(&quot;activityJourneyId&quot;, primaryConfig.journey?.uniqueId ?: &quot;&quot;)
    varsRef.put(&quot;activityJourneyName&quot;, primaryConfig.journey?.journeyName ?: &quot;&quot;)

    // Page Details
    varsRef.put(&quot;activityPageId&quot;, primaryConfig.page?.uniqueId ?: &quot;&quot;)
    varsRef.put(&quot;activityPageName&quot;, primaryConfig.page?.pageName ?: &quot;&quot;)

    // Form Details (used by Field Mappings and Form Fields APIs)
    varsRef.put(&quot;formId&quot;, primaryConfig.form?.uniqueId ?: &quot;&quot;)
    varsRef.put(&quot;currentFormName&quot;, primaryConfig.form?.formName ?: &quot;&quot;)
    varsRef.put(&quot;activityFormIdentifier&quot;, primaryConfig.form?.formIdentifier ?: &quot;&quot;)

    // Entry Configuration (Dynamic with UDV Fallback)
    def isMultiEntry = primaryConfig.isMultiEntry ?: false
    def minEntries = 1
    def maxEntries = 1

    if (isMultiEntry) {
        def _activityFormIdentifier = primaryConfig.form?.formIdentifier ?: &quot;&quot;
        def _activityFormUniqueId   = primaryConfig.form?.uniqueId ?: &quot;&quot;
        (minEntries, maxEntries) = props.get(&quot;fn_multiFormEntries&quot;)(primaryConfig.minEntries, primaryConfig.maxEntries, vars, _activityFormIdentifier, _activityFormUniqueId)
    } else {
    }

    varsRef.put(&quot;activityIsMultiEntry&quot;, isMultiEntry.toString())
    varsRef.put(&quot;activityMinEntries&quot;, minEntries.toString())
    varsRef.put(&quot;activityMaxEntries&quot;, maxEntries.toString())

    // Calculate random entries for multi-entry forms
    def totalEntries = isMultiEntry ? (java.util.concurrent.ThreadLocalRandom.current().nextInt(maxEntries - minEntries + 1) + minEntries) : 1
    varsRef.put(&quot;activityTotalEntries&quot;, totalEntries.toString())

    // HELPER: Extract resourceTypeId and masterTypeId from formUIConfig
    // Sets topicMasterTypeId if masterTypeId found in primary form, presenterResourceTypeId for participant forms
    def extractResourceTypeId = { formUIConfigRaw, prefix, isPrimaryForm -&gt;
                try {
            def formUIConfig = []

            if (formUIConfigRaw instanceof String) {
                            def parsed = new groovy.json.JsonSlurper().parseText(formUIConfigRaw)
                formUIConfig = parsed?.config ?: parsed ?: []
                        } else if (formUIConfigRaw instanceof Map) {
                formUIConfig = formUIConfigRaw?.config ?: []
                        } else if (formUIConfigRaw instanceof List) {
                formUIConfig = formUIConfigRaw
                        } else {
                logRef.warn(&quot;[extractResourceTypeId] Unknown formUIConfigRaw type: ${formUIConfigRaw?.getClass()?.getName()}&quot;)
            }

            // CRITICAL FIX: Collect all fields including those inside SECTION items
            def allFields = []
            formUIConfig.each { item -&gt;
                            if (item?.type == &quot;SECTION&quot;) {
                    def sectionFields = item.formFields ?: []
                                    allFields.addAll(sectionFields)
                } else {
                    allFields.add(item)
                }
            }

                    allFields.each { field -&gt;
                def fieldName = field?.dataMapping ?: field?.formControlName ?: &quot;unknown&quot;
                def fieldType = field?.formControlType ?: field?.type ?: &quot;unknown&quot;
                            // Extract resourceTypeId (for RESOURCE type fields)
                def resourceTypeId = field?.resourceTypeId ?: field?.resourceType?.uniqueId ?: field?.resourceType?.id
                if (field?.resourceType instanceof String) {
                    resourceTypeId = field.resourceType
                }

                if (resourceTypeId) {
                    varsRef.put(prefix + &quot;resourceTypeId&quot;, resourceTypeId)
                                    if (!isPrimaryForm) {
                        varsRef.put(&quot;presenterResourceTypeId&quot;, resourceTypeId)
                                        }
                }

                // Extract masterTypeId (for MASTER type fields)
                def masterTypeId = field?.masterTypeId ?: field?.masterType?.uniqueId ?: field?.masterType?.id
                if (field?.masterType instanceof String) {
                    masterTypeId = field.masterType
                }

                // ALSO check if formControlType is MASTER - might have masterType as object
                if (fieldType == &quot;MASTER&quot; &amp;&amp; field?.masterType) {
                                    if (field.masterType instanceof Map) {
                                            masterTypeId = masterTypeId ?: field.masterType.uniqueId ?: field.masterType.id
                    }
                }

                if (masterTypeId) {
                    varsRef.put(prefix + &quot;masterTypeId&quot;, masterTypeId.toString())
                                    if (isPrimaryForm) {
                        varsRef.put(&quot;topicMasterTypeId&quot;, masterTypeId.toString())
                                        }
                }
            }

                } catch (Exception e) {
            logRef.error(&quot;[extractResourceTypeId] Error: ${e.message}&quot;)
            e.printStackTrace()
        }
    }

    // STEP 5: Store ALL Configs as Indexed Variables
    // Config 0 = Primary form, Config 1+ = Secondary forms (e.g., Participants)
    def secondaryConfigCount = 0
    varsRef.put(&quot;activityResourceTypeIds_count&quot;, &quot;0&quot;)  // Reset for this activity type

    configs.eachWithIndex { cfg, idx -&gt;
        def prefix = &quot;activityConfig_${idx}_&quot;

        // Form Details
        varsRef.put(prefix + &quot;formId&quot;, cfg.form?.uniqueId ?: &quot;&quot;)
        varsRef.put(prefix + &quot;formName&quot;, cfg.form?.formName ?: &quot;&quot;)
        varsRef.put(prefix + &quot;formIdentifier&quot;, cfg.form?.formIdentifier ?: &quot;&quot;)
        varsRef.put(prefix + &quot;handler&quot;, cfg.form?.handler ?: &quot;&quot;)

        // Journey &amp; Page
        varsRef.put(prefix + &quot;journeyId&quot;, cfg.journey?.uniqueId ?: &quot;&quot;)
        varsRef.put(prefix + &quot;pageId&quot;, cfg.page?.uniqueId ?: &quot;&quot;)
        varsRef.put(prefix + &quot;moduleId&quot;, varsRef.get(&quot;currentActivityModuleId&quot;) ?: cfg.module?.uniqueId ?: &quot;&quot;)

        // Entry Configuration (Dynamic with UDV Fallback)
        def cfgIsMultiEntry = cfg.isMultiEntry ?: false
        varsRef.put(prefix + &quot;isMultiEntry&quot;, cfgIsMultiEntry.toString())

        if (cfgIsMultiEntry) {
            def _cfgFormIdentifier = cfg.form?.formIdentifier ?: &quot;&quot;
            def _cfgFormUniqueId   = cfg.form?.uniqueId ?: &quot;&quot;
            def (udvMin, udvMax) = props.get(&quot;fn_multiFormEntries&quot;)(cfg.minEntries, cfg.maxEntries, vars, _cfgFormIdentifier, _cfgFormUniqueId)
            varsRef.put(prefix + &quot;minEntries&quot;, udvMin.toString())
            varsRef.put(prefix + &quot;maxEntries&quot;, udvMax.toString())
        } else {
            // isMultiEntry = false: Single entry only
            varsRef.put(prefix + &quot;minEntries&quot;, &quot;1&quot;)
            varsRef.put(prefix + &quot;maxEntries&quot;, &quot;1&quot;)
        }

        // FormUIConfig (handle both String and Object types)
        def uiConfig = cfg.form?.formUIConfig
        varsRef.put(prefix + &quot;formUIConfig&quot;, props.get(&quot;fn_normalizeFormUIConfig&quot;)(uiConfig))

        // Primary Config Processing (idx == 0) - Extract masterTypeId if exists
        if (idx == 0) {
                                                    def rawFormUIConfig = cfg.form?.formUIConfig
                    if (rawFormUIConfig == null) {
                logRef.error(&quot;formUIConfig is NULL!&quot;)
            } else if (rawFormUIConfig instanceof String) {
                                    } else if (rawFormUIConfig instanceof Map) {
                            if (rawFormUIConfig.config) {
                                    rawFormUIConfig.config.eachWithIndex { item, i -&gt;
                                            if (item?.type == &quot;SECTION&quot;) {
                                                    item.formFields?.eachWithIndex { ff, j -&gt;
                                                        }
                        } else if (item?.formControlType == &quot;MASTER&quot; || item?.type == &quot;MASTER&quot;) {
                                                }
                    }
                }
            }

            extractResourceTypeId(cfg.form?.formUIConfig, prefix, true)
                                }
                                
        // Secondary Config Processing (idx &gt; 0) - Extract resourceTypeId for participant forms
        if (idx &gt; 0) {
            secondaryConfigCount++

            // Check if formUIConfig has resourceTypeId (indicates participant/resource selector)
            // FIX: Handle both flat fields AND nested SECTION structures
            def hasResourceTypeId = false
            try {
                def formUIConfig = []
                if (uiConfig instanceof String &amp;&amp; uiConfig.trim()) {
                    def parsed = new groovy.json.JsonSlurper().parseText(uiConfig)
                    formUIConfig = parsed?.config ?: []
                } else if (uiConfig instanceof Map) {
                    formUIConfig = uiConfig?.config ?: []
                }

                // Flatten all fields from both top-level and SECTION items
                def allFieldsToCheck = []
                formUIConfig.each { item -&gt;
                    if (item?.type == &quot;SECTION&quot;) {
                        allFieldsToCheck.addAll(item.formFields ?: [])
                    } else if (item?.type == &quot;FORMFIELD&quot;) {
                        allFieldsToCheck.add(item)
                    } else {
                        // Also check top-level items directly
                        allFieldsToCheck.add(item)
                    }
                }

                hasResourceTypeId = allFieldsToCheck.any { field -&gt; field?.resourceTypeId }

                if (hasResourceTypeId) {
                                }
            } catch (Exception e) {
                logRef.warn(&quot;Could not check resourceTypeId: ${e.message}&quot;)
            }

            varsRef.put(prefix + &quot;isParticipantForm&quot;, hasResourceTypeId.toString())

            // Extract resourceTypeId from formUIConfig (sets presenterResourceTypeId for participant forms)
            extractResourceTypeId(cfg.form?.formUIConfig, prefix, false)

            // DIRECTLY set activityResourceTypeId for ForEach controller
            def extractedRtId = varsRef.get(prefix + &quot;resourceTypeId&quot;)
            if (extractedRtId) {
                varsRef.put(&quot;activityResourceTypeId_&quot; + secondaryConfigCount, extractedRtId)
                varsRef.put(&quot;activityResourceTypeName_&quot; + secondaryConfigCount, cfg.form?.formName)
                varsRef.put(&quot;activityResourceTypeIds_count&quot;, secondaryConfigCount.toString())
                        }

                                }

        // DOCUMENT FORM DETECTION: Check formIdentifier for DOCUMENT form
        def cfgFormIdentifier = cfg.form?.formIdentifier ?: &quot;&quot;
        def cfgHandler = cfg.form?.handler ?: &quot;&quot;
        if (cfgFormIdentifier == &quot;DOCUMENT&quot; || cfgHandler == &quot;documentFormHandler&quot;) {
            varsRef.put(&quot;activityDocumentFormId&quot;, cfg.form?.uniqueId ?: &quot;&quot;)
            varsRef.put(&quot;activityDocumentFormName&quot;, cfg.form?.formName ?: &quot;Topic Document&quot;)
            def docUIConfig = cfg.form?.formUIConfig
            if (docUIConfig instanceof String) {
                varsRef.put(&quot;activityDocumentFormUIConfig&quot;, docUIConfig)
            } else {
                varsRef.put(&quot;activityDocumentFormUIConfig&quot;, groovy.json.JsonOutput.toJson(docUIConfig ?: [:]))
            }
            logRef.info(&quot;[Config] DOCUMENT form detected: ${cfg.form?.formName} id=${cfg.form?.uniqueId}&quot;)
        }
    }

    varsRef.put(&quot;activitySecondaryConfigCount&quot;, secondaryConfigCount.toString())
    
}
props.put(&quot;fn_activityTypeConfigPostProcessor&quot;, _fn_activityTypeConfigPostProcessor)
log.info(&quot;Common Function - Payload and PostProcessors initialized&quot;)
