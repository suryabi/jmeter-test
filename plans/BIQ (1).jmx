        <hashTree/>
        <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Agenda Variables" enabled="true">
          <collectionProp name="Arguments.arguments">
            <elementProp name="rooms" elementType="Argument">
              <stringProp name="Argument.name">rooms</stringProp>
              <stringProp name="Argument.value">2,3</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Rooms to create per activity day — randomly picked (e.g. 1,2,3). 0 or empty = no rooms. Ignored if allowedRooms variable value is set</stringProp>
            </elementProp>
            <elementProp name="locationResourceType" elementType="Argument">
              <stringProp name="Argument.name">locationResourceType</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, LABEL=locationResourceType. Resource type used to load location resources</stringProp>
            </elementProp>
            <elementProp name="locationResourceUniqueId" elementType="Argument">
              <stringProp name="Argument.name">locationResourceUniqueId</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, LABEL=locationResource. Used as the parent location for loading allowed rooms. Requires a Location Resource Type</stringProp>
            </elementProp>
            <elementProp name="allowedRooms" elementType="Argument">
              <stringProp name="Argument.name">allowedRooms</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, MULTI. Limit room creation to specific rooms only. Empty = selects from all vacant rooms based on the room count. When specified, only the selected rooms are used. Requires a Location Resource</stringProp>
            </elementProp>
            <elementProp name="roomBufferMinutes" elementType="Argument">
              <stringProp name="Argument.name">roomBufferMinutes</stringProp>
              <stringProp name="Argument.value">30,60</stringProp>
              <stringProp name="Argument.desc">Minutes to adjust logistics room timings. Comma-separated values (e.g., 30,60); for each room, the start and end buffer are each independently selected at random from the list (may match or differ) — start buffer is added to the start time, end buffer is subtracted from the end time</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
            <elementProp name="vacantSlotDurations" elementType="Argument">
              <stringProp name="Argument.name">vacantSlotDurations</stringProp>
              <stringProp name="Argument.value">30,60,45</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Vacant slot duration in minutes for activity types like topics, caterings (positive integers, comma-separated, e.g. 30,60). 0 or empty = skip</stringProp>
            </elementProp>
            <elementProp name="caterings" elementType="Argument">
              <stringProp name="Argument.name">caterings</stringProp>
              <stringProp name="Argument.value">10%</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Caterings per room. Enter percentage values (e.g., 50%, 80%). One value is chosen randomly. 0 or empty = none; negative values = skip</stringProp>
            </elementProp>
            <elementProp name="cateringTimings" elementType="Argument">
              <stringProp name="Argument.name">cateringTimings</stringProp>
              <stringProp name="Argument.value">11:30, 12:00, 12:30, 13:00, 19:00, 19:30, 20:00, 20:30</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Allowed catering start times. Enter comma-separated times in HH:mm format (e.g., 11:00,11:30); one value is selected randomly. Empty = any available slot</stringProp>
            </elementProp>
            <elementProp name="topics" elementType="Argument">
              <stringProp name="Argument.name">topics</stringProp>
              <stringProp name="Argument.value">60%</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Topics per room. Enter percentage values (e.g., 50%, 80%). One value is chosen randomly. 0 or empty = none; negative values = skip</stringProp>
            </elementProp>
            <elementProp name="topicTimings" elementType="Argument">
              <stringProp name="Argument.name">topicTimings</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Allowed start times for topics. Enter comma-separated times in HH:mm format (e.g., 10:00,10:30). Empty = any available slot in the room</stringProp>
            </elementProp>
            <elementProp name="presenters" elementType="Argument">
              <stringProp name="Argument.name">presenters</stringProp>
              <stringProp name="Argument.value">5</stringProp>
              <stringProp name="Argument.desc">Presenters to create per request. Comma-separated values (e.g., 3,5); one value is selected randomly. 0 or empty = none</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
            <elementProp name="presentersPerTopic" elementType="Argument">
              <stringProp name="Argument.name">presentersPerTopic</stringProp>
              <stringProp name="Argument.value">1,2,3</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Presenters to assign per topic. Enter comma-separated values (e.g., 1,2,3); one value is selected randomly. 0 or empty = skip</stringProp>
            </elementProp>
          </collectionProp>
        </Arguments>
        <hashTree/>
        <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Configuration Variables" enabled="true">
          <collectionProp name="Arguments.arguments">
            <elementProp name="journeyModuleType" elementType="Argument">
              <stringProp name="Argument.name">journeyModuleType</stringProp>
              <stringProp name="Argument.value">JOURNEY</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, HIDE. Module type of Journey</stringProp>
