                </JSR223PreProcessor>
                <hashTree/>
                <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Get Module Config - ${currentModuleName}" enabled="true">
                  <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
                    <collectionProp name="Arguments.arguments"/>
                  </elementProp>
                  <stringProp name="HTTPSampler.domain"></stringProp>
                  <stringProp name="HTTPSampler.port"></stringProp>
                  <stringProp name="HTTPSampler.protocol"></stringProp>
                  <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                  <stringProp name="HTTPSampler.path">/${contextname}/api/modules/${moduleId}/configs</stringProp>
                  <stringProp name="HTTPSampler.method">GET</stringProp>
                  <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
                  <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                  <boolProp name="HTTPSampler.use_keepalive">false</boolProp>
                  <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                  <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                  <stringProp name="HTTPSampler.connect_timeout">30000</stringProp>
                  <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
                </HTTPSamplerProxy>
                <hashTree>
                  <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                    <collectionProp name="HeaderManager.headers">
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-customerid</stringProp>
                        <stringProp name="Header.value">${customerId}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                        <stringProp name="Header.value">${categoryTypeId}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                        <stringProp name="Header.value">${categoryId}</stringProp>
                      </elementProp>
                    </collectionProp>
                  </HeaderManager>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Module Config PostProcessor" enabled="true">
                    <stringProp name="script">

log.info(&quot;Module: &quot; + vars.get(&quot;currentModuleName&quot;))

// STEP 1: Parse API Response
def response = prev.getResponseDataAsString()
def json = new groovy.json.JsonSlurper().parseText(response)

// STEP 2: Extract Configs Array (only active configs)
def allConfigs = json._embedded?.configs ?: []
def configs = allConfigs.findAll { it.isActive }
def totalConfigs = configs.size()

// STEP 3: Clear Previous Config Variables
def prevConfigCount = (vars.get(&quot;moduleConfigsCount&quot;) ?: &quot;0&quot;).toInteger()
for (int i = 1; i &lt;= prevConfigCount + 5; i++) {
    vars.remove(&quot;journeyId_&quot; + i)
    vars.remove(&quot;journeyName_&quot; + i)
    vars.remove(&quot;pageId_&quot; + i)
    vars.remove(&quot;pageName_&quot; + i)
    vars.remove(&quot;formId_&quot; + i)
    vars.remove(&quot;formName_&quot; + i)
    vars.remove(&quot;formIdentifier_&quot; + i)
    vars.remove(&quot;formHandler_&quot; + i)
    vars.remove(&quot;isMultiEntry_&quot; + i)
    vars.remove(&quot;minEntries_&quot; + i)
    vars.remove(&quot;maxEntries_&quot; + i)
}

// STEP 4: Store Count for ForEach Controller
vars.put(&quot;moduleConfigsCount&quot;, totalConfigs.toString())

// STEP 5: Handle Empty Config - Skip to Calendar Flow
if (totalConfigs == 0) {
    log.info(&quot;No configs found for &quot; + vars.get(&quot;currentModuleName&quot;) + &quot; - entering calendar flow&quot;)
    vars.put(&quot;skipActivityType&quot;, &quot;true&quot;)
    vars.put(&quot;skipToCalendar&quot;, &quot;true&quot;)
    vars.put(&quot;configIndex&quot;, &quot;0&quot;)
    vars.put(&quot;moduleFormHandler&quot;, &quot;&quot;)
    log.info(&quot;moduleConfigsCount set to: 0&quot;)
    return
}

// Reset skip flags when config exists
vars.put(&quot;skipActivityType&quot;, &quot;false&quot;)
vars.put(&quot;skipToCalendar&quot;, &quot;false&quot;)

// STEP 6: Extract and Store Config Details
configs.eachWithIndex { config, idx -&gt;
    def i = idx + 1

    // Journey Details
    vars.put(&quot;journeyId_&quot; + i, config.journey?.uniqueId ?: &quot;&quot;)
    vars.put(&quot;journeyName_&quot; + i, config.journey?.journeyName ?: &quot;&quot;)

    // Page Details
    vars.put(&quot;pageId_&quot; + i, config.page?.uniqueId ?: &quot;&quot;)
    vars.put(&quot;pageName_&quot; + i, config.page?.pageName ?: &quot;&quot;)

    // Module Details
    vars.put(&quot;moduleId_&quot; + i, config.module?.uniqueId ?: &quot;&quot;)

    // Form Details
    vars.put(&quot;formId_&quot; + i, config.form?.uniqueId ?: &quot;&quot;)
    vars.put(&quot;formName_&quot; + i, config.form?.formName ?: &quot;&quot;)
    vars.put(&quot;formIdentifier_&quot; + i, config.form?.formIdentifier ?: &quot;&quot;)
    vars.put(&quot;formHandler_&quot; + i, config.form?.handler ?: &quot;&quot;)

    // Entry Configuration (Priority: Config &gt; UDV)
    def isMultiEntry = config.isMultiEntry ?: false
    vars.put(&quot;isMultiEntry_&quot; + i, isMultiEntry.toString())

    if (isMultiEntry) {
        def _moduleFormIdentifier = config.form?.formIdentifier ?: &quot;&quot;
        def _moduleFormUniqueId   = config.form?.uniqueId ?: &quot;&quot;
        def (minVal, maxVal) = props.get(&quot;fn_multiFormEntries&quot;)(config.minEntries, config.maxEntries, vars, _moduleFormIdentifier, _moduleFormUniqueId)
        vars.put(&quot;minEntries_&quot; + i, minVal.toString())
        vars.put(&quot;maxEntries_&quot; + i, maxVal.toString())
    } else {
        vars.put(&quot;minEntries_&quot; + i, &quot;1&quot;)
        vars.put(&quot;maxEntries_&quot; + i, &quot;1&quot;)
    }
}

// STEP 7: Store Module-Level Form Handler (for If Condition check)
def moduleFormHandler = &quot;&quot;
if (configs.size() &gt; 0) {
    moduleFormHandler = configs[0].form?.handler ?: &quot;&quot;
}
vars.put(&quot;moduleFormHandler&quot;, moduleFormHandler)

// STEP 8: Reset Config Index for ForEach Iteration
vars.put(&quot;configIndex&quot;, &quot;0&quot;)

log.info(&quot;Module: ${vars.get(&apos;currentModuleName&apos;)} | Handler: ${moduleFormHandler} | Configs: ${totalConfigs}&quot;)</stringProp>
