                                    <hashTree/>
                                    <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Vacant Resource Id" enabled="true">
                                      <stringProp name="JSONPostProcessor.referenceNames">vacantSlotId</stringProp>
                                      <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.resourceTimeSlots[*].resources[*].uniqueId</stringProp>
                                      <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                                      <boolProp name="JSONPostProcessor.compute_concat">true</boolProp>
                                    </JSONPostProcessor>
