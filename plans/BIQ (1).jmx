                                          <hashTree/>
                                          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Zoom Link PostProcessor" enabled="true">
                                            <stringProp name="script">def responseCode = prev.getResponseCode()
def activityId = vars.get(&quot;activityId&quot;) ?: &quot;&quot;
def roomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown&quot;

if (responseCode == &quot;200&quot;) {
    log.info(&quot;✅ Zoom added successfully to Topic | Activity: &quot; + activityId + &quot; | Room: &quot; + roomName)
    vars.put(&quot;zoomLinkAdded&quot;, &quot;true&quot;)
} else {
    log.warn(&quot;❌ Failed to add Zoom | Response: &quot; + responseCode + &quot; | Activity: &quot; + activityId)
    vars.put(&quot;zoomLinkAdded&quot;, &quot;false&quot;)
}
</stringProp>
