                            <stringProp name="script">

log.info(&quot;Entered: Dynamic Resource PostProcessor&quot;)

// PURPOSE:
// - Extract and store resources from API response
// - Used for form payload generation
// - Supports multiple response formats (flat &amp; nested)

// Get current resource type being processed (set by ForEach Controller)
def currentResourceTypeId = vars.get(&quot;currentResourceTypeId&quot;)
log.info(&quot;Processing resourceTypeId: ${currentResourceTypeId}&quot;)
// STEP 1: Parse API Response
def response = prev.getResponseDataAsString()

// Validate response exists
if (!response || response.isEmpty()) {
    log.warn(&quot;Empty response - no resources found&quot;)
    vars.put(&quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_count&quot;, &quot;0&quot;)
    return
}

def json = new groovy.json.JsonSlurper().parseText(response)
// STEP 2: Extract Resources Array (supports multiple response formats)
def resources = json._embedded?.resources ?: json.resources ?: (json instanceof List ? json : [])

//}&quot;)
// STEP 3: Store Resources Keyed by ResourceTypeId
// Handles two data structures:
//   - Flat:   { uniqueId: &quot;xxx&quot;, displayName: &quot;yyy&quot; }
//   - Nested: { data: { uniqueId: &quot;xxx&quot;, searchDisplayText: &quot;yyy&quot; } }

def count = 0

resources.each { resource -&gt;
    count++

    // Handle both flat and nested (data) structures
    def data = resource.data ?: resource
    // Extract Unique ID (try multiple possible field names)
    def uniqueId = data.uniqueId ?:
                   data.id ?:
                   resource.uniqueId ?:
                   resource.id
    // Extract Display Name (try multiple possible field names)
    def displayName = data.searchDisplayText ?:
                      data.displayName ?:
                      data.resourceName ?:
                      data.name ?:
                      resource.displayName ?:
                      resource.name ?:
                      uniqueId  // Fallback to ID if no name found
    // Store Resource as JMeter Variables
    def varPrefix = &quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_&quot; + count
    vars.put(varPrefix + &quot;_id&quot;, uniqueId)
    vars.put(varPrefix + &quot;_name&quot;, displayName)
    def parentId = (resource?.parent?.uniqueId ?: resource?.parent?.id ?: data?.parent?.uniqueId ?: data?.parent?.id ?: data?.parentId)?.toString()?.trim() ?: &quot;&quot;
    vars.put(varPrefix + &quot;_parentId&quot;, parentId)

    log.info(&quot;[${count}] ${displayName} (${uniqueId})&quot;)
}
// STEP 4: Store Total Count for Later Iteration
vars.put(&quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_count&quot;, count.toString())

log.info(&quot;----- Terminated: Dynamic Resource PostProcessor -----&quot;)</stringProp>
