          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="👤 User - ${currentUser}" enabled="true">
            <stringProp name="script">def currentUser = vars.get(&quot;currentUser&quot;)
def firstUser = vars.get(&quot;user_1&quot;)
def userCount = vars.get(&quot;userCount&quot;) ?: &quot;1&quot;

// Find user index by matching against stored user_1, user_2, etc.
def userIndex = 0
for (int i = 1; i &lt;= userCount.toInteger(); i++) {
    def storedUser = vars.get(&quot;user_&quot; + i)
    log.info(&quot;DEBUG MATCH: user_&quot; + i + &quot;=&quot; + storedUser + &quot; vs currentUser=&quot; + currentUser + &quot; match=&quot; + (storedUser == currentUser))
    if (storedUser == currentUser) {
        userIndex = i
        break
    }
}

// Safety fallback
if (userIndex == 0) {
    log.error(&quot;Current user &apos;&quot; + currentUser + &quot;&apos; not found in user list! Defaulting to index 1&quot;)
    userIndex = 1
}

// Determine if this is the first user by comparing identity
def isFirstUser = (currentUser == firstUser) ? &quot;true&quot; : &quot;false&quot;
vars.put(&quot;isFirstUser&quot;, isFirstUser)
vars.put(&quot;userIterationIndex&quot;, userIndex.toString())

log.info(&quot;========================================&quot;)
log.info(&quot;USER ITERATION: &quot; + userIndex + &quot; of &quot; + userCount)
log.info(&quot;User: &quot; + currentUser)
log.info(&quot;First User: &quot; + firstUser)
log.info(&quot;Is First User: &quot; + isFirstUser)
log.info(&quot;========================================&quot;)

// For subsequent users - set flags to reuse existing request
if (isFirstUser != &quot;true&quot;) {
    def existingRequestId = vars.get(&quot;requestId&quot;)
    if (existingRequestId != null &amp;&amp; !existingRequestId.trim().isEmpty()) {
        vars.put(&quot;requestCreated&quot;, &quot;true&quot;)
        vars.put(&quot;requestFailed&quot;, &quot;false&quot;)
        log.info(&quot;SUBSEQUENT USER: Reusing requestId: &quot; + existingRequestId)
        log.info(&quot;Customer: &quot; + vars.get(&quot;customerName&quot;))
        log.info(&quot;CategoryType: &quot; + vars.get(&quot;categoryTypeName&quot;))
        log.info(&quot;Parent Category: &quot; + vars.get(&quot;parentCategoryName&quot;))
        log.info(&quot;Category: &quot; + vars.get(&quot;categoryName&quot;))
    } else {
        log.error(&quot;SUBSEQUENT USER but no requestId found from previous user!&quot;)
        vars.put(&quot;requestCreated&quot;, &quot;false&quot;)
        vars.put(&quot;requestFailed&quot;, &quot;true&quot;)
    }
}

def originalLabel = SampleResult.getSampleLabel()
SampleResult.setSampleLabel(&quot;───── &quot; + originalLabel + &quot; (&quot; + userIndex + &quot;/&quot; + userCount + &quot;) ─────&quot;)
SampleResult.setResponseData(&quot;User &quot; + userIndex + &quot;: &quot; + vars.get(&quot;currentUser&quot;) + &quot; | isFirstUser: &quot; + isFirstUser, &quot;UTF-8&quot;)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)
</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
          </JSR223Sampler>
          <hashTree/>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Calculate Request" enabled="true">
            <stringProp name="script">import java.time.*
import java.time.format.DateTimeFormatter

def dateFormatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;)
def timeFormatter = DateTimeFormatter.ofPattern(&quot;HH:mm&quot;)

// ===== VALIDATION: Check required UDV variables =====
def errors = []
def requestStartDate  = vars.get(&quot;requestStartDate&quot;)?.trim()
def requestEndDate    = vars.get(&quot;requestEndDate&quot;)?.trim()
def requestStartTimes = vars.get(&quot;requestStartTimes&quot;)?.trim()
def requestDurations  = vars.get(&quot;requestDurations&quot;)?.trim()
def categoryType      = vars.get(&quot;categoryType&quot;)?.trim()
def parentCategory    = vars.get(&quot;parentCategory&quot;)?.trim()
def category          = vars.get(&quot;category&quot;)?.trim()
def defaultUser       = vars.get(&quot;defaultUser&quot;)?.trim()

// Capture user-provided customerName once (-J props take precedence; vars may be overwritten per iteration)
if (vars.get(&quot;_userDefinedCustomerNameCaptured&quot;) != &quot;true&quot;) {
    def udnCustomer = (props.get(&quot;customerName&quot;) ?: vars.get(&quot;customerName&quot;) ?: &quot;&quot;).trim()
    vars.put(&quot;userDefinedCustomerName&quot;, udnCustomer)
    vars.put(&quot;_userDefinedCustomerNameCaptured&quot;, &quot;true&quot;)
    if (udnCustomer) {
        log.info(&quot;User-defined customerName (fixed for all iterations): ${udnCustomer}&quot;)
    } else {
        log.info(&quot;customerName not set — a unique random customer will be picked per request iteration&quot;)
    }
}

// ===== Abort helper =====
def abort = { String msg, String responseMsg = &quot;&quot; -&gt;
    log.error(&quot;========================================&quot;)
    log.error(msg)
    log.error(&quot;Please fix these variables in User Defined Variables before running the test.&quot;)
    log.error(&quot;========================================&quot;)
    vars.put(&quot;totalRequestCount&quot;, &quot;0&quot;)
    vars.put(&quot;totalValidDays&quot;, &quot;0&quot;)
    SampleResult.setResponseData(msg, &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;400&quot;)
    if (responseMsg) SampleResult.setResponseMessage(responseMsg)
    SampleResult.setSuccessful(false)
    SampleResult.setStopTestNow(true)
}

// ===== Required field presence checks =====
[
    [requestStartDate,  &quot;requestStartDate is empty — set a value in UDV (format: yyyy-MM-dd, e.g. 2026-12-02)&quot;],
    [requestEndDate,    &quot;requestEndDate is empty — set a value in UDV (format: yyyy-MM-dd, e.g. 2026-12-31)&quot;],
    [requestStartTimes, &quot;requestStartTimes is empty — set a value in UDV (format: HH:mm comma-separated, e.g. 07:00,08:00,09:00)&quot;],
    [requestDurations,  &quot;requestDurations is empty — set a value in UDV (in minutes comma-separated, e.g. 420,480,540,600)&quot;],
    [categoryType,      &quot;categoryType is empty — set a value in UDV (e.g. CATEGORY_TYPE_BRIEFINGS)&quot;],
    [parentCategory,    &quot;parentCategory is empty — set a value in UDV (UUID, e.g. 72DCAF42-C7C0-4006-8F31-7952185E5D61)&quot;],
    [category,          &quot;category is empty — set a value in UDV (UUID, e.g. D06189A1-69AF-4D17-AC5B-480F7589D427)&quot;],
    [defaultUser,       &quot;defaultUser is empty — set a value in UDV (e.g. supportuser@allianceit.com)&quot;]
].each { val, msg -&gt; if (!val) errors.add(msg) }

if (defaultUser &amp;&amp; !(defaultUser ==~ /^[^@]+@[^@]+\.[^@]+$/))
    errors.add(&quot;defaultUser must be a valid email (e.g. user@domain.com), got: &apos;${defaultUser}&apos;&quot;)

// ===== Date format + parse validation (shared closure) =====
def validateDate = { String val, String name -&gt;
    if (val &amp;&amp; !(val ==~ /\d{4}-\d{2}-\d{2}/)) {
        errors.add(&quot;${name} has invalid format: &apos;${val}&apos; (expected: yyyy-MM-dd, e.g. 2026-12-02)&quot;)
    } else if (val) {
        try { LocalDate.parse(val, dateFormatter) }
        catch (Exception e) { errors.add(&quot;${name} is not a valid date: &apos;${val}&apos; (${e.message})&quot;) }
    }
}
validateDate(requestStartDate, &quot;requestStartDate&quot;)
validateDate(requestEndDate,   &quot;requestEndDate&quot;)

// ===== requestStartTimes validation =====
if (requestStartTimes) {
    def rawTimes   = requestStartTimes.split(&quot;,&quot;).collect { it.trim() }
    def validTimes = rawTimes.findAll { t -&gt;
        if (!(t ==~ /^\d{2}:\d{2}$/)) return false
        try { LocalTime.parse(t, timeFormatter); return true } catch (Exception e) { return false }
    }
    def invalidTimes = rawTimes - validTimes
    if (validTimes.isEmpty())
        errors.add(&quot;requestStartTimes has no valid times: &apos;${requestStartTimes}&apos; (expected: HH:mm, e.g. 07:00,08:00,09:00)&quot;)
    else if (!invalidTimes.isEmpty())
        errors.add(&quot;requestStartTimes has invalid entries that will be skipped: ${invalidTimes} (expected: HH:mm, e.g. 07:00)&quot;)
}

// ===== requestDurations validation =====
if (requestDurations) {
    def rawDurations   = requestDurations.split(&quot;,&quot;).collect { it.trim() }
    def validDurations = rawDurations.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt;= 30 }
    def invalidDurations = rawDurations - validDurations
    if (validDurations.isEmpty())
        errors.add(&quot;requestDurations has no valid values: &apos;${requestDurations}&apos; (expected: integers &gt;= 30 minutes, e.g. 420,480,540,600)&quot;)
    else if (!invalidDurations.isEmpty())
        errors.add(&quot;requestDurations has invalid entries that will be skipped: ${invalidDurations} (must be &gt;= 30 minutes)&quot;)
}

// ===== Validate optional numeric comma-separated UDVs =====
def validateIntList = { String varName, String description -&gt;
    def raw = vars.get(varName)?.trim()
    if (raw &amp;&amp; raw != &quot;0&quot;) {
        def invalid = raw.split(&quot;,&quot;).collect { it.trim() }.findAll { !it.isInteger() || it.toInteger() &lt; 0 }
        if (!invalid.isEmpty())
            errors.add(&quot;${varName} has invalid entries: ${invalid} in &apos;${raw}&apos; (expected: ${description})&quot;)
    }
}

// ===== Validate required positive integer list =====
def validatePositiveIntList = { String varName, String description -&gt;
    def raw = vars.get(varName)?.trim()
    if (!raw || raw.isEmpty()) return
    def invalid = raw.split(&quot;,&quot;).collect { it.trim() }.findAll { !it.isInteger() || it.toInteger() &lt;= 0 }
    if (!invalid.isEmpty())
        errors.add(&quot;${varName} has invalid entries: ${invalid} in &apos;${raw}&apos; (expected: ${description})&quot;)
}

// ===== Validate time list =====
def validateTimeList = { String varName, String description -&gt;
    def raw = vars.get(varName)?.trim()
    if (raw) {
        def invalid = raw.split(&quot;,&quot;).collect { it.trim() }.findAll { t -&gt;
            if (!(t ==~ /^\d{2}:\d{2}$/)) return true
            try { LocalTime.parse(t, timeFormatter); return false } catch (Exception e) { return true }
        }
        if (!invalid.isEmpty())
            errors.add(&quot;${varName} has invalid entries: ${invalid} in &apos;${raw}&apos; (expected: ${description})&quot;)
    }
}

validatePositiveIntList(&quot;requestsPerDay&quot;,       &quot;positive integers, e.g. 1,2,3&quot;)
validatePositiveIntList(&quot;requestDays&quot;,          &quot;positive integers, e.g. 1,2,3,4,5&quot;)
validateIntList(&quot;rooms&quot;,                        &quot;positive integers, e.g. 1,2,3&quot;)
validateIntList(&quot;presenters&quot;,                   &quot;positive integers, e.g. 3,5&quot;)
validateIntList(&quot;presentersPerTopic&quot;,           &quot;positive integers, e.g. 1,2,3&quot;)
validateIntList(&quot;multiFormRange&quot;,              &quot;positive integers for min,max range, e.g. 1,5&quot;)

// ===== Validate multiFormRange min &lt;= max and exactly 2 values =====
def rawRange = vars.get(&quot;multiFormRange&quot;)?.trim()
if (rawRange &amp;&amp; rawRange != &quot;0&quot;) {
    def rangeParts = rawRange.split(&quot;,&quot;)*.trim()
    if (!rangeParts.every { it.isInteger() }) {
        errors.add(&quot;multiFormRange &apos;${rawRange}&apos; is invalid — must be positive integers e.g. 1,5&quot;)
    } else if (rangeParts.any { it.toInteger() &lt; 0 }) {
        errors.add(&quot;multiFormRange &apos;${rawRange}&apos; is invalid — negative values not allowed&quot;)
    } else if (rangeParts.size() &gt; 2) {
        errors.add(&quot;multiFormRange &apos;${rawRange}&apos; is invalid — expected either a single value (e.g. 1) or a range (e.g. 1,3)&quot;)
    } else if (rangeParts.size() == 2 &amp;&amp; rangeParts[0].isInteger() &amp;&amp; rangeParts[1].isInteger()) {
        if (rangeParts[0].toInteger() &gt; rangeParts[1].toInteger()) {
            errors.add(&quot;multiFormRange &apos;${rawRange}&apos; is invalid — min (${rangeParts[0]}) must be &lt;= max (${rangeParts[1]}), e.g. 1,3&quot;)
        }
    }
}

// ===== Validate secondaryOpportunities UDV =====
def rawSecOpp = vars.get(&quot;secondaryOpportunities&quot;)?.trim()
if (rawSecOpp &amp;&amp; rawSecOpp != &quot;0&quot;) {
    def secParts = rawSecOpp.split(&quot;,&quot;)*.trim()
    if (!secParts.every { it.isInteger() }) {
        errors.add(&quot;secondaryOpportunities &apos;${rawSecOpp}&apos; is invalid — must be positive integers e.g. 2,5&quot;)
    } else if (secParts.any { it.toInteger() &lt; 0 }) {
        errors.add(&quot;secondaryOpportunities &apos;${rawSecOpp}&apos; is invalid — negative values not allowed&quot;)
    } else if (secParts.size() &gt; 2) {
        errors.add(&quot;secondaryOpportunities &apos;${rawSecOpp}&apos; is invalid — expected 1 or 2 values (e.g. 2 or 2,5)&quot;)
    } else if (secParts.size() == 2 &amp;&amp; secParts[0].toInteger() &gt; secParts[1].toInteger()) {
        errors.add(&quot;secondaryOpportunities &apos;${rawSecOpp}&apos; is invalid — min (${secParts[0]}) must be &lt;= max (${secParts[1]})&quot;)
    }
}

// ===== Validate multiDropDownRange for mandatory multi-select fields =====
def rawMultiDropDownRange = vars.get(&quot;multiDropDownRange&quot;)?.trim()

// Optional field - empty or 0 = skip, validate only if provided
if (rawMultiDropDownRange &amp;&amp; rawMultiDropDownRange != &quot;0&quot;) {
    def parts = rawMultiDropDownRange.split(&quot;,&quot;)*.trim()

    // Validate positive integers (&gt;0) first
    def invalid = parts.findAll { !it.isInteger() || it.toInteger() &lt;= 0 }

    if (!invalid.isEmpty()) {
        errors.add(&quot;multiDropDownRange has invalid entries: ${invalid} in &apos;${rawMultiDropDownRange}&apos; (expected: positive integers for min,max range, e.g. 1,3)&quot;)
    } else if (parts.size() &gt; 2) {
        // Only single value or min,max range allowed
        errors.add(&quot;multiDropDownRange &apos;${rawMultiDropDownRange}&apos; is invalid — expected either a single value (e.g. 1) or a range (e.g. 1,3)&quot;)
    } else if (parts.size() == 2) {
        int min = parts[0].toInteger()
        int max = parts[1].toInteger()
        if (min &gt; max) {
            errors.add(&quot;multiDropDownRange &apos;${rawMultiDropDownRange}&apos; is invalid — min (${min}) must be &lt;= max (${max}), e.g. 1,3&quot;)
        }
    }
}

validateIntList(&quot;vacantSlotDurations&quot;,          &quot;positive integers in minutes, e.g. 30,60&quot;)
validateIntList(&quot;blockedSlots&quot;,                 &quot;integers &gt;= 0, e.g. 0,1,2&quot;)
validateIntList(&quot;blockedDurations&quot;,             &quot;positive integers in minutes, e.g. 30,60&quot;)

// ===== Abort on validation errors =====
if (errors.size() &gt; 0) {
    def errorMsg = &quot;ABORTING: UDV validation failed:\n&quot; + errors.collect { &quot;  ✗ ${it}&quot; }.join(&quot;\n&quot;)
    errors.each { log.error(&quot;✗ ${it}&quot;) }
    abort(errorMsg)
    return
}

// ===== Read requestsPerDay (default: 1, supports comma-separated e.g. 1,2,3) =====
boolean allowWeekends = vars.get(&quot;allowWeekends&quot;)?.equalsIgnoreCase(&quot;true&quot;) ?: false
def requestsPerDayStr = vars.get(&quot;requestsPerDay&quot;)?.trim()
int requestsPerDay = 1
try {
    if (requestsPerDayStr) {
        def options = requestsPerDayStr.split(&quot;,&quot;).collect { it.trim() }
            .findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }
            .collect { it.toInteger() }
        if (options.size() &gt; 0) {
            requestsPerDay = options[java.util.concurrent.ThreadLocalRandom.current().nextInt(options.size())]
            log.info(&quot;requestsPerDay options: ${options} → randomly picked: ${requestsPerDay}&quot;)
        }
    }
} catch (Exception e) {
    log.warn(&quot;Invalid requestsPerDay: ${requestsPerDayStr}, using default 1&quot;)
}

// ===== Read and validate date range =====
LocalDate startDate = LocalDate.parse(requestStartDate, dateFormatter)
LocalDate endDate   = LocalDate.parse(requestEndDate, dateFormatter)

if (endDate.isBefore(startDate)) {
    def msg = &quot;ABORTING: UDV validation failed:\n  ✗ requestEndDate (${requestEndDate}) is before requestStartDate (${requestStartDate}) — end date must be same as or after start date&quot;
    abort(msg, &quot;End date is before start date&quot;)
    return
}

// ===== Collect valid days (skip weekends if not allowed) =====
def validDates      = []
def skippedWeekends = []
LocalDate current   = startDate
while (!current.isAfter(endDate)) {
    if (allowWeekends || !(current.dayOfWeek in [DayOfWeek.SATURDAY, DayOfWeek.SUNDAY]))
        validDates.add(current)
    else
        skippedWeekends.add(current)
    current = current.plusDays(1)
}

// ===== Store valid dates for sequential access =====
int totalDays         = validDates.size()
int totalRequestCount = totalDays * requestsPerDay

validDates.eachWithIndex { date, idx -&gt; vars.put(&quot;validDate_&quot; + (idx + 1), date.format(dateFormatter)) }
vars.put(&quot;totalValidDays&quot;,    totalDays.toString())
vars.put(&quot;requestsPerDay&quot;,    requestsPerDay.toString())
vars.put(&quot;totalRequestCount&quot;, totalRequestCount.toString())

// ===== Build summary =====
def sb = new StringBuilder()
sb.append(&quot;========================================\n&quot;)
sb.append(&quot;REQUEST CALCULATION SUMMARY\n&quot;)
sb.append(&quot;========================================\n&quot;)
sb.append(&quot;Date Range      : ${startDate} to ${endDate}\n&quot;)
sb.append(&quot;Allow Weekends  : ${allowWeekends}\n&quot;)
sb.append(&quot;Requests/Day    : ${requestsPerDay}\n&quot;)
sb.append(&quot;========================================\n&quot;)

if (totalRequestCount == 0) {
    sb.append(&quot;\n⚠️ WARNING: No valid dates found!\n&quot;)
    sb.append(&quot;All dates in the range fall on weekends and allowWeekends is set to false.\n&quot;)
    if (!skippedWeekends.isEmpty()) {
        sb.append(&quot;Skipped weekend dates:\n&quot;)
        skippedWeekends.each { sb.append(&quot;  ❌ ${it} (${it.dayOfWeek})\n&quot;) }
    }
    sb.append(&quot;\nPlease change the date range or set allowWeekends=true in UDV.\n&quot;)

    log.error(&quot;========================================&quot;)
    log.error(&quot;No valid dates found — all dates are weekends and allowWeekends=false&quot;)
    log.error(&quot;Date Range: ${startDate} to ${endDate}&quot;)
    skippedWeekends.each { log.error(&quot;  ❌ ${it} (${it.dayOfWeek}) - SKIPPED (weekend)&quot;) }
    log.error(&quot;========================================&quot;)

    abort(sb.toString(), &quot;No valid dates - all dates are weekends&quot;)
} else {
    validDates.each      { sb.append(&quot;  ✅ ${it} (${it.dayOfWeek})\n&quot;) }
    if (!skippedWeekends.isEmpty()) {
        sb.append(&quot;\nSkipped weekend dates:\n&quot;)
        skippedWeekends.each { sb.append(&quot;  ❌ ${it} (${it.dayOfWeek})\n&quot;) }
    }
    sb.append(&quot;\n✅ ${totalRequestCount} request(s) will be created across ${totalDays} valid day(s).\n&quot;)

    log.info(&quot;========================================&quot;)
    log.info(&quot;REQUEST CALCULATION&quot;)
    log.info(&quot;Date Range: ${startDate} to ${endDate} | Allow Weekends: ${allowWeekends}&quot;)
    log.info(&quot;Valid Days: ${totalDays} | Requests/Day: ${requestsPerDay} | Total: ${totalRequestCount}&quot;)
    validDates.each      { log.info(&quot;  ✅ ${it} (${it.dayOfWeek})&quot;) }
    skippedWeekends.each { log.info(&quot;  ❌ ${it} (${it.dayOfWeek}) - SKIPPED (weekend)&quot;) }
    log.info(&quot;========================================&quot;)

    SampleResult.setResponseData(sb.toString(), &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;200&quot;)
    SampleResult.setResponseMessage(&quot;${totalRequestCount} requests planned&quot;)
    SampleResult.setSuccessful(true)
    SampleResult.setIgnore()
}</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
          </JSR223Sampler>
          <hashTree/>
          <LoopController guiclass="LoopControlPanel" testclass="LoopController" testname="Request Creation Loop" enabled="true">
            <boolProp name="LoopController.continue_forever">true</boolProp>
            <stringProp name="LoopController.loops">${totalRequestCount}</stringProp>
          </LoopController>
          <hashTree>
            <IfController guiclass="IfControllerPanel" testclass="IfController" testname="◉ If (First User - Create Request)" enabled="true">
              <stringProp name="IfController.condition">${__groovy(vars.get(&quot;isFirstUser&quot;) == &quot;true&quot;)}</stringProp>
              <boolProp name="IfController.useExpression">true</boolProp>
              <boolProp name="IfController.evaluateAll">false</boolProp>
            </IfController>
            <hashTree>
              <CounterConfig guiclass="CounterConfigGui" testclass="CounterConfig" testname="Request Count" enabled="true">
                <stringProp name="CounterConfig.start">1</stringProp>
                <stringProp name="CounterConfig.end"></stringProp>
                <stringProp name="CounterConfig.incr">1</stringProp>
                <stringProp name="CounterConfig.name">RequestCount</stringProp>
                <stringProp name="CounterConfig.format"></stringProp>
                <boolProp name="CounterConfig.per_user">true</boolProp>
              </CounterConfig>
              <hashTree/>
              <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="✦───── Creation of Request ─────✦" enabled="true">
                <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
                  <collectionProp name="Arguments.arguments"/>
                </elementProp>
                <stringProp name="HTTPSampler.domain"></stringProp>
                <stringProp name="HTTPSampler.port"></stringProp>
                <stringProp name="HTTPSampler.protocol"></stringProp>
                <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                <stringProp name="HTTPSampler.path">/${contextname}/api</stringProp>
                <stringProp name="HTTPSampler.method">GET</stringProp>
                <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
                <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                <boolProp name="HTTPSampler.use_keepalive">false</boolProp>
                <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
                <stringProp name="HTTPSampler.connect_timeout">30000</stringProp>
                <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
              </HTTPSamplerProxy>
              <hashTree>
                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Request Count PostProcessor" enabled="true">
                  <stringProp name="script">import java.time.format.TextStyle
import java.util.Locale

def RequestCount = vars.get(&quot;RequestCount&quot;)
def isFirstUser = vars.get(&quot;isFirstUser&quot;) ?: &quot;true&quot;
def requestsPerDay = (vars.get(&quot;requestsPerDay&quot;) ?: &quot;1&quot;).toInteger()
def totalValidDays = (vars.get(&quot;totalValidDays&quot;) ?: &quot;1&quot;).toInteger()
def totalRequestCount = vars.get(&quot;totalRequestCount&quot;) ?: &quot;1&quot;
def rc = RequestCount.toInteger()

// Calculate day index and request-in-day
int dayIndex = ((rc - 1) / requestsPerDay).intValue() + 1
int requestInDay = ((rc - 1) % requestsPerDay) + 1
def dateForDay = vars.get(&quot;validDate_&quot; + dayIndex) ?: &quot;unknown&quot;

// Get short day name (Mon, Tue, etc.)
def dayName = &quot;&quot;
try {
    def parsedDate = java.time.LocalDate.parse(dateForDay)
    dayName = parsedDate.dayOfWeek.getDisplayName(TextStyle.SHORT, Locale.ENGLISH)
} catch (Exception e) {
    dayName = &quot;&quot;
}

// Set readable sampler label for View Results Tree
prev.setSampleLabel(&quot;✦─── Request (&quot; + RequestCount + &quot;/&quot; + totalRequestCount + &quot;) | &quot; + dateForDay + &quot; (&quot; + dayName + &quot;) | Per Day (&quot; + requestInDay + &quot;/&quot; + requestsPerDay + &quot;) ───✦&quot;)

log.info(&quot;═══════════════════════════════════════════════════&quot;)
log.info(&quot;Request &quot; + RequestCount + &quot;/&quot; + totalRequestCount + &quot; Creation Started&quot;)
log.info(&quot;Day: &quot; + dayIndex + &quot;/&quot; + totalValidDays + &quot; (&quot; + dateForDay + &quot; - &quot; + dayName + &quot;)&quot;)
log.info(&quot;Request for this day: &quot; + requestInDay + &quot;/&quot; + requestsPerDay)
log.info(&quot;Is First User: &quot; + isFirstUser)
log.info(&quot;═══════════════════════════════════════════════════&quot;)

// Only reset room counts for the first user
if (isFirstUser == &quot;true&quot;) {
    log.info(&quot;First user - resetting room counters and processedFields tracking&quot;)

    // New request iteration must not reuse prior event/customer from a previous loop
    vars.put(&quot;skipEventCreation&quot;, &quot;false&quot;)
    vars.put(&quot;requestCreated&quot;, &quot;false&quot;)
    vars.put(&quot;requestFailed&quot;, &quot;false&quot;)
    vars.remove(&quot;requestId&quot;)
    vars.put(&quot;stateActionIteration&quot;, &quot;0&quot;)

    def userDefinedCustomer = vars.get(&quot;userDefinedCustomerName&quot;)?.trim()
    if (!userDefinedCustomer) {
        vars.remove(&quot;customerName&quot;)
        log.info(&quot;Auto-pick mode: cleared runtime customerName for new iteration&quot;)
    } else {
        vars.put(&quot;customerName&quot;, userDefinedCustomer)
        log.info(&quot;User-defined customer mode: customerName=${userDefinedCustomer}&quot;)
    }

	def roomsRaw = vars.get(&quot;rooms&quot;) ?: &quot;0&quot;
	def roomOptions = roomsRaw.split(&quot;,&quot;).findAll { it.trim().isInteger() &amp;&amp; it.trim().toInteger() &gt;= 0 }.collect { it.trim().toInteger() }
	def maxRooms = roomOptions ? roomOptions[java.util.concurrent.ThreadLocalRandom.current().nextInt(roomOptions.size())] : 0
    for (int day = 1; day &lt;= totalValidDays; day++) {
        vars.put(&quot;createdRoomCount_Day${day}&quot;, &quot;0&quot;)
        System.clearProperty(&quot;jmeter.roomCount.Day${day}&quot;)
        for (int i = 1; i &lt;= maxRooms; i++) {
            vars.remove(&quot;createdRoom_Day${day}_${i}_id&quot;)
            vars.remove(&quot;createdRoom_Day${day}_${i}_name&quot;)
            System.clearProperty(&quot;jmeter.room.Day${day}_${i}_id&quot;)
            System.clearProperty(&quot;jmeter.room.Day${day}_${i}_name&quot;)
        }
    }

    def reqId = vars.get(&quot;requestId&quot;) ?: &quot;unknown&quot;
    def clearProps = { String prefix -&gt;
        def keys = props.keys().findAll { it.startsWith(prefix) }
        keys.each { props.remove(it) }
        log.info(&quot;Cleared ${keys.size()} entries for prefix: ${prefix}&quot;)
    }
    clearProps(&quot;processedFields_${reqId}_&quot;)
    clearProps(&quot;existingFormData_snapshot_${reqId}_&quot;)

} else {
    log.info(&quot;Subsequent user - preserving room data from first user&quot;)
}</stringProp>
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
