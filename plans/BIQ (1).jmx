// Returns a specific value from a comma-separated string by 1-based index; falls back to the first value if the index is out of range.
def _fn_getIndexedValue = { String csv, int entryIdx -&gt;
    if (!csv) return null
    if (csv.contains(&quot;,&quot;)) {
        def vals = csv.split(&quot;,&quot;)
        def idx = entryIdx - 1
        return (idx &gt;= 0 &amp;&amp; idx &lt; vals.length) ? vals[idx].trim() : vals[0].trim()
    }
    return csv.trim()
}
props.put(&quot;fn_getIndexedValue&quot;, _fn_getIndexedValue)

// Splits a comma-separated module type string into a trimmed list of tokens for classifying modules by type bucket.
def _fn_parseModuleTypeTokens = { String raw -&gt;
    if (!raw?.trim()) return [] as List
    raw.split(/,/).collect { it.trim() }.findAll { it }
}
props.put(&quot;fn_parseModuleTypeTokens&quot;, _fn_parseModuleTypeTokens)

// Checks if the current module type ID or name matches any token in the configured UDV list (e.g. journeyModuleType).
def _fn_moduleTypeMatches = { varsRef, udvKey, currentTypeId, currentTypeName = null -&gt;
    def configured = props.get(&quot;fn_parseModuleTypeTokens&quot;)(varsRef.get(udvKey) ?: &quot;&quot;)
    if (!configured) return false
    def typeId = (currentTypeId ?: &quot;&quot;).trim()
    def typeName = (currentTypeName ?: &quot;&quot;).trim()
    configured.any { token -&gt;
        token.equalsIgnoreCase(typeId) || (typeName &amp;&amp; token.equalsIgnoreCase(typeName))
    }
}
props.put(&quot;fn_moduleTypeMatches&quot;, _fn_moduleTypeMatches)

// Returns true if the current module matches any configured journeyModuleType token — used directly in IfController conditions.
def _fn_matchesJourneyType = { varsRef -&gt;
    props.get(&quot;fn_moduleTypeMatches&quot;)(varsRef, &quot;journeyModuleType&quot;, varsRef.get(&quot;currentModuleTypeId&quot;) ?: &quot;&quot;, varsRef.get(&quot;currentModuleTypeName&quot;) ?: &quot;&quot;)
}
props.put(&quot;fn_matchesJourneyType&quot;, _fn_matchesJourneyType)

// Returns true if the current module matches any configured logisticsModuleType token — used directly in IfController conditions.
def _fn_matchesLogisticsType = { varsRef -&gt;
    props.get(&quot;fn_moduleTypeMatches&quot;)(varsRef, &quot;logisticsModuleType&quot;, varsRef.get(&quot;currentModuleTypeId&quot;) ?: &quot;&quot;, varsRef.get(&quot;currentModuleTypeName&quot;) ?: &quot;&quot;)
}
props.put(&quot;fn_matchesLogisticsType&quot;, _fn_matchesLogisticsType)

// Returns true if the current module matches any configured agendaModuleType token — used directly in IfController conditions.
def _fn_matchesAgendaType = { varsRef -&gt;
    props.get(&quot;fn_moduleTypeMatches&quot;)(varsRef, &quot;agendaModuleType&quot;, varsRef.get(&quot;currentModuleTypeId&quot;) ?: &quot;&quot;, varsRef.get(&quot;currentModuleTypeName&quot;) ?: &quot;&quot;)
}
props.put(&quot;fn_matchesAgendaType&quot;, _fn_matchesAgendaType)

// Returns true if the current module matches any configured virtualConnectionModuleType token — used directly in IfController conditions.
def _fn_matchesVirtualConnectionType = { varsRef -&gt;
    props.get(&quot;fn_moduleTypeMatches&quot;)(varsRef, &quot;virtualConnectionModuleType&quot;, varsRef.get(&quot;currentModuleTypeId&quot;) ?: &quot;&quot;, varsRef.get(&quot;currentModuleTypeName&quot;) ?: &quot;&quot;)
}
props.put(&quot;fn_matchesVirtualConnectionType&quot;, _fn_matchesVirtualConnectionType)

