                  <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
                </HTTPSamplerProxy>
                <hashTree>
                  <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
                    <collectionProp name="HeaderManager.headers">
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-customerid</stringProp>
                        <stringProp name="Header.value">${customerId}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                        <stringProp name="Header.value">${categoryTypeId}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                        <stringProp name="Header.value">${categoryId}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                        <stringProp name="Header.value">${baseTimezone}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                        <stringProp name="Header.value">${clientTimeZone}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">X-Cloud-Context-Timezone</stringProp>
                        <stringProp name="Header.value">${baseTimezone}</stringProp>
                      </elementProp>
                      <elementProp name="" elementType="Header">
                        <stringProp name="Header.name">X_cloud_user</stringProp>
                        <stringProp name="Header.value">${currentUser}</stringProp>
                      </elementProp>
                    </collectionProp>
                  </HeaderManager>
                  <hashTree/>
                  <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="New Request PreProcessor" enabled="true">
                    <stringProp name="script">def rand = java.util.concurrent.ThreadLocalRandom.current()

// Helper Function: Generate 4-digit random number (1000-9999) - using shared function
def random4 = { -&gt; props.get(&quot;fn_random4&quot;)() }

// Multi-select configuration from User Defined Variables
def minSelection = props.get(&quot;fn_parseMultiDropDownRange&quot;)(vars, null).min
def maxSelection = props.get(&quot;fn_parseMultiDropDownRange&quot;)(vars, null).max

// Helper function to generate random selection count
def getRandomSelectionCount = { int availableCount -&gt;
    def maxPossible = Math.min(availableCount, maxSelection)
    def minPossible = Math.min(minSelection, maxPossible)
    return minPossible + rand.nextInt((maxPossible - minPossible) + 1)
}

def checkDuplicateCustomer = vars.get(&quot;checkDuplicateCustomer&quot;) ?: &quot;true&quot;
def selectedCustomer = vars.get(&quot;customerName&quot;)
log.info(&quot;Check Duplicate Customer: ${checkDuplicateCustomer}&quot;)
log.info(&quot;Using customer: ${selectedCustomer}&quot;)
log.info(&quot;Skip event creation flag: ${vars.get(&apos;skipEventCreation&apos;)}&quot;)

// Secondary Opportunity IDs
// Count driven by secondaryOpportunities UDV — falls back to multiDropDownRange if empty
def oppRange = props.get(&quot;fn_parseSecondaryOpportunities&quot;)(vars)
def oppMin = oppRange.min
def oppMax = oppRange.max
def oppSource = oppRange.source

def opportunityIds = [] as Set

if (oppMax &gt; 0) {
    int opportunityCount = oppMin + rand.nextInt(oppMax - oppMin + 1)
    int maxAttempts = opportunityCount * 10
    int attempts = 0
    while (opportunityIds.size() &lt; opportunityCount &amp;&amp; attempts &lt; maxAttempts) {
        opportunityIds.add(String.valueOf(random4()))
        attempts++
    }
    log.info(&quot;Secondary Opportunity IDs (count=${opportunityIds.size()}, min=${oppMin}, max=${oppMax}, source=${oppSource}): &quot; + opportunityIds.join(&quot;, &quot;))
} else {
    opportunityIds.add(String.valueOf(random4()))
    log.info(&quot;Secondary Opportunity ID (oppMax=0, single fallback): &quot; + opportunityIds[0])
}

vars.put(&quot;secondaryOpportunity&quot;, opportunityIds.join(&quot;,&quot;))

// Primary Opportunity - unique, not in secondary list
def primaryOpportunityId
do {
    primaryOpportunityId = String.valueOf(random4())
} while (opportunityIds.contains(primaryOpportunityId))

vars.put(&quot;primaryOpportunity&quot;, primaryOpportunityId)
log.info(&quot;Primary Opportunity ID: &quot; + primaryOpportunityId)

// FIX: opportunity = primary first, then secondary (indexed per entry via fn_getIndexedValue)
// entry 1 (isPrimary=true) gets primaryOpportunityId, entry 2+ get secondary IDs
vars.put(&quot;opportunity&quot;, primaryOpportunityId + &quot;,&quot; + opportunityIds.join(&quot;,&quot;))
log.info(&quot;All Opportunity IDs (opportunity var): &quot; + vars.get(&quot;opportunity&quot;))

// Log Generated Values
log.info(&quot;Customer Name: &quot; + selectedCustomer)
log.info(&quot;Duration: &quot;    + vars.get(&quot;duration&quot;))
log.info(&quot;Start Date: &quot;  + vars.get(&quot;startDate&quot;))
log.info(&quot;Start Time: &quot;  + vars.get(&quot;startTime&quot;))
log.info(&quot;End Time: &quot;    + vars.get(&quot;endTime&quot;))

log.info(&quot;----- Terminated: New Request PreProcessor -----&quot;)</stringProp>
