                <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Module Name PreProcessor" enabled="true">
                  <stringProp name="script">// v7: Reduced logging - only logs when module changes

// Find current module details from ForEach iteration
def currentModuleId = vars.get(&quot;moduleId&quot;)
def moduleCount = vars.get(&quot;navModules_count&quot;)?.toInteger() ?: 0

for (int i = 1; i &lt;= moduleCount; i++) {
    if (vars.get(&quot;moduleUniqueId_&quot; + i) == currentModuleId) {
        vars.put(&quot;currentModuleName&quot;, vars.get(&quot;moduleName_&quot; + i) ?: &quot;Unknown&quot;)
        vars.put(&quot;currentModuleTypeId&quot;, vars.get(&quot;moduleTypeId_&quot; + i) ?: &quot;&quot;)
        break
    }
}

def lastLoggedNavModule = vars.get(&quot;lastLoggedNavModule&quot;) ?: &quot;&quot;
def currentModule = vars.get(&quot;currentModuleName&quot;) ?: &quot;Unknown&quot;
if (lastLoggedNavModule != currentModule) {
        vars.put(&quot;lastLoggedNavModule&quot;, currentModule)
}</stringProp>
