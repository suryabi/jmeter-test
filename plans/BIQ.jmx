                                </HeaderManager>
                                <hashTree/>
                                <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Room ID Extractor" enabled="true">
                                  <stringProp name="JSONPostProcessor.referenceNames">roomId</stringProp>
                                  <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.resourceTimeSlots[*].resources[*].uniqueId</stringProp>
                                  <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                                  <stringProp name="JSONPostProcessor.defaultValues">NOT_FOUND</stringProp>
                                </JSONPostProcessor>
                                <hashTree/>
                                <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Room Name Extractor" enabled="true">
                                  <stringProp name="JSONPostProcessor.referenceNames">roomName</stringProp>
                                  <stringProp name="JSONPostProcessor.jsonPathExprs">$._embedded.resourceTimeSlots[*].resources[*].data.name</stringProp>
                                  <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
                                  <stringProp name="JSONPostProcessor.defaultValues">NOT_FOUND</stringProp>
                                </JSONPostProcessor>
                                <hashTree/>
                                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Prepare Room Selection" enabled="true">
                                  <stringProp name="script">// Prepare room selection - create shuffle and adjust room count
// This only runs ONCE per Activity Day (when RoomIndex == 1)

def dayIndex = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def extractedRoomCount = vars.get(&quot;roomId_matchNr&quot;)?.toInteger() ?: 0
def roomsPickedCount = vars.get(&quot;_roomsPickedCount&quot;)?.toInteger() ?: 0  // 0 means no cap

log.info(&quot;Day ${dayIndex}: Available ${extractedRoomCount} vacant rooms | rooms cap: ${roomsPickedCount == 0 ? &quot;none&quot; : roomsPickedCount}&quot;)

if (extractedRoomCount == 0) {
    log.warn(&quot;Day ${dayIndex}: No vacant rooms available&quot;)
    vars.put(&quot;TotalRoomsToCreate&quot;, &quot;0&quot;)
    return
}

// ============================================================
// allowedRooms FILTER
// ============================================================
def allowedRoomsRaw = vars.get(&quot;allowedRooms&quot;)?.trim() ?: &quot;&quot;

def isUUID = { String val -&gt;
    val?.contains(&quot;-&quot;) &amp;&amp; val.trim().length() &gt;= 30
}

if (allowedRoomsRaw) {
    // Parse allowed list into separate UUID and name lists
    def allowedEntries = allowedRoomsRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it }
    def allowedUUIDs   = allowedEntries.findAll { isUUID(it) }.collect { it.toUpperCase() }
    def allowedNames   = allowedEntries.findAll { !isUUID(it) }.collect { it.toLowerCase() }

    log.info(&quot;Day ${dayIndex}: allowedRooms filter active — UUIDs: ${allowedUUIDs}, Names: ${allowedNames}&quot;)

    // Walk all extracted rooms and keep only those that match
    def matchedIndices = []
    for (int i = 1; i &lt;= extractedRoomCount; i++) {
        def roomId   = vars.get(&quot;roomId_&quot; + i)   ?: &quot;&quot;
        def roomName = vars.get(&quot;roomName_&quot; + i) ?: &quot;&quot;

        boolean matchById   = allowedUUIDs &amp;&amp; allowedUUIDs.contains(roomId.toUpperCase())
        boolean matchByName = allowedNames &amp;&amp; allowedNames.contains(roomName.trim().toLowerCase())

        if (matchById || matchByName) {
            matchedIndices.add(i)
            def matchType = matchById ? &quot;UUID&quot; : &quot;Name&quot;
            log.info(&quot;  ✅ MATCH [${matchType}] Room [${i}]: ${roomName} (${roomId})&quot;)
        } else {
            log.info(&quot;  ⛔ SKIP Room [${i}]: ${roomName} (${roomId})&quot;)
        }
    }

    // No matches — skip room creation, continue test
    if (matchedIndices.isEmpty()) {
        def availableRoomNames = (1..extractedRoomCount).collect { i -&gt; vars.get(&quot;roomName_&quot; + i) ?: &quot;Room ${i}&quot; }.join(&quot;, &quot;)
        log.warn(&quot;========================================&quot;)
        log.warn(&quot;SKIPPING ROOMS: allowedRooms did not match any vacant room for Day ${dayIndex}.&quot;)
        log.warn(&quot;allowedRooms requested: ${allowedRoomsRaw}&quot;)
        log.warn(&quot;Vacant rooms available: ${availableRoomNames}&quot;)
        log.warn(&quot;Room creation skipped — test will continue with remaining steps.&quot;)
        log.warn(&quot;========================================&quot;)
        vars.put(&quot;TotalRoomsToCreate&quot;, &quot;0&quot;)
        vars.put(&quot;shuffledRoomIndices_Day${dayIndex}&quot;, &quot;&quot;)
        vars.put(&quot;_skipRoomReason&quot;, &quot;allowedRooms &apos;${allowedRoomsRaw}&apos; did not match any vacant room. Available: ${availableRoomNames}&quot;)
        return
    }

    // ============================================================
    // Apply rooms UDV as a cap on matched allowedRooms
    //
    //   roomsPickedCount &gt;= matchedIndices.size() → create ALL matched (cap exceeds available)
    //   roomsPickedCount &lt; matchedIndices.size() → pick roomsPickedCount randomly from matched
    //
    // Note: rooms=0/empty is already handled in the Activity Day sampler
    //       (TotalRoomsToCreate=0, so this block is never reached in that case)
    // ============================================================
    def rand = java.util.concurrent.ThreadLocalRandom.current()
    Collections.shuffle(matchedIndices, rand)  // always shuffle for randomness

    def finalIndices
    if (roomsPickedCount &gt;= matchedIndices.size()) {
        // Cap exceeds matched — create all matched rooms
        finalIndices = matchedIndices
        log.info(&quot;Day ${dayIndex}: rooms cap ${roomsPickedCount} &gt;= matched ${matchedIndices.size()} — creating ALL ${matchedIndices.size()} matched room(s)&quot;)
    } else {
        // Cap is less than matched — pick only roomsPickedCount rooms from shuffled matched list
        finalIndices = matchedIndices.take(roomsPickedCount)
        log.info(&quot;Day ${dayIndex}: rooms cap ${roomsPickedCount} &lt; matched ${matchedIndices.size()} — creating ${roomsPickedCount} room(s) from matched list&quot;)
    }

    vars.put(&quot;TotalRoomsToCreate&quot;, finalIndices.size().toString())
    vars.put(&quot;shuffledRoomIndices_Day${dayIndex}&quot;, finalIndices.join(&quot;,&quot;))

    log.info(&quot;Day ${dayIndex}: Final rooms to create: ${finalIndices.size()} — indices: ${finalIndices}&quot;)

} else {
    // ============================================================
    // ORIGINAL BEHAVIOR — no allowedRooms, rooms UDV controls count
    // ============================================================
    def requestedRooms = roomsPickedCount
    def finalCount = requestedRooms

    if (requestedRooms &gt; extractedRoomCount) {
        log.info(&quot;Day ${dayIndex}: Limiting rooms from ${requestedRooms} to ${extractedRoomCount}&quot;)
        finalCount = extractedRoomCount
    }

    vars.put(&quot;TotalRoomsToCreate&quot;, finalCount.toString())

    def rand = java.util.concurrent.ThreadLocalRandom.current()
    def availableIndices = (1..extractedRoomCount).collect { it }
    Collections.shuffle(availableIndices, rand)
    vars.put(&quot;shuffledRoomIndices_Day${dayIndex}&quot;, availableIndices.join(&quot;,&quot;))

    log.info(&quot;Day ${dayIndex}: No allowedRooms filter — creating ${finalCount} room(s) from ${extractedRoomCount} vacant&quot;)
}</stringProp>
                                  <stringProp name="scriptLanguage">groovy</stringProp>
                                  <stringProp name="parameters"></stringProp>
                                  <stringProp name="filename"></stringProp>
                                  <stringProp name="cacheKey">false</stringProp>
                                </JSR223PostProcessor>
                                <hashTree/>
                                <com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter guiclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.gui.JSONFormatterGui" testclass="com.atlantbh.jmeter.plugins.jsonutils.jsonformatter.JSONFormatter" testname="jp@gc - JSON Format Post Processor" enabled="true"/>
                                <hashTree/>
                              </hashTree>
                            </hashTree>
                            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Select Current Room (${currentRoomIndex})" enabled="true">
                              <stringProp name="script">SampleResult.setIgnore()

// Make visible for debugging
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)

import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

// Select room based on current room index
def roomIndex = vars.get(&quot;currentRoomIndex&quot;)?.toInteger() ?: 1
def totalRooms = vars.get(&quot;TotalRoomsToCreate&quot;)?.toInteger() ?: 1
def dayIndex = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;

// Get extracted room count (from Get Vacant Rooms - only called for first room)
def extractedRoomCount = vars.get(&quot;roomId_matchNr&quot;)?.toInteger() ?: 0

// Get room type from lookup values - NO hardcoded values
def rand = java.util.concurrent.ThreadLocalRandom.current()
def roomTypeCount = vars.get(&quot;roomType_count&quot;)?.toInteger() ?: 0
def roomType = &quot;&quot;

// Skip room creation if no ROOM_TYPE lookup values found
if (roomTypeCount == 0) {
    log.warn(&quot;Day ${dayIndex}: No ROOM_TYPE lookup values found - skipping room creation&quot;)
    vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
    return
}

if (roomTypeCount &gt; 0) {
    if (roomIndex == 1) {
        // First room: Must be Main Room (find from lookup)
        for (int i = 1; i &lt;= roomTypeCount; i++) {
            def lookupValue = vars.get(&quot;roomType_&quot; + i)
            if (lookupValue?.toLowerCase()?.contains(&quot;main&quot;)) {
                roomType = lookupValue
                break
            }
        }
        // If no Main Room found in lookup, use first available
        if (!roomType) {
            roomType = vars.get(&quot;roomType_1&quot;) ?: &quot;&quot;
        }
    } else {
        // Other rooms: Pick randomly from non-Main Room types
        def otherTypes = []
        for (int i = 1; i &lt;= roomTypeCount; i++) {
            def lookupValue = vars.get(&quot;roomType_&quot; + i)
            if (lookupValue &amp;&amp; !lookupValue.toLowerCase().contains(&quot;main&quot;)) {
                otherTypes.add(lookupValue)
            }
        }
        if (otherTypes.size() &gt; 0) {
            roomType = otherTypes[rand.nextInt(otherTypes.size())]
        } else {
            // If only Main Room exists in lookup, pick randomly from all
            def randomIdx = rand.nextInt(roomTypeCount) + 1
            roomType = vars.get(&quot;roomType_&quot; + randomIdx) ?: &quot;&quot;
        }
    }
}

// Skip if no vacant rooms found
if (extractedRoomCount == 0) {
    log.warn(&quot;Day ${dayIndex}: No vacant rooms found - skipping room creation&quot;)
    vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
    return
}

// ROOM SELECTION - use shuffled list created during first room iteration
def selectedRoomId = &quot;&quot;
def selectedRoomName = &quot;&quot;

// Get shuffled indices (created when RoomIndex == 1 in Get Vacant Rooms PostProcessor)
def shuffledIndicesStr = vars.get(&quot;shuffledRoomIndices_Day${dayIndex}&quot;)

// Safety check: if shuffledRoomIndices is empty/null (no match or 0 rooms), skip creation

if (!shuffledIndicesStr) {
    // No shuffled indices means Prepare Room Selection aborted or found 0 rooms — do NOT fallback
    log.warn(&quot;Day ${dayIndex}: shuffledRoomIndices is empty — skipping room creation for Room ${roomIndex}&quot;)
    vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
    return
}

if (shuffledIndicesStr) {
    def shuffledIndices = shuffledIndicesStr.split(&quot;,&quot;).collect { it.toInteger() }

    // Pick room based on roomIndex from shuffled list
    if (roomIndex &lt;= shuffledIndices.size()) {
        def selectedIndex = shuffledIndices[roomIndex - 1]
        selectedRoomId = vars.get(&quot;roomId_&quot; + selectedIndex)
        selectedRoomName = vars.get(&quot;roomName_&quot; + selectedIndex) ?: &quot;&quot;
    } else {
        log.warn(&quot;Day ${dayIndex}: roomIndex ${roomIndex} exceeds shuffled list size ${shuffledIndices.size()} — skipping&quot;)
        vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
        return
    }
}

// Skip if roomId is empty
if (!selectedRoomId || selectedRoomId == &quot;NOT_FOUND&quot;) {
    log.warn(&quot;Day ${dayIndex} Room ${roomIndex}: No valid roomId found - skipping&quot;)
    vars.put(&quot;skipRoomCreation&quot;, &quot;true&quot;)
    return
}

// DYNAMIC TIME OFFSET - random start/end times per room
def activityStart = vars.get(&quot;activityStartTime&quot;) ?: &quot;&quot;
def activityEnd = vars.get(&quot;activityEndTime&quot;) ?: &quot;&quot;

// Clean up original times - remove milliseconds and Z suffix
def cleanTime = { String timeStr -&gt;
    if (!timeStr) return timeStr
    return timeStr.replace(&quot;Z&quot;, &quot;&quot;).replaceAll(/\\.[0-9]+/, &quot;&quot;)
}

def roomStartTime = cleanTime(activityStart)
def roomEndTime = cleanTime(activityEnd)

// Parse roomTimeOffset variable (e.g., &quot;0,30,60,90,120&quot;)
def timeOffsetRaw = vars.get(&quot;roomTimeOffset&quot;)?.trim() ?: &quot;0&quot;
def timeOffsets = timeOffsetRaw.split(&quot;,&quot;)
    .collect { it.trim() }
    .findAll { it.isInteger() }
    .collect { it.toInteger() }
    .findAll { it &gt;= 0 }

// If no valid offsets, default to [0]
if (timeOffsets.isEmpty()) {
    timeOffsets = [0]
}

if (activityStart &amp;&amp; activityEnd &amp;&amp; timeOffsets.size() &gt; 0) {
    try {
        // Parse ISO datetime
        def formatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)

        def startStr = activityStart.replace(&quot;Z&quot;, &quot;&quot;).replaceAll(/\\.[0-9]+/, &quot;&quot;)
        def endStr = activityEnd.replace(&quot;Z&quot;, &quot;&quot;).replaceAll(/\\.[0-9]+/, &quot;&quot;)

        def startDt = LocalDateTime.parse(startStr, formatter)
        def endDt = LocalDateTime.parse(endStr, formatter)

        // Calculate total duration in minutes
        def totalDurationMins = java.time.Duration.between(startDt, endDt).toMinutes()
        def minRoomDuration = 30 // Minimum room duration in minutes

        // Filter offsets - only pick offsets that leave at least minRoomDuration
        def maxTotalOffset = totalDurationMins - minRoomDuration

        if (maxTotalOffset &gt; 0) {
            // Filter valid start offsets
            def validStartOffsets = timeOffsets.findAll { it &lt;= maxTotalOffset }
            if (validStartOffsets.isEmpty()) validStartOffsets = [0]

            def startOffset = validStartOffsets[rand.nextInt(validStartOffsets.size())]

            // Remaining time after start offset
            def remainingForEnd = maxTotalOffset - startOffset

            // Filter valid end offsets
            def validEndOffsets = timeOffsets.findAll { it &lt;= remainingForEnd }
            if (validEndOffsets.isEmpty()) validEndOffsets = [0]

            def endOffset = validEndOffsets[rand.nextInt(validEndOffsets.size())]

            // Calculate new times
            def newStartDt = startDt.plusMinutes(startOffset)
            def newEndDt = endDt.minusMinutes(endOffset)

            def outputFormatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)
            roomStartTime = newStartDt.format(outputFormatter)
            roomEndTime = newEndDt.format(outputFormatter)

            log.info(&quot;Room ${roomIndex}: Duration=${totalDurationMins}min, Start +${startOffset}min, End -${endOffset}min&quot;)
        }
    } catch (Exception e) {
        log.warn(&quot;Error calculating room time offset: ${e.message}&quot;)
    }
}

// Set current room variables
vars.put(&quot;roomId&quot;, selectedRoomId)
vars.put(&quot;currentRoomName&quot;, selectedRoomName)
vars.put(&quot;roomType&quot;, roomType)
vars.put(&quot;logisticsRoomType&quot;, roomType)
vars.put(&quot;roomStartTime&quot;, roomStartTime)
vars.put(&quot;roomEndTime&quot;, roomEndTime)
vars.put(&quot;skipRoomCreation&quot;, &quot;false&quot;)

// Logistics Room Notes - random note for each room
def logisticsRoomNotesOptions = [
    &quot;Ensure projector and screen are set up before the session&quot;,
    &quot;Extra power strips required for laptop charging&quot;,
    &quot;Blinds to be closed for projector visibility&quot;,
    &quot;Reserved seating for VIP guests at the front&quot;,
    &quot;Signage to be placed outside the room&quot;,
    &quot;Whiteboard markers and eraser needed&quot;,
    &quot;Print and place agenda copies at each seat&quot;,
    &quot;Wireless microphone and speaker system required&quot;,
    &quot;Place welcome kits at each seat&quot;,
    &quot;Room lighting to be adjusted for presentation mode&quot;,
    &quot;Do not disturb sign to be placed during the session&quot;
]
def noteIndex = (roomIndex - 1) % logisticsRoomNotesOptions.size()
vars.put(&quot;logisticsRoomNotes&quot;, logisticsRoomNotesOptions[noteIndex])

// Store created room for Agenda section - PER DAY to avoid overwrites
// Using SYSTEM PROPERTIES for guaranteed cross-module persistence
def roomIdx = vars.get(&quot;RoomIndex&quot;)?.toInteger() ?: 1
def dayIdx = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;

// Build property names with prefix to avoid conflicts
String propNameId = &quot;jmeter.room.Day${dayIdx}_${roomIdx}_id&quot;.toString()
String propNameName = &quot;jmeter.room.Day${dayIdx}_${roomIdx}_name&quot;.toString()
String propNameCount = &quot;jmeter.roomCount.Day${dayIdx}&quot;.toString()

// Store values using SYSTEM properties (Java-level global)
String roomIdValue = selectedRoomId ?: &quot;&quot;
String roomNameValue = selectedRoomName ?: &quot;&quot;
String roomCountValue = roomIdx.toString()

System.setProperty(propNameId, roomIdValue)
System.setProperty(propNameName, roomNameValue)
System.setProperty(propNameCount, roomCountValue)

// VERIFY immediately after storage
String verifyId = System.getProperty(propNameId)
String verifyCount = System.getProperty(propNameCount)
log.info(&quot;VERIFY STORAGE - propNameId=&apos;${propNameId}&apos; stored=&apos;${roomIdValue}&apos; read=&apos;${verifyId}&apos;&quot;)
log.info(&quot;VERIFY STORAGE - propNameCount=&apos;${propNameCount}&apos; stored=&apos;${roomCountValue}&apos; read=&apos;${verifyCount}&apos;&quot;)

// Also store in vars for local access
vars.put(&quot;createdRoom_Day${dayIdx}_${roomIdx}_id&quot;.toString(), roomIdValue)
vars.put(&quot;createdRoom_Day${dayIdx}_${roomIdx}_name&quot;.toString(), roomNameValue)
vars.put(&quot;createdRoomCount_Day${dayIdx}&quot;.toString(), roomCountValue)

log.info(&quot;Stored for Agenda - Day ${dayIdx} Room [${roomIdx}]: ${selectedRoomName} (${selectedRoomId})&quot;)
log.info(&quot;  Props: ${propNameId} = &apos;${verifyId}&apos;&quot;)
log.info(&quot;  Props: ${propNameCount} = &apos;${verifyCount}&apos;&quot;)

// Debug output
def debugInfo = &quot;&quot;&quot;
Day: ${dayIndex}
RoomIndex (current): ${roomIndex}
TotalRooms: ${totalRooms}
SelectedRoomId: ${selectedRoomId}
SelectedRoomName: ${selectedRoomName}
RoomType: ${roomType}
LogisticsRoomNotes: ${vars.get(&quot;logisticsRoomNotes&quot;)}
ShuffledIndices: ${vars.get(&quot;shuffledRoomIndices_Day&quot; + dayIndex)}
ExtractedRoomCount: ${vars.get(&quot;roomId_matchNr&quot;)}
&quot;&quot;&quot;
SampleResult.setResponseData(debugInfo, &quot;UTF-8&quot;)

log.info(&quot;Day ${dayIndex} - Room ${roomIndex}/${totalRooms}: ${selectedRoomName} [${roomType}]&quot;)</stringProp>
                              <stringProp name="scriptLanguage">groovy</stringProp>
