def _fn_normalizeFormUIConfig = { rawConfig -&gt;
    if (rawConfig == null) return &quot;{}&quot;
    if (rawConfig instanceof String) return rawConfig
    return groovy.json.groovy.json.JsonOutput.toJson(rawConfig)
}
