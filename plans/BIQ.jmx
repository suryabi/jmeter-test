                        <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Check Existing Document Count" enabled="true">
                          <stringProp name="script">

try {
    def response = prev.getResponseDataAsString()
    log.info(&quot;Get Existing Documents response: ${response?.take(500)}&quot;)

    def docCount = 0

    if (response &amp;&amp; response.trim()) {
        def json = new groovy.json.JsonSlurper().parseText(response)

        if (json instanceof List) {
            // Direct array response: [...]
            docCount = json.size()
        } else if (json instanceof Map) {
            // HAL response: {_embedded: {documents: [...]}} or {_embedded: {uploadDocumentModels: [...]}}
            def embedded = json._embedded
            if (embedded) {
                // Try all possible key names
                def docs = embedded.documents ?: embedded.documentModels ?: 
                           embedded.uploadDocumentModels ?: embedded.formDocuments ?:
                           embedded.values()?.find { it instanceof List } ?: []
                docCount = (docs instanceof List) ? docs.size() : 0
            } else if (json.content instanceof List) {
                // Spring Page response: {content: [...]}
                docCount = json.content.size()
            } else if (json.totalElements != null) {
                docCount = json.totalElements
            }
        }
    }

    vars.put(&quot;existingDocumentCount&quot;, docCount.toString())
    log.info(&quot;Existing documents for form: ${docCount}&quot;)

    if (docCount &gt; 0) {
        log.info(&quot;Documents already exist - will SKIP upload&quot;)
    } else {
        log.info(&quot;No documents found - will proceed with upload&quot;)
    }
} catch (Exception e) {
    log.warn(&quot;Error checking existing documents: ${e.message} - assuming no documents&quot;)
    vars.put(&quot;existingDocumentCount&quot;, &quot;0&quot;)
}</stringProp>
