                            <hashTree/>
                            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Document Cleanup PostProcessor" enabled="true">
                              <stringProp name="script">props.get(&quot;fn_documentCleanup&quot;)(vars, log)</stringProp>
                              <stringProp name="scriptLanguage">groovy</stringProp>
