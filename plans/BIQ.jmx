                                      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Dynamic Payload Builder PreProcessor" enabled="true">
                                        <stringProp name="script">
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

def formName = vars.get(&quot;currentFormName&quot;)

def rand = java.util.concurrent.ThreadLocalRandom.current()

def minSelection = props.get(&quot;fn_parseMultiSelectRange&quot;)(vars, null).min
def maxSelection = props.get(&quot;fn_parseMultiSelectRange&quot;)(vars, null).max

def getRandomSelectionCount = { int availableCount -&gt;
    def maxPossible = Math.min(availableCount, maxSelection)
    def minPossible = Math.min(minSelection, maxPossible)
    return minPossible + rand.nextInt((maxPossible - minPossible) + 1)
}

def generateRandomNumber(int min, int max) { return props.get(&quot;fn_generateRandomNumber&quot;)(min, max) }

def generateFutureDate = { props.get(&quot;fn_generateFutureDate&quot;)(vars) }

def generateFutureTime(int hoursOffset) { return props.get(&quot;fn_generateFutureTime&quot;)(vars, hoursOffset) }
props.get(&quot;fn_resetFutureTimeDayOffset&quot;)(vars)

def formUIConfigStr = vars.get(&quot;currentFormUIConfig&quot;)

if (!formUIConfigStr) {
    log.warn(&quot;formUIConfig not found - skipping&quot;)
    vars.put(&quot;dynamicFormPayload&quot;, &quot;{}&quot;)
    log.info(&quot;Terminated: Dynamic Payload Builder&quot;)
    return
}

def fieldMappingsStr = vars.get(&quot;currentFieldMappings&quot;)
def fieldMappingsMap = props.get(&quot;fn_parseFieldMappings&quot;)(fieldMappingsStr)

def allFields = props.get(&quot;fn_extractAllFields&quot;)(formUIConfigStr)
vars.put(&quot;existingFormData&quot;, &quot;{}&quot;)

def currentActivityType = (vars.get(&quot;calcActivityType&quot;) ?: vars.get(&quot;loopActivityType&quot;) ?: vars.get(&quot;activityType&quot;) ?: &quot;unknown&quot;).toLowerCase()
def cateringTypeName = (vars.get(&quot;cateringTypeName&quot;) ?: &quot;catering&quot;).toLowerCase()

vars.remove(&quot;meetingName&quot;)
vars.remove(&quot;meetingDescription&quot;)
vars.remove(&quot;meetingAgenda&quot;)

if (currentActivityType == cateringTypeName) {
    def activityModuleName = vars.get(&quot;currentActivityModuleName&quot;) ?: vars.get(&quot;currentModuleName&quot;) ?: &quot;Catering&quot;
    vars.put(&quot;meetingName&quot;, activityModuleName)

    def cateringNotes = [
        &quot;Include extra napkins and utensils&quot;,
        &quot;Ensure hot items are kept warm until serving&quot;,
        &quot;Water and refreshments should be available throughout&quot;,
        &quot;Serve coffee and tea after the main course&quot;,
        &quot;Keep dietary restriction labels visible&quot;,
        &quot;Ensure gluten-free options are available&quot;,
        &quot;Set up a separate station for beverages&quot;,
        &quot;Include fresh fruit as a healthy option&quot;,
        &quot;Provide to-go containers for leftovers&quot;,
        &quot;Please bring serving spoons and tongs&quot;,
        &quot;Keep cold items refrigerated until serving&quot;,
        &quot;Setup should be complete before guests arrive&quot;,
        &quot;Ensure portion sizes are adequate for all guests&quot;,
        &quot;Desserts should be individually portioned&quot;,
        &quot;Avoid strongly scented foods for this meeting&quot;,
        &quot;Vegetarian options should be clearly marked&quot;,
        &quot;Use eco-friendly cutlery if possible&quot;,
        &quot;No peanuts or tree nuts in any dishes&quot;
    ]
    def note = cateringNotes[rand.nextInt(cateringNotes.size())]
    vars.put(&quot;notes&quot;, note)
    vars.put(&quot;meetingDescription&quot;, note)
    vars.put(&quot;meetingAgenda&quot;, &quot;&quot;)

    String[] caterers = [
        &quot;Sodexo Catering Services&quot;,
        &quot;Aramark Corporate Dining&quot;,
        &quot;Compass Group Catering&quot;,
        &quot;Wolfgang Puck Catering&quot;,
        &quot;Delaware North Catering&quot;,
        &quot;Fresh Ideas Food Service&quot;,
        &quot;Canteen Vending Services&quot;,
        &quot;Eurest Dining Services&quot;
    ]
    vars.put(&quot;catererOrderedFrom&quot;, caterers[rand.nextInt(caterers.length)])

    def contactIndex = rand.nextInt(1, (vars.get(&quot;randomUserCount&quot;) ?: &quot;50&quot;).toInteger() + 1)
    def contactFirst = vars.get(&quot;randomUser${contactIndex}firstName&quot;) ?: &quot;John&quot;
    def contactLast = vars.get(&quot;randomUser${contactIndex}lastName&quot;) ?: &quot;Doe&quot;
    def contactStartDigit = [7, 8, 9][rand.nextInt(3)]
    def contactPhone = String.valueOf(contactStartDigit) +
        String.valueOf(java.util.concurrent.ThreadLocalRandom.current().nextLong(100000000L, 1000000000L))
    vars.put(&quot;onsiteDeliveryContact&quot;, contactFirst + &quot; &quot; + contactLast + &quot; - &quot; + contactPhone)

    String[] setupLocations = [
        &quot;Main Cafeteria&quot;, &quot;Executive Dining Hall&quot;,
        &quot;Food Court&quot;, &quot;Bistro Corner&quot;,
        &quot;Coffee Bar&quot;, &quot;Snack Bar&quot;, &quot;Juice Bar&quot;, &quot;Pantry - Floor 1&quot;, &quot;Pantry - Floor 2&quot;,
        &quot;Pantry - Floor 3&quot;,
        &quot;Kitchen Area&quot;, &quot;Dining Area - East&quot;, &quot;Dining Area - West&quot;,
        &quot;Dining Area - North&quot;, &quot;Catering Station A&quot;, &quot;Catering Station B&quot;,
        &quot;Catering Station C&quot;, &quot;Buffet Area&quot;,
        &quot;Outdoor Dining Area&quot;, &quot;Patio Dining&quot;, &quot;Terrace Cafe&quot;,
        &quot;Vending Area&quot;, &quot;Refreshment Station&quot;, &quot;Beverage Station&quot;,
        &quot;Banquet Hall&quot;, &quot;Private Dining Room&quot;, &quot;Guest Dining Area&quot;,
        &quot;Staff Kitchen&quot;, &quot;Shared Kitchen&quot;, &quot;Satellite Kitchen&quot;,
        &quot;Tea Station&quot;, &quot;Coffee Lounge&quot;, &quot;Espresso Bar&quot;,
        &quot;Salad Bar Area&quot;, &quot;Hot Food Counter&quot;, &quot;Grab and Go Station&quot;,
        &quot;Food Service Area&quot;, &quot;Dining Lounge&quot;,
        &quot;Rooftop Cafe&quot;, &quot;Basement Cafeteria&quot;, &quot;Lobby Cafe&quot;
    ]
    vars.put(&quot;setupLocation&quot;, setupLocations[rand.nextInt(setupLocations.length)])

    log.info(&quot;[Activity DPB] CATERING: notes=&quot; + note)
    log.info(&quot;[Activity DPB] CATERING: catererOrderedFrom=&quot; + vars.get(&quot;catererOrderedFrom&quot;))
    log.info(&quot;[Activity DPB] CATERING: onsiteDeliveryContact=&quot; + vars.get(&quot;onsiteDeliveryContact&quot;))
    log.info(&quot;[Activity DPB] CATERING: setupLocation=&quot; + vars.get(&quot;setupLocation&quot;))
}

def formData = [:]

def defaultTexts = props.get(&quot;fn_defaultTextFields&quot;)

def textareaValues = props.get(&quot;fn_defaultTextAreas&quot;)

def _depResult = props.get(&quot;fn_buildDependentControlsMap&quot;)(allFields)
def dependentControlsMap = _depResult.map
def dependentFieldsSet = _depResult.fieldSet

// FIX: Two-pass ordering — process parent/standalone fields first, dependent fields second.
def nonDependentFields = allFields.findAll { f -&gt; !dependentFieldsSet.contains(f.dataMapping ?: f.formControlName) }
def dependentFields    = allFields.findAll { f -&gt;  dependentFieldsSet.contains(f.dataMapping ?: f.formControlName) }
def orderedFields = nonDependentFields + dependentFields
log.info(&quot;PayloadBuilder: field order — ${nonDependentFields.size()} parent/standalone + ${dependentFields.size()} dependent&quot;)

def shouldShowDependentField(String depFieldName, Map formDataSoFar) {
    props.get(&quot;fn_shouldShowDependentField&quot;)(depFieldName, formDataSoFar, dependentControlsMap, vars)
}

def existingFormDataStr = vars.get(&quot;existingFormData&quot;)
def existingFormData = existingFormDataStr ? new groovy.json.JsonSlurper().parseText(existingFormDataStr) : [:]

// STEP 5: Process Each Field (ordered: parents first, dependent children second)
orderedFields.each { field -&gt;

    def fieldName = field.dataMapping ?: field.formControlName
    def fieldType = field.formControlType
    def fieldLabel = field.fieldLabel ?: fieldName
    def isMultiple = field.isMultiple ?: false
    def lookupName = field.lookupName
    def isHidden = field.hide ?: false
    def isDisabled = field.disabled ?: false

    def existingValue = existingFormData[fieldName]
    def isNumericField = fieldType in [&quot;NUMBER&quot;, &quot;CURRENCY&quot;, &quot;DECIMAL&quot;]
    def isBooleanField = fieldType == &quot;CHECKBOX&quot;
    def isEmptyNumeric = isNumericField &amp;&amp; (existingValue == 0 || existingValue == 0.0 || existingValue == &quot;0&quot;)
    def isEmptyBoolean = isBooleanField &amp;&amp; (existingValue == false || existingValue == &quot;false&quot;)

    if (existingValue != null &amp;&amp; existingValue.toString().trim() != &quot;&quot; &amp;&amp; !isEmptyNumeric &amp;&amp; !isEmptyBoolean) {
        formData[fieldName] = existingValue
        return
    }

    def resourceTypeId = field.resourceTypeId ?: field.resourceType?.id ?:
                         field.resourceType?.uniqueId ?:
                         (field.resourceType instanceof String ? field.resourceType : null)
    def masterTypeId = field.masterTypeId ?: field.masterType?.id ?:
                       field.masterType?.uniqueId ?:
                       (field.masterType instanceof String ? field.masterType : null)
    def enumType = field.enumType ?: &quot;&quot;

    def mappingInfo = fieldMappingsMap[fieldName]
    def aliasName = mappingInfo?.aliasName

    if (isHidden) {
        return
    }

    def hiddenRoles = field.hiddenRoles ?: []
    if (hiddenRoles) {
        def userRole = vars.get(&quot;roleId&quot;) ?: &quot;&quot;
        if (hiddenRoles.contains(userRole)) {
            log.info(&quot;Skipping field &apos;${fieldName}&apos; - user role &apos;${userRole}&apos; is in hiddenRoles: ${hiddenRoles}&quot;)
            return
        }
    }

    def readOnlyRoles = field.readOnlyRoles ?: []
    if (readOnlyRoles) {
        if (readOnlyRoles.contains(userRole)) {
            log.info(&quot;Skipping field &apos;${fieldName}&apos; - user role &apos;${userRole}&apos; is in readOnlyRoles: ${readOnlyRoles}&quot;)
            return
        }
    }

    if (isDisabled) {
        return
    }

    if (dependentFieldsSet.contains(fieldName)) {
        if (!shouldShowDependentField(fieldName, formData)) {
            return
        }
    }

    def value = null
    def skipField = false

    def skipAliasForMultiSelect = (fieldType == &quot;SELECT&quot; &amp;&amp; isMultiple &amp;&amp; lookupName)

    if (aliasName &amp;&amp; !skipAliasForMultiSelect) {
        value = vars.get(aliasName)

        if (value != null &amp;&amp; value != &quot;&quot;) {
            if (fieldType != &quot;TEXTAREA&quot; &amp;&amp; value instanceof String &amp;&amp; value.contains(&quot;,&quot;)) {
                if (isMultiple) {
                    value = value.split(&quot;,&quot;).collect { it.trim() }.toList()
                } else {
                    value = value.split(&quot;,&quot;)[0].trim()
                }
            } else {
                if (isMultiple) {
                    value = [value]
                }
            }
        }
    }

    if (value == null || value == &quot;&quot;) {

        def nameAliases = (vars.get(&quot;meetingNameAliases&quot;) ?: &quot;NAME,TITLE,SUBJECT&quot;).toUpperCase().split(&quot;,&quot;).collect{it.trim()}
        def descAliases = (vars.get(&quot;meetingDescAliases&quot;) ?: &quot;DESCRIPTION,DESC&quot;).toUpperCase().split(&quot;,&quot;).collect{it.trim()}
        def agendaAliases = (vars.get(&quot;meetingAgendaAliases&quot;) ?: &quot;AGENDA&quot;).toUpperCase().split(&quot;,&quot;).collect{it.trim()}

        def aliasUpper = aliasName?.toUpperCase() ?: &quot;&quot;
        def isNameField = nameAliases.any { aliasUpper.contains(it) }
        def isDescField = descAliases.any { aliasUpper.contains(it) }
        def isAgendaField = agendaAliases.any { aliasUpper.contains(it) }

        switch(fieldType) {

            case &quot;TEXT&quot;:
                if (isNameField) {
                    value = vars.get(&quot;meetingName&quot;) ?: defaultTexts[rand.nextInt(defaultTexts.length)]
                } else if (isDescField) {
                    value = vars.get(&quot;meetingDescription&quot;) ?: defaultTexts[rand.nextInt(defaultTexts.length)]
                } else if (isMultiple) {
                    def count = getRandomSelectionCount(defaultTexts.length)
                    def values = []
                    for (int j = 0; j &lt; count; j++) {
                        values.add(defaultTexts[rand.nextInt(defaultTexts.length)])
                    }
                    value = values
                } else {
                    value = defaultTexts[rand.nextInt(defaultTexts.length)]
                }
                break

            case &quot;TEXTAREA&quot;:
                if (isDescField) {
                    value = vars.get(&quot;meetingDescription&quot;) ?: textareaValues[rand.nextInt(textareaValues.length)]
                } else if (isAgendaField) {
                    value = vars.get(&quot;meetingAgenda&quot;) ?: textareaValues[rand.nextInt(textareaValues.length)]
                } else {
                    value = textareaValues[rand.nextInt(textareaValues.length)]
                }
                break

            case &quot;NUMBER&quot;:
                value = props.get(&quot;fn_randomNumber1to5&quot;)()
                break

            case &quot;CURRENCY&quot;:
                value = props.get(&quot;fn_randomNumber1to5&quot;)()
                break

            case &quot;CLOUD_DATE&quot;:
                value = generateFutureDate()
                break

            case &quot;CLOUD_TIME&quot;:
                def slotStartTime = vars.get(&quot;currentVacantSlotStartTime&quot;) ?: &quot;&quot;
                def slotEndTime = vars.get(&quot;currentVacantSlotEndTime&quot;) ?: &quot;&quot;
                def durationMinsStr1 = vars.get(&quot;currentActivityDuration&quot;)
                if (!durationMinsStr1 || !durationMinsStr1.isInteger() || durationMinsStr1.toInteger() &lt;= 0) {
                    def vacantRaw1 = vars.get(&quot;vacantSlotDurations&quot;)?.trim()
                    if (vacantRaw1) {
                        def validDurs1 = vacantRaw1.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }
                        durationMinsStr1 = validDurs1 ? validDurs1[0] : &quot;0&quot;
                    } else {
                        durationMinsStr1 = &quot;0&quot;
                    }
                }
                def durationMins = durationMinsStr1.toInteger()

                def fieldLower = fieldName?.toLowerCase() ?: &quot;&quot;
                def aliasLower = aliasName?.toLowerCase() ?: &quot;&quot;
                def isStartField = fieldLower.contains(&quot;start&quot;) || aliasLower.contains(&quot;start&quot;)
                def isEndField = fieldLower.contains(&quot;end&quot;) || aliasLower.contains(&quot;end&quot;)

                if (isStartField &amp;&amp; slotStartTime) {
                    value = slotStartTime
                } else if (isEndField &amp;&amp; slotStartTime) {
                    try {
                        def formatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)
                        def startDT = LocalDateTime.parse(slotStartTime, formatter)
                        def endDT = startDT.plusMinutes(durationMins)
                        value = endDT.format(formatter)
                    } catch (Exception e) {
                        log.warn(&quot;CLOUD_TIME: Could not calculate endTime: ${e.message}&quot;)
                        value = slotEndTime ?: generateFutureTime(18)
                    }
                } else {
                    if (slotStartTime) {
                        value = slotStartTime
                    } else {
                        value = generateFutureTime(rand.nextInt(9) + 8)
                    }
                }
                break

            case &quot;SELECT&quot;:
                if (enumType == &quot;TIMEZONE&quot;) {
                    value = vars.get(&quot;requestTimeZone&quot;) ?: &quot;&quot;
                } else if (enumType == &quot;MASTER&quot; &amp;&amp; masterTypeId) {
                    def mtCountStr = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_count&quot;)
                    if (mtCountStr &amp;&amp; mtCountStr.isInteger() &amp;&amp; mtCountStr.toInteger() &gt; 0) {
                        def mtCount = mtCountStr.toInteger()
                        if (isMultiple) {
                            def selectCount = getRandomSelectionCount(mtCount)
                            def selectedValues = []
                            def indices = (1..mtCount).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def masterId = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                if (masterId) selectedValues.add(masterId)
                            }
                            if (selectedValues) {
                                value = selectedValues
                            }
                        } else {
                            def randomIndex = rand.nextInt(mtCount) + 1
                            def masterId = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                            def masterName = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + randomIndex + &quot;_name&quot;) ?: &quot;Unknown&quot;
                            value = masterId
                        }
                    } else {
                        log.warn(&quot;No masters found for masterTypeId: ${masterTypeId} - SKIPPING field&quot;)
                        skipField = true
                    }
                } else if (lookupName) {
                    def words = lookupName.toLowerCase().split(&apos;_&apos;)
                    def camelCaseName = words[0] + words.drop(1).collect { it.capitalize() }.join(&apos;&apos;)

                    if (isMultiple) {
                        def countStr = vars.get(camelCaseName + &quot;_count&quot;)
                        if (countStr &amp;&amp; countStr.isInteger()) {
                            def count = countStr.toInteger()
                            def selectCount = getRandomSelectionCount(count)
                            def selectedValues = []
                            def indices = (1..count).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def val = vars.get(camelCaseName + &quot;_&quot; + idx)
                                if (val) selectedValues.add(val)
                            }
                            if (selectedValues) {
                                value = selectedValues
                            } else {
                                log.warn(&quot;No lookup values for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                                skipField = true
                            }
                        } else {
                            log.warn(&quot;No lookup count for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                            skipField = true
                        }
                    } else {
                        def countStr = vars.get(camelCaseName + &quot;_count&quot;)
                        if (countStr &amp;&amp; countStr.isInteger() &amp;&amp; countStr.toInteger() &gt; 0) {
                            def count = countStr.toInteger()

                            def dayIndex = vars.get(&quot;ActivityDayCount&quot;) ?: vars.get(&quot;dayLoopCounter&quot;) ?: &quot;1&quot;
                            def actType = vars.get(&quot;activityType&quot;) ?: &quot;unknown&quot;
                            def roomIdx = vars.get(&quot;roomLoopCounter&quot;) ?: vars.get(&quot;currentRoomCounter&quot;) ?: &quot;1&quot;
                            def activityIter = vars.get(&quot;activityLoopCounter&quot;) ?: &quot;1&quot;

                            def usedKey = &quot;usedLookup_${camelCaseName}_Day${dayIndex}_Room${roomIdx}_${actType}&quot;
                            def usedValuesStr = vars.get(usedKey) ?: &quot;&quot;
                            def usedIndices = usedValuesStr ? usedValuesStr.split(&quot;,&quot;).collect { it.trim().toInteger() } : []

                            def allIndices = (1..count).toList()
                            def availableIndices = allIndices - usedIndices

                            def randomIndex
                            if (availableIndices.size() &gt; 0) {
                                randomIndex = availableIndices[rand.nextInt(availableIndices.size())]
                            } else {
                                randomIndex = rand.nextInt(count) + 1
                            }

                            usedIndices.add(randomIndex)
                            def newUsedStr = usedIndices.join(&quot;,&quot;)
                            vars.put(usedKey, newUsedStr)

                            value = vars.get(camelCaseName + &quot;_&quot; + randomIndex)

                        } else {
                            log.warn(&quot;No valid _count for &apos;${camelCaseName}&apos; - attempting fallback&quot;)
                            def foundValues = []
                            for (int i = 1; i &lt;= 20; i++) {
                                def v = vars.get(camelCaseName + &quot;_&quot; + i)
                                if (v) foundValues.add(v)
                                else break
                            }
                            if (foundValues.size() &gt; 0) {
                                value = foundValues[rand.nextInt(foundValues.size())]
                            } else {
                                value = vars.get(camelCaseName)
                                if (!value) {
                                    log.warn(&quot;No lookup value for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                                    skipField = true
                                }
                            }
                        }
                    }
                } else if (enumType == &quot;RESOURCE&quot; &amp;&amp; resourceTypeId) {
                    def rtCountStr = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_count&quot;)
                    if (rtCountStr &amp;&amp; rtCountStr.isInteger() &amp;&amp; rtCountStr.toInteger() &gt; 0) {
                        def rtCount = rtCountStr.toInteger()
                        def randomIndex = rand.nextInt(rtCount) + 1
                        def resourceId = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                        value = [&quot;uniqueId&quot;: resourceId]
                    } else {
                        log.warn(&quot;No resources found for resourceTypeId: ${resourceTypeId} - SKIPPING field&quot;)
                        skipField = true
                    }
                } else {
                    log.warn(&quot;SELECT field without lookupName/enumType - SKIPPING field&quot;)
                    skipField = true
                }
                break

            case &quot;CHECKBOX&quot;:
                value = rand.nextBoolean()
                break

            case &quot;RESOURCE&quot;:
                if (resourceTypeId) {
                    def rtCountStr = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_count&quot;)
                    if (rtCountStr &amp;&amp; rtCountStr.isInteger() &amp;&amp; rtCountStr.toInteger() &gt; 0) {
                        def rtCount = rtCountStr.toInteger()
                        if (isMultiple) {
                            def selectCount = getRandomSelectionCount(rtCount)
                            def selectedValues = []
                            def indices = (1..rtCount).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def resourceId = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                if (resourceId) selectedValues.add(resourceId)
                            }
                            if (selectedValues) {
                                value = selectedValues
                            }
                        } else {
                            def randomIndex = rand.nextInt(rtCount) + 1
                            value = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                        }
                    } else {
                        log.warn(&quot;No resources fetched for resourceTypeId: ${resourceTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                } else {
                    log.warn(&quot;RESOURCE field without resourceTypeId - SKIPPING&quot;)
                    skipField = true
                }
                break

            case &quot;MASTER&quot;:
                if (masterTypeId) {
                    def mtCountStr = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_count&quot;)
                    if (mtCountStr &amp;&amp; mtCountStr.isInteger() &amp;&amp; mtCountStr.toInteger() &gt; 0) {
                        def mtCount = mtCountStr.toInteger()
                        if (isMultiple) {
                            def selectCount = getRandomSelectionCount(mtCount)
                            def selectedValues = []
                            def indices = (1..mtCount).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def masterId = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                if (masterId) selectedValues.add(masterId)
                            }
                            if (selectedValues) {
                                value = selectedValues
                            }
                        } else {
                            def randomIndex = rand.nextInt(mtCount) + 1
                            value = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                        }
                    } else {
                        log.warn(&quot;No masters fetched for masterTypeId: ${masterTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                } else {
                    log.warn(&quot;MASTER field without masterTypeId - SKIPPING&quot;)
                    skipField = true
                }
                break

            default:
                log.warn(&quot;Unknown field type &apos;${fieldType}&apos; - SKIPPING field&quot;)
                skipField = true
        }
    }

    if (!skipField &amp;&amp; value != null &amp;&amp; value != &quot;&quot;) {
        if ((fieldType == &quot;CLOUD_DATE&quot; || fieldType == &quot;CLOUD_TIME&quot;) &amp;&amp; !(value instanceof Map)) {
            formData[fieldName] = [&quot;isoDate&quot;: value]
        } else if (fieldType == &quot;CHECKBOX&quot;) {
            formData[fieldName] = (value instanceof String) ? value.toLowerCase() == &quot;true&quot; : value
        } else if (fieldType == &quot;NUMBER&quot;) {
            formData[fieldName] = (value instanceof String &amp;&amp; value.isInteger()) ? value.toInteger() : value
        } else if (isMultiple &amp;&amp; !(value instanceof List)) {
            formData[fieldName] = [value]
        } else {
            formData[fieldName] = value
        }
    }
}

def payload = [
    &quot;moduleId&quot; : vars.get(&quot;activityConfig_0_moduleId&quot;) ?: vars.get(&quot;currentActivityModuleId&quot;) ?: vars.get(&quot;moduleId&quot;),
    &quot;formId&quot;   : vars.get(&quot;activityConfig_0_formId&quot;) ?: vars.get(&quot;formId&quot;),
    &quot;journeyId&quot;: vars.get(&quot;activityJourneyId&quot;) ?: vars.get(&quot;currentJourneyId&quot;),
    &quot;pageId&quot;   : vars.get(&quot;activityPageId&quot;) ?: vars.get(&quot;currentPageId&quot;),
    &quot;data&quot;     : formData
]

def payloadJson = groovy.json.JsonOutput.prettyPrint(groovy.json.JsonOutput.toJson(payload))
vars.put(&quot;dynamicFormPayload&quot;, payloadJson)

// FIX: Scope by requestId to prevent processedFields bleeding across different requests
def _trackModuleName = vars.get(&quot;currentModuleName&quot;) ?: vars.get(&quot;currentActivityModuleName&quot;) ?: vars.get(&quot;newRequestModuleName&quot;) ?: &quot;unknown&quot;
def _trackFormName = vars.get(&quot;currentFormName&quot;) ?: vars.get(&quot;requestFormName&quot;) ?: &quot;unknown&quot;
def _trackRequestId = vars.get(&quot;requestId&quot;) ?: &quot;unknown&quot;
def _trackKey = &quot;processedFields_&quot; + _trackRequestId + &quot;_&quot; + _trackModuleName + &quot;_&quot; + _trackFormName
def _existingTracked = props.get(_trackKey) ?: (new HashSet())
for (def k : formData.keySet()) { _existingTracked.add(k) }
props.put(_trackKey, _existingTracked)
log.info(&quot;Field Tracking: Stored ${formData.size()} fields for &apos;${_trackKey}&apos; (total tracked: ${_existingTracked.size()})&quot;)</stringProp>
