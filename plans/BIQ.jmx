                          <stringProp name="Header.value">${customerId}</stringProp>
                        </elementProp>
                        <elementProp name="" elementType="Header">
                          <stringProp name="Header.name">x-cloud-categorytypeid</stringProp>
                          <stringProp name="Header.value">${categoryTypeId}</stringProp>
                        </elementProp>
                        <elementProp name="" elementType="Header">
                          <stringProp name="Header.name">x-cloud-categoryid</stringProp>
                          <stringProp name="Header.value">${categoryId}</stringProp>
                        </elementProp>
                        <elementProp name="" elementType="Header">
                          <stringProp name="Header.name">X-Cloud-Requested-Timezone</stringProp>
                          <stringProp name="Header.value">${baseTimezone}</stringProp>
                        </elementProp>
                        <elementProp name="" elementType="Header">
                          <stringProp name="Header.name">X-Cloud-Client-Timezone</stringProp>
                          <stringProp name="Header.value">${clientTimeZone}</stringProp>
                        </elementProp>
                        <elementProp name="" elementType="Header">
                          <stringProp name="Header.name">X-Cloud-Context-Timezone</stringProp>
                          <stringProp name="Header.value">${baseTimezone}</stringProp>
                        </elementProp>
                        <elementProp name="" elementType="Header">
                          <stringProp name="Header.name">x-cloud-eventid</stringProp>
                          <stringProp name="Header.value">${requestId}</stringProp>
                        </elementProp>
                        <elementProp name="" elementType="Header">
                          <stringProp name="Header.name">X_cloud_user</stringProp>
                          <stringProp name="Header.value">${currentUser}</stringProp>
                        </elementProp>
                      </collectionProp>
                    </HeaderManager>
                    <hashTree/>
                    <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Module Feature Access Extractor" enabled="true">
                      <stringProp name="script">

String responseData = prev.getResponseDataAsString()
def parsedResponse = null

try {
    parsedResponse = new groovy.json.JsonSlurper().parseText(responseData)
} catch (Exception e) {
    log.error(&quot;Failed to parse response: ${e.message}&quot;)
    vars.put(&quot;activityModules_count&quot;, &quot;0&quot;)
    vars.put(&quot;roleModuleAccess_count&quot;, &quot;0&quot;)
    log.info(&quot;Terminated: Feature Access Extractor&quot;)
    return
}

def roleModuleAccess = []

if (parsedResponse instanceof List) {
    roleModuleAccess = parsedResponse
} else if (parsedResponse instanceof Map) {
    if (parsedResponse._embedded) {
        roleModuleAccess = parsedResponse._embedded?.values()?.flatten() ?: []
    } else {
        roleModuleAccess = parsedResponse.values().toList()
    }
} else {
    log.error(&quot;Unexpected response type: ${parsedResponse?.getClass()?.getName()}&quot;)
    vars.put(&quot;activityModules_count&quot;, &quot;0&quot;)
    vars.put(&quot;roleModuleAccess_count&quot;, &quot;0&quot;)
    log.info(&quot;Terminated: Feature Access Extractor&quot;)
    return
}

vars.put(&quot;roleModuleAccess_count&quot;, roleModuleAccess.size().toString())

if (roleModuleAccess.isEmpty()) {
    log.warn(&quot;No role module access entries - Activities will NOT be created!&quot;)
    vars.put(&quot;activityModules_count&quot;, &quot;0&quot;)
    log.info(&quot;Terminated: Feature Access Extractor&quot;)
    return
}

log.info(&quot;Total role module access entries: ${roleModuleAccess.size()}&quot;)

String userFeaturesRaw = vars.get(&quot;userFeatures_ALL&quot;) ?: &quot;&quot;
def userFeatures = userFeaturesRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it }

def activityModules = roleModuleAccess.findAll { access -&gt;
    def feature = access?.feature
    def module = access?.module

    String featureCode = feature?.featureCode ?: feature?.code ?: &quot;&quot;

    boolean hasFeature = userFeatures.isEmpty() || userFeatures.contains(featureCode)

    def moduleUIConfig = module?.moduleUIConfig
    boolean hasActivityType = false

    if (moduleUIConfig instanceof Map) {
        String actType = moduleUIConfig?.activityType ?: &quot;&quot;
        hasActivityType = !actType.isEmpty()
    } else if (moduleUIConfig instanceof String &amp;&amp; moduleUIConfig.contains(&quot;activityType&quot;)) {
        try {
            def parsed = new groovy.json.JsonSlurper().parseText(moduleUIConfig)
            String actType = parsed?.activityType ?: &quot;&quot;
            hasActivityType = !actType.isEmpty()
        } catch (Exception e) {
        }
    }

    hasFeature &amp;&amp; hasActivityType
}

log.info(&quot;Filtered activity modules: ${activityModules.size()}&quot;)

def priorityRaw = vars.get(&quot;activityTypesPriority&quot;) ?: &quot;&quot;
def priorityOrder = priorityRaw.split(&quot;,&quot;).collect { it.trim().toLowerCase() }.findAll { it }

if (priorityOrder) {
    log.info(&quot;Sorting by priority: ${priorityOrder}&quot;)

    def getPriority = { access -&gt;
        def module = access?.module
        String moduleName = (module?.moduleName ?: module?.name ?: &quot;&quot;).toLowerCase()

        def moduleUIConfig = module?.moduleUIConfig
        String activityType = &quot;&quot;
        if (moduleUIConfig instanceof Map) {
            activityType = (moduleUIConfig?.activityType ?: &quot;&quot;).toLowerCase()
        }

        int priority = priorityOrder.size() + 1  // Default: lowest priority

        for (int i = 0; i &lt; priorityOrder.size(); i++) {
            def p = priorityOrder[i]
            if (moduleName.contains(p) || activityType == p) {
                priority = i + 1
                break
            }
        }

        return priority
    }

    activityModules = activityModules.sort { a, b -&gt; getPriority(a) &lt;=&gt; getPriority(b) }
} else {
    log.info(&quot;No priority set - using API order&quot;)
}

int count = activityModules.size()
vars.put(&quot;activityModules_count&quot;, count.toString())

def moduleIds = []
def moduleNames = []
def activityTypes = []
def featureCodes = []

activityModules.eachWithIndex { access, idx -&gt;
    int num = idx + 1

    def module = access?.module
    def feature = access?.feature

    String moduleId = module?.uniqueId ?: module?.id ?: &quot;&quot;
    String moduleName = module?.moduleName ?: module?.name ?: &quot;&quot;

    def moduleUIConfig = module?.moduleUIConfig
    String activityType = &quot;&quot;

    if (moduleUIConfig instanceof Map) {
        activityType = moduleUIConfig?.activityType ?: &quot;&quot;
    } else if (moduleUIConfig instanceof String &amp;&amp; moduleUIConfig.contains(&quot;activityType&quot;)) {
        try {
            def parsed = new groovy.json.JsonSlurper().parseText(moduleUIConfig)
            activityType = parsed?.activityType ?: &quot;&quot;
        } catch (Exception e) {
            log.warn(&quot;Could not parse moduleUIConfig: ${moduleUIConfig}&quot;)
        }
    }

    String featureCode = feature?.featureCode ?: feature?.code ?: &quot;&quot;

    vars.put(&quot;activityModuleId_&quot; + num, moduleId)
    vars.put(&quot;activityModuleName_&quot; + num, moduleName)
    vars.put(&quot;activityType_&quot; + num, activityType)
    vars.put(&quot;activityFeatureCode_&quot; + num, featureCode)

    moduleIds.add(moduleId)
    moduleNames.add(moduleName)
    activityTypes.add(activityType)
    featureCodes.add(featureCode)

}

vars.put(&quot;activityModuleId_ALL&quot;, moduleIds.join(&quot;,&quot;))
vars.put(&quot;activityModuleName_ALL&quot;, moduleNames.join(&quot;,&quot;))
vars.put(&quot;activityType_ALL&quot;, activityTypes.join(&quot;,&quot;))
vars.put(&quot;moduleFeatureAccess_ALL&quot;, featureCodes.join(&quot;,&quot;))

log.info(&quot;----- Terminated: Extract activity type features based on priority -----&quot;)</stringProp>
