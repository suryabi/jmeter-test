                                <hashTree/>
                                <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Dynamic Payload Builder PreProcessor" enabled="true">
                                  <stringProp name="script">

// Dynamic payload entry

// Clear stale existingFormData from previous modules
vars.put(&quot;existingFormData&quot;, &quot;{}&quot;)

def formName = vars.get(&quot;currentFormName&quot;)

// Get room name for TEXT field (Main Room or Breakout Room X)
def roomNameForText = vars.get(&quot;currentRoomName&quot;)
def roomNameUsed = false

def rand = java.util.concurrent.ThreadLocalRandom.current()

// Multi-select configuration from User Defined Variables
def minSelection = props.get(&quot;fn_parseMultiSelectRange&quot;)(vars, null).min
def maxSelection = props.get(&quot;fn_parseMultiSelectRange&quot;)(vars, null).max

// Helper function to generate random selection count
def getRandomSelectionCount = { int availableCount -&gt;
    def maxPossible = Math.min(availableCount, maxSelection)
    def minPossible = Math.min(minSelection, maxPossible)
    return minPossible + rand.nextInt((maxPossible - minPossible) + 1)
}

// Load shared function: generateRandomNumber
def generateRandomNumber(int min, int max) { return props.get(&quot;fn_generateRandomNumber&quot;)(min, max) }

// Load shared function: generateFutureDate
def generateFutureDate = { props.get(&quot;fn_generateFutureDate&quot;)(vars) }

// Load shared function: generateFutureTime
def generateFutureTime(int hoursOffset) { return props.get(&quot;fn_generateFutureTime&quot;)(vars, hoursOffset) }
// Reset future time day offset for this form
props.get(&quot;fn_resetFutureTimeDayOffset&quot;)(vars)
// STEP 1: Get formUIConfig
def formUIConfigStr = vars.get(&quot;currentFormUIConfig&quot;)

if (!formUIConfigStr) {
    log.warn(&quot;formUIConfig not found - skipping&quot;)
    vars.put(&quot;dynamicFormPayload&quot;, &quot;{}&quot;)
    return
}
// STEP 2: Get and Parse fieldMappings
def fieldMappingsStr = vars.get(&quot;currentFieldMappings&quot;)
def fieldMappingsMap = props.get(&quot;fn_parseFieldMappings&quot;)(fieldMappingsStr)
// STEP 3: Parse formUIConfig and Extract All Fields
def allFields = props.get(&quot;fn_extractAllFields&quot;)(formUIConfigStr)
// STEP 4: Initialize Form Data and Default Values
def formData = [:]

// Default text values for auto-generation
def defaultTexts = props.get(&quot;fn_defaultTextFields&quot;)

// Default textarea values for auto-generation
def textareaValues = props.get(&quot;fn_defaultTextAreas&quot;)
// STEP 4.5: Build Dependent Controls Map
def _depResult = props.get(&quot;fn_buildDependentControlsMap&quot;)(allFields)
def dependentControlsMap = _depResult.map
def dependentFieldsSet = _depResult.fieldSet

// FIX: Two-pass ordering — process parent/standalone fields first, dependent fields second.
def nonDependentFields = allFields.findAll { f -&gt; !dependentFieldsSet.contains(f.dataMapping ?: f.formControlName) }
def dependentFields    = allFields.findAll { f -&gt;  dependentFieldsSet.contains(f.dataMapping ?: f.formControlName) }
def orderedFields = nonDependentFields + dependentFields
log.info(&quot;PayloadBuilder: field order — ${nonDependentFields.size()} parent/standalone + ${dependentFields.size()} dependent&quot;)

// Helper: Check if dependent field should be shown
def shouldShowDependentField(String depFieldName, Map formDataSoFar) {
    props.get(&quot;fn_shouldShowDependentField&quot;)(depFieldName, formDataSoFar, dependentControlsMap, vars)
}

// Get existing form data (stored from Get Form API)
def existingFormDataStr = vars.get(&quot;existingFormData&quot;)
def existingFormData = existingFormDataStr ? new groovy.json.JsonSlurper().parseText(existingFormDataStr) : [:]

// STEP 5: Process Each Field (ordered: parents first, dependent children second)
orderedFields.each { field -&gt;

    // Extract field properties
    def fieldName = field.dataMapping ?: field.formControlName
    def fieldType = field.formControlType
    def fieldLabel = field.fieldLabel ?: fieldName
    def isMultiple = field.isMultiple ?: false
    def lookupName = field.lookupName
    def isHidden = field.hide ?: false
    def isDisabled = field.disabled ?: false 

    // CHECK: Skip if field already has MEANINGFUL value in existing data
    def existingValue = existingFormData[fieldName]
    def isNumericField = fieldType in [&quot;NUMBER&quot;, &quot;CURRENCY&quot;, &quot;DECIMAL&quot;]
    def isBooleanField = fieldType == &quot;CHECKBOX&quot;
    def isEmptyNumeric = isNumericField &amp;&amp; (existingValue == 0 || existingValue == 0.0 || existingValue == &quot;0&quot;)
    def isEmptyBoolean = isBooleanField &amp;&amp; (existingValue == false || existingValue == &quot;false&quot;)

    if (existingValue != null &amp;&amp; existingValue.toString().trim() != &quot;&quot; &amp;&amp; !isEmptyNumeric &amp;&amp; !isEmptyBoolean) {
        formData[fieldName] = existingValue
        return
    }

    // Extract Resource/Master Type IDs
    def resourceTypeId = field.resourceTypeId ?: field.resourceType?.id ?:
                         field.resourceType?.uniqueId ?:
                         (field.resourceType instanceof String ? field.resourceType : null)
    def masterTypeId = field.masterTypeId ?: field.masterType?.id ?:
                       field.masterType?.uniqueId ?:
                       (field.masterType instanceof String ? field.masterType : null)

    // Get aliasName from fieldMappings
    def mappingInfo = fieldMappingsMap[fieldName]
    def aliasName = mappingInfo?.aliasName
    // Skip Hidden Fields
    if (isHidden) {
        return
    }

    // Skip fields based on hiddenRoles (check against selected role only)
    def hiddenRoles = field.hiddenRoles ?: []
    if (hiddenRoles) {
        def userRole = vars.get(&quot;roleId&quot;) ?: &quot;&quot;

        if (hiddenRoles.contains(userRole)) {
            log.info(&quot;Skipping field &apos;${fieldName}&apos; - user role &apos;${userRole}&apos; is in hiddenRoles: ${hiddenRoles}&quot;)
            return
        }
    }

     // Skip fields based on readOnlyRoles (check against selected role only)
    def readOnlyRoles = field.readOnlyRoles ?: []
    if (readOnlyRoles) {

        if (readOnlyRoles.contains(userRole)) {
            log.info(&quot;Skipping field &apos;${fieldName}&apos; - user role &apos;${userRole}&apos; is in readOnlyRoles: ${readOnlyRoles}&quot;)
            return
        }
    }

    if (isDisabled) {
        return
    }
    // Check Dependent Field Visibility
    if (dependentFieldsSet.contains(fieldName)) {
        if (!shouldShowDependentField(fieldName, formData)) {
            return
        }
    }

    def value = null
    def skipField = false
    // PRIORITY 1: Get Value from JMeter Variable (via alias)
    // For SELECT fields with isMultiple=true and lookupName, skip alias to use multi-select logic
    def skipAliasForMultiSelect = (fieldType == &quot;SELECT&quot; &amp;&amp; isMultiple &amp;&amp; lookupName)

    if (aliasName &amp;&amp; !skipAliasForMultiSelect) {
        value = vars.get(aliasName)

        if (value != null &amp;&amp; value != &quot;&quot;) {
            // Smart handling based on isMultiple from form config
            // SKIP comma-splitting for TEXTAREA fields - they can legitimately contain commas
            if (fieldType != &quot;TEXTAREA&quot; &amp;&amp; value instanceof String &amp;&amp; value.contains(&quot;,&quot;)) {
                if (isMultiple) {
                    // isMultiple = true  to  Convert to array
                    value = value.split(&quot;,&quot;).collect { it.trim() }.toList()
                } else {
                    // isMultiple = false  to  Take FIRST value only
                    value = value.split(&quot;,&quot;)[0].trim()
                }
            } else {
                // Single value
                if (isMultiple) {
                    value = [value]
                }
            }
        }
    }
    // PRIORITY 2: Auto-generate if No Alias or No Value
    if (isNumericField &amp;&amp; (value == &quot;0&quot; || value == 0 || value == 0.0)) value = null
    if (value == null || value == &quot;&quot;) {
        switch(fieldType) {

            // TEXT Field
            case &quot;TEXT&quot;:
                // Use roomNameForText for first TEXT field (for room creation)
                if (roomNameForText &amp;&amp; !roomNameUsed &amp;&amp; !isMultiple) {
                    value = roomNameForText
                    roomNameUsed = true
                } else if (isMultiple) {
                    def count = getRandomSelectionCount(defaultTexts.length)
                    def values = []
                    for (int j = 0; j &lt; count; j++) {
                        values.add(defaultTexts[rand.nextInt(defaultTexts.length)])
                    }
                    value = values
                } else {
                    value = defaultTexts[rand.nextInt(defaultTexts.length)]
                }
                break

            // TEXTAREA Field
            case &quot;TEXTAREA&quot;:
                value = textareaValues[rand.nextInt(textareaValues.length)]
                break

            // NUMBER Field
            case &quot;NUMBER&quot;:
                value = props.get(&quot;fn_randomNumber1to5&quot;)()
                break

            // CURRENCY Field
            case &quot;CURRENCY&quot;:
                value = props.get(&quot;fn_randomNumber1to5&quot;)()
                break

            // CLOUD_DATE Field
            case &quot;CLOUD_DATE&quot;:
                value = generateFutureDate()
                break

            // CLOUD_TIME Field
            case &quot;CLOUD_TIME&quot;:
                if (fieldName.toLowerCase().contains(&quot;start&quot;)) {
                    value = generateFutureTime(9)
                } else if (fieldName.toLowerCase().contains(&quot;end&quot;)) {
                    value = generateFutureTime(18)
                } else {
                    value = generateFutureTime(rand.nextInt(9) + 8)
                }
                break

            // SELECT Field
            case &quot;SELECT&quot;:
                // Check for TIMEZONE enumType
                if ((field.enumType ?: &quot;&quot;) == &quot;TIMEZONE&quot;) {
                    value = vars.get(&quot;requestTimeZone&quot;) ?: &quot;&quot;
                } else if ((field.enumType ?: &quot;&quot;) == &quot;RESOURCE&quot; &amp;&amp; resourceTypeId) {
                    // FIX: SELECT fields with enumType=RESOURCE (e.g. Briefing Manager, Technical Manager)
                    def rtCountStr = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_count&quot;)
                    if (rtCountStr &amp;&amp; rtCountStr.isInteger() &amp;&amp; rtCountStr.toInteger() &gt; 0) {
                        def rtCount = rtCountStr.toInteger()
                        if (isMultiple) {
                            def selectCount = getRandomSelectionCount(rtCount)
                            def selectedValues = []
                            def indices = (1..rtCount).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def resourceId = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                if (resourceId) selectedValues.add(resourceId)
                            }
                            if (selectedValues) { value = selectedValues }
                        } else {
                            def randomIndex = rand.nextInt(rtCount) + 1
                            value = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                        }
                        if (!value) {
                            log.warn(&quot;SELECT[RESOURCE] field &apos;${fieldName}&apos; - no resource value found for typeId: ${resourceTypeId} - SKIPPING&quot;)
                            skipField = true
                        }
                    } else {
                        log.warn(&quot;SELECT[RESOURCE] field &apos;${fieldName}&apos; - no resources fetched for typeId: ${resourceTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                } else if (lookupName) {
                    // Check if this is ROOM_TYPE and we already have a roomType set
                    if (lookupName == &quot;ROOM_TYPE&quot;) {
                        def existingRoomType = vars.get(&quot;roomType&quot;)
                        if (existingRoomType) {
                            value = existingRoomType
                            break
                        }
                    }

                    // Convert SNAKE_CASE to camelCase
                    def words = lookupName.toLowerCase().split(&apos;_&apos;)
                    def camelCaseName = words[0] + words.drop(1).collect { it.capitalize() }.join(&apos;&apos;)

                    if (isMultiple) {
                        // Multi-select: pick random values based on minSelection/maxSelection
                        def countStr = vars.get(camelCaseName + &quot;_count&quot;)

                        if (countStr &amp;&amp; countStr.isInteger()) {
                            def count = countStr.toInteger()
                            def selectCount = getRandomSelectionCount(count)
                            def selectedValues = []
                            def indices = (1..count).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def val = vars.get(camelCaseName + &quot;_&quot; + idx)
                                if (val) selectedValues.add(val)
                            }
                            if (selectedValues) {
                                value = selectedValues

                            } else {
                                log.warn(&quot;No lookup values for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                                skipField = true
                            }
                        } else {
                            log.warn(&quot;No lookup count for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                            skipField = true
                        }
                    } else {
                        // Single select: pick one random value
                        def countStr = vars.get(camelCaseName + &quot;_count&quot;)
                        if (countStr &amp;&amp; countStr.isInteger()) {
                            def count = countStr.toInteger()
                            def randomIndex = rand.nextInt(count) + 1
                            value = vars.get(camelCaseName + &quot;_&quot; + randomIndex)

                        } else {
                            value = vars.get(camelCaseName)
                            if (value) {

                            } else {
                                log.warn(&quot;No lookup value for &apos;${lookupName}&apos; - SKIPPING field&quot;)
                                skipField = true
                            }
                        }
                    }
                } else {
                    log.warn(&quot;No lookupName defined - SKIPPING field&quot;)
                    skipField = true
                }
                break

            // CHECKBOX Field
            case &quot;CHECKBOX&quot;:
                value = rand.nextBoolean()
                break

            // RESOURCE Field
            case &quot;RESOURCE&quot;:
                if (resourceTypeId) {

                    def rtCountStr = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_count&quot;)
                    if (rtCountStr &amp;&amp; rtCountStr.isInteger() &amp;&amp; rtCountStr.toInteger() &gt; 0) {
                        def rtCount = rtCountStr.toInteger()

                        if (isMultiple) {
                            // Multi-select resources
                            def selectCount = getRandomSelectionCount(rtCount)
                            def selectedValues = []
                            def indices = (1..rtCount).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def resourceId = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                if (resourceId) selectedValues.add(resourceId)
                            }
                            if (selectedValues) {
                                value = selectedValues

                            }
                        } else {
                            // Single select resource
                            def randomIndex = rand.nextInt(rtCount) + 1
                            value = vars.get(&quot;resourcesFor_&quot; + resourceTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                        }
                    } else {
                        log.warn(&quot;No resources fetched for resourceTypeId: ${resourceTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                } else {
                    log.warn(&quot;RESOURCE/AUTOCOMPLETE field without resourceTypeId - SKIPPING&quot;)
                    skipField = true
                }
                break

            // MASTER Field
            case &quot;MASTER&quot;:
                if (masterTypeId) {

                    def mtCountStr = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_count&quot;)
                    if (mtCountStr &amp;&amp; mtCountStr.isInteger() &amp;&amp; mtCountStr.toInteger() &gt; 0) {
                        def mtCount = mtCountStr.toInteger()

                        if (isMultiple) {
                            // Multi-select masters
                            def selectCount = getRandomSelectionCount(mtCount)
                            def selectedValues = []
                            def indices = (1..mtCount).toList()
                            Collections.shuffle(indices)
                            for (def idx : indices.take(selectCount)) {
                                def masterId = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + idx + &quot;_id&quot;)
                                if (masterId) selectedValues.add(masterId)
                            }
                            if (selectedValues) {
                                value = selectedValues

                            }
                        } else {
                            // Single select master
                            def randomIndex = rand.nextInt(mtCount) + 1
                            value = vars.get(&quot;mastersFor_&quot; + masterTypeId + &quot;_&quot; + randomIndex + &quot;_id&quot;)
                        }
                    } else {
                        log.warn(&quot;No masters fetched for masterTypeId: ${masterTypeId} - SKIPPING&quot;)
                        skipField = true
                    }
                } else {
                    log.warn(&quot;MASTER field without masterTypeId - SKIPPING&quot;)
                    skipField = true
                }
                break

            // Unknown Field Type
            default:
                log.warn(&quot;Unknown field type &apos;${fieldType}&apos; - SKIPPING field&quot;)
                skipField = true
        }
    }
    // STEP 6: Add to formData with Proper Type Handling
    if (!skipField &amp;&amp; value != null &amp;&amp; value != &quot;&quot;) {
        if ((fieldType == &quot;CLOUD_DATE&quot; || fieldType == &quot;CLOUD_TIME&quot;) &amp;&amp; !(value instanceof Map)) {
            // Wrap date/time in isoDate format
            formData[fieldName] = [&quot;isoDate&quot;: value]
        } else if (fieldType == &quot;CHECKBOX&quot;) {
            // Ensure boolean type
            formData[fieldName] = (value instanceof String) ? value.toLowerCase() == &quot;true&quot; : value
        } else if (fieldType == &quot;NUMBER&quot;) {
            // Ensure integer type
            formData[fieldName] = (value instanceof String &amp;&amp; value.isInteger()) ? value.toInteger() : value
        } else if (isMultiple &amp;&amp; !(value instanceof List)) {
            // Wrap single value in array for multi-select fields
            formData[fieldName] = [value]
        } else {
            formData[fieldName] = value
        }
    }
}
// STEP 7: Build Complete Payload
def payload = [
    &quot;moduleId&quot; : vars.get(&quot;currentModuleId&quot;) ?: vars.get(&quot;moduleId&quot;),
    &quot;formId&quot;   : vars.get(&quot;currentFormId&quot;) ?: vars.get(&quot;formId&quot;),
    &quot;journeyId&quot;: vars.get(&quot;currentJourneyId&quot;),
    &quot;pageId&quot;   : vars.get(&quot;currentPageId&quot;),
    &quot;id&quot;       : vars.get(&quot;activityDayResourceId&quot;),
    &quot;data&quot;     : formData
]

// Convert to JSON and store
def payloadJson = groovy.json.JsonOutput.prettyPrint(groovy.json.JsonOutput.toJson(payload))
vars.put(&quot;dynamicFormPayload&quot;, payloadJson)
// ============ FIELD TRACKING ============
// Store processed field keys for cross-user comparison (shared via props)
// FIX: Scope by requestId to prevent processedFields bleeding across different requests
def _trackModuleName = vars.get(&quot;currentModuleName&quot;) ?: vars.get(&quot;currentActivityModuleName&quot;) ?: vars.get(&quot;newRequestModuleName&quot;) ?: &quot;unknown&quot;
def _trackFormName = vars.get(&quot;currentFormName&quot;) ?: vars.get(&quot;requestFormName&quot;) ?: &quot;unknown&quot;
def _trackRequestId = vars.get(&quot;requestId&quot;) ?: &quot;unknown&quot;
def _trackKey = &quot;processedFields_&quot; + _trackRequestId + &quot;_&quot; + _trackModuleName + &quot;_&quot; + _trackFormName
def _existingTracked = props.get(_trackKey) ?: (new HashSet())
for (def k : formData.keySet()) { _existingTracked.add(k) }
props.put(_trackKey, _existingTracked)
log.info(&quot;Field Tracking: Stored ${formData.size()} fields for &apos;${_trackKey}&apos; (total tracked: ${_existingTracked.size()})&quot;)
</stringProp>
