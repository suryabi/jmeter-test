                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Request Count PostProcessor" enabled="true">
                  <stringProp name="script">import java.time.format.TextStyle
import java.util.Locale

def RequestCount = vars.get(&quot;RequestCount&quot;)
def isFirstUser = vars.get(&quot;isFirstUser&quot;) ?: &quot;true&quot;
def requestsPerDay = (vars.get(&quot;requestsPerDay&quot;) ?: &quot;1&quot;).toInteger()
def totalValidDays = (vars.get(&quot;totalValidDays&quot;) ?: &quot;1&quot;).toInteger()
def totalRequestCount = vars.get(&quot;totalRequestCount&quot;) ?: &quot;1&quot;
def rc = RequestCount.toInteger()

// Calculate day index and request-in-day
int dayIndex = ((rc - 1) / requestsPerDay).intValue() + 1
int requestInDay = ((rc - 1) % requestsPerDay) + 1
def dateForDay = vars.get(&quot;validDate_&quot; + dayIndex) ?: &quot;unknown&quot;

// Get short day name (Mon, Tue, etc.)
def dayName = &quot;&quot;
try {
    def parsedDate = java.time.LocalDate.parse(dateForDay)
    dayName = parsedDate.dayOfWeek.getDisplayName(TextStyle.SHORT, Locale.ENGLISH)
} catch (Exception e) {
    dayName = &quot;&quot;
}

// Set readable sampler label for View Results Tree
prev.setSampleLabel(&quot;✦─── Request (&quot; + RequestCount + &quot;/&quot; + totalRequestCount + &quot;) | &quot; + dateForDay + &quot; (&quot; + dayName + &quot;) | Per Day (&quot; + requestInDay + &quot;/&quot; + requestsPerDay + &quot;) ───✦&quot;)

log.info(&quot;═══════════════════════════════════════════════════&quot;)
log.info(&quot;Request &quot; + RequestCount + &quot;/&quot; + totalRequestCount + &quot; Creation Started&quot;)
log.info(&quot;Day: &quot; + dayIndex + &quot;/&quot; + totalValidDays + &quot; (&quot; + dateForDay + &quot; - &quot; + dayName + &quot;)&quot;)
log.info(&quot;Request for this day: &quot; + requestInDay + &quot;/&quot; + requestsPerDay)
log.info(&quot;Is First User: &quot; + isFirstUser)
log.info(&quot;═══════════════════════════════════════════════════&quot;)

// Only reset room counts for the first user
if (isFirstUser == &quot;true&quot;) {
    log.info(&quot;First user - resetting room counters and processedFields tracking&quot;)

	def roomsRaw = vars.get(&quot;rooms&quot;) ?: &quot;0&quot;
	def roomOptions = roomsRaw.split(&quot;,&quot;).findAll { it.trim().isInteger() &amp;&amp; it.trim().toInteger() &gt;= 0 }.collect { it.trim().toInteger() }
	def maxRooms = roomOptions ? roomOptions[java.util.concurrent.ThreadLocalRandom.current().nextInt(roomOptions.size())] : 0
    for (int day = 1; day &lt;= totalValidDays; day++) {
        vars.put(&quot;createdRoomCount_Day${day}&quot;, &quot;0&quot;)
        System.clearProperty(&quot;jmeter.roomCount.Day${day}&quot;)
        for (int i = 1; i &lt;= maxRooms; i++) {
            vars.remove(&quot;createdRoom_Day${day}_${i}_id&quot;)
            vars.remove(&quot;createdRoom_Day${day}_${i}_name&quot;)
            System.clearProperty(&quot;jmeter.room.Day${day}_${i}_id&quot;)
            System.clearProperty(&quot;jmeter.room.Day${day}_${i}_name&quot;)
        }
    }

    def reqId = vars.get(&quot;requestId&quot;) ?: &quot;unknown&quot;
    def clearProps = { String prefix -&gt;
        def keys = props.keys().findAll { it.startsWith(prefix) }
        keys.each { props.remove(it) }
        log.info(&quot;Cleared ${keys.size()} entries for prefix: ${prefix}&quot;)
    }
    clearProps(&quot;processedFields_${reqId}_&quot;)
    clearProps(&quot;existingFormData_snapshot_${reqId}_&quot;)

} else {
    log.info(&quot;Subsequent user - preserving room data from first user&quot;)
}</stringProp>
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">false</stringProp>
                </JSR223PostProcessor>
                <hashTree/>
              </hashTree>
              <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Generate Dates for a Request" enabled="true">
                <stringProp name="script">import java.time.*
import java.time.format.DateTimeFormatter

def rand = java.util.concurrent.ThreadLocalRandom.current()
DateTimeFormatter dateFormatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;)
DateTimeFormatter timeFormatter = DateTimeFormatter.ofPattern(&quot;HH:mm&quot;)

// ===================== READ VARIABLES =====================
boolean allowWeekends = vars.get(&quot;allowWeekends&quot;)?.equalsIgnoreCase(&quot;true&quot;) ?: false
int requestCount = (vars.get(&quot;RequestCount&quot;) ?: &quot;1&quot;).toInteger()
int requestsPerDay = (vars.get(&quot;requestsPerDay&quot;) ?: &quot;1&quot;).toInteger()
int totalValidDays = (vars.get(&quot;totalValidDays&quot;) ?: &quot;1&quot;).toInteger()

// ===================== HELPER METHODS =====================
// Parses comma-separated string to list of positive integers
def parseIntList = { String raw, List&lt;Integer&gt; defaults -&gt;
    if (!raw) return defaults
    def parsed = raw.split(&quot;,&quot;)
        .findAll { it.trim().isInteger() &amp;&amp; it.trim().toInteger() &gt; 0 }
        .collect { it.trim().toInteger() }
    return parsed.isEmpty() ? defaults : parsed
}

// Parses comma-separated string to list of times (HH:mm)
def parseTimeList = { String raw, List&lt;LocalTime&gt; defaults -&gt;
    if (!raw) return defaults
    def parsed = raw.split(&quot;,&quot;)
        .collect { it.trim() }
        .findAll { it ==~ /^\d{2}:\d{2}$/ }
        .findAll {
            try { LocalTime.parse(it, timeFormatter) != LocalTime.MIDNIGHT } catch (Exception e) { false }
        }
        .collect { LocalTime.parse(it, timeFormatter) }
    return parsed.isEmpty() ? defaults : parsed
}

// ===================== SEQUENTIAL DATE ASSIGNMENT =====================
// dayIndex: which day are we on (1-based)
// requestInDay: which request within that day (1-based)
int dayIndex = ((requestCount - 1) / requestsPerDay).intValue() + 1
int requestInDay = ((requestCount - 1) % requestsPerDay) + 1

// Get the pre-calculated date for this dayIndex
String dateStr = vars.get(&quot;validDate_&quot; + dayIndex)
if (!dateStr) {
    log.error(&quot;No validDate found for dayIndex ${dayIndex}! Falling back to validDate_1&quot;)
    dateStr = vars.get(&quot;validDate_1&quot;)
}

LocalDate selectedDate = LocalDate.parse(dateStr, dateFormatter)

boolean actualWeekend = selectedDate.dayOfWeek in [DayOfWeek.SATURDAY, DayOfWeek.SUNDAY]
vars.put(&quot;isWeekend&quot;, String.valueOf(actualWeekend &amp;&amp; !allowWeekends))

// ===================== START TIME &amp; DURATION =====================
def possibleTimes = parseTimeList(vars.get(&quot;requestStartTimes&quot;)?.trim(), [LocalTime.of(8, 0), LocalTime.of(9, 0)])
LocalTime randomStartTime = possibleTimes[rand.nextInt(possibleTimes.size())]

def daysOptions = parseIntList(vars.get(&quot;requestDays&quot;)?.trim(), [1])
int randomDurationDays = daysOptions[rand.nextInt(daysOptions.size())]

def durations = parseIntList(vars.get(&quot;requestDurations&quot;)?.trim(), [480, 540, 600]).findAll { it &gt;= 30 }
if (durations.isEmpty()) durations = [480, 540, 600]
int durationMinutes = durations[rand.nextInt(durations.size())]

// ===================== CALCULATE DATES =====================
LocalDateTime startDateMidnight = selectedDate.atTime(0, 0)
LocalDateTime startDateWithRandomTime = LocalDateTime.of(selectedDate, randomStartTime)
LocalDateTime endDateTime = startDateWithRandomTime.plusMinutes(durationMinutes)

DateTimeFormatter isoFormatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)

// ===================== SAVE VARIABLES =====================
vars.put(&quot;startDate&quot;, startDateMidnight.format(isoFormatter))
vars.put(&quot;startTime&quot;, startDateWithRandomTime.format(isoFormatter))
vars.put(&quot;endTime&quot;, endDateTime.format(isoFormatter))
vars.put(&quot;duration&quot;, String.valueOf(randomDurationDays))

log.info(&quot;Request ${requestCount}: Day ${dayIndex}/${totalValidDays} (${selectedDate} - ${selectedDate.dayOfWeek}) | Request ${requestInDay}/${requestsPerDay} for this day | Time: ${randomStartTime} | Duration: ${durationMinutes}min&quot;)</stringProp>
