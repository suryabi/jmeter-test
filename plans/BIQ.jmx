// Generate a future date based on startDate or current date
def _fn_generateFutureDate = { varsRef -&gt;
    def rand = java.util.concurrent.ThreadLocalRandom.current()
    def startDateStr = varsRef.get(&quot;startDate&quot;) ?: &quot;&quot;
    def baseDate
    if (startDateStr) {
        baseDate = Date.parse(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;, startDateStr)
    } else {
        baseDate = new Date()
    }
    def futureDate = baseDate.plus(rand.nextInt(30) + 1)
    return futureDate.format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)
}
props.put(&quot;fn_generateFutureDate&quot;, _fn_generateFutureDate)

// Generate a future time with a fixed hour
def _fn_generateFutureTime = { varsRef, int hoursOffset -&gt;
    def rand = java.util.concurrent.ThreadLocalRandom.current()
    def calendar = Calendar.getInstance()
    // Reuse the same random day offset if already generated for this form
    def dayOffsetKey = &quot;_futureTimeDayOffset&quot;
    def existingOffset = varsRef.get(dayOffsetKey)
    int dayOffset
    if (existingOffset != null &amp;&amp; existingOffset.isInteger()) {
        dayOffset = existingOffset.toInteger()
    } else {
        dayOffset = rand.nextInt(30) + 1
        varsRef.put(dayOffsetKey, String.valueOf(dayOffset))
    }
    calendar.add(Calendar.DAY_OF_MONTH, dayOffset)
    calendar.set(Calendar.HOUR_OF_DAY, hoursOffset)
    calendar.set(Calendar.MINUTE, 0)
    calendar.set(Calendar.SECOND, 0)
    calendar.set(Calendar.MILLISECOND, 0)
    return calendar.getTime().format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;)
}
props.put(&quot;fn_generateFutureTime&quot;, _fn_generateFutureTime)

// when starting a new form / record so next item gets a fresh day
def _fn_resetFutureTimeDayOffset = { varsRef -&gt;
    varsRef.remove(&quot;_futureTimeDayOffset&quot;)
}
props.put(&quot;fn_resetFutureTimeDayOffset&quot;, _fn_resetFutureTimeDayOffset)

// Returns a random integer between min and max
def _fn_generateRandomNumber = { int min, int max -&gt;
    def rand = java.util.concurrent.ThreadLocalRandom.current()
    return rand.nextInt(max - min + 1) + min
}
props.put(&quot;fn_generateRandomNumber&quot;, _fn_generateRandomNumber)

