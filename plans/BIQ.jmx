                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Pick Random State Action Iterations" enabled="true">
                  <stringProp name="script">// Pick random value from comma-separated stateActionIterations
def iterationsConfig = vars.get(&quot;stateActionIterations&quot;)?.trim() ?: &quot;&quot;
def options = iterationsConfig.split(&quot;,&quot;)*.trim().findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() }
if (iterationsConfig.isEmpty() || options.isEmpty()) {
    log.info(&quot;stateActionIterations is 0 or empty - skipping state actions entirely&quot;)
    vars.put(&quot;stateActionLoopCount&quot;, &quot;0&quot;)
    vars.put(&quot;stateActionIteration&quot;, &quot;0&quot;)
    return
}
def randomIterations = options[java.util.concurrent.ThreadLocalRandom.current().nextInt(options.size())]
vars.put(&quot;stateActionLoopCount&quot;, randomIterations.toString())
vars.put(&quot;stateActionIteration&quot;, &quot;0&quot;)
vars.put(&quot;exitStateActionLoop&quot;, &quot;false&quot;)
log.info(&quot;State Action Iterations: picked ${randomIterations} from options [${iterationsConfig}]&quot;)</stringProp>
                  <stringProp name="scriptLanguage">groovy</stringProp>
