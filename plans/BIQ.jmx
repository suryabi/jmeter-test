                                    <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Validate Slot" enabled="true">
                                      <stringProp name="script">
def activityType = vars.get(&quot;activityType&quot;)?.toLowerCase() ?: &quot;activity&quot;
def rand = java.util.concurrent.ThreadLocalRandom.current()

def durationRaw = vars.get(&quot;vacantSlotDurations&quot;)?.trim()
def durationUdvName = &quot;vacantSlotDurations&quot;

def validDurations = durationRaw ? durationRaw.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 } : []

if (validDurations.isEmpty()) {
    log.info(&quot;[${activityType}] Skipping Get Vacant Slots - ${durationUdvName} is empty or has no valid values (must be &gt; 0)&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
    sampler.setEnabled(false)
    return
}

def parsedDuration = validDurations.collect { it.toInteger() }.min().toString()
vars.put(&quot;parsedVacantSlotDuration&quot;, parsedDuration)
vars.put(&quot;allValidDurations&quot;, validDurations.join(&quot;,&quot;))

// Early exit: if no time gap &gt;= minDuration remains in this day/room window, skip API call
def _dayNum  = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;
def _roomIdx = vars.get(&quot;roomLoopCounter&quot;)  ?: &quot;1&quot;
def _dayIdx  = vars.get(&quot;currentDayIndex&quot;)  ?: &quot;1&quot;
def _winStartStr = vars.get(&quot;activityStartTime_&quot; + _dayNum) ?: &quot;&quot;
def _winEndStr   = vars.get(&quot;activityEndTime_&quot;   + _dayNum) ?: &quot;&quot;
def _minDur = parsedDuration.toInteger()

def _parseToMins = { String ts -&gt;
    if (!ts) return -1
    try {
        def tp = ts.contains(&quot;T&quot;) ? ts.substring(11, 16) : ts.trim()
        def p = tp.split(&quot;:&quot;); return p[0].toInteger() * 60 + p[1].toInteger()
    } catch(Exception _e) { return -1 }
}

int _winStart = _parseToMins(_winStartStr)
int _winEnd   = _parseToMins(_winEndStr)

if (_winStart &gt;= 0 &amp;&amp; _winEnd &gt; _winStart) {
    def _usedKey    = &quot;usedSlotRanges_Day&quot; + _dayIdx + &quot;_Room&quot; + _roomIdx
    def _blockedKey = &quot;reservedBlockedTimes_Day&quot; + _dayIdx + &quot;_Room&quot; + _roomIdx
    def _usedRanges = []

    def _usedStr = vars.get(_usedKey) ?: &quot;&quot;
    if (_usedStr) {
        _usedStr.split(&quot;;&quot;).each { r -&gt;
            def p = r.split(&quot;:&quot;); if (p.size() == 2) _usedRanges &lt;&lt; [s: p[0].toInteger(), e: p[1].toInteger()]
        }
    }
    def _blockedStr = vars.get(_blockedKey) ?: &quot;&quot;
    if (_blockedStr) {
        _blockedStr.split(&quot;,&quot;).each { r -&gt;
            def p = r.split(&quot;-&quot;); if (p.size() == 2) _usedRanges &lt;&lt; [s: p[0].toInteger(), e: p[1].toInteger()]
        }
    }

    def _occupied = _usedRanges.sort { it.s }
    def _pos = _winStart
    def _hasGap = false
    for (def _r : _occupied) {
        if (_r.s &gt; _pos &amp;&amp; (_r.s - _pos) &gt;= _minDur) { _hasGap = true; break }
        if (_r.e &gt; _pos) _pos = _r.e
    }
    if (!_hasGap &amp;&amp; (_winEnd - _pos) &gt;= _minDur) _hasGap = true

    if (!_hasGap) {
        def _hasTimings = vars.get(activityType + &quot;Timings&quot;)?.trim()
        log.info(&quot;[${activityType}] No available slots in day window - skipping Get Vacant Slots API call&quot;)
        vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
        if (!_hasTimings) vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
        sampler.setEnabled(false)
        return
    }
}

if (vars.get(&quot;skipActivity&quot;) == &quot;true&quot;) {
    log.warn(&quot;Skipping Get Vacant Slots - skipActivity is true&quot;)
    sampler.setEnabled(false)
}

</stringProp>
