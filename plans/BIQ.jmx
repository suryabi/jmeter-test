                                    <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Activity Type Resources Extractor" enabled="true">
                                      <stringProp name="script">

def currentResourceTypeId = vars.get(&quot;currentActivityResourceTypeId&quot;)
def resourceTypeName = vars.get(&quot;currentActivityResourceTypeName&quot;) ?: &quot;Resource&quot;

def response = prev.getResponseDataAsString()

if (!response || response.trim().isEmpty()) {
    log.warn(&quot;Empty response - no resources found&quot;)
    vars.put(&quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_count&quot;, &quot;0&quot;)
        return
}

try {
    def json = new groovy.json.JsonSlurper().parseText(response)

    def resources = json._embedded?.resources ?: json.resources ?: (json instanceof List ? json : [])

    def count = 0
    resources.each { resource -&gt;
        count++

        def data = resource.data ?: resource

        def uniqueId = data.uniqueId ?:
                       data.id ?:
                       resource.uniqueId ?:
                       resource.id ?: &quot;&quot;

        def displayName = data.searchDisplayText ?:
                          data.displayName ?:
                          data.resourceName ?:
                          data.name ?:
                          resource.displayName ?:
                          resource.name ?:
                          uniqueId  // Fallback to ID if no name found

        def varPrefix = &quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_&quot; + count
        vars.put(varPrefix + &quot;_id&quot;, uniqueId)
        vars.put(varPrefix + &quot;_name&quot;, displayName)

        vars.put(varPrefix + &quot;_data&quot;, groovy.json.JsonOutput.toJson(data))

        vars.put(varPrefix + &quot;_primaryEmail&quot;, data.primaryEmail ?: data.textField4 ?: &quot;&quot;)
        vars.put(varPrefix + &quot;_designation&quot;, data.designation ?: data.textField5 ?: &quot;&quot;)
        vars.put(varPrefix + &quot;_mobile&quot;, data.mobile ?: data.textField7 ?: &quot;&quot;)
        vars.put(varPrefix + &quot;_firstName&quot;, data.firstName ?: data.textField1 ?: &quot;&quot;)
        vars.put(varPrefix + &quot;_lastName&quot;, data.lastName ?: data.textField2 ?: &quot;&quot;)

        if (count &lt;= 5) {
                    }
    }

    if (count &gt; 5) {
            }

    vars.put(&quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_count&quot;, count.toString())
    def presenterRtId = vars.get(&quot;presenterResourceTypeId&quot;)
    if (presenterRtId &amp;&amp; presenterRtId == currentResourceTypeId) {
                vars.put(&quot;presenterId_matchNr&quot;, count.toString())

        for (int i = 1; i &lt;= count; i++) {
            def id = vars.get(&quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_&quot; + i + &quot;_id&quot;)
            def name = vars.get(&quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_&quot; + i + &quot;_name&quot;)
            def dataJson = vars.get(&quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_&quot; + i + &quot;_data&quot;)
            def email = vars.get(&quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_&quot; + i + &quot;_primaryEmail&quot;)
            def designation = vars.get(&quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_&quot; + i + &quot;_designation&quot;)

            vars.put(&quot;presenterId_&quot; + i, id ?: &quot;&quot;)
            vars.put(&quot;presenterName_&quot; + i, name ?: &quot;&quot;)
            vars.put(&quot;presenterData_&quot; + i, dataJson ?: &quot;{}&quot;)
            vars.put(&quot;presenterEmail_&quot; + i, email ?: &quot;&quot;)
            vars.put(&quot;presenterDesignation_&quot; + i, designation ?: &quot;&quot;)
        }
            }

} catch (Exception e) {
    log.error(&quot;Error parsing resources: ${e.message}&quot;)
    vars.put(&quot;resourcesFor_&quot; + currentResourceTypeId + &quot;_count&quot;, &quot;0&quot;)
}
</stringProp>
