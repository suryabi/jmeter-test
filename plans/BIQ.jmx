                          <stringProp name="cacheKey">false</stringProp>
                          <stringProp name="script">// FIX: Save existingFormData into props before any PreProcessor clears it.
// This snapshot is used by fn_dynamicPayloadBuilder to preserve fields filled by previous users.
def requestId = vars.get(&quot;requestId&quot;) ?: &quot;unknown&quot;
def formId = vars.get(&quot;currentFormId&quot;) ?: vars.get(&quot;formId&quot;) ?: &quot;unknown&quot;
def snapshotKey = &quot;existingFormData_snapshot_&quot; + requestId + &quot;_&quot; + formId
def existingFormDataStr = vars.get(&quot;existingFormData&quot;)
if (existingFormDataStr &amp;&amp; existingFormDataStr.trim() != &quot;{}&quot; &amp;&amp; existingFormDataStr.trim() != &quot;&quot;) {
    props.put(snapshotKey, existingFormDataStr)
    log.info(&quot;Saved existingFormData snapshot for key: &quot; + snapshotKey)
} else {
    log.info(&quot;existingFormData is empty - no snapshot saved for key: &quot; + snapshotKey)
}</stringProp>
                        </JSR223PostProcessor>
