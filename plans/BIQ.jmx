                    <stringProp name="script">

// Check if test is aborting due to previous validation failure
if (props.get(&quot;fn_checkAbort&quot;)(vars, prev)) return

// Parse JSON response
def response = prev.getResponseDataAsString()
def json = new groovy.json.JsonSlurper().parseText(response)

// Extract parent categories from response
def parentCategories = json._embedded?.categories ?: []

// Validate parent categories exist
if (parentCategories.isEmpty()) {
    log.error(&quot;No parent categories found!&quot;)
    return
}

// Get preferred parent category from User Defined Variables
def preferredParentCategory = vars.get(&quot;parentCategory&quot;)?.trim()
def selectedParentCategory = null

// Search for preferred parent category if specified
if (preferredParentCategory) {
    selectedParentCategory = parentCategories.find {
        it.uniqueId?.equalsIgnoreCase(preferredParentCategory)
    }

    if (selectedParentCategory) {
        log.info(&quot;Parent category: &quot; + preferredParentCategory)
    } else {
        def availableCategories = parentCategories.collect { it.uniqueId + &quot; (&quot; + (it.categoryName ?: &quot;&quot;) + &quot;)&quot; }.join(&quot;, &quot;)
        props.get(&quot;fn_abortNotFound&quot;)(vars, prev, &quot;parentCategory&quot;, preferredParentCategory, availableCategories, ctx)
        return
    }
}

// Use selected parent category (already validated)
// Extract baseTimezone from resource.data
def baseTimezone = selectedParentCategory.resource?.data?.baseTimezone ?: &quot;UTC&quot;

// Extract Location ResourceType
def locationResourceType = selectedParentCategory.resourceType
def locationResourceTypeId = locationResourceType?.uniqueId ?: &quot;&quot;
def locationResourceTypeName = locationResourceType?.name ?: &quot;&quot;

// Extract Location Resource uniqueId
def locationResourceId = selectedParentCategory.resource?.uniqueId ?: &quot;&quot;

// Store selected parent category variables
vars.put(&quot;parentCategoryId&quot;, selectedParentCategory.uniqueId ?: &quot;&quot;)
vars.put(&quot;parentCategoryName&quot;, selectedParentCategory.categoryName ?: &quot;&quot;)
vars.put(&quot;baseTimezone&quot;, baseTimezone)

// Store Location ResourceType variables
vars.put(&quot;locationResourceTypeId&quot;, locationResourceTypeId)
vars.put(&quot;locationResourceTypeName&quot;, locationResourceTypeName)

// Store Location Resource uniqueId
vars.put(&quot;locationResourceId&quot;, locationResourceId)

// Update sampler label with selected parent category
def parentCatName = vars.get(&quot;parentCategoryName&quot;) ?: &quot;&quot;
if (parentCatName) {
    prev.setSampleLabel(prev.getSampleLabel() + &quot; - &quot; + parentCatName)
}

// Logging for debugging
log.info(&quot;Selected Parent Category ID: &quot; + vars.get(&quot;parentCategoryId&quot;))
log.info(&quot;Selected Parent Category Name: &quot; + vars.get(&quot;parentCategoryName&quot;))
log.info(&quot;Base Timezone: &quot; + vars.get(&quot;baseTimezone&quot;))
log.info(&quot;Location ResourceType ID: &quot; + vars.get(&quot;locationResourceTypeId&quot;))
log.info(&quot;Location ResourceType Name: &quot; + vars.get(&quot;locationResourceTypeName&quot;))
log.info(&quot;Location Resource UniqueId: &quot; + vars.get(&quot;locationResourceId&quot;))

log.info(&quot;----- Terminated: Parent Category PostProcessor -----&quot;)</stringProp>
