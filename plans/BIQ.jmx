                                            <stringProp name="script">vars.put(&quot;zoomLinkAdded&quot;, &quot;false&quot;)

def zoomLink = vars.get(&quot;zoom&quot;) ?: &quot;&quot;
def activityId = vars.get(&quot;activityId&quot;) ?: &quot;&quot;
def activityType = vars.get(&quot;loopActivityType&quot;) ?: vars.get(&quot;activityType&quot;) ?: &quot;unknown&quot;
def roomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown&quot;

log.info(&quot;=== Adding Zoom to Topic ===&quot;)
log.info(&quot;Activity ID: &quot; + activityId)
log.info(&quot;Activity Type: &quot; + activityType)
log.info(&quot;Room: &quot; + roomName)
log.info(&quot;Zoom Link: &quot; + zoomLink)

if (!zoomLink || zoomLink.trim().isEmpty() || zoomLink.contains(&quot;null&quot;)) {
    log.warn(&quot;Invalid zoom link - skipping request&quot;)
    sampler.setEnabled(false)
}
</stringProp>
