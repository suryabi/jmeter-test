                                    </hashTree>
                                    <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If (Has Participants)" enabled="true">
                                      <stringProp name="IfController.condition">${__groovy(vars.get(&quot;activitySecondaryConfigCount&quot;)?.toInteger() &gt; 0 &amp;&amp; vars.get(&quot;activityConfig_1_isParticipantForm&quot;) == &quot;true&quot;)}</stringProp>
                                      <boolProp name="IfController.useExpression">true</boolProp>
                                      <boolProp name="IfController.evaluateAll">false</boolProp>
                                    </IfController>
                                    <hashTree>
                                      <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Prepare Participant Payloads" enabled="true">
                                        <stringProp name="script">SampleResult.setIgnore()

try {

def rand = java.util.concurrent.ThreadLocalRandom.current()
def loopType = vars.get(&quot;loopActivityType&quot;)
def moduleType = vars.get(&quot;activityType&quot;)
def activityType = loopType ?: moduleType ?: &quot;unknown&quot;
def activityId = vars.get(&quot;activityId&quot;)

def setEmptyResult = { String message -&gt;
    log.warn(&quot;EARLY EXIT: ${message}&quot;)
    vars.put(&quot;participantPayloads&quot;, &quot;[]&quot;)
    vars.put(&quot;participantPayloadsCount&quot;, &quot;0&quot;)
    vars.put(&quot;participantLoopIdx&quot;, &quot;0&quot;)
    SampleResult.setSuccessful(true)
    SampleResult.setResponseCode(&quot;200&quot;)
    SampleResult.setResponseMessage(message)
}

def participantFormId = vars.get(&quot;activityConfig_1_formId&quot;)
def participantJourneyId = vars.get(&quot;activityConfig_1_journeyId&quot;) ?: vars.get(&quot;activityJourneyId&quot;)
def participantPageId = vars.get(&quot;activityConfig_1_pageId&quot;) ?: vars.get(&quot;activityPageId&quot;)
def participantModuleId = vars.get(&quot;activityConfig_1_moduleId&quot;) ?: vars.get(&quot;currentActivityModuleId&quot;)
def participantFormName = vars.get(&quot;activityConfig_1_formName&quot;)
def isMultiEntry = vars.get(&quot;activityConfig_1_isMultiEntry&quot;) == &quot;true&quot;

if (!participantFormId) {
    log.info(&quot;No secondary form config - skipping participant creation&quot;)
    setEmptyResult(&quot;No secondary form config&quot;)
        return
}

def targetPresenterCount = 0
def countSource = &quot;&quot;

if (isMultiEntry) {
    def configMin = vars.get(&quot;activityConfig_1_minEntries&quot;)
    def configMax = vars.get(&quot;activityConfig_1_maxEntries&quot;)

        if (configMin &amp;&amp; configMax &amp;&amp; configMin.isInteger() &amp;&amp; configMax.isInteger()) {
        def minEntries = configMin.toInteger()
        def maxEntries = configMax.toInteger()
        if (minEntries &gt; 0 &amp;&amp; maxEntries &gt;= minEntries) {
            targetPresenterCount = rand.nextInt(maxEntries - minEntries + 1) + minEntries
            countSource = &quot;Module Config (${minEntries}-${maxEntries}) -&gt; picked ${targetPresenterCount}&quot;
                    }
    }
}

if (targetPresenterCount == 0 &amp;&amp; isMultiEntry) {
    def minSelection = props.get(&quot;fn_parseMultiSelectRange&quot;)(vars, null).min
    def maxSelection = props.get(&quot;fn_parseMultiSelectRange&quot;)(vars, null).max

    log.info(&quot;Module Config not found - using UDV: multiSelectRange=${vars.get(&apos;multiSelectRange&apos;)} (min=${minSelection}, max=${maxSelection})&quot;)

    targetPresenterCount = rand.nextInt(maxSelection - minSelection + 1) + minSelection
    countSource = &quot;UDV multiSelectRange (${minSelection}-${maxSelection}) -&gt; picked ${targetPresenterCount}&quot;
    log.info(&quot;Using UDV: min=${minSelection}, max=${maxSelection}, selected=${targetPresenterCount}&quot;)
}

if (targetPresenterCount == 0 &amp;&amp; !isMultiEntry) {
    targetPresenterCount = 1
    countSource = &quot;Single entry form -&gt; 1&quot;
}

def formUIConfigStr = vars.get(&quot;activityConfig_1_formUIConfig&quot;)

def participantFieldName = null
def resourceTypeId = null
def dependentFieldMappings = []
def statusFieldName = null
def statusLookupName = null

if (!formUIConfigStr) {
    log.warn(&quot;formUIConfig not available - trying fallback&quot;)

    resourceTypeId = vars.get(&quot;secondaryResourceTypeId&quot;) ?: vars.get(&quot;activityConfig_1_resourceTypeId&quot;)

    if (!resourceTypeId) {
        log.error(&quot;No resourceTypeId available&quot;)
        setEmptyResult(&quot;No resourceTypeId available&quot;)
                return
    }
}

if (formUIConfigStr) {
    try {
        def formConfig = new groovy.json.JsonSlurper().parseText(formUIConfigStr)
        def configItems = formConfig.config ?: []

        configItems.each { field -&gt;
            def dataMapping = field.dataMapping ?: field.formControlName
            def enumType = field.enumType
            def dependentControls = field.dependentControls ?: []

            if (enumType == &quot;RESOURCE&quot; &amp;&amp; field.resourceTypeId) {
                participantFieldName = dataMapping
                resourceTypeId = field.resourceTypeId
                dependentControls.each { dep -&gt;
                    def depFieldName = dep.formControlName
                    def mapTo = dep.rules?.map

                    if (depFieldName &amp;&amp; mapTo) {
                        dependentFieldMappings.add([
                            fieldName: depFieldName,
                            mapTo    : mapTo
                        ])
                                            }
                }
            }

            if (enumType == &quot;LOOKUP&quot; &amp;&amp; field.lookupName) {
                statusFieldName = dataMapping
                statusLookupName = field.lookupName
                            }
        }
    } catch (e) {
        log.error(&quot;Failed to parse formUIConfig: ${e.message}&quot;)
        setEmptyResult(&quot;Failed to parse formUIConfig&quot;)
                return
    }
}

if (!resourceTypeId) {
    resourceTypeId = vars.get(&quot;secondaryResourceTypeId&quot;) ?: vars.get(&quot;activityConfig_1_resourceTypeId&quot;)
}

if (resourceTypeId) {
    vars.put(&quot;participantResourceTypeId&quot;, resourceTypeId)
    vars.put(&quot;secondaryResourceTypeId&quot;, resourceTypeId)
    }

if (!participantFieldName) {
    participantFieldName = &quot;participant&quot;  // Default field name
    log.info(&quot;Using default participant field name: ${participantFieldName}&quot;)
}

if (!resourceTypeId) {
    log.error(&quot;ResourceTypeId not found&quot;)
    setEmptyResult(&quot;ResourceTypeId not found&quot;)
        return
}

def statusLookupValues = []
if (statusLookupName) {
    def words = statusLookupName.toLowerCase().split(&apos;_&apos;)
    def statusVariable = words[0] + words.drop(1).collect { it.capitalize() }.join(&apos;&apos;)

    def countStr = vars.get(statusVariable + &quot;_count&quot;)
    if (countStr?.isInteger()) {
        def count = countStr.toInteger()
        for (int i = 1; i &lt;= count; i++) {
            def val = vars.get(statusVariable + &quot;_&quot; + i)
            if (val) statusLookupValues.add(val)
        }
            }
}

def presenterCount = vars.get(&quot;selectedPresenterCount&quot;)?.toInteger() ?: 0

if (presenterCount == 0) {
    log.warn(&quot;No presenters available - ensure Get/Add Presenters was called at request level&quot;)
    setEmptyResult(&quot;No presenters available&quot;)
        return
}

def presentersPerTopicUdv = vars.get(&quot;presentersPerTopic&quot;)?.trim() ?: &quot;1,2&quot;
def perTopicOptions = presentersPerTopicUdv.split(&quot;,&quot;).collect { it.trim() }.findAll { it.isInteger() &amp;&amp; it.toInteger() &gt; 0 }.collect { it.toInteger() }
if (perTopicOptions.isEmpty()) {
    perTopicOptions = [1]
    log.info(&quot;presentersPerTopic UDV has no valid values - defaulting to 1&quot;)
}
def desiredPerTopic = perTopicOptions[rand.nextInt(perTopicOptions.size())]
def entriesToCreate = Math.min(desiredPerTopic, presenterCount)
log.info(&quot;Presenters per topic: desired=${desiredPerTopic}, available=${presenterCount}, assigning=${entriesToCreate}&quot;)

def participantPayloads = []
def usedIndices = []

for (int i = 0; i &lt; entriesToCreate; i++) {

    def presenterIdx = 0
    def attempts = 0
    while (attempts &lt; 20) {
        presenterIdx = rand.nextInt(presenterCount) + 1
        if (!usedIndices.contains(presenterIdx)) {
            usedIndices.add(presenterIdx)
            break
        }
        attempts++
    }

    def presenterId = vars.get(&quot;selectedPresenterId_${presenterIdx}&quot;)

    if (!presenterId) {
        log.warn(&quot;Skipping - no selectedPresenterId at index ${presenterIdx}&quot;)
        continue
    }

    def presenterDataStr = vars.get(&quot;selectedPresenterData_${presenterIdx}&quot;)
    def presenterData = [:]
    if (presenterDataStr) {
        try {
            presenterData = new groovy.json.JsonSlurper().parseText(presenterDataStr)
        } catch (e) {
            log.warn(&quot;Failed to parse selectedPresenterData_${presenterIdx}: ${e.message}&quot;)
        }
    }

    def dataPayload = [:]

    dataPayload[participantFieldName] = [&quot;uniqueId&quot;: presenterId]

    dependentFieldMappings.each { mapping -&gt;
        def fieldName = mapping.fieldName
        def mapTo = mapping.mapTo

        def value = null

        def keyVariations = [
            mapTo,                                           // exact: primaryEmail
            mapTo.replaceAll(/^primary/, &apos;&apos;),              // simplified: Email -&gt; email
            mapTo.replaceAll(/^primary/, &apos;&apos;).toLowerCase(), // lowercase: email
            &quot;primary&quot; + mapTo.capitalize(),                  // with prefix: primaryEmail
            mapTo.replaceAll(/([A-Z])/, &apos;_$1&apos;).toLowerCase().replaceFirst(&apos;^_&apos;, &apos;&apos;)  // snake_case: primary_email
        ]

        for (key in keyVariations) {
            if (presenterData.containsKey(key) &amp;&amp; presenterData[key]) {
                value = presenterData[key]
                                break
            }
        }

        if (value) {
            dataPayload[fieldName] = value
        } else {
        }
    }

    if (statusFieldName &amp;&amp; statusLookupValues.size() &gt; 0) {
        def selectedStatus = statusLookupValues[rand.nextInt(statusLookupValues.size())]
        dataPayload[statusFieldName] = selectedStatus

    }

    def payload = [
        &quot;formId&quot;   : participantFormId,
        &quot;journeyId&quot;: participantJourneyId,
        &quot;pageId&quot;   : participantPageId,
        &quot;moduleId&quot; : participantModuleId,
        &quot;data&quot;     : dataPayload
    ]

    participantPayloads.add(payload)
}

vars.put(&quot;participantPayloads&quot;, groovy.json.JsonOutput.toJson(participantPayloads))
vars.put(&quot;participantPayloadsCount&quot;, participantPayloads.size().toString())
vars.put(&quot;participantLoopIdx&quot;, &quot;0&quot;)
vars.put(&quot;participantFormId&quot;, participantFormId)
vars.put(&quot;participantFormName&quot;, participantFormName ?: &quot;Participants&quot;)

SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setResponseMessage(&quot;Created ${participantPayloads.size()} participant payloads&quot;)

} catch (Exception e) {
    log.error(&quot;EXCEPTION in Prepare Participant Payloads: ${e.message}&quot;)
    log.error(&quot;Stack trace: ${e.stackTrace.take(5).join(&apos;\\n&apos;)}&quot;)
    vars.put(&quot;participantPayloads&quot;, &quot;[]&quot;)
    vars.put(&quot;participantPayloadsCount&quot;, &quot;0&quot;)
    vars.put(&quot;participantLoopIdx&quot;, &quot;0&quot;)
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode(&quot;500&quot;)
    SampleResult.setResponseMessage(&quot;Exception: ${e.message}&quot;)
}</stringProp>
