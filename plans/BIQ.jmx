                      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Set Activity Day Date &amp; Time" enabled="true">
                        <stringProp name="script">// Current day index
def dayIndex = vars.get(&quot;ActivityDayCount&quot;) ?: &quot;1&quot;

// Pick values for this day
def eventDate = vars.get(&quot;activityDate_&quot; + dayIndex) ?: &quot;&quot;
def startTime = vars.get(&quot;activityStartTime_&quot; + dayIndex) ?: &quot;&quot;
def endTime = vars.get(&quot;activityEndTime_&quot; + dayIndex) ?: &quot;&quot;

// Store generic variables for API usage
vars.put(&quot;eventDate&quot;, eventDate)
vars.put(&quot;eventStartTime&quot;, startTime)
vars.put(&quot;eventEndTime&quot;, endTime)

// Debug logging
log.info(&quot;Using Activity Day ${dayIndex}&quot;)
log.info(&quot;Event Date: ${eventDate}&quot;)
log.info(&quot;Start Time: ${startTime}&quot;)
log.info(&quot;End Time: ${endTime}&quot;)</stringProp>
                        <stringProp name="scriptLanguage">groovy</stringProp>
                        <stringProp name="parameters"></stringProp>
                        <stringProp name="filename"></stringProp>
                        <stringProp name="cacheKey">false</stringProp>
                      </JSR223PreProcessor>
                      <hashTree/>
                      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Check Existing Event Resources" enabled="true">
                        <stringProp name="script">

try {
    def response = prev.getResponseDataAsString()
    def resourceCount = 0

    if (response &amp;&amp; response.trim()) {
        def json = new groovy.json.JsonSlurper().parseText(response)

        // Response is array of eventDates, each may have nested resources[]
        // Example: [{eventDateId:..., resources:[{resourceId:..., resource:{data:{name:&quot;Room1&quot;}}}]}, ...]
        // When no rooms: [{eventDateId:..., eventDate:...}] (no resources field)

        if (json instanceof List) {
            json.each { eventDate -&gt;
                def resources = eventDate.resources ?: []
                resourceCount += resources.size()
            }
        } else if (json instanceof Map) {
            // HAL or other format
            def eventDates = json._embedded?.eventResources ?: json._embedded?.eventResourceModels ?: 
                             json.content ?: []
            eventDates.each { eventDate -&gt;
                def resources = eventDate.resources ?: []
                resourceCount += resources.size()
            }
            if (json.totalElements != null &amp;&amp; resourceCount == 0) {
                resourceCount = json.totalElements
            }
        }
    }

    vars.put(&quot;existingEventResourceCount&quot;, resourceCount.toString())
    log.info(&quot;Existing event resources (rooms): ${resourceCount}&quot;)

    if (resourceCount &gt; 0) {
        log.info(&quot;Rooms already exist in Logistics - will SKIP room creation&quot;)
    } else {
        log.info(&quot;No rooms found in Logistics - will CREATE rooms&quot;)
    }
} catch (Exception e) {
    log.warn(&quot;Error checking existing event resources: ${e.message}&quot;)
    vars.put(&quot;existingEventResourceCount&quot;, &quot;0&quot;)
}</stringProp>
                        <stringProp name="scriptLanguage">groovy</stringProp>
