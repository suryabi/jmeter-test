                            <hashTree/>
                            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Entry Index PreProcessor" enabled="true">
                              <stringProp name="scriptLanguage">groovy</stringProp>
                              <stringProp name="parameters"></stringProp>
                              <stringProp name="filename"></stringProp>
                              <stringProp name="cacheKey">false</stringProp>
                              <stringProp name="script">// Entry Index PreProcessor
// Place this INSIDE the Create HTTP sampler as a child PreProcessor

def totalEntryCount = (vars.get(&quot;totalEntryCount&quot;) ?: &quot;1&quot;).toInteger()
def currentEntryIndex = (vars.get(&quot;currentEntryIndex&quot;) ?: &quot;0&quot;).toInteger()

if (currentEntryIndex == 0 || currentEntryIndex &gt;= totalEntryCount) {
    currentEntryIndex = 1
} else {
    currentEntryIndex = currentEntryIndex + 1
}

vars.put(&quot;currentEntryIndex&quot;, currentEntryIndex.toString())
log.info(&quot;Entry Index: &quot; + currentEntryIndex + &quot; / &quot; + totalEntryCount)</stringProp>
