          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="👤 User - ${currentUser}" enabled="true">
            <stringProp name="script">def currentUser = vars.get(&quot;currentUser&quot;)
def firstUser = vars.get(&quot;user_1&quot;)
def userCount = vars.get(&quot;userCount&quot;) ?: &quot;1&quot;

// Find user index by matching against stored user_1, user_2, etc.
def userIndex = 0
for (int i = 1; i &lt;= userCount.toInteger(); i++) {
    def storedUser = vars.get(&quot;user_&quot; + i)
    log.info(&quot;DEBUG MATCH: user_&quot; + i + &quot;=&quot; + storedUser + &quot; vs currentUser=&quot; + currentUser + &quot; match=&quot; + (storedUser == currentUser))
    if (storedUser == currentUser) {
        userIndex = i
        break
    }
}

// Safety fallback
if (userIndex == 0) {
    log.error(&quot;Current user &apos;&quot; + currentUser + &quot;&apos; not found in user list! Defaulting to index 1&quot;)
    userIndex = 1
}

// Determine if this is the first user by comparing identity
def isFirstUser = (currentUser == firstUser) ? &quot;true&quot; : &quot;false&quot;
vars.put(&quot;isFirstUser&quot;, isFirstUser)
vars.put(&quot;userIterationIndex&quot;, userIndex.toString())

log.info(&quot;========================================&quot;)
log.info(&quot;USER ITERATION: &quot; + userIndex + &quot; of &quot; + userCount)
log.info(&quot;User: &quot; + currentUser)
log.info(&quot;First User: &quot; + firstUser)
log.info(&quot;Is First User: &quot; + isFirstUser)
log.info(&quot;========================================&quot;)

// For subsequent users - set flags to reuse existing request
if (isFirstUser != &quot;true&quot;) {
    def existingRequestId = vars.get(&quot;requestId&quot;)
    if (existingRequestId != null &amp;&amp; !existingRequestId.trim().isEmpty()) {
        vars.put(&quot;requestCreated&quot;, &quot;true&quot;)
        vars.put(&quot;requestFailed&quot;, &quot;false&quot;)
        log.info(&quot;SUBSEQUENT USER: Reusing requestId: &quot; + existingRequestId)
        log.info(&quot;Customer: &quot; + vars.get(&quot;customerName&quot;))
        log.info(&quot;CategoryType: &quot; + vars.get(&quot;categoryTypeName&quot;))
        log.info(&quot;Parent Category: &quot; + vars.get(&quot;parentCategoryName&quot;))
        log.info(&quot;Category: &quot; + vars.get(&quot;categoryName&quot;))
    } else {
        log.error(&quot;SUBSEQUENT USER but no requestId found from previous user!&quot;)
        vars.put(&quot;requestCreated&quot;, &quot;false&quot;)
        vars.put(&quot;requestFailed&quot;, &quot;true&quot;)
    }
}

def originalLabel = SampleResult.getSampleLabel()
SampleResult.setSampleLabel(&quot;───── &quot; + originalLabel + &quot; (&quot; + userIndex + &quot;/&quot; + userCount + &quot;) ─────&quot;)
SampleResult.setResponseData(&quot;User &quot; + userIndex + &quot;: &quot; + vars.get(&quot;currentUser&quot;) + &quot; | isFirstUser: &quot; + isFirstUser, &quot;UTF-8&quot;)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setSuccessful(true)
</stringProp>
