                        <hashTree>
                          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Attendee PreProcessor" enabled="true">
                            <stringProp name="scriptLanguage">groovy</stringProp>
                            <stringProp name="parameters"></stringProp>
                            <stringProp name="filename"></stringProp>
                            <stringProp name="cacheKey">false</stringProp>
                            <stringProp name="script">

// For multi-entry CREATE forms, always use fresh data from PreProcessors
def isCreatePath = (vars.get(&quot;currentFormDataId&quot;) == null || vars.get(&quot;currentFormDataId&quot;) == &quot;&quot;)
if (isCreatePath) {
    vars.put(&quot;existingFormData&quot;, &quot;{}&quot;)
}

def totalUsers = (vars.get(&quot;randomUserCount&quot;) ?: &quot;50&quot;).toInteger()
def totalEntryCount = (vars.get(&quot;totalEntryCount&quot;) ?: &quot;1&quot;).toInteger()

// ============ userIndex for picking attendee name ============
def userIndex = (vars.get(&quot;randomUserIndex&quot;) ?: &quot;1&quot;).toInteger()
if (userIndex &gt; totalUsers) {
    userIndex = ((userIndex - 1) % totalUsers) + 1
}

// ============ currentEntryIndex — read only, incremented by Entry Index PreProcessor inside Create sampler ============
def currentEntryIndex = (vars.get(&quot;currentEntryIndex&quot;) ?: &quot;0&quot;).toInteger()

// ============ INITIALIZATION ============
def formName = vars.get(&quot;currentFormName&quot;)
def rand = java.util.concurrent.ThreadLocalRandom.current()

// ============ Company ============
vars.put(&quot;company&quot;, vars.get(&quot;customerName&quot;))

// ============ Attendee Information ============
def attendeeFirstName = vars.get(&quot;randomUser_${userIndex}_firstName&quot;) ?: &quot;John&quot;
def attendeeLastName  = vars.get(&quot;randomUser_${userIndex}_lastName&quot;)  ?: &quot;Doe&quot;
def rawGender         = vars.get(&quot;randomUser_${userIndex}_gender&quot;)    ?: &quot;male&quot;

// ============ Map gender to proper salutation prefix ============
def attendeePrefix
switch (rawGender.toLowerCase().trim()) {
    case &quot;female&quot;:
        attendeePrefix = [&quot;Ms&quot;, &quot;Mrs&quot;][rand.nextInt(2)]
        break
    default:
        attendeePrefix = &quot;Mr&quot;
        break
}

// ============ Email - using shared function ============
def emailDomain = props.get(&quot;fn_extractEmailDomain&quot;)(vars)

def email = attendeeFirstName.toLowerCase() + &quot;.&quot; + attendeeLastName.toLowerCase() + &quot;@&quot; + emailDomain
vars.put(&quot;email&quot;, email)

// ============ Business Title ============
def randomTitle = props.get(&quot;fn_getRandomBusinessTitle&quot;)()
vars.put(&quot;businessTitle&quot;, randomTitle)

// ============ Gift Type ============
String[] giftTypes = [
    &quot;Welcome Package&quot;, &quot;Gift Card&quot;, &quot;Welcome Kit&quot;, &quot;Leather Notebook&quot;,
    &quot;Chocolates&quot;, &quot;Sunglasses&quot;, &quot;Watch&quot;, &quot;Cookies&quot;, &quot;Headphones&quot;,
    &quot;Travel Adapter&quot;, &quot;Smart Pen&quot;, &quot;Event Tickets&quot;, &quot;Champagne&quot;,
    &quot;Signed Book&quot;, &quot;Fitness Tracker&quot;, &quot;Concert Tickets&quot;, &quot;AirPods&quot;,
    &quot;Webcam&quot;, &quot;Branded Polo Shirt&quot;
]
def randomGiftType = giftTypes[rand.nextInt(giftTypes.length)]
vars.put(&quot;giftType&quot;, randomGiftType)

// ============ Boolean Fields ============
def isTechnical   = rand.nextBoolean().toString()
def decisionMaker = rand.nextBoolean().toString()
def influencer    = rand.nextBoolean().toString()
def isRemote      = rand.nextBoolean().toString()
def translator    = rand.nextBoolean().toString()

// ============ NUMBER Fields (1-5 range) — using shared function ============
def randomNumber1to5 = { -&gt; props.get(&quot;fn_randomNumber1to5&quot;)() }
def numberField1Value = randomNumber1to5()
def numberField2Value = randomNumber1to5()
def numberField3Value = randomNumber1to5()
vars.put(&quot;attendeeNumberField1&quot;, String.valueOf(numberField1Value))
vars.put(&quot;attendeeNumberField2&quot;, String.valueOf(numberField2Value))
vars.put(&quot;attendeeNumberField3&quot;, String.valueOf(numberField3Value))

vars.put(&quot;isTechnical&quot;,   isTechnical)
vars.put(&quot;decisionMaker&quot;, decisionMaker)
vars.put(&quot;influencer&quot;,    influencer)
vars.put(&quot;isRemote&quot;,      isRemote)
vars.put(&quot;translator&quot;,    translator)
vars.put(&quot;firstName&quot;,     attendeeFirstName)
vars.put(&quot;lastName&quot;,      attendeeLastName)
vars.put(&quot;prefix&quot;,        attendeePrefix)

// ============ Increment randomUserIndex for next iteration ============
def nextIndex = userIndex + 1
vars.put(&quot;randomUserIndex&quot;, nextIndex.toString())

// ============ Logging ============
log.info(&quot;========== Attendee PreProcessor ==========&quot;)
log.info(&quot;userIndex:      &quot; + userIndex + &quot; / &quot; + totalUsers)
log.info(&quot;entryIndex:     &quot; + currentEntryIndex + &quot; / &quot; + totalEntryCount)
log.info(&quot;firstName:      &quot; + attendeeFirstName)
log.info(&quot;lastName:       &quot; + attendeeLastName)
log.info(&quot;rawGender:      &quot; + rawGender)
log.info(&quot;prefix:         &quot; + attendeePrefix)
log.info(&quot;email:          &quot; + email)
log.info(&quot;emailDomain:    &quot; + emailDomain)
log.info(&quot;businessTitle:  &quot; + randomTitle)
log.info(&quot;isTechnical:    &quot; + isTechnical)
log.info(&quot;decisionMaker:  &quot; + decisionMaker)
log.info(&quot;influencer:     &quot; + influencer)
log.info(&quot;isRemote:       &quot; + isRemote)
log.info(&quot;giftType:       &quot; + randomGiftType)
log.info(&quot;numberField1:   &quot; + numberField1Value + &quot; (range 1-5)&quot;)
log.info(&quot;numberField2:   &quot; + numberField2Value + &quot; (range 1-5)&quot;)
log.info(&quot;numberField3:   &quot; + numberField3Value + &quot; (range 1-5)&quot;)
log.info(&quot;nextUserIndex:  &quot; + nextIndex)
log.info(&quot;===========================================&quot;)</stringProp>
                          </JSR223PreProcessor>
