                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Store Random User Data" enabled="true">
                  <stringProp name="script">

def fallbackUsers = [
    [first:&quot;James&quot;, last:&quot;Anderson&quot;, gender:&quot;male&quot;],
    [first:&quot;Sarah&quot;, last:&quot;Mitchell&quot;, gender:&quot;female&quot;],
    [first:&quot;Robert&quot;, last:&quot;Thompson&quot;, gender:&quot;male&quot;],
    [first:&quot;Emily&quot;, last:&quot;Carter&quot;, gender:&quot;female&quot;],
    [first:&quot;Michael&quot;, last:&quot;Rodriguez&quot;, gender:&quot;male&quot;],
    [first:&quot;Jessica&quot;, last:&quot;Patel&quot;, gender:&quot;female&quot;],
    [first:&quot;David&quot;, last:&quot;Nakamura&quot;, gender:&quot;male&quot;],
    [first:&quot;Ashley&quot;, last:&quot;O&apos;Brien&quot;, gender:&quot;female&quot;],
    [first:&quot;Christopher&quot;, last:&quot;Kim&quot;, gender:&quot;male&quot;],
    [first:&quot;Amanda&quot;, last:&quot;Johansson&quot;, gender:&quot;female&quot;],
    [first:&quot;Daniel&quot;, last:&quot;Morales&quot;, gender:&quot;male&quot;],
    [first:&quot;Lauren&quot;, last:&quot;Chen&quot;, gender:&quot;female&quot;],
    [first:&quot;Matthew&quot;, last:&quot;Williams&quot;, gender:&quot;male&quot;],
    [first:&quot;Stephanie&quot;, last:&quot;Gupta&quot;, gender:&quot;female&quot;],
    [first:&quot;Andrew&quot;, last:&quot;Sullivan&quot;, gender:&quot;male&quot;],
    [first:&quot;Nicole&quot;, last:&quot;Fernandez&quot;, gender:&quot;female&quot;],
    [first:&quot;Joshua&quot;, last:&quot;Park&quot;, gender:&quot;male&quot;],
    [first:&quot;Rachel&quot;, last:&quot;Schmidt&quot;, gender:&quot;female&quot;],
    [first:&quot;Ryan&quot;, last:&quot;Takahashi&quot;, gender:&quot;male&quot;],
    [first:&quot;Megan&quot;, last:&quot;Kowalski&quot;, gender:&quot;female&quot;]
]

def users = []
def source = &quot;fallback&quot;

try {
    def response = prev.getResponseDataAsString()
    def json = new groovy.json.JsonSlurper().parseText(response)
    def apiUsers = json.results ?: []

    if (apiUsers.size() &gt; 0) {
        apiUsers.each { user -&gt;
            users.add([
                first: user.name?.first ?: &quot;John&quot;,
                last: user.name?.last ?: &quot;Doe&quot;,
                gender: user.gender ?: &quot;male&quot;
            ])
        }
        source = &quot;API (${apiUsers.size()} users)&quot;
    }
} catch (Exception e) {
    log.warn(&quot;Random User API parse error: ${e.message}&quot;)
}

// Fallback if API returned nothing
if (users.isEmpty()) {
    users = fallbackUsers
    Collections.shuffle(users)
    source = &quot;fallback (${fallbackUsers.size()} built-in users)&quot;
    log.warn(&quot;Random User API failed - using built-in fallback dataset&quot;)
}

// Store each user as separate variables
users.eachWithIndex { user, index -&gt;
    def i = index + 1
    vars.put(&quot;randomUser_${i}_firstName&quot;, user.first)
    vars.put(&quot;randomUser_${i}_lastName&quot;, user.last)
    vars.put(&quot;randomUser_${i}_gender&quot;, user.gender)
}

vars.put(&quot;randomUserCount&quot;, users.size().toString())
vars.put(&quot;randomUserIndex&quot;, &quot;1&quot;)

log.info(&quot;Loaded ${users.size()} random users [${source}]&quot;)</stringProp>
                  <stringProp name="scriptLanguage">groovy</stringProp>
