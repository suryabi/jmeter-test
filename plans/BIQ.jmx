<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.4.1">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="BIQ - EIQ" enabled="true">
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <stringProp name="TestPlan.comments"></stringProp>
      <stringProp name="TestPlan.user_define_classpath"></stringProp>
    </TestPlan>
    <hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="BIQ Request flow" enabled="true">
        <stringProp name="ThreadGroup.num_threads">1</stringProp>
        <stringProp name="ThreadGroup.ramp_time">1</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <stringProp name="ThreadGroup.duration"></stringProp>
        <stringProp name="ThreadGroup.delay"></stringProp>
      </ThreadGroup>
      <hashTree>
        <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Request Variables" enabled="true">
          <collectionProp name="Arguments.arguments">
            <elementProp name="requestStartDate" elementType="Argument">
              <stringProp name="Argument.name">requestStartDate</stringProp>
              <stringProp name="Argument.value">2026-12-10</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DATE, REQUIRED. Start date for request creation (format: yyyy-MM-dd, e.g. 2026-12-02)</stringProp>
            </elementProp>
            <elementProp name="requestEndDate" elementType="Argument">
              <stringProp name="Argument.name">requestEndDate</stringProp>
              <stringProp name="Argument.value">2026-12-10</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DATE, REQUIRED. End date for request creation (format: yyyy-MM-dd, e.g. 2026-12-31). Must be same as or after start date</stringProp>
            </elementProp>
            <elementProp name="requestsPerDay" elementType="Argument">
              <stringProp name="Argument.name">requestsPerDay</stringProp>
              <stringProp name="Argument.value">1</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Requests to create per day (positive integers, comma-separated, e.g. 1,2,3). Empty = defaults to 1</stringProp>
            </elementProp>
            <elementProp name="requestDays" elementType="Argument">
              <stringProp name="Argument.name">requestDays</stringProp>
              <stringProp name="Argument.value">1</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Days a request should span (positive integers, comma-separated, e.g. 1,2,3). Empty = defaults to 1</stringProp>
            </elementProp>
            <elementProp name="allowWeekends" elementType="Argument">
              <stringProp name="Argument.name">allowWeekends</stringProp>
              <stringProp name="Argument.value">false</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">BOOLEAN. Flag to allow/disallow request creation on weekends. (Default = false)</stringProp>
            </elementProp>
            <elementProp name="requestStartTimes" elementType="Argument">
              <stringProp name="Argument.name">requestStartTimes</stringProp>
              <stringProp name="Argument.value">07:00, 07:30, 08:00, 08:30, 09:00</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">REQUIRED. Random start time of a request (HH:mm, comma-separated, e.g. 07:00,08:00,09:00)</stringProp>
            </elementProp>
            <elementProp name="requestDurations" elementType="Argument">
              <stringProp name="Argument.name">requestDurations</stringProp>
              <stringProp name="Argument.value">420, 480, 540, 600</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">REQUIRED. Random duration in minutes, min 30 (comma-separated, e.g. 420,480,540,600)</stringProp>
            </elementProp>
            <elementProp name="categoryType" elementType="Argument">
              <stringProp name="Argument.name">categoryType</stringProp>
              <stringProp name="Argument.value">CATEGORY_TYPE_BRIEFINGS</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, REQUIRED. Category type for request creation</stringProp>
            </elementProp>
            <elementProp name="parentCategory" elementType="Argument">
              <stringProp name="Argument.name">parentCategory</stringProp>
              <stringProp name="Argument.value">72DCAF42-C7C0-4006-8F31-7952185E5D61</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, REQUIRED. Parent category (location)</stringProp>
            </elementProp>
            <elementProp name="category" elementType="Argument">
              <stringProp name="Argument.name">category</stringProp>
              <stringProp name="Argument.value">D06189A1-69AF-4D17-AC5B-480F7589D427</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, REQUIRED. Request category</stringProp>
            </elementProp>
            <elementProp name="stateActionIterations" elementType="Argument">
              <stringProp name="Argument.name">stateActionIterations</stringProp>
              <stringProp name="Argument.value">2,3,4</stringProp>
              <stringProp name="Argument.desc">Times to iterate state actions for request (comma-separated, e.g. 2,3). First iteration always executes SUBMIT. Remaining iterations pick randomly from includedStateActions. 0 or empty = skip state actions entirely</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
            <elementProp name="includedStateActions" elementType="Argument">
              <stringProp name="Argument.name">includedStateActions</stringProp>
              <stringProp name="Argument.value">CONFIRM, HOLD, WAITLIST</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, MULTI. State actions to pick from after SUBMIT. Empty = all available actions allowed</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
          </collectionProp>
        </Arguments>
        <hashTree/>
        <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Customer Variables" enabled="true">
          <collectionProp name="Arguments.arguments">
            <elementProp name="defaultUser" elementType="Argument">
              <stringProp name="Argument.name">defaultUser</stringProp>
              <stringProp name="Argument.value">supportuser@allianceit.com</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">REQUIRED. Support user for fetching APIs — categories, lookups, forms etc (e.g. supportuser@allianceit.com)</stringProp>
            </elementProp>
            <elementProp name="users" elementType="Argument">
              <stringProp name="Argument.name">users</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Comma-separated list of users to iterate for a given request in given order. Leave empty to use defaultUser</stringProp>
            </elementProp>
            <elementProp name="customerName" elementType="Argument">
              <stringProp name="Argument.name">customerName</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Set a specific customer name (e.g. AllianceIT). If the customer already exists, request creation is skipped. Empty = picks a unique random customer per request from list of companies</stringProp>
            </elementProp>
            <elementProp name="checkDuplicateCustomer" elementType="Argument">
              <stringProp name="Argument.name">checkDuplicateCustomer</stringProp>
              <stringProp name="Argument.value">true</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">BOOLEAN. Check for duplicate customer names (true = check &amp; pick unique, false = allow any)</stringProp>
            </elementProp>
            <elementProp name="duplicateCustomerFromDate" elementType="Argument">
              <stringProp name="Argument.name">duplicateCustomerFromDate</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DATE. Start date for duplicate check (yyyy-MM-dd). Empty = checks across all events in the given category.</stringProp>
            </elementProp>
            <elementProp name="duplicateCustomerToDate" elementType="Argument">
              <stringProp name="Argument.name">duplicateCustomerToDate</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DATE. End date for duplicate check (yyyy-MM-dd). Empty = checks across all events in the given category.</stringProp>
            </elementProp>
            <elementProp name="clientTimeZone" elementType="Argument">
              <stringProp name="Argument.name">clientTimeZone</stringProp>
              <stringProp name="Argument.value">Asia/Calcutta</stringProp>
              <stringProp name="Argument.desc">Timezone of the user creating the request</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
          </collectionProp>
        </Arguments>
        <hashTree/>
        <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Agenda Variables" enabled="true">
          <collectionProp name="Arguments.arguments">
            <elementProp name="rooms" elementType="Argument">
              <stringProp name="Argument.name">rooms</stringProp>
              <stringProp name="Argument.value">2,3</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Rooms to create per activity day (positive integers, comma-separated, e.g. 1,2,3). 0 or empty = no rooms. Ignored if allowedRooms variable value is set.</stringProp>
            </elementProp>
            <elementProp name="allowedRooms" elementType="Argument">
              <stringProp name="Argument.name">allowedRooms</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Restrict room creation to specific rooms only (comma-separated room names, UUIDs, or a mix of both, e.g. Boardroom A, EAC8F953-99D0-43DF-8E15-CA03F21EA92D). Empty = picks from all vacant rooms based on the rooms variable count. When set, only matching rooms are used and the rooms variable is ignored.</stringProp>
            </elementProp>
            <elementProp name="roomTimeOffset" elementType="Argument">
              <stringProp name="Argument.name">roomTimeOffset</stringProp>
              <stringProp name="Argument.value">0</stringProp>
              <stringProp name="Argument.desc">Random minutes to add to start time and subtract from end time in logistics (comma-separated, e.g., 0,30,60)</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
            <elementProp name="vacantSlotDurations" elementType="Argument">
              <stringProp name="Argument.name">vacantSlotDurations</stringProp>
              <stringProp name="Argument.value">30,60</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Vacant slot duration in minutes for activity types like topics, caterings (positive integers, comma-separated, e.g. 30,60). 0 or empty = skip</stringProp>
            </elementProp>
            <elementProp name="caterings" elementType="Argument">
              <stringProp name="Argument.name">caterings</stringProp>
              <stringProp name="Argument.value">10%</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Number of catering activities to create per room. Accepts positive integers, a percentage of available slots (e.g. 80 or 80%), or a comma-separated mix of both (e.g. 5, 80%). 0 or empty = no caterings. Negative value = skip catering creation entirely.</stringProp>
            </elementProp>
            <elementProp name="cateringTimings" elementType="Argument">
              <stringProp name="Argument.name">cateringTimings</stringProp>
              <stringProp name="Argument.value">11:30, 12:00, 12:30, 13:00, 19:00, 19:30, 20:00, 20:30</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Allowed start times for caterings (HH:mm, comma-separated, e.g. 11:00,11:30,12:00). Empty = any available slot of that room</stringProp>
            </elementProp>
            <elementProp name="topics" elementType="Argument">
              <stringProp name="Argument.name">topics</stringProp>
              <stringProp name="Argument.value">10%</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Number of topics to create per room. Accepts positive integers, a percentage of available slots (e.g. 80 or 80%), or a comma-separated mix of both (e.g. 5, 80%). 0 or empty = no topics. Negative value = skip topic creation entirely.</stringProp>
            </elementProp>
            <elementProp name="topicTimings" elementType="Argument">
              <stringProp name="Argument.name">topicTimings</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Allowed start times for topics (HH:mm, comma-separated, e.g. 10:00,10:30,11:00). Empty = any available slot of that room</stringProp>
            </elementProp>
            <elementProp name="presenters" elementType="Argument">
              <stringProp name="Argument.name">presenters</stringProp>
              <stringProp name="Argument.value">5</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Presenters to create for a request (positive integers, comma-separated, e.g. 3,5). 0 or empty = no presenters</stringProp>
            </elementProp>
            <elementProp name="presentersPerTopic" elementType="Argument">
              <stringProp name="Argument.name">presentersPerTopic</stringProp>
              <stringProp name="Argument.value">1,2,3</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Number of presenters to randomly assign per topic (positive integers, comma-separated, e.g. 1, 2, 3). 0 or empty = skip presenter assignment.</stringProp>
            </elementProp>
            <elementProp name="multiEntryRange" elementType="Argument">
              <stringProp name="Argument.name">multiEntryRange</stringProp>
              <stringProp name="Argument.value">1,5</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Min and max range for multi-entry record iterations like attendees, opportunities (positive integers, e.g. 1,3 means randomly between 1 to 3 records created, or 2 means exactly 2 records created). 0 or empty = skip. Negative values or more than 2 values = error thrown</stringProp>
            </elementProp>
            <elementProp name="multiSelectRange" elementType="Argument">
              <stringProp name="Argument.name">multiSelectRange</stringProp>
              <stringProp name="Argument.value">1,2</stringProp>
              <stringProp name="Argument.desc">Min and max range for dropdown field selections (positive integers, e.g. 1,3 means randomly between 1 to 3 options selected, or 1 means exactly 1 option selected). 0 or empty = skip dropdown multi-selection. Negative values or more than 2 values = error thrown</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
          </collectionProp>
          <stringProp name="TestPlan.comments">sales@allianceit.com, admin@allianceit.com</stringProp>
        </Arguments>
        <hashTree/>
        <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Configuration Variables" enabled="true">
          <collectionProp name="Arguments.arguments">
            <elementProp name="journeyModuleType" elementType="Argument">
              <stringProp name="Argument.name">journeyModuleType</stringProp>
              <stringProp name="Argument.value">JOURNEY</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API. Module type of Journey</stringProp>
            </elementProp>
            <elementProp name="logisticsModuleType" elementType="Argument">
              <stringProp name="Argument.name">logisticsModuleType</stringProp>
              <stringProp name="Argument.value">LOGISTICS</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API. Module type of Logistics</stringProp>
            </elementProp>
            <elementProp name="agendaModuleType" elementType="Argument">
              <stringProp name="Argument.name">agendaModuleType</stringProp>
              <stringProp name="Argument.value">CALENDAR_LISTING</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API. Module type of Agenda</stringProp>
            </elementProp>
            <elementProp name="virtualConnectionModuleType" elementType="Argument">
              <stringProp name="Argument.name">virtualConnectionModuleType</stringProp>
              <stringProp name="Argument.value">VIRTUAL_CONNECTION</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API. Module type of Virtual Connection</stringProp>
            </elementProp>
            <elementProp name="blockedSlots" elementType="Argument">
              <stringProp name="Argument.name">blockedSlots</stringProp>
              <stringProp name="Argument.value">0</stringProp>
              <stringProp name="Argument.desc">Slots to keep empty per room (integers &gt;= 0, comma-separated, e.g. 0,1,2). 0 or empty = no blocked slots</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
            <elementProp name="blockedDurations" elementType="Argument">
              <stringProp name="Argument.name">blockedDurations</stringProp>
              <stringProp name="Argument.value">30,60</stringProp>
              <stringProp name="Argument.desc">Blocked slot durations in minutes (positive integers, comma-separated, e.g. 30,60). 0 or empty = skip</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
            <elementProp name="activityTypesPriority" elementType="Argument">
              <stringProp name="Argument.name">activityTypesPriority</stringProp>
              <stringProp name="Argument.value">catering</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Order of the Activity Type priority</stringProp>
            </elementProp>
            <elementProp name="skipActivityTypes" elementType="Argument">
              <stringProp name="Argument.name">skipActivityTypes</stringProp>
              <stringProp name="Argument.value">blocked</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Activity types to exclude from creation (comma-separated). Leave empty to create all</stringProp>
            </elementProp>
            <elementProp name="zoomAllowedActions" elementType="Argument">
              <stringProp name="Argument.name">zoomAllowedActions</stringProp>
              <stringProp name="Argument.value">CONFIRM</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Actions that allow adding Zoom link to topic (comma-separated)</stringProp>
            </elementProp>
            <elementProp name="roomResourceTypeId" elementType="Argument">
              <stringProp name="Argument.name">roomResourceTypeId</stringProp>
              <stringProp name="Argument.value">EAC8F953-99D0-43DF-8E15-CA03F21EA92D</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API. Resource type for Room</stringProp>
            </elementProp>
            <elementProp name="activityFormId" elementType="Argument">
              <stringProp name="Argument.name">activityFormId</stringProp>
              <stringProp name="Argument.value">5622B58C-55BA-4473-9B3A-38D732DDD04B</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API. Topic activity form</stringProp>
            </elementProp>
            <elementProp name="excludedModuleIds" elementType="Argument">
              <stringProp name="Argument.name">excludedModuleIds</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.desc">DROPDOWN, API, MULTI. Module IDs to exclude</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
          </collectionProp>
        </Arguments>
        <hashTree/>
        <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Environment Variables" enabled="true">
          <collectionProp name="Arguments.arguments">
            <elementProp name="protocol" elementType="Argument">
              <stringProp name="Argument.name">protocol</stringProp>
              <stringProp name="Argument.value">https</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">HTTP protocol</stringProp>
            </elementProp>
            <elementProp name="host" elementType="Argument">
              <stringProp name="Argument.name">host</stringProp>
              <stringProp name="Argument.value">briefings.briefingiq.com</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Server hostname</stringProp>
            </elementProp>
            <elementProp name="port" elementType="Argument">
              <stringProp name="Argument.name">port</stringProp>
              <stringProp name="Argument.value">443</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Server port number</stringProp>
            </elementProp>
            <elementProp name="contextname" elementType="Argument">
              <stringProp name="Argument.name">contextname</stringProp>
              <stringProp name="Argument.value">events</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">Application context/root path </stringProp>
            </elementProp>
          </collectionProp>
        </Arguments>
        <hashTree/>
        <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="API Field Variables" enabled="false">
          <collectionProp name="Arguments.arguments">
            <elementProp name="categoryType" elementType="Argument">
              <stringProp name="Argument.name">categoryType</stringProp>
              <stringProp name="Argument.value">/${contextname}/api/categorytypes</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">items=_embedded.categoryTypes display=categoryTypeName value=uniqueId ignore=CATEGORY_TYPE_EVENTS</stringProp>
            </elementProp>
            <elementProp name="parentCategory" elementType="Argument">
              <stringProp name="Argument.name">parentCategory</stringProp>
              <stringProp name="Argument.value">/${contextname}/api/categorytypes/${categoryType}/categories?identifier=LOCATION</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">items=_embedded.categories display=categoryName value=uniqueId depends=categoryType</stringProp>
            </elementProp>
            <elementProp name="category" elementType="Argument">
              <stringProp name="Argument.name">category</stringProp>
              <stringProp name="Argument.value">/${contextname}/api/categorytypes/${categoryType}/categories?identifier=REQUEST_TYPE&amp;parent=${parentCategory}&amp;features=CREATE_EVENT</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">items=_embedded.categories display=categoryName value=uniqueId depends=categoryType,parentCategory</stringProp>
            </elementProp>
            <elementProp name="journeyModuleType" elementType="Argument">
              <stringProp name="Argument.name">journeyModuleType</stringProp>
              <stringProp name="Argument.value">/${contextname}/api/moduletypes?isActive=true</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">items=_embedded.moduleTypes display=moduleTypeName value=uniqueId</stringProp>
            </elementProp>
            <elementProp name="logisticsModuleType" elementType="Argument">
              <stringProp name="Argument.name">logisticsModuleType</stringProp>
              <stringProp name="Argument.value">/${contextname}/api/moduletypes?isActive=true</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">items=_embedded.moduleTypes display=moduleTypeName value=uniqueId</stringProp>
            </elementProp>
            <elementProp name="agendaModuleType" elementType="Argument">
              <stringProp name="Argument.name">agendaModuleType</stringProp>
              <stringProp name="Argument.value">/${contextname}/api/moduletypes?isActive=true</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">items=_embedded.moduleTypes display=moduleTypeName value=uniqueId</stringProp>
            </elementProp>
            <elementProp name="virtualConnectionModuleType" elementType="Argument">
              <stringProp name="Argument.name">virtualConnectionModuleType</stringProp>
              <stringProp name="Argument.value">/${contextname}/api/moduletypes?isActive=true</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">items=_embedded.moduleTypes display=moduleTypeName value=uniqueId</stringProp>
            </elementProp>
            <elementProp name="excludedModuleIds" elementType="Argument">
              <stringProp name="Argument.name">excludedModuleIds</stringProp>
              <stringProp name="Argument.value">/${contextname}/api/modules</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">items=_embedded.modules display=moduleName value=uniqueId depends=category,categoryType header.x-cloud-categoryid=field:category header.x-cloud-categorytypeid=field:categoryType multi=true</stringProp>
            </elementProp>
            <elementProp name="roomResourceTypeId" elementType="Argument">
              <stringProp name="Argument.name">roomResourceTypeId</stringProp>
              <stringProp name="Argument.value">/${contextname}/api/resourcetypes</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">items=_embedded.resourceTypes display=name value=uniqueId header.x-cloud-customerid=field:customerId</stringProp>
            </elementProp>
            <elementProp name="activityFormId" elementType="Argument">
              <stringProp name="Argument.name">activityFormId</stringProp>
              <stringProp name="Argument.value">/${contextname}/api/forms</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">items=_embedded.forms display=formName value=uniqueId depends=categoryType header.x-cloud-categorytypeid=field:categoryType</stringProp>
            </elementProp>
            <elementProp name="includedStateActions" elementType="Argument">
              <stringProp name="Argument.name">includedStateActions</stringProp>
              <stringProp name="Argument.value">/${contextname}/api/admin/actions</stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
              <stringProp name="Argument.desc">items=_embedded.actions display=displayText value=uniqueId multi=true</stringProp>
            </elementProp>
          </collectionProp>
