                      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
                        <stringProp name="script">// Get original sampler name from HTTP Request
def originalName = sampler.getName()

// Get current iteration (set by State Action Selector PostProcessor)
def currentIteration = vars.get(&quot;stateActionIteration&quot;)

// Get total iterations (set from UDV: stateActionIterations)
def totalIterations = vars.get(&quot;stateActionLoopCount&quot;)

// Set dynamic sampler label with iteration count
sampler.setName(&quot;${originalName} - (${currentIteration}/${totalIterations})&quot;)</stringProp>
