                                        <stringProp name="filename"></stringProp>
                                        <stringProp name="cacheKey">false</stringProp>
                                      </JSR223Sampler>
                                      <hashTree/>
                                      <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="◉ While (Participant Loop)" enabled="true">
                                        <stringProp name="WhileController.condition">${__groovy(vars.get(&quot;participantLoopIdx&quot;)?.toInteger() &lt; vars.get(&quot;participantPayloadsCount&quot;)?.toInteger())}</stringProp>
                                      </WhileController>
                                      <hashTree>
                                        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Get Participant Payload" enabled="true">
                                          <stringProp name="script">

def idx = vars.get(&quot;participantLoopIdx&quot;)?.toInteger() ?: 0

def payloadsStr = vars.get(&quot;participantPayloads&quot;) ?: &quot;[]&quot;
def payloads = new groovy.json.JsonSlurper().parseText(payloadsStr)
def total = payloads.size()

if (idx &lt; total) {
    def payload = payloads[idx]
    def payloadJson = groovy.json.JsonOutput.prettyPrint(groovy.json.JsonOutput.toJson(payload))
    vars.put(&quot;currentParticipantPayload&quot;, payloadJson)

    def participantId = payload?.data?.participant?.uniqueId ?: payload?.data?.values()?.find { it instanceof Map &amp;&amp; it.uniqueId }?.uniqueId ?: &quot;N/A&quot;
    def dataFields = payload?.data?.keySet()?.findAll { it != &quot;participant&quot; }?.take(3)?.collect { k -&gt; &quot;${k}=${payload.data[k]?.toString()?.take(15)}&quot; }?.join(&quot;, &quot;) ?: &quot;&quot;

} else {
    vars.put(&quot;currentParticipantPayload&quot;, &quot;{}&quot;)
    log.warn(&quot;Index ${idx} out of bounds (total: ${total})&quot;)
}</stringProp>
