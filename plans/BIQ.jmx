                                  <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Next Activity" enabled="true">
                                    <stringProp name="script">SampleResult.setIgnore()

def attempts = (vars.get(&quot;activityAttemptCounter&quot;)?.toInteger() ?: 0) + 1
vars.put(&quot;activityAttemptCounter&quot;, attempts.toString())

def maxAttempts = (vars.get(&quot;currentActivityLoopCount&quot;)?.toInteger() ?: 10) * 3
if (attempts &gt; maxAttempts) {
    log.warn(&quot;Max attempts reached (${attempts}/${maxAttempts}) - stopping loop&quot;)
    vars.put(&quot;stopRoomActivityLoop&quot;, &quot;true&quot;)
    vars.put(&quot;gapFillActive&quot;, &quot;false&quot;)  
}

vars.put(&quot;skipActivity&quot;, &quot;false&quot;)

vars.put(&quot;createActivityPayload&quot;, &quot;&quot;)
vars.put(&quot;currentVacantSlotStartTime&quot;, &quot;&quot;)
vars.put(&quot;currentVacantSlotEndTime&quot;, &quot;&quot;)
vars.put(&quot;currentVacantSlotId&quot;, &quot;&quot;)

def currentRoomId = vars.get(&quot;currentRoomId&quot;) ?: &quot;&quot;

if (!currentRoomId || currentRoomId.trim().isEmpty()) {
    log.error(&quot;[Activity Loop Start] CRITICAL: No valid room ID - skipping ALL remaining activities for this room&quot;)
    vars.put(&quot;skipActivity&quot;, &quot;true&quot;)
    vars.put(&quot;skipActivityModule&quot;, &quot;true&quot;)  // Stop the entire activity loop for this room
}

def loopType = vars.get(&quot;loopActivityType&quot;)
def moduleType = vars.get(&quot;activityType&quot;)
def activityType = loopType ?: moduleType ?: &quot;unknown&quot;
def loopCount = vars.get(&quot;currentActivityLoopCount&quot;) ?: &quot;?&quot;
def currentRoomName = vars.get(&quot;currentRoomName&quot;) ?: &quot;Unknown&quot;
def counter = vars.get(&quot;activityLoopCounter&quot;)?.toInteger() ?: 0

SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setResponseMessage(activityType + &quot; #&quot; + (counter + 1) + &quot;/&quot; + loopCount + &quot; (attempt &quot; + attempts + &quot;)&quot;)</stringProp>
