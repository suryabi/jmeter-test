                          <hashTree/>
                          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Visit Summary PreProcessor" enabled="true">
                            <stringProp name="scriptLanguage">groovy</stringProp>
                            <stringProp name="parameters"></stringProp>
                            <stringProp name="filename"></stringProp>
                            <stringProp name="cacheKey">false</stringProp>
                            <stringProp name="script">

// ============ INITIALIZATION ============
def formName = vars.get(&quot;currentFormName&quot;)

def rand = java.util.concurrent.ThreadLocalRandom.current()

// ============ RANDOM NUMBER GENERATOR - using shared function ============
def random5 = { -&gt; props.get(&quot;fn_random5&quot;)() }  // 5 digits (10000-99999)
def randomNumber1to5 = { -&gt; props.get(&quot;fn_randomNumber1to5&quot;)() }  // 1-5 range for NUMBER fields

// ============ OPPORTUNITY DATA ============
def oppRevenue = String.valueOf(random5())
def primaryOppId = String.valueOf(random5())
def secondaryOppId = String.valueOf(random5())
vars.put(&quot;oppRevenue&quot;, oppRevenue)
vars.put(&quot;primaryOppId&quot;, primaryOppId)
vars.put(&quot;secondaryOppId&quot;, secondaryOppId)

// ============ CUSTOMER VISIT OBJECTIVES ============
String[] visitObjectives = [
    &quot;Understand customer&apos;s technology landscape&quot;,
    &quot;Identify opportunities for platform optimization&quot;,
    &quot;Present product capabilities and roadmap&quot;,
    &quot;Discuss digital transformation initiatives&quot;,
    &quot;Demonstrate solution value and use cases&quot;,
    &quot;Strengthen technical alignment with customer teams&quot;,
    &quot;Support customer&apos;s upcoming technology decisions&quot;,
    &quot;Address technical challenges and propose fixes&quot;,
    &quot;Establish alignment with customer stakeholders&quot;,
    &quot;Validate deployment readiness&quot;,
    &quot;Deep-dive into current system limitations&quot;,
    &quot;Evaluate solution fit for current use cases&quot;
]
def customerVisitObjective = visitObjectives[rand.nextInt(visitObjectives.length)]
vars.put(&quot;customerVisitObjective&quot;, customerVisitObjective)

// ============ DESIRED OUTCOMES ============
String[] desiredOutcomes = [
    &quot;Define next steps for solution deployment&quot;,
    &quot;Align on technical roadmap and priorities&quot;,
    &quot;Validate integration approach&quot;,
    &quot;Review current pain points and propose solutions&quot;,
    &quot;Review implementation plan and milestones&quot;,
    &quot;Capture client requirements for next release&quot;,
    &quot;Finalize architecture recommendations&quot;,
    &quot;Discuss scalability and performance improvements&quot;,
    &quot;Finalize technical validation for next phase&quot;,
    &quot;Confirm alignment on system requirements&quot;,
    &quot;Document customer success metrics&quot;,
    &quot;Address outstanding technical queries&quot;,
    &quot;Present prioritized improvement plan&quot;
]
def desiredOutcome = desiredOutcomes[rand.nextInt(desiredOutcomes.length)]
vars.put(&quot;desiredOutcome&quot;, desiredOutcome)

// ============ CUSTOMER IT INITIATIVES ============
String[] itInitiatives = [
    &quot;Cloud migration and modernization&quot;,
    &quot;AI and machine learning adoption&quot;,
    &quot;Data analytics and automation initiatives&quot;,
    &quot;Cybersecurity enhancements&quot;,
    &quot;API-first architecture adoption&quot;,
    &quot;Digital workplace transformation&quot;,
    &quot;Infrastructure optimization&quot;,
    &quot;Enterprise application integration&quot;,
    &quot;Microservices modernization&quot;,
    &quot;Migration to serverless architecture&quot;,
    &quot;Enterprise data lake implementation&quot;,
    &quot;Cloud cost optimization strategy&quot;,
    &quot;Business intelligence modernization&quot;
]
def customerInitiative = itInitiatives[rand.nextInt(itInitiatives.length)]
vars.put(&quot;customerInitiative&quot;, customerInitiative)

// ============ COMPETITORS ============
String[] competitors = [
    &quot;On-premise legacy vendors&quot;,
    &quot;Other analytics and automation platforms&quot;,
    &quot;Workflow automation competitors&quot;,
    &quot;Industry-specific software providers&quot;,
    &quot;Cloud-native startups&quot;,
    &quot;Open-source alternatives&quot;,
    &quot;Regional technology providers&quot;,
    &quot;Enterprise software giants&quot;
]
def competitor = competitors[rand.nextInt(competitors.length)]
vars.put(&quot;competitors&quot;, competitor)

// ============ SENSITIVE ISSUES ============
String[] sensitiveIssues = [
    &quot;No critical issues reported&quot;,
    &quot;Pending technical dependencies&quot;,
    &quot;Concerns about data security compliance&quot;,
    &quot;Performance issues under evaluation&quot;,
    &quot;Integration blockers identified&quot;,
    &quot;Customer highlighted onboarding challenges&quot;,
    &quot;Risk flagged regarding legacy systems&quot;,
    &quot;Security audit findings under review&quot;,
    &quot;Data privacy concerns raised&quot;,
    &quot;User adoption challenges reported&quot;
]
def sensitiveIssue = sensitiveIssues[rand.nextInt(sensitiveIssues.length)]
vars.put(&quot;anySensitiveIssues&quot;, sensitiveIssue)

// ============ CLOSED REVENUE ============
def closedRevenue = String.valueOf(random5())
vars.put(&quot;closedRevenue&quot;, closedRevenue)

// ============ BUSINESS CASE ============
String[] businessCases = [
    &quot;Improving operational efficiency through automation&quot;,
    &quot;Reducing cost through system consolidation&quot;,
    &quot;Enhancing customer experience via digital tools&quot;,
    &quot;Streamlining workflow through platform integration&quot;,
    &quot;Driving business insights using analytics&quot;,
    &quot;Supporting scalability for future growth&quot;,
    &quot;Modernizing infrastructure for better performance&quot;,
    &quot;Minimizing system downtime via modernization&quot;,
    &quot;Accelerating digital transformation initiatives&quot;,
    &quot;Improving developer productivity with modern tooling&quot;,
    &quot;Increasing productivity through platform integration&quot;
]
def businessCase = businessCases[rand.nextInt(businessCases.length)]
vars.put(&quot;businessCase&quot;, businessCase)

// ============ SUMMARY ============
String[] summaries = [
    &quot;Key actions identified and next steps agreed&quot;,
    &quot;Customer priorities captured and aligned&quot;,
    &quot;Technical challenges discussed and solution proposed&quot;,
    &quot;Opportunities for improvement identified&quot;,
    &quot;Architecture review completed with recommendations&quot;,
    &quot;Stakeholder expectations aligned for next phase&quot;,
    &quot;Key decisions made and communicated&quot;,
    &quot;Open issues tracked for follow-up&quot;,
    &quot;Integration strategy validated with engineering team&quot;,
    &quot;Next review session scheduled with stakeholders&quot;,
    &quot;Pending risks documented and mitigation planned&quot;
]
def summary = summaries[rand.nextInt(summaries.length)]
vars.put(&quot;summary&quot;, summary)

// ============ NUMBER FIELDS (1-5 range) ============
def numberField1Value = randomNumber1to5()
vars.put(&quot;visitSummaryNumberField1&quot;, String.valueOf(numberField1Value))

// ============ LOGGING ============
log.info(&quot;Opportunity Revenue: &quot; + oppRevenue)
log.info(&quot;Primary Opportunity ID: &quot; + primaryOppId)
log.info(&quot;Secondary Opportunity ID: &quot; + secondaryOppId)
log.info(&quot;Customer Visit Objective: &quot; + customerVisitObjective)
log.info(&quot;Desired Outcome: &quot; + desiredOutcome)
log.info(&quot;Customer IT Initiative: &quot; + customerInitiative)
log.info(&quot;Competitors: &quot; + competitor)
log.info(&quot;Sensitive Issues: &quot; + sensitiveIssue)
log.info(&quot;Closed Revenue: &quot; + closedRevenue)
log.info(&quot;Business Case: &quot; + businessCase)
log.info(&quot;Summary: &quot; + summary)

log.info(&quot;Number Field 1 (1-5): &quot; + numberField1Value)
log.info(&quot;----- Terminated: Visit Summary Form PostProcessor -----&quot;)</stringProp>
