props.put(&quot;fn_random5&quot;, _fn_random5)

// Generate 6-digit random number
def _fn_random6 = { java.util.concurrent.ThreadLocalRandom.current().nextInt(100000, 1000000) }   // 6 digits (100000-999999)
props.put(&quot;fn_random6&quot;, _fn_random6)

// Generates a realistic 10-digit phone number
def _fn_generatePhone = {
    def rand = java.util.concurrent.ThreadLocalRandom.current()
    def validStartDigits = [7, 8, 9]
    def digit = validStartDigits[rand.nextInt(validStartDigits.size())]
    def rest = rand.nextLong(100000000L, 1000000000L)
    return String.valueOf(digit) + String.valueOf(rest)
}
props.put(&quot;fn_generatePhone&quot;, _fn_generatePhone)

// Extract email domain from form config validators
def _fn_extractEmailDomain = { varsRef -&gt;
    def emailDomain = &quot;gmail.com&quot;
    try {
        def formUIConfigStr = varsRef.get(&quot;currentFormUIConfig&quot;)
        if (formUIConfigStr) {
            def formUIConfig = new groovy.json.JsonSlurper().parseText(formUIConfigStr)
            def configItems = formUIConfig.config ?: []
            configItems.each { item -&gt;
                if (item.validators) {
                    item.validators.each { validator -&gt;
                        if (validator.toString().startsWith(&quot;DOMAIN_EMAIL:&quot;)) {
                            emailDomain = validator.toString().split(&quot;:&quot;)[1]
                        }
                    }
                }
            }
        }
    } catch (Exception e) {
        log.warn(&quot;Error parsing formUIConfig for email domain: &quot; + e.message)
    }
    return emailDomain
}
props.put(&quot;fn_extractEmailDomain&quot;, _fn_extractEmailDomain)

def _fn_getCustomers = { varsRef -&gt;
    def industryMap = props.get(&quot;fn_customersByIndustry&quot;)
    def customerSector = varsRef?.get(&quot;customerSector&quot;)?.trim()

    if (!customerSector) {
        return industryMap.values().flatten() as String[]
    }

    // Support comma-separated sectors e.g. &quot;Technology,Banking &amp; Finance&quot;
    def sectors = customerSector.split(&quot;,&quot;)*.trim().findAll { it }
    def matched = [] as Set
    def unmatched = []

    sectors.each { sector -&gt;
        def list = industryMap[sector]
        if (list) {
            matched.addAll(list)
        } else {
            unmatched.add(sector)
        }
    }

    if (unmatched) {
        log.warn(&quot;Unknown customerSector value(s): ${unmatched.join(&apos;, &apos;)} - Valid options: ${industryMap.keySet().sort().join(&apos;, &apos;)}&quot;)
    }

    if (matched) {
        return matched as String[]
    }

    log.warn(&quot;No valid sectors matched - returning empty list to block creation&quot;)
    return [] as String[]
}
props.put(&quot;fn_getCustomers&quot;, _fn_getCustomers)

def _fn_lookupNameById = { varsRef, idVar, countVar, idPrefix, namePrefix, outputVar, defaultName, logRef -&gt;
    def currentId = varsRef.get(idVar) ?: &quot;&quot;
    def count = varsRef.get(countVar)?.toInteger() ?: 0
    def resolvedName = defaultName

    for (int i = 1; i &lt;= count; i++) {
        if (varsRef.get(idPrefix + i) == currentId) {
            resolvedName = varsRef.get(namePrefix + i) ?: defaultName
            break
        }
    }

    varsRef.put(outputVar, resolvedName)
    logRef.info(&quot;fn_lookupNameById | ${outputVar}: ${resolvedName}&quot;)
}
props.put(&quot;fn_lookupNameById&quot;, _fn_lookupNameById)

