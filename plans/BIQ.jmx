def _fn_resolveEntries = { configMin, configMax, v -&gt;
    if (configMin != null &amp;&amp; configMax != null) {
        return [configMin, configMax]
    }
    return props.get(&quot;fn_parseMultiEntryRange&quot;)(v)
}
props.put(&quot;fn_resolveEntries&quot;, _fn_resolveEntries)

// Stop execution if abort flag is already set
def _fn_checkAbort = { v, p -&gt;
    if (v.get(&quot;_abortTest&quot;) == &quot;true&quot;) {
        p.setSuccessful(false)
        p.setResponseMessage(&quot;SKIPPED: Test aborting — &quot; + (v.get(&quot;_abortReason&quot;) ?: &quot;previous validation failed&quot;))
        return true
    }
    return false
}
props.put(&quot;fn_checkAbort&quot;, _fn_checkAbort)

// Abort test when required value is not found
def _fn_abortNotFound = { varsRef, prevRef, varName, value, available, ctxRef -&gt;
    log.error(&quot;========================================&quot;)
    log.error(&quot;${varName} &apos;${value}&apos; not found in API response&quot;)
    log.error(&quot;Available: ${available}&quot;)
    log.error(&quot;========================================&quot;)
    prevRef.setSuccessful(false)
    prevRef.setResponseMessage(&quot;ABORTING: ${varName} &apos;${value}&apos; not found. Available: ${available}&quot;)
    varsRef.put(&quot;_abortTest&quot;, &quot;true&quot;)
    varsRef.put(&quot;_abortReason&quot;, &quot;${varName} &apos;${value}&apos; not found in API response. Available: ${available}&quot;)
    ctxRef.getEngine().stopTest()
}
props.put(&quot;fn_abortNotFound&quot;, _fn_abortNotFound)

// multi-entry range

// multi-entry range
def _fn_parseMultiEntryRange = { v -&gt;
    def raw = v.get(&quot;multiEntryRange&quot;)?.trim()
    if (!raw || raw == &quot;0&quot;) return [0, 0]
    def parts = raw.split(&quot;,&quot;)*.trim()
    if (parts.size() &gt; 2) {
        log.warn(&quot;multiEntryRange &apos;${raw}&apos; has too many values (${parts.size()}) — expected exactly 2 (min,max). Using [0,0].&quot;)
        return [0, 0]
    }
    def minVal = parts[0].isInteger() ? parts[0].toInteger() : 0
    def maxVal = parts.size() &gt; 1 ? (parts[1].isInteger() ? parts[1].toInteger() : 0) : minVal
    if (minVal &lt; 0 || maxVal &lt; 0) {
        def errorMsg = &quot;multiEntryRange &apos;${raw}&apos; is invalid — negative values are not allowed. Use positive integers only (e.g. 1,3) or leave empty to skip.&quot;
        log.error(errorMsg)
        throw new IllegalArgumentException(errorMsg)
    }
    if (minVal &gt; maxVal) {
        log.warn(&quot;multiEntryRange &apos;${raw}&apos; is invalid — min (${minVal}) &gt; max (${maxVal}). Expected format: min,max e.g. 1,3. Using [0,0].&quot;)
        return [0, 0]
    }
    return [minVal, maxVal]
}
props.put(&quot;fn_parseMultiEntryRange&quot;, _fn_parseMultiEntryRange)

// Drop down Multi Select range
def _fn_parseMultiSelectRange = { v, defaultRange -&gt;
    def raw = v.get(&quot;multiSelectRange&quot;)?.trim()
    if (!raw || raw == &quot;0&quot;) return [min: 0, max: 0]
    def parts = raw.split(&quot;,&quot;)*.trim()
    def minVal = parts[0].isInteger() ? parts[0].toInteger() : 0
    def maxVal = parts.size() &gt; 1 ? (parts[1].isInteger() ? parts[1].toInteger() : 0) : minVal
    if (minVal &lt; 0 || maxVal &lt; 0) {
        def errorMsg = &quot;multiSelectRange &apos;${raw}&apos; is invalid — negative values are not allowed. Use positive integers only (e.g. 1,3) or leave empty to skip.&quot;
        log.error(errorMsg)
        throw new IllegalArgumentException(errorMsg)
    }
    return [min: minVal, max: maxVal]
}
props.put(&quot;fn_parseMultiSelectRange&quot;, _fn_parseMultiSelectRange)



