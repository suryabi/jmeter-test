                      <stringProp name="script">SampleResult.setIgnore()

def count = vars.get(&quot;activityModules_count&quot;)?.toInteger() ?: 0
def roomCount = vars.get(&quot;selectedRoomCount&quot;)?.toInteger() ?: 0

if (count == 0) {
    log.error(&quot;No activity modules found&quot;)
} else {
    def modulesSummary = []
    for (int i = 1; i &lt;= count; i++) {
        def moduleId = vars.get(&quot;activityModuleId_&quot; + i) ?: &quot;&quot;
        def moduleName = vars.get(&quot;activityModuleName_&quot; + i) ?: &quot;Unknown&quot;
        def activityType = vars.get(&quot;activityType_&quot; + i) ?: &quot;unknown&quot;

        modulesSummary.add(&quot;${moduleName}(${activityType})&quot;)

        if (!moduleId) {
            log.warn(&quot;Module ${i} has empty ID - will be skipped&quot;)
        }
    }
    log.info(&quot;${count} modules: ${modulesSummary.join(&apos;, &apos;)}&quot;)
}

if (roomCount == 0) {
    log.warn(&quot;No rooms available - activities will NOT be created&quot;)
} else {
    }

def status = (count &gt; 0 &amp;&amp; roomCount &gt; 0) ? &quot;Ready&quot; : &quot;Not Ready&quot;
log.info(&quot;----- Status: ${status} (${count} modules, ${roomCount} rooms) -----&quot;)</stringProp>
