    return titles[java.util.concurrent.ThreadLocalRandom.current().nextInt(titles.length)]
}
props.put(&quot;fn_getRandomBusinessTitle&quot;, _fn_getRandomBusinessTitle)

// Generate a random number between 1 and 5 (inclusive) — used for all NUMBER fields
def _fn_randomNumber1to5 = { -&gt; java.util.concurrent.ThreadLocalRandom.current().nextInt(1, 6) }   // range 1-5
props.put(&quot;fn_randomNumber1to5&quot;, _fn_randomNumber1to5)

// Normalize dropdown option text fetched from API:
// Fixes double-encoded non-breaking space: UTF-8 bytes \u00c2\u00a0 misread as Latin-1 → normalize to plain \u00a0
// Also trims surrounding whitespace.
// Apply when storing lookup values AND when comparing stored var against API options.
def _fn_normalizeDropdownText = { String raw -&gt;
    if (!raw) return raw
    return raw.replace(&quot;\u00c2\u00a0&quot;, &quot;\u00a0&quot;).trim()
}
props.put(&quot;fn_normalizeDropdownText&quot;, _fn_normalizeDropdownText)

def _fn_lookupNameToCamelCase = { String lookupName -&gt;
    if (!lookupName) return &quot;&quot;
    def words = lookupName.toLowerCase().split(&apos;_&apos;)
    return words[0] + words.drop(1).collect { it.capitalize() }.join(&apos;&apos;)
}
props.put(&quot;fn_lookupNameToCamelCase&quot;, _fn_lookupNameToCamelCase)

// Form field lookupContext: tenant (customer-wide) or category (category-scoped API)
def _fn_normalizeLookupContext = { String lookupContext -&gt;
    def normalized = lookupContext?.trim()?.toLowerCase()
    if (normalized in [&quot;category&quot;, &quot;location&quot;]) return &quot;category&quot;
    return &quot;tenant&quot;
}
props.put(&quot;fn_normalizeLookupContext&quot;, _fn_normalizeLookupContext)

// Deep-search nested form field JSON for lookupContext (API may nest it under attributes, etc.)
def _fn_deepFindLookupContext = { obj, depth = 0 -&gt;
    if (obj == null || depth &gt; 8) return null
    def deepFind = props.get(&quot;fn_deepFindLookupContext&quot;)
    if (obj instanceof Map) {
        if (obj.lookupContext != null &amp;&amp; obj.lookupContext.toString().trim() != &quot;&quot;) {
            return obj.lookupContext
        }
        for (entry in obj.entrySet()) {
            def k = entry.key
            def v = entry.value
            if (k?.toString()?.equalsIgnoreCase(&quot;lookupContext&quot;) &amp;&amp; v != null &amp;&amp; v.toString().trim() != &quot;&quot;) {
                return v
            }
            if (v instanceof Map || v instanceof List) {
                def found = deepFind(v, depth + 1)
                if (found) return found
            }
        }
    } else if (obj instanceof List) {
        for (item in obj) {
            def found = deepFind(item, depth + 1)
            if (found) return found
        }
    }
    return null
}
props.put(&quot;fn_deepFindLookupContext&quot;, _fn_deepFindLookupContext)

// Resolve lookupContext from form template field (top-level or nested attributes)
def _fn_resolveFieldLookupContext = { field, logRef = null -&gt;
    if (!field) return &quot;tenant&quot;
    def raw = field.lookupContext
    if (!raw &amp;&amp; field.attributes instanceof Map) {
        raw = field.attributes.lookupContext ?: field.attributes.get(&quot;lookupContext&quot;)
    }
    if (!raw &amp;&amp; field.attributes instanceof List) {
        def attr = field.attributes.find {
            def name = it?.name ?: it?.attributeName ?: it?.key ?: it?.code
            name?.toString()?.equalsIgnoreCase(&quot;lookupContext&quot;)
        }
        raw = attr?.value ?: attr?.attributeValue
    }
    if (!raw &amp;&amp; field.fieldAttributes instanceof Map) {
        raw = field.fieldAttributes.lookupContext ?: field.fieldAttributes.get(&quot;lookupContext&quot;)
    }
    if (!raw &amp;&amp; field.formFieldAttributes instanceof Map) {
        raw = field.formFieldAttributes.lookupContext ?: field.formFieldAttributes.get(&quot;lookupContext&quot;)
    }
    if (!raw &amp;&amp; field.lookupType instanceof Map) {
        raw = field.lookupType.lookupContext
    }
    if (!raw &amp;&amp; field.lookup instanceof Map) {
        raw = field.lookup.lookupContext
    }
    if (!raw) {
        raw = props.get(&quot;fn_deepFindLookupContext&quot;)(field)
    }
    def resolved = props.get(&quot;fn_normalizeLookupContext&quot;)(raw ?: &quot;tenant&quot;)
    if (!raw &amp;&amp; field.lookupName &amp;&amp; logRef) {
        logRef.warn(&quot;lookupContext missing for field ${field.dataMapping ?: field.formControlName} lookupName=${field.lookupName} — defaulting to tenant&quot;)
    }
    return resolved
}
props.put(&quot;fn_resolveFieldLookupContext&quot;, _fn_resolveFieldLookupContext)

def _fn_valueInLookupStore = { varsRef, lookupName, lookupContext, valueCandidate -&gt;
    if (!lookupName || valueCandidate == null) return false
    def ctx = props.get(&quot;fn_normalizeLookupContext&quot;)(lookupContext)
    def base = props.get(&quot;fn_lookupVarBase&quot;)(lookupName, ctx)
    def allStr = varsRef.get(base + &quot;_all&quot;) ?: &quot;&quot;
    if (!allStr &amp;&amp; ctx == &quot;tenant&quot;) {
        def legacy = props.get(&quot;fn_lookupNameToCamelCase&quot;)(lookupName)
        allStr = varsRef.get(legacy + &quot;_all&quot;) ?: &quot;&quot;
    }
    if (!allStr) return false
    def allowed = allStr.split(&quot;,&quot;).collect { props.get(&quot;fn_normalizeDropdownText&quot;)(it.trim()) } as Set
    def matches = { v -&gt;
        def s = props.get(&quot;fn_normalizeDropdownText&quot;)(v?.toString() ?: &quot;&quot;)
        s &amp;&amp; allowed.contains(s)
    }
    if (valueCandidate instanceof List) return valueCandidate.every { matches(it) }
    return matches(valueCandidate)
}
props.put(&quot;fn_valueInLookupStore&quot;, _fn_valueInLookupStore)

def _fn_lookupVarBase = { String lookupName, String lookupContext -&gt;
    def camel = props.get(&quot;fn_lookupNameToCamelCase&quot;)(lookupName)
    def ctx = props.get(&quot;fn_normalizeLookupContext&quot;)(lookupContext)
    return ctx + &quot;_&quot; + camel
}
props.put(&quot;fn_lookupVarBase&quot;, _fn_lookupVarBase)

def _fn_resolveLookupRowId = { lookup -&gt;
    def id = lookup?.id ?: lookup?.uniqueId ?: lookup?.lookupValueId
    return id != null ? id.toString().trim() : null
}
props.put(&quot;fn_resolveLookupRowId&quot;, _fn_resolveLookupRowId)

def _fn_resolveLookupRowParentId = { lookup -&gt;
    def pid = lookup?.parentId
    if ((pid == null || pid.toString().trim() == &quot;&quot;) &amp;&amp; lookup?.parent instanceof Map) {
        pid = lookup.parent.id ?: lookup.parent.uniqueId
    }
    if (pid == null || pid.toString().trim() == &quot;&quot; || pid.toString().equalsIgnoreCase(&quot;null&quot;)) return null
    return pid.toString().trim()
}
props.put(&quot;fn_resolveLookupRowParentId&quot;, _fn_resolveLookupRowParentId)

def _fn_resolveFieldLookupMode = { field -&gt;
    if (!field) return null
    def raw = field.lookupMode
    if (!raw &amp;&amp; field.attributes instanceof Map) raw = field.attributes.lookupMode
    if (!raw) return null
    def mode = raw.toString().trim().toLowerCase()
    return (mode == &quot;parent&quot; || mode == &quot;child&quot;) ? mode : null
}
props.put(&quot;fn_resolveFieldLookupMode&quot;, _fn_resolveFieldLookupMode)

// Child lookup field -&gt; parent field (from dependentControls on parent form fields)
def _fn_buildLookupParentFieldMap = { allFieldsList -&gt;
    def map = [:]
    (allFieldsList ?: []).each { field -&gt;
        def parentFN = field.dataMapping ?: field.formControlName
        (field.dependentControls ?: []).each { dep -&gt;
            def childFN = dep?.formControlName
            if (childFN) map[childFN] = parentFN
        }
    }
    return map
}
props.put(&quot;fn_buildLookupParentFieldMap&quot;, _fn_buildLookupParentFieldMap)

def _fn_getLookupRows = { varsRef, lookupName, lookupContext -&gt;
    def ctx = props.get(&quot;fn_normalizeLookupContext&quot;)(lookupContext)
    def base = props.get(&quot;fn_lookupVarBase&quot;)(lookupName, ctx)
    def rowsJson = varsRef.get(base + &quot;_rows&quot;)
    if (!rowsJson &amp;&amp; ctx == &quot;tenant&quot;) {
        def legacy = props.get(&quot;fn_lookupNameToCamelCase&quot;)(lookupName)
        rowsJson = varsRef.get(legacy + &quot;_rows&quot;)
        if (!rowsJson) base = legacy
    }
    if (rowsJson) {
        try {
            return new groovy.json.JsonSlurper().parseText(rowsJson) ?: []
        } catch (Exception ignored) { }
    }
    def countStr = varsRef.get(base + &quot;_count&quot;)
    if (!(countStr &amp;&amp; countStr.isInteger() &amp;&amp; countStr.toInteger() &gt; 0)) return []
    def count = countStr.toInteger()
    return (1..count).collect { idx -&gt;
        [id: null, parentId: null, value: varsRef.get(base + &quot;_&quot; + idx)]
    }.findAll { it.value }
}
props.put(&quot;fn_getLookupRows&quot;, _fn_getLookupRows)

def _fn_lookupParentIdsForValues = { rows, parentFieldValues -&gt;
    def vals = []
    if (parentFieldValues instanceof List) vals = parentFieldValues
    else if (parentFieldValues != null &amp;&amp; parentFieldValues.toString().trim() != &quot;&quot;) vals = [parentFieldValues]
    if (!vals) return [] as Set
    def normSet = vals.collect { props.get(&quot;fn_normalizeDropdownText&quot;)(it?.toString() ?: &quot;&quot;) }.findAll { it } as Set
    def ids = [] as Set
    (rows ?: []).each { row -&gt;
        if (row?.parentId) return
        def nv = props.get(&quot;fn_normalizeDropdownText&quot;)(row?.value?.toString() ?: &quot;&quot;)
        if (nv &amp;&amp; normSet.contains(nv) &amp;&amp; row?.id) ids.add(row.id.toString())
    }
    return ids
}
props.put(&quot;fn_lookupParentIdsForValues&quot;, _fn_lookupParentIdsForValues)

def _fn_filterLookupRowsByMode = { rows, lookupMode, parentFieldValues = null -&gt;
    def mode = lookupMode?.toString()?.trim()?.toLowerCase()
    if (!mode || mode == &quot;parent&quot;) {
        return (rows ?: []).findAll { row -&gt; !row?.parentId }
    }
    if (mode == &quot;child&quot;) {
        def parentIds = props.get(&quot;fn_lookupParentIdsForValues&quot;)(rows, parentFieldValues)
        if (!parentIds) return []
        return (rows ?: []).findAll { row -&gt;
            row?.parentId &amp;&amp; parentIds.contains(row.parentId.toString())
        }
    }
    return rows ?: []
}
props.put(&quot;fn_filterLookupRowsByMode&quot;, _fn_filterLookupRowsByMode)

def _fn_storeLookupValues = { varsRef, lookupValuesList, contextKey, logRef -&gt;
    def lookupMap = [:]
    def rowsMap = [:]
    def skippedInactive = 0
    (lookupValuesList ?: []).each { lookup -&gt;
        def active = lookup?.isActive
        if (active == false || active?.toString()?.equalsIgnoreCase(&quot;false&quot;)) {
            skippedInactive++
            return
        }
        def code = lookup.lookupType?.code
        def value = lookup.value
        if (code &amp;&amp; value != null &amp;&amp; value.toString().trim() != &quot;&quot;) {
            def normalizedValue = props.get(&quot;fn_normalizeDropdownText&quot;)(value.toString())
            def rowId = props.get(&quot;fn_resolveLookupRowId&quot;)(lookup)
            def rowParentId = props.get(&quot;fn_resolveLookupRowParentId&quot;)(lookup)
            if (!lookupMap.containsKey(code)) lookupMap[code] = []
            if (!rowsMap.containsKey(code)) rowsMap[code] = []
            lookupMap[code].add(normalizedValue)
            rowsMap[code].add([id: rowId, parentId: rowParentId, value: normalizedValue])
        }
    }
    def ctx = props.get(&quot;fn_normalizeLookupContext&quot;)(contextKey)
    rowsMap.each { code, rows -&gt;
        def values = lookupMap[code] ?: []
        def base = props.get(&quot;fn_lookupVarBase&quot;)(code, ctx)
        def rowsJson = groovy.json.JsonOutput.toJson(rows)
        varsRef.put(base + &quot;_rows&quot;, rowsJson)
        varsRef.put(base + &quot;_all&quot;, values.join(&quot;,&quot;))
        varsRef.put(base + &quot;_count&quot;, String.valueOf(values.size()))
        values.eachWithIndex { val, idx -&gt; varsRef.put(base + &quot;_&quot; + (idx + 1), val) }
        // Backward compat: tenant lookups also mirror unprefixed vars (e.g. customerSector_count)
        if (ctx == &quot;tenant&quot;) {
            def camel = props.get(&quot;fn_lookupNameToCamelCase&quot;)(code)
            varsRef.put(camel + &quot;_rows&quot;, rowsJson)
            varsRef.put(camel + &quot;_all&quot;, values.join(&quot;,&quot;))
            varsRef.put(camel + &quot;_count&quot;, String.valueOf(values.size()))
            values.eachWithIndex { val, idx -&gt; varsRef.put(camel + &quot;_&quot; + (idx + 1), val) }
        }
    }
    varsRef.put(ctx + &quot;LookupValues&quot;, groovy.json.JsonOutput.toJson(lookupMap))
    if (skippedInactive &gt; 0) {
        logRef.info(&quot;Stored ${lookupMap.size()} lookup type(s) for context &apos;${ctx}&apos; (skipped ${skippedInactive} inactive rows)&quot;)
    }
    return lookupMap
}
props.put(&quot;fn_storeLookupValues&quot;, _fn_storeLookupValues)

def _fn_pickLookupValue = { varsRef, lookupName, lookupContext, isMultiple, selectionCountFn, randRef, fieldName = null, logRef = null, pickOptions = null -&gt;
    if (lookupName == &quot;ROOM_TYPE&quot;) {
        def existingRoomType = varsRef.get(&quot;roomType&quot;)
        if (existingRoomType) return existingRoomType
    }
    def logFn = logRef ?: log
    def ctx = props.get(&quot;fn_normalizeLookupContext&quot;)(lookupContext)
    def lookupMode = pickOptions?.lookupMode?.toString()?.trim()?.toLowerCase()
    def base = props.get(&quot;fn_lookupVarBase&quot;)(lookupName, ctx)
    def allRows = props.get(&quot;fn_getLookupRows&quot;)(varsRef, lookupName, ctx)
    if (!allRows &amp;&amp; ctx == &quot;tenant&quot;) {
        def legacy = props.get(&quot;fn_lookupNameToCamelCase&quot;)(lookupName)
        def legacyCount = varsRef.get(legacy + &quot;_count&quot;)
        if (legacyCount &amp;&amp; legacyCount.isInteger() &amp;&amp; legacyCount.toInteger() &gt; 0) base = legacy
    }
    def parentFieldValues = pickOptions?.parentFieldValues
    def candidates = lookupMode
        ? props.get(&quot;fn_filterLookupRowsByMode&quot;)(allRows, lookupMode, parentFieldValues)
        : allRows
    if (lookupMode == &quot;child&quot; &amp;&amp; !candidates) {
        logFn.warn(&quot;fn_pickLookupValue: no child rows for ${lookupName} context=${ctx} field=${fieldName ?: &apos;n/a&apos;} (parent selections=${parentFieldValues})&quot;)
        return null
    }
    if (lookupMode == &quot;parent&quot; &amp;&amp; !candidates) {
        logFn.warn(&quot;fn_pickLookupValue: no parent rows (parentId null) for ${lookupName} context=${ctx} field=${fieldName ?: &apos;n/a&apos;}&quot;)
        return null
    }
    if (!candidates) {
        def countStr = varsRef.get(base + &quot;_count&quot;)
        if (!(countStr &amp;&amp; countStr.isInteger() &amp;&amp; countStr.toInteger() &gt; 0)) {
            logFn.warn(&quot;fn_pickLookupValue: no values for lookupName=${lookupName} context=${ctx} (checked ${base}_count)&quot;)
            return null
        }
        def count = countStr.toInteger()
        if (isMultiple) {
            def selectCount = selectionCountFn(count)
            def selectedValues = []
            def indices = (1..count).toList()
            Collections.shuffle(indices)
            indices.take(selectCount).each { idx -&gt;
                def val = varsRef.get(base + &quot;_&quot; + idx)
                if (val) selectedValues.add(val)
            }
            return selectedValues ?: null
        }
        def randomIndex = randRef.nextInt(count) + 1
        return varsRef.get(base + &quot;_&quot; + randomIndex)
    }
    if (isMultiple) {
        def selectCount = selectionCountFn(candidates.size())
        def shuffled = candidates.toList()
        Collections.shuffle(shuffled)
        def selectedValues = shuffled.take(selectCount).collect { it.value }.findAll { it }
        return selectedValues ?: null
    }
    def pickedRow = candidates[randRef.nextInt(candidates.size())]
    return pickedRow?.value
}
props.put(&quot;fn_pickLookupValue&quot;, _fn_pickLookupValue)

// Generate 4-digit random number
