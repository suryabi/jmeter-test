def roomIndex = vars.get(&quot;RoomIndex&quot;)?.toInteger() ?: 1
def totalRooms = vars.get(&quot;TotalRoomsToCreate&quot;)?.toInteger() ?: 1

vars.put(&quot;currentRoomIndex&quot;, roomIndex.toString())

log.info(&quot;Processing Room ${roomIndex}/${totalRooms}&quot;)</stringProp>
