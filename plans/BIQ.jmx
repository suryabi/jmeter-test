                          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="MasterType PostProcessor" enabled="true">
                            <stringProp name="script">

// Get current master type being processed (set by ForEach Controller)
def currentMasterTypeId = vars.get(&quot;currentMasterTypeId&quot;)
log.info(&quot;Processing masterTypeId: ${currentMasterTypeId}&quot;)

// STEP 1: Parse API Response
def response = prev.getResponseDataAsString()

// Validate response exists
if (!response || response.isEmpty()) {
    log.warn(&quot;Empty response - no masters found&quot;)
    vars.put(&quot;mastersFor_&quot; + currentMasterTypeId + &quot;_count&quot;, &quot;0&quot;)
    return
}

def json = new groovy.json.JsonSlurper().parseText(response)
// STEP 2: Extract Masters Array (supports multiple response formats)
// Handles multiple API response formats:
//   - HAL format:    { _embedded: { masters: [...] } }
//   - Simple format: { masters: [...] }
//   - Array format:  [...]

def masters = json._embedded?.masters ?: json.masters ?: (json instanceof List ? json : [])

//}&quot;)
// STEP 3: Store Masters Keyed by MasterTypeId
// Handles two data structures:
//   - Flat:   { uniqueId: &quot;xxx&quot;, displayName: &quot;yyy&quot; }
//   - Nested: { data: { uniqueId: &quot;xxx&quot;, searchDisplayText: &quot;yyy&quot; } }

def count = 0

masters.each { master -&gt;
    count++

    // Handle both flat and nested (data) structures
    def data = master.data ?: master
    // Extract Unique ID (try multiple possible field names)
    def uniqueId = data.uniqueId ?:
                   data.id ?:
                   master.uniqueId ?:
                   master.id
    // Extract Display Name (try multiple possible field names)
    def displayName = data.searchDisplayText ?:
                      data.displayName ?:
                      data.masterName ?:
                      data.name ?:
                      master.displayName ?:
                      master.name ?:
                      uniqueId  // Fallback to ID if no name found
    // Store Master as JMeter Variables
    def varPrefix = &quot;mastersFor_&quot; + currentMasterTypeId + &quot;_&quot; + count
    vars.put(varPrefix + &quot;_id&quot;, uniqueId)
    vars.put(varPrefix + &quot;_name&quot;, displayName)

    log.info(&quot;   [${count}] ${displayName} (${uniqueId})&quot;)
}
// STEP 4: Store Total Count for Later Iteration
vars.put(&quot;mastersFor_&quot; + currentMasterTypeId + &quot;_count&quot;, count.toString())

log.info(&quot;----- Terminated: Dynamic Master PostProcessor -----&quot;)</stringProp>
