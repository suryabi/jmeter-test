                              <stringProp name="IfController.condition">${__groovy(vars.get(&quot;skipRoomCreation&quot;) != &quot;true&quot; &amp;&amp; vars.get(&quot;roomId&quot;) != null &amp;&amp; vars.get(&quot;roomId&quot;) != &quot;&quot; &amp;&amp; vars.get(&quot;roomId&quot;) != &quot;NOT_FOUND&quot;)}</stringProp>
