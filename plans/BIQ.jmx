                                            <stringProp name="script">def responseCode = prev.getResponseCode()
def idx = (vars.get(&quot;participantLoopIdx&quot;)?.toInteger() ?: 0) + 1
def total = vars.get(&quot;participantPayloadsCount&quot;) ?: &quot;?&quot;

if (responseCode == &quot;200&quot;) {
} else {
    log.warn(&quot;Participant ${idx}/${total} failed: ${responseCode}&quot;)
    log.warn(&quot;Response: ${prev.getResponseDataAsString()?.take(500)}&quot;)
