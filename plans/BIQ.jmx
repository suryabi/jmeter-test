log.info(&quot;Category lookups: HTTP ${prev.getResponseCode()} | categoryId(header)=${vars.get(&apos;parentCategoryId&apos;)} | rows=${lookupValues.size()} | types=${lookupMap?.size() ?: 0}&quot;)

log.info(&quot;----- Terminated: Category Lookup Values PostProcessor -----&quot;)</stringProp>
