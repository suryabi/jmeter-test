// Calculates how many values should be picked for a multi-select field
def _fn_multiSelectCount = { int availableCount, int minSel, int maxSel -&gt;
    def rand = java.util.concurrent.ThreadLocalRandom.current()
    def maxPossible = Math.min(availableCount, maxSel)
    def minPossible = Math.min(minSel, maxPossible)
    return minPossible + rand.nextInt((maxPossible - minPossible) + 1)
}
props.put(&quot;fn_multiSelectCount&quot;, _fn_multiSelectCount)

// Returns a specific value from a comma-separated string using 1-based index
def _fn_getIndexedValue = { String csv, int entryIdx -&gt;
    if (!csv) return null
    if (csv.contains(&quot;,&quot;)) {
        def vals = csv.split(&quot;,&quot;)
        def idx = entryIdx - 1
        return (idx &gt;= 0 &amp;&amp; idx &lt; vals.length) ? vals[idx].trim() : vals[0].trim()
    }
    return csv.trim()
}
props.put(&quot;fn_getIndexedValue&quot;, _fn_getIndexedValue)

