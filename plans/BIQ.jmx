                          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Visit Info PreProcessor" enabled="true">
                            <stringProp name="scriptLanguage">groovy</stringProp>
                            <stringProp name="parameters"></stringProp>
                            <stringProp name="filename"></stringProp>
                            <stringProp name="cacheKey">false</stringProp>
                            <stringProp name="script">

def totalUsers = (vars.get(&quot;randomUserCount&quot;) ?: &quot;50&quot;).toInteger()

// ============ Pick 3 unique random users upfront ============
def allIndices = (1..totalUsers).toList()
Collections.shuffle(allIndices)

def hostIndex = allIndices[0]
def reqIndex = allIndices[Math.min(1, totalUsers - 1)]
def secIndex = allIndices[Math.min(2, totalUsers - 1)]

// ============ INITIALIZATION ============
def formName = vars.get(&quot;currentFormName&quot;)

def rand = java.util.concurrent.ThreadLocalRandom.current()

// ============ Random Number Generators - using shared functions ============
def random5 = props.get(&quot;fn_random5&quot;)()

// Helper: Generate phone - using shared function
def generatePhone = { props.get(&quot;fn_generatePhone&quot;)() }

// ============ Company Info ============
vars.put(&quot;companyName&quot;, vars.get(&quot;customerName&quot;))
vars.put(&quot;accountName&quot;, vars.get(&quot;customerName&quot;))

// Company Website
String customer = vars.get(&quot;customerName&quot;) ?: &quot;&quot;
String customerWebsite = customer.toLowerCase().replaceAll(&quot;[^a-z0-9]&quot;, &quot;&quot;).trim()
vars.put(&quot;companyWebsite&quot;, &quot;www.${customerWebsite}.com&quot;)

// ============ Dates ============
vars.put(&quot;alternativeDate&quot;, vars.get(&quot;alternativeDate&quot;))
vars.put(&quot;lastDateMetWithES&quot;, vars.get(&quot;lastDateMetWithES&quot;))

// ============ Cost Center ============
vars.put(&quot;costCenter&quot;, String.valueOf(random5))

// ============ Special Request ============
String[] specialRequests = [
    &quot;Visitors require escort badges and lobby pickup on arrival&quot;,
    &quot;Please arrange executive parking near the main entrance&quot;,
    &quot;Guests need NDA signed before entering the briefing center&quot;,
    &quot;Request interpreter services for non-English speaking attendees&quot;,
    &quot;Visitors have dietary restrictions - no nuts or shellfish&quot;,
    &quot;Please provide visitor Wi-Fi credentials in advance via email&quot;,
    &quot;Guest requires wheelchair accessible room and entrance&quot;,
    &quot;Request company-branded welcome packets for all visitors&quot;,
    &quot;Visitors arriving early - please open briefing room by 7 AM&quot;,
    &quot;VIP guests - please arrange executive lounge access during breaks&quot;
]
vars.put(&quot;specialRequest&quot;, specialRequests[rand.nextInt(specialRequests.length)])

// ============ Meeting Objective ============
String[] meetingObjectives = [
    &quot;Discuss strategic initiatives and business priorities&quot;,
    &quot;Review product capabilities and solution overview&quot;,
    &quot;Explore partnership opportunities and collaboration&quot;,
    &quot;Understand customer requirements and pain points&quot;,
    &quot;Present technical architecture and integration options&quot;,
    &quot;Align on project goals and success criteria&quot;,
    &quot;Evaluate platform features and functionality&quot;,
    &quot;Discuss implementation roadmap and timeline&quot;,
    &quot;Review business case and expected outcomes&quot;,
    &quot;Strengthen executive relationships and engagement&quot;,
    &quot;Address technical questions and concerns&quot;,
    &quot;Demonstrate solution value and ROI potential&quot;,
    &quot;Gather feedback on proposed approach&quot;,
    &quot;Discuss expansion and growth opportunities&quot;,
    &quot;Review industry trends and best practices&quot;,
    &quot;Assess current challenges and solutions&quot;,
    &quot;Plan next steps and action items&quot;,
    &quot;Explore digital transformation opportunities&quot;,
    &quot;Validate solution fit for business needs&quot;,
    &quot;Discuss security and compliance requirements&quot;,
    &quot;Review performance metrics and optimization&quot;,
    &quot;Align stakeholders on key objectives&quot;,
    &quot;Present innovation and future roadmap&quot;,
    &quot;Evaluate competitive landscape and positioning&quot;,
    &quot;Discuss resource planning and allocation&quot;,
    &quot;Review customer success and adoption strategies&quot;,
    &quot;Assess training and enablement needs&quot;,
    &quot;Explore automation and efficiency improvements&quot;,
    &quot;Discuss data strategy and analytics capabilities&quot;,
    &quot;Plan for scalability and future growth&quot;
]
vars.put(&quot;meetingObjective&quot;, meetingObjectives[rand.nextInt(meetingObjectives.length)])

// ============ Email - using shared function ============
def emailDomain = props.get(&quot;fn_extractEmailDomain&quot;)(vars)

// Business Titles - using shared function from Common Utility
def getRandomBusinessTitle = { props.get(&quot;fn_getRandomBusinessTitle&quot;)() }

// ============ Host Info ============
def hostFirstName = vars.get(&quot;randomUser_${hostIndex}_firstName&quot;) ?: &quot;John&quot;
def hostLastName = vars.get(&quot;randomUser_${hostIndex}_lastName&quot;) ?: &quot;Doe&quot;

vars.put(&quot;oracleHostName&quot;, hostFirstName + &quot; &quot; + hostLastName)
vars.put(&quot;oracleHostEmail&quot;, hostFirstName.toLowerCase() + &quot;.&quot; + hostLastName.toLowerCase() + &quot;@&quot; + emailDomain)
vars.put(&quot;oracleHostCellPhone&quot;, generatePhone())
vars.put(&quot;oracleHostBusinessTitle&quot;, getRandomBusinessTitle())

// ============ Requester Information ============
def requesterFirstName = vars.get(&quot;randomUser_${reqIndex}_firstName&quot;) ?: &quot;Jane&quot;
def requesterLastName = vars.get(&quot;randomUser_${reqIndex}_lastName&quot;) ?: &quot;Doe&quot;

vars.put(&quot;requesterName&quot;, requesterFirstName + &quot; &quot; + requesterLastName)
vars.put(&quot;requesterJobTitle&quot;, getRandomBusinessTitle())
vars.put(&quot;requesterPhone&quot;, generatePhone())

// ============ Secondary Host Information ============
def secondaryHostFirstName = vars.get(&quot;randomUser_${secIndex}_firstName&quot;) ?: &quot;Alex&quot;
def secondaryHostLastName = vars.get(&quot;randomUser_${secIndex}_lastName&quot;) ?: &quot;Smith&quot;

vars.put(&quot;oracleSecondaryHostName&quot;, secondaryHostFirstName + &quot; &quot; + secondaryHostLastName)
vars.put(&quot;oracleSecondaryHostBusinessTitle&quot;, getRandomBusinessTitle())
vars.put(&quot;oracleSecondaryHostEmail&quot;, secondaryHostFirstName.toLowerCase() + &quot;.&quot; + secondaryHostLastName.toLowerCase() + &quot;@&quot; + emailDomain)
vars.put(&quot;oracleSecondaryHostCellPhone&quot;, generatePhone())

// ============ Strategic Client ============
vars.put(&quot;isStrategicClient&quot;, rand.nextBoolean().toString())

// ============ Cost Center Apporving Manager Email ============
def costCenterApprManagerFirstName = vars.get(&quot;randomUser_${secIndex}_firstName&quot;)
def costCenterApprManagerLastName = vars.get(&quot;randomUser_${secIndex}_lastName&quot;)
vars.put(&quot;costCenterApprovingManagerEmail&quot;, costCenterApprManagerFirstName.toLowerCase() + &quot;.&quot; + costCenterApprManagerLastName.toLowerCase() + &quot;@&quot; + emailDomain)

// ============ Logging ============
log.info(&quot;companyName: &quot; + vars.get(&quot;companyName&quot;))
log.info(&quot;accountName: &quot; + vars.get(&quot;accountName&quot;))
log.info(&quot;companyWebsite: &quot; + vars.get(&quot;companyWebsite&quot;))
log.info(&quot;alternativeDate: &quot; + vars.get(&quot;alternativeDate&quot;))
log.info(&quot;lastDateMetWithES: &quot; + vars.get(&quot;lastDateMetWithES&quot;))
log.info(&quot;costCenter: &quot; + vars.get(&quot;costCenter&quot;))
log.info(&quot;meetingObjective: &quot; + vars.get(&quot;meetingObjective&quot;))
log.info(&quot;oracleHostName: &quot; + vars.get(&quot;oracleHostName&quot;))
log.info(&quot;oracleHostEmail: &quot; + vars.get(&quot;oracleHostEmail&quot;))
log.info(&quot;oracleHostCellPhone: &quot; + vars.get(&quot;oracleHostCellPhone&quot;))
log.info(&quot;oracleHostBusinessTitle: &quot; + vars.get(&quot;oracleHostBusinessTitle&quot;))
log.info(&quot;isStrategicClient: &quot; + vars.get(&quot;isStrategicClient&quot;))
log.info(&quot;briefingManager: &quot; + vars.get(&quot;briefingManager&quot;))
log.info(&quot;technicalManager: &quot; + vars.get(&quot;technicalManager&quot;))
log.info(&quot;backupTechnicalManager: &quot; + vars.get(&quot;backupTechnicalManager&quot;))
log.info(&quot;executiveSponser: &quot; + vars.get(&quot;executiveSponser&quot;))
log.info(&quot;tier: &quot; + vars.get(&quot;tier&quot;))
log.info(&quot;requesterName: &quot; + vars.get(&quot;requesterName&quot;))
log.info(&quot;requesterJobTitle: &quot; + vars.get(&quot;requesterJobTitle&quot;))
log.info(&quot;requesterPhone: &quot; + vars.get(&quot;requesterPhone&quot;))
log.info(&quot;specialRequest: &quot; + vars.get(&quot;specialRequest&quot;))
log.info(&quot;oracleSecondaryHostName: &quot; + vars.get(&quot;oracleSecondaryHostName&quot;))
log.info(&quot;oracleSecondaryHostBusinessTitle: &quot; + vars.get(&quot;oracleSecondaryHostBusinessTitle&quot;))
log.info(&quot;oracleSecondaryHostCellPhone: &quot; + vars.get(&quot;oracleSecondaryHostCellPhone&quot;))
log.info(&quot;oracleSecondaryHostEmail: &quot; + vars.get(&quot;oracleSecondaryHostEmail&quot;))
log.info(&quot;costCenterApprovingManagerEmail: &quot; + vars.get(&quot;costCenterApprovingManagerEmail&quot;))

log.info(&quot;----- Terminated: Visit Info Form PostProcessor -----&quot;)</stringProp>
                          </JSR223PreProcessor>
                          <hashTree/>
                          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Opportunity PreProcessor" enabled="true">
                            <stringProp name="scriptLanguage">groovy</stringProp>
                            <stringProp name="parameters"></stringProp>
                            <stringProp name="filename"></stringProp>
                            <stringProp name="cacheKey">false</stringProp>
                            <stringProp name="script">

// For multi-entry CREATE forms, always use fresh data from PreProcessors
def isCreatePath = (vars.get(&quot;currentFormDataId&quot;) == null || vars.get(&quot;currentFormDataId&quot;) == &quot;&quot;)
if (isCreatePath) {
    vars.put(&quot;existingFormData&quot;, &quot;{}&quot;)
}

// ============ INITIALIZATION ============
def formName = vars.get(&quot;currentFormName&quot;)
def rand = java.util.concurrent.ThreadLocalRandom.current()
def currentEntryIndex = (vars.get(&quot;currentEntryIndex&quot;) ?: &quot;1&quot;).toInteger()
def totalEntryCount = (vars.get(&quot;totalEntryCount&quot;) ?: &quot;5&quot;).toInteger()

// ============ Random Number Generators (FRESH per entry) - using shared functions ============
def random4 = props.get(&quot;fn_random4&quot;)()
def random5 = props.get(&quot;fn_random5&quot;)()
def random6 = props.get(&quot;fn_random6&quot;)()

// ============ Revenue Fields (unique per entry) ============
vars.put(&quot;opportunityId&quot;, String.valueOf(random4))
vars.put(&quot;initialOpportunityRevenue&quot;, String.valueOf(props.get(&quot;fn_random4&quot;)()))
vars.put(&quot;opportunityRevenue&quot;, String.valueOf(props.get(&quot;fn_random5&quot;)()))
vars.put(&quot;closedOpportunityRevenue&quot;, String.valueOf(props.get(&quot;fn_random6&quot;)()))

// ============ Date Fields ============
// Generate different closed dates per entry
def startDateStr = vars.get(&quot;startDate&quot;) ?: &quot;&quot;
vars.put(&quot;openedDate&quot;, startDateStr)

// Random closed date (1-30 days after open date)
try {
    def sdf = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd&quot;)
    if (startDateStr) {
        def openDate = sdf.parse(startDateStr)
        def daysToAdd = rand.nextInt(1, 31)
        def calendar = Calendar.getInstance()
        calendar.setTime(openDate)
        calendar.add(Calendar.DAY_OF_MONTH, daysToAdd)
        vars.put(&quot;closedDate&quot;, sdf.format(calendar.getTime()))
    }
} catch (Exception e) {
    vars.put(&quot;closedDate&quot;, vars.get(&quot;closedDate&quot;) ?: &quot;&quot;)
}

// Quarter of Close
String[] quarters = [&quot;Q1&quot;, &quot;Q2&quot;, &quot;Q3&quot;, &quot;Q4&quot;]
vars.put(&quot;quarterOfClose&quot;, quarters[rand.nextInt(quarters.length)])

// ============ Status &amp; Probability ============
def statusProbabilityMap = [
    &quot;Open&quot;        : [&quot;10&quot;, &quot;20&quot;, &quot;25&quot;],
    &quot;In Progress&quot; : [&quot;30&quot;, &quot;40&quot;, &quot;50&quot;],
    &quot;Pending&quot;     : [&quot;50&quot;, &quot;60&quot;, &quot;65&quot;],
    &quot;On Hold&quot;     : [&quot;20&quot;, &quot;30&quot;, &quot;40&quot;],
    &quot;Closed Won&quot;  : [&quot;100&quot;],
    &quot;Closed Lost&quot; : [&quot;0&quot;]
]

String[] statuses = statusProbabilityMap.keySet() as String[]
String randomStatus = statuses[rand.nextInt(statuses.length)]
vars.put(&quot;oppStatus&quot;, randomStatus)

String[] matchingProbabilities = statusProbabilityMap[randomStatus]
String randomProbability = matchingProbabilities[rand.nextInt(matchingProbabilities.length)]
vars.put(&quot;probabilityOfClose&quot;, randomProbability)

// ============ isPrimary Logic ============
boolean isPrimaryFlag = (currentEntryIndex == 1)
vars.put(&quot;isPrimary&quot;, String.valueOf(isPrimaryFlag))

// ============ Logging ============
log.info(&quot;Entry ${currentEntryIndex}/${totalEntryCount}&quot;)
log.info(&quot;opportunityId: &quot; + vars.get(&quot;opportunityId&quot;))
log.info(&quot;initialOpportunityRevenue: &quot; + vars.get(&quot;initialOpportunityRevenue&quot;))
log.info(&quot;opportunityRevenue: &quot; + vars.get(&quot;opportunityRevenue&quot;))
log.info(&quot;closedOpportunityRevenue: &quot; + vars.get(&quot;closedOpportunityRevenue&quot;))
log.info(&quot;openedDate: &quot; + vars.get(&quot;openedDate&quot;))
log.info(&quot;closedDate: &quot; + vars.get(&quot;closedDate&quot;))
log.info(&quot;quarterOfClose: &quot; + vars.get(&quot;quarterOfClose&quot;))
log.info(&quot;oppStatus: &quot; + randomStatus + &quot; -&gt; probabilityOfClose: &quot; + randomProbability)
log.info(&quot;isPrimary: &quot; + vars.get(&quot;isPrimary&quot;))
log.info(&quot;----- Terminated: Opportunity Form PostProcessor -----&quot;)</stringProp>
                          </JSR223PreProcessor>
                          <hashTree/>
                          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Virtual Connection PreProcessor" enabled="true">
                            <stringProp name="scriptLanguage">groovy</stringProp>
                            <stringProp name="parameters"></stringProp>
                            <stringProp name="filename"></stringProp>
