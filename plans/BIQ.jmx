def currentMasterTypeId = vars.get(&quot;currentActivityMasterTypeId&quot;)
def masterTypeName = vars.get(&quot;currentActivityMasterTypeName&quot;) ?: &quot;Master&quot;

def response = prev.getResponseDataAsString()

if (!response || response.trim().isEmpty()) {
    log.warn(&quot;Empty response - no masters found&quot;)
    vars.put(&quot;mastersFor_&quot; + currentMasterTypeId + &quot;_count&quot;, &quot;0&quot;)
        return
}

try {
    def json = new groovy.json.JsonSlurper().parseText(response)

    def masters = json._embedded?.masters ?: json.masters ?: (json instanceof List ? json : [])

    def count = 0
    masters.each { master -&gt;
        count++

        def data = master.data ?: master

        def uniqueId = data.uniqueId ?:
                       data.id ?:
                       master.uniqueId ?:
                       master.id ?: &quot;&quot;

        def displayName = data.searchDisplayText ?:
                          data.displayName ?:
                          data.masterName ?:
                          data.topicName ?:
                          data.name ?:
                          master.displayName ?:
                          master.name ?:
                          uniqueId  // Fallback to ID if no name found

        def varPrefix = &quot;mastersFor_&quot; + currentMasterTypeId + &quot;_&quot; + count
        vars.put(varPrefix + &quot;_id&quot;, uniqueId)
        vars.put(varPrefix + &quot;_name&quot;, displayName)

        if (count &lt;= 5) {
                    }
    }

    if (count &gt; 5) {
            }

    vars.put(&quot;mastersFor_&quot; + currentMasterTypeId + &quot;_count&quot;, count.toString())
    } catch (Exception e) {
    log.error(&quot;Error parsing masters: ${e.message}&quot;)
    vars.put(&quot;mastersFor_&quot; + currentMasterTypeId + &quot;_count&quot;, &quot;0&quot;)
}
