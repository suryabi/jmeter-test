{
  "name": "jmeter-local-runner",
  "version": "1.0.0",
  "private": true,
  "description": "Local JMeter runner for BIQ.jmx testing",
  "main": "server.js",
  "scripts": {
    "init": "node scripts/init.js",
    "validate": "node scripts/validate.js",
    "install:jmeter-plugins": "node scripts/install-jmeter-plugins.js",
    "uninstall:jmeter-plugins": "node scripts/uninstall-jmeter-plugins.js",
    "start": "node server.js",
    "start:api": "node server.js",
    "start:ui": "npm start --prefix ui",
    "dev": "concurrently -n api,ui -c blue,green \"npm run start:api\" \"npm run start:ui\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
